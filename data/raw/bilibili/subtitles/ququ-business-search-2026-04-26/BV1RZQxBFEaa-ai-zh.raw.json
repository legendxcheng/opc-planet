{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.1,
      "to": 2.22,
      "sid": 1,
      "location": 2,
      "content": "大蚂蝗每个人都爱吃",
      "music": 0.0
    },
    {
      "from": 2.22,
      "to": 4.02,
      "sid": 2,
      "location": 2,
      "content": "但你们了解蚂蝗吗",
      "music": 0.0
    },
    {
      "from": 4.02,
      "to": 7.779,
      "sid": 3,
      "location": 2,
      "content": "对于这个古老而神秘的生物都有哪些特别之处",
      "music": 0.0
    },
    {
      "from": 7.779,
      "to": 9.419,
      "sid": 4,
      "location": 2,
      "content": "内脏究竟能不能吃",
      "music": 0.0
    },
    {
      "from": 9.419,
      "to": 11.24,
      "sid": 5,
      "location": 2,
      "content": "本期视频大揭秘",
      "music": 0.0
    },
    {
      "from": 11.24,
      "to": 12.28,
      "sid": 6,
      "location": 2,
      "content": "哈喽大家好",
      "music": 0.0
    },
    {
      "from": 12.28,
      "to": 13.04,
      "sid": 7,
      "location": 2,
      "content": "我是老郭",
      "music": 0.0
    },
    {
      "from": 13.04,
      "to": 15.2,
      "sid": 8,
      "location": 2,
      "content": "本期是个硬核题材啊",
      "music": 0.0
    },
    {
      "from": 15.2,
      "to": 18.049,
      "sid": 9,
      "location": 2,
      "content": "眼前这个生物大家并不陌生吧",
      "music": 0.0
    },
    {
      "from": 18.049,
      "to": 20.069,
      "sid": 10,
      "location": 2,
      "content": "蚂蝗也就是水质",
      "music": 0.0
    },
    {
      "from": 20.069,
      "to": 23.45,
      "sid": 11,
      "location": 2,
      "content": "可能很多人认为蚂蝗是一种很邪恶的生物",
      "music": 0.0
    },
    {
      "from": 23.45,
      "to": 25.59,
      "sid": 12,
      "location": 2,
      "content": "都觉得这玩意吸引血呀",
      "music": 0.0
    },
    {
      "from": 25.59,
      "to": 28.29,
      "sid": 13,
      "location": 2,
      "content": "其实不是所有的蚂蝗都吸血",
      "music": 0.0
    },
    {
      "from": 28.29,
      "to": 32.34,
      "sid": 14,
      "location": 2,
      "content": "像这种大个体的宽体进献字就不吸血啊",
      "music": 0.0
    },
    {
      "from": 32.34,
      "to": 35.38,
      "sid": 15,
      "location": 2,
      "content": "用手把玩的话非常的解压",
      "music": 0.0
    },
    {
      "from": 37.04,
      "to": 38.92,
      "sid": 16,
      "location": 2,
      "content": "我们再确认一个问题啊",
      "music": 0.0
    },
    {
      "from": 38.92,
      "to": 40.46,
      "sid": 17,
      "location": 2,
      "content": "蚂蝗到底能不能吃",
      "music": 0.0
    },
    {
      "from": 40.46,
      "to": 41.78,
      "sid": 18,
      "location": 2,
      "content": "肯定是能吃的啊",
      "music": 0.0
    },
    {
      "from": 41.78,
      "to": 45.41,
      "sid": 19,
      "location": 2,
      "content": "像这种宽体金线制不仅是一种特色美食",
      "music": 0.0
    },
    {
      "from": 45.41,
      "to": 47.45,
      "sid": 20,
      "location": 2,
      "content": "药用价值也非常的高",
      "music": 0.0
    },
    {
      "from": 47.45,
      "to": 49.49,
      "sid": 21,
      "location": 2,
      "content": "主要就是吃它的肉壁啊",
      "music": 0.0
    },
    {
      "from": 49.49,
      "to": 52.2,
      "sid": 22,
      "location": 2,
      "content": "这期视频我耗时了两个半月呀",
      "music": 0.0
    },
    {
      "from": 52.2,
      "to": 55.4,
      "sid": 23,
      "location": 2,
      "content": "从怎么产卵到孵化到剖瓷一体",
      "music": 0.0
    },
    {
      "from": 55.4,
      "to": 56.4,
      "sid": 24,
      "location": 2,
      "content": "很不容易",
      "music": 0.0
    },
    {
      "from": 56.4,
      "to": 58.76,
      "sid": 25,
      "location": 2,
      "content": "大部分的镜头你们都没有看到过",
      "music": 0.0
    },
    {
      "from": 58.76,
      "to": 60.5,
      "sid": 26,
      "location": 2,
      "content": "请大家认真观看",
      "music": 0.0
    },
    {
      "from": 60.5,
      "to": 62.32,
      "sid": 27,
      "location": 2,
      "content": "水质属于环节动物",
      "music": 0.0
    },
    {
      "from": 62.32,
      "to": 64.41,
      "sid": 28,
      "location": 2,
      "content": "身体共分34个体积",
      "music": 0.0
    },
    {
      "from": 64.41,
      "to": 66.61,
      "sid": 29,
      "location": 2,
      "content": "每个体节还分若干个体环",
      "music": 0.0
    },
    {
      "from": 66.61,
      "to": 68.58,
      "sid": 30,
      "location": 2,
      "content": "加起来一共有100多环吧",
      "music": 0.0
    },
    {
      "from": 71.1,
      "to": 72.32,
      "sid": 31,
      "location": 2,
      "content": "身上没有毛毛",
      "music": 0.0
    },
    {
      "from": 72.32,
      "to": 74.8,
      "sid": 32,
      "location": 2,
      "content": "它的体型呈扁平的纺锤形",
      "music": 0.0
    },
    {
      "from": 74.8,
      "to": 76.6,
      "sid": 33,
      "location": 2,
      "content": "头尾各长有一个C盘",
      "music": 0.0
    },
    {
      "from": 76.6,
      "to": 78.1,
      "sid": 34,
      "location": 2,
      "content": "头部的吸盘略小",
      "music": 0.0
    },
    {
      "from": 78.1,
      "to": 79.54,
      "sid": 35,
      "location": 2,
      "content": "尾部的吸盘较大",
      "music": 0.0
    },
    {
      "from": 79.54,
      "to": 81.36,
      "sid": 36,
      "location": 2,
      "content": "吸盘相当于它的脚丫",
      "music": 0.0
    },
    {
      "from": 81.36,
      "to": 85.48,
      "sid": 37,
      "location": 2,
      "content": "运动的时候靠前后吸盘交替吸着地面进行移动",
      "music": 0.0
    },
    {
      "from": 85.48,
      "to": 88.02,
      "sid": 38,
      "location": 2,
      "content": "它在水里的游泳能力也非常的强",
      "music": 0.0
    },
    {
      "from": 88.02,
      "to": 89.8,
      "sid": 39,
      "location": 2,
      "content": "游泳时背腹肌收缩",
      "music": 0.0
    },
    {
      "from": 89.8,
      "to": 91.23,
      "sid": 40,
      "location": 2,
      "content": "身体变扁形",
      "music": 0.0
    },
    {
      "from": 91.23,
      "to": 91.87,
      "sid": 41,
      "location": 2,
      "content": "如柳叶",
      "music": 0.0
    },
    {
      "from": 91.87,
      "to": 93.23,
      "sid": 42,
      "location": 2,
      "content": "做波浪式的运动",
      "music": 0.0
    },
    {
      "from": 93.23,
      "to": 96.42,
      "sid": 43,
      "location": 2,
      "content": "在头部背面的顶端长有一些小黑点",
      "music": 0.0
    },
    {
      "from": 96.42,
      "to": 98.1,
      "sid": 44,
      "location": 2,
      "content": "这是他的大眼珠子",
      "music": 0.0
    },
    {
      "from": 98.1,
      "to": 101.13,
      "sid": 45,
      "location": 2,
      "content": "一共有五对可以感知光线的强弱",
      "music": 0.0
    },
    {
      "from": 101.13,
      "to": 104.67,
      "sid": 46,
      "location": 2,
      "content": "嘴位于头吸盘处里面长有三足腭片",
      "music": 0.0
    },
    {
      "from": 104.67,
      "to": 108.32,
      "sid": 47,
      "location": 2,
      "content": "颚片相当于牙花子上面长有细小的牙齿",
      "music": 0.0
    },
    {
      "from": 108.32,
      "to": 109.24,
      "sid": 48,
      "location": 2,
      "content": "重点来了",
      "music": 0.0
    },
    {
      "from": 109.24,
      "to": 112.52,
      "sid": 49,
      "location": 2,
      "content": "吸血型水质和非吸血型水质的齿结构",
      "music": 0.0
    },
    {
      "from": 112.52,
      "to": 113.8,
      "sid": 50,
      "location": 2,
      "content": "有着明显的区别",
      "music": 0.0
    },
    {
      "from": 113.8,
      "to": 115.8,
      "sid": 51,
      "location": 2,
      "content": "比如吸血型的非牛字",
      "music": 0.0
    },
    {
      "from": 115.8,
      "to": 117.9,
      "sid": 52,
      "location": 2,
      "content": "它的每片颚上都长有一排",
      "music": 0.0
    },
    {
      "from": 117.9,
      "to": 120.04,
      "sid": 53,
      "location": 2,
      "content": "100克左右的锋利的锯齿",
      "music": 0.0
    },
    {
      "from": 120.04,
      "to": 122.98,
      "sid": 54,
      "location": 2,
      "content": "这些锯齿能够轻松地将皮肤割破",
      "music": 0.0
    },
    {
      "from": 122.98,
      "to": 124.54,
      "sid": 55,
      "location": 2,
      "content": "然后吸食血液",
      "music": 0.0
    },
    {
      "from": 124.54,
      "to": 126.66,
      "sid": 56,
      "location": 2,
      "content": "那么它是如何吸血的呢",
      "music": 0.0
    },
    {
      "from": 126.66,
      "to": 129.399,
      "sid": 57,
      "location": 2,
      "content": "她的皮肤上分布着很多感觉细胞",
      "music": 0.0
    },
    {
      "from": 129.399,
      "to": 131.359,
      "sid": 58,
      "location": 2,
      "content": "其中有一种热敏细胞",
      "music": 0.0
    },
    {
      "from": 131.359,
      "to": 134.019,
      "sid": 59,
      "location": 2,
      "content": "能够感知宿主体表的温度变化",
      "music": 0.0
    },
    {
      "from": 134.019,
      "to": 137.36,
      "sid": 60,
      "location": 2,
      "content": "人类的体温正好是他喜欢的吸血宿主",
      "music": 0.0
    },
    {
      "from": 137.36,
      "to": 141.3,
      "sid": 61,
      "location": 2,
      "content": "吸血的时候会用头部的吸盘紧紧的吸住皮肤",
      "music": 0.0
    },
    {
      "from": 141.3,
      "to": 144.04,
      "sid": 62,
      "location": 2,
      "content": "这时三组恶片同时开始切割",
      "music": 0.0
    },
    {
      "from": 144.04,
      "to": 145.36,
      "sid": 63,
      "location": 2,
      "content": "还是有痛感的啊",
      "music": 0.0
    },
    {
      "from": 145.36,
      "to": 146.36,
      "sid": 64,
      "location": 2,
      "content": "像针扎一样",
      "music": 0.0
    },
    {
      "from": 146.36,
      "to": 147.68,
      "sid": 65,
      "location": 2,
      "content": "皮肤切割完以后",
      "music": 0.0
    },
    {
      "from": 147.68,
      "to": 149.2,
      "sid": 66,
      "location": 2,
      "content": "会向我的体内注入",
      "music": 0.0
    },
    {
      "from": 149.2,
      "to": 151.82,
      "sid": 67,
      "location": 2,
      "content": "能够使血管扩张的类组胺化合物",
      "music": 0.0
    },
    {
      "from": 151.82,
      "to": 154.18,
      "sid": 68,
      "location": 2,
      "content": "这种化合物能够造成血流不止",
      "music": 0.0
    },
    {
      "from": 154.18,
      "to": 157.4,
      "sid": 69,
      "location": 2,
      "content": "然后颚片上密布的唾液性乳突会分泌",
      "music": 0.0
    },
    {
      "from": 157.4,
      "to": 160.28,
      "sid": 70,
      "location": 2,
      "content": "防止血液凝固的物质称之为水质素",
      "music": 0.0
    },
    {
      "from": 160.28,
      "to": 162.62,
      "sid": 71,
      "location": 2,
      "content": "水质会利用咽部的咽肌收缩",
      "music": 0.0
    },
    {
      "from": 162.62,
      "to": 163.96,
      "sid": 72,
      "location": 2,
      "content": "产生巨大的吸力",
      "music": 0.0
    },
    {
      "from": 163.96,
      "to": 166.68,
      "sid": 73,
      "location": 2,
      "content": "将血液和水质素同时吸入体内",
      "music": 0.0
    },
    {
      "from": 166.68,
      "to": 169.94,
      "sid": 74,
      "location": 2,
      "content": "防止因血液凝块影响水质的身体运动",
      "music": 0.0
    },
    {
      "from": 169.94,
      "to": 171.24,
      "sid": 75,
      "location": 2,
      "content": "它吸血一次",
      "music": 0.0
    },
    {
      "from": 171.24,
      "to": 173.34,
      "sid": 76,
      "location": 2,
      "content": "一年内不进食也不会饿死",
      "music": 0.0
    },
    {
      "from": 173.34,
      "to": 175.86,
      "sid": 77,
      "location": 2,
      "content": "有些人担心水质会不会钻入体内",
      "music": 0.0
    },
    {
      "from": 175.86,
      "to": 176.44,
      "sid": 78,
      "location": 2,
      "content": "放心啊",
      "music": 0.0
    },
    {
      "from": 176.44,
      "to": 177.1,
      "sid": 79,
      "location": 2,
      "content": "不会滴",
      "music": 0.0
    },
    {
      "from": 177.1,
      "to": 177.58,
      "sid": 80,
      "location": 2,
      "content": "行了",
      "music": 0.0
    },
    {
      "from": 177.58,
      "to": 178.18,
      "sid": 81,
      "location": 2,
      "content": "下来吧",
      "music": 0.0
    },
    {
      "from": 178.18,
      "to": 180.329,
      "sid": 82,
      "location": 2,
      "content": "我已经让它足足吸了20分钟了",
      "music": 0.0
    },
    {
      "from": 180.329,
      "to": 181.849,
      "sid": 83,
      "location": 2,
      "content": "如果让它吸饱的话",
      "music": 0.0
    },
    {
      "from": 181.849,
      "to": 183.289,
      "sid": 84,
      "location": 2,
      "content": "体重会增加数倍",
      "music": 0.0
    },
    {
      "from": 183.289,
      "to": 185.16,
      "sid": 85,
      "location": 2,
      "content": "完了我这胳膊是废了",
      "music": 0.0
    },
    {
      "from": 185.16,
      "to": 187.16,
      "sid": 86,
      "location": 2,
      "content": "被咬了一个Y字型的伤口",
      "music": 0.0
    },
    {
      "from": 187.16,
      "to": 187.74,
      "sid": 87,
      "location": 2,
      "content": "兄弟们",
      "music": 0.0
    },
    {
      "from": 187.74,
      "to": 189.58,
      "sid": 88,
      "location": 2,
      "content": "我这都付出了血的代价",
      "music": 0.0
    },
    {
      "from": 189.58,
      "to": 191.46,
      "sid": 89,
      "location": 2,
      "content": "能不能给老郭来波赞呢",
      "music": 0.0
    },
    {
      "from": 191.46,
      "to": 192.99,
      "sid": 90,
      "location": 2,
      "content": "我求个单位来",
      "music": 0.0
    },
    {
      "from": 192.99,
      "to": 196.91,
      "sid": 91,
      "location": 2,
      "content": "我们再看一下非吸血制宽体金线制的齿结构",
      "music": 0.0
    },
    {
      "from": 196.91,
      "to": 199.15,
      "sid": 92,
      "location": 2,
      "content": "它的齿是由两排组成",
      "music": 0.0
    },
    {
      "from": 199.15,
      "to": 200.93,
      "sid": 93,
      "location": 2,
      "content": "此面既平又钝",
      "music": 0.0
    },
    {
      "from": 200.93,
      "to": 204.17,
      "sid": 94,
      "location": 2,
      "content": "这种锋利程度根本割破不了我们的皮肤",
      "music": 0.0
    },
    {
      "from": 204.17,
      "to": 206.27,
      "sid": 95,
      "location": 2,
      "content": "但切割体壁相对较薄",
      "music": 0.0
    },
    {
      "from": 206.27,
      "to": 208.75,
      "sid": 96,
      "location": 2,
      "content": "较脆弱的软体动物还是很容易的",
      "music": 0.0
    },
    {
      "from": 208.75,
      "to": 212.24,
      "sid": 97,
      "location": 2,
      "content": "所以田螺就是宽体金限制的主要食物",
      "music": 0.0
    },
    {
      "from": 212.24,
      "to": 213.3,
      "sid": 98,
      "location": 2,
      "content": "捕食的时候",
      "music": 0.0
    },
    {
      "from": 213.3,
      "to": 215.79,
      "sid": 99,
      "location": 2,
      "content": "它会把头部伸进田螺的壳内",
      "music": 0.0
    },
    {
      "from": 215.79,
      "to": 216.85,
      "sid": 100,
      "location": 2,
      "content": "吸食体液",
      "music": 0.0
    },
    {
      "from": 216.85,
      "to": 218.01,
      "sid": 101,
      "location": 2,
      "content": "啃食生殖腺",
      "music": 0.0
    },
    {
      "from": 218.01,
      "to": 220.05,
      "sid": 102,
      "location": 2,
      "content": "肝脏等一些有氧的器官",
      "music": 0.0
    },
    {
      "from": 220.05,
      "to": 221.49,
      "sid": 103,
      "location": 2,
      "content": "螺头肉是不吃的",
      "music": 0.0
    },
    {
      "from": 221.49,
      "to": 222.94,
      "sid": 104,
      "location": 2,
      "content": "因为根本就啃不动",
      "music": 0.0
    },
    {
      "from": 222.94,
      "to": 225.22,
      "sid": 105,
      "location": 2,
      "content": "水质也有一些纯肉食性的",
      "music": 0.0
    },
    {
      "from": 225.22,
      "to": 227.12,
      "sid": 106,
      "location": 2,
      "content": "比如位于加里曼丹岛",
      "music": 0.0
    },
    {
      "from": 227.12,
      "to": 230.08,
      "sid": 107,
      "location": 2,
      "content": "生长一种金英纳巴鲁巨型红水质",
      "music": 0.0
