{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.1,
      "to": 2.58,
      "sid": 1,
      "location": 2,
      "content": "最近刷到黄磊老师做锅包肉的视频",
      "music": 0.0
    },
    {
      "from": 2.58,
      "to": 3.66,
      "sid": 2,
      "location": 2,
      "content": "先是徒手搅鸡蛋",
      "music": 0.0
    },
    {
      "from": 3.66,
      "to": 6.14,
      "sid": 3,
      "location": 2,
      "content": "再把酥脆的锅包肉硬生生做成了炖肉",
      "music": 0.0
    },
    {
      "from": 6.14,
      "to": 7.92,
      "sid": 4,
      "location": 2,
      "content": "最后还往锅里放了把山楂",
      "music": 0.0
    },
    {
      "from": 7.92,
      "to": 8.72,
      "sid": 5,
      "location": 2,
      "content": "我看不懂",
      "music": 0.0
    },
    {
      "from": 8.72,
      "to": 9.8,
      "sid": 6,
      "location": 2,
      "content": "但是大受震撼",
      "music": 0.0
    },
    {
      "from": 9.8,
      "to": 11.6,
      "sid": 7,
      "location": 2,
      "content": "评论区的网友也是纷纷感叹",
      "music": 0.0
    },
    {
      "from": 11.6,
      "to": 13.26,
      "sid": 8,
      "location": 2,
      "content": "这头猪算是白死了",
      "music": 0.0
    },
    {
      "from": 13.26,
      "to": 15.26,
      "sid": 9,
      "location": 2,
      "content": "甚至啊有人说黄磊老师做饭",
      "music": 0.0
    },
    {
      "from": 15.26,
      "to": 17.26,
      "sid": 10,
      "location": 2,
      "content": "那就是对明星的服从性测试",
      "music": 0.0
    },
    {
      "from": 17.26,
      "to": 19.5,
      "sid": 11,
      "location": 2,
      "content": "那毕竟江湖他不是打打杀杀",
      "music": 0.0
    },
    {
      "from": 19.5,
      "to": 20.58,
      "sid": 12,
      "location": 2,
      "content": "而是人情世故",
      "music": 0.0
    },
    {
      "from": 20.58,
      "to": 21.66,
      "sid": 13,
      "location": 2,
      "content": "就算做的很难吃",
      "music": 0.0
    },
    {
      "from": 21.66,
      "to": 22.58,
      "sid": 14,
      "location": 2,
      "content": "也不好表现出来",
      "music": 0.0
    },
    {
      "from": 22.58,
      "to": 24.26,
      "sid": 15,
      "location": 2,
      "content": "之前某期黄老师做的炖豆角",
      "music": 0.0
    },
    {
      "from": 24.26,
      "to": 26.78,
      "sid": 16,
      "location": 2,
      "content": "他自己和宋丹丹老师在出锅前尝了一口",
      "music": 0.0
    },
    {
      "from": 26.78,
      "to": 28.939,
      "sid": 17,
      "location": 2,
      "content": "结果眼里直吐胆汁",
      "music": 0.0
    },
    {
      "from": 31.019,
      "to": 32.459,
      "sid": 18,
      "location": 2,
      "content": "胆汁出来了",
      "music": 0.0
    },
    {
      "from": 32.459,
      "to": 34.979,
      "sid": 19,
      "location": 2,
      "content": "甚至宋丹丹老师这个时候都没好意思说",
      "music": 0.0
    },
    {
      "from": 34.979,
      "to": 36.219,
      "sid": 20,
      "location": 2,
      "content": "黄磊煮的豆角没熟",
      "music": 0.0
    },
    {
      "from": 36.219,
      "to": 37.799,
      "sid": 21,
      "location": 2,
      "content": "硬是说自己胃里有毒",
      "music": 0.0
    },
    {
      "from": 37.799,
      "to": 39.94,
      "sid": 22,
      "location": 2,
      "content": "我觉得得去洗胃",
      "music": 0.0
    },
    {
      "from": 40.65,
      "to": 42.53,
      "sid": 23,
      "location": 2,
      "content": "要不然这胃里面有毒",
      "music": 0.0
    },
    {
      "from": 42.53,
      "to": 46.03,
      "sid": 24,
      "location": 2,
      "content": "黄磊老师的炖豆角也被网友戏称为战农鸭",
      "music": 0.0
    },
    {
      "from": 46.03,
      "to": 47.23,
      "sid": 25,
      "location": 2,
      "content": "背景介绍完了啊",
      "music": 0.0
    },
    {
      "from": 47.23,
      "to": 49.63,
      "sid": 26,
      "location": 2,
      "content": "所以黄磊老师做的菜真的有那么难吃吗",
      "music": 0.0
    },
    {
      "from": 49.63,
      "to": 50.43,
      "sid": 27,
      "location": 2,
      "content": "带着这个疑问",
      "music": 0.0
    },
    {
      "from": 50.43,
      "to": 53.1,
      "sid": 28,
      "location": 2,
      "content": "我打算今天复刻一下黄磊老师做的锅包肉",
      "music": 0.0
    },
    {
      "from": 53.1,
      "to": 55.26,
      "sid": 29,
      "location": 2,
      "content": "因为原片的制作方法不是特别完整",
      "music": 0.0
    },
    {
      "from": 55.26,
      "to": 57.12,
      "sid": 30,
      "location": 2,
      "content": "所以原片里面没有展现的部分呢",
      "music": 0.0
    },
    {
      "from": 57.12,
      "to": 59.64,
      "sid": 31,
      "location": 2,
      "content": "我结合了黄小厨账号的锅包肉教程",
      "music": 0.0
    },
    {
      "from": 59.64,
      "to": 61.6,
      "sid": 32,
      "location": 2,
      "content": "首先准备一些切好的外脊肉",
      "music": 0.0
    },
    {
      "from": 61.6,
      "to": 62.48,
      "sid": 33,
      "location": 2,
      "content": "用刀背敲松",
      "music": 0.0
    },
    {
      "from": 62.48,
      "to": 63.2,
      "sid": 34,
      "location": 2,
      "content": "裹上淀粉",
      "music": 0.0
    },
    {
      "from": 63.2,
      "to": 64.68,
      "sid": 35,
      "location": 2,
      "content": "放到锅里炸到酥脆的状态",
      "music": 0.0
    },
    {
      "from": 64.68,
      "to": 67.46,
      "sid": 36,
      "location": 2,
      "content": "捞出可以看得出来黄老师是真的很爱生姜",
      "music": 0.0
    },
    {
      "from": 67.46,
      "to": 70.08,
      "sid": 37,
      "location": 2,
      "content": "之前做的赛螃蟹就加了大量的生姜和醋",
      "music": 0.0
    },
    {
      "from": 70.08,
      "to": 70.82,
      "sid": 38,
      "location": 2,
      "content": "一口下去",
      "music": 0.0
    },
    {
      "from": 70.82,
      "to": 73.72,
      "sid": 39,
      "location": 2,
      "content": "赵丽颖和谢娜好像突然苍老了20岁",
      "music": 0.0
    },
    {
      "from": 73.72,
      "to": 76.04,
      "sid": 40,
      "location": 2,
      "content": "这次的锅包肉呢依旧是生姜其臭",
      "music": 0.0
    },
    {
      "from": 76.04,
      "to": 76.84,
      "sid": 41,
      "location": 2,
      "content": "然后重点来了",
      "music": 0.0
    },
    {
      "from": 76.84,
      "to": 79.64,
      "sid": 42,
      "location": 2,
      "content": "字幕上说的是倒入60块钱一个的鸡蛋蛋液",
      "music": 0.0
    },
    {
      "from": 79.64,
      "to": 81.24,
      "sid": 43,
      "location": 2,
      "content": "但是炒过鸡蛋的朋友都知道啊",
      "music": 0.0
    },
    {
      "from": 81.24,
      "to": 82.26,
      "sid": 44,
      "location": 2,
      "content": "鸡蛋是自状态下",
      "music": 0.333333300653584
    },
    {
      "from": 82.26,
      "to": 83.46,
      "sid": 45,
      "location": 2,
      "content": "它是不会这么细的",
      "music": 0.0
    },
    {
      "from": 83.46,
      "to": 84.58,
      "sid": 46,
      "location": 2,
      "content": "很明显里面是加了水",
      "music": 0.0
    },
    {
      "from": 84.58,
      "to": 86.62,
      "sid": 47,
      "location": 2,
      "content": "而且后面部分呢也没有再给到锅包肉",
      "music": 0.0
    },
    {
      "from": 86.62,
      "to": 87.22,
      "sid": 48,
      "location": 2,
      "content": "调味的镜头",
      "music": 0.0
    },
    {
      "from": 87.22,
      "to": 88.82,
      "sid": 49,
      "location": 2,
      "content": "所以推测这里黄老师",
      "music": 0.0
    },
    {
      "from": 88.82,
      "to": 91.06,
      "sid": 50,
      "location": 2,
      "content": "他是把糖醋汁一起给调到蛋液里了",
      "music": 0.0
    },
    {
      "from": 91.06,
      "to": 93.02,
      "sid": 51,
      "location": 2,
      "content": "再结合黄小厨的锅包肉教程",
      "music": 0.0
    },
    {
      "from": 93.02,
      "to": 94.58,
      "sid": 52,
      "location": 2,
      "content": "那这碗里面的应该是白糖",
      "music": 0.0
    },
    {
      "from": 94.58,
      "to": 95.78,
      "sid": 53,
      "location": 2,
      "content": "白醋鸡蛋水",
      "music": 0.0
    },
    {
      "from": 95.78,
      "to": 97.1,
      "sid": 54,
      "location": 2,
      "content": "还有生抽的结合体",
      "music": 0.0
    },
    {
      "from": 97.1,
      "to": 98.38,
      "sid": 55,
      "location": 2,
      "content": "接着重中之重",
      "music": 0.0
    },
    {
      "from": 98.38,
      "to": 100.94,
      "sid": 56,
      "location": 2,
      "content": "一定要用你的四根手指充分搅拌",
      "music": 0.0
    },
    {
      "from": 100.94,
      "to": 103.04,
      "sid": 57,
      "location": 2,
      "content": "让手汗和料汁完美融合",
      "music": 0.0
    },
    {
      "from": 103.04,
      "to": 105.92,
      "sid": 58,
      "location": 2,
      "content": "这样食客才能吃出你独有的专属味道",
      "music": 0.0
    },
    {
      "from": 105.92,
      "to": 106.88,
      "sid": 59,
      "location": 2,
      "content": "真不是我硬黑啊",
      "music": 0.0
    },
    {
      "from": 106.88,
      "to": 107.28,
      "sid": 60,
      "location": 2,
      "content": "黄老师",
      "music": 0.0
    },
    {
      "from": 107.28,
      "to": 109.32,
      "sid": 61,
      "location": 2,
      "content": "他是真的很爱把手作为厨具使用",
      "music": 0.0
    },
    {
      "from": 109.32,
      "to": 111.84,
      "sid": 62,
      "location": 2,
      "content": "之前黄老师上某综艺车少正在品尝美食",
      "music": 0.0
    },
    {
      "from": 111.84,
      "to": 113.04,
      "sid": 63,
      "location": 2,
      "content": "黄老师看的口水直流",
      "music": 0.0
    },
    {
      "from": 113.04,
      "to": 114.4,
      "sid": 64,
      "location": 2,
      "content": "于是他大步上去",
      "music": 0.0
    },
    {
      "from": 114.4,
      "to": 120.86,
      "sid": 65,
      "location": 2,
      "content": "然后啊啊这操作把旁边的海全都给看懵了",
      "music": 0.2850877130463222
    },
    {
      "from": 120.86,
      "to": 121.3,
      "sid": 66,
      "location": 2,
      "content": "黄老师",
      "music": 0.0
    },
    {
      "from": 121.3,
      "to": 122.82,
      "sid": 67,
      "location": 2,
      "content": "您这平常是这么常态的",
      "music": 0.0
    },
    {
      "from": 122.82,
      "to": 125.62,
      "sid": 68,
      "location": 2,
      "content": "他估计是想要那种法国米其林大厨",
      "music": 0.0
    },
    {
      "from": 125.62,
      "to": 127.62,
      "sid": 69,
      "location": 2,
      "content": "那种用手指尝菜的充实感",
      "music": 0.0
    },
    {
      "from": 127.62,
      "to": 128.54,
      "sid": 70,
      "location": 2,
      "content": "结果没那气质",
      "music": 0.0
    },
    {
      "from": 128.54,
      "to": 130.0,
      "sid": 71,
      "location": 2,
      "content": "学的死不像承认了",
      "music": 0.0
    },
    {
      "from": 130.0,
      "to": 131.96,
      "sid": 72,
      "location": 2,
      "content": "这时候呢我们就可以把这碗料汁下锅了",
      "music": 0.0
    },
    {
      "from": 131.96,
      "to": 134.6,
      "sid": 73,
      "location": 2,
      "content": "真的怀疑黄老师是不是偷偷去印度进修",
      "music": 0.0
    },
    {
      "from": 134.6,
      "to": 136.3,
      "sid": 74,
      "location": 2,
      "content": "这完全不像东亚地区的做法",
      "music": 0.0
    },
    {
      "from": 136.3,
      "to": 138.86,
      "sid": 75,
      "location": 2,
      "content": "突然想起来黄老师最爱的张飞旺放了",
      "music": 0.0
    },
    {
      "from": 138.86,
      "to": 139.48,
      "sid": 76,
      "location": 2,
      "content": "赶紧补上",
      "music": 0.0
    },
    {
      "from": 139.48,
      "to": 141.26,
      "sid": 77,
      "location": 2,
      "content": "我这汤不放的区别好像也不是太大",
      "music": 0.0
    },
    {
      "from": 141.26,
      "to": 143.36,
      "sid": 78,
      "location": 2,
      "content": "接着把炸好的肉片往锅里一倒",
      "music": 0.0
    },
    {
      "from": 143.36,
      "to": 146.159,
      "sid": 79,
      "location": 2,
      "content": "翻炒啊",
      "music": 0.0
    },
    {
      "from": 146.159,
      "to": 148.679,
      "sid": 80,
      "location": 2,
      "content": "我不打扰我走了哈",
      "music": 0.0
    },
    {
      "from": 150.58,
      "to": 152.34,
      "sid": 81,
      "location": 2,
      "content": "最后等汤汁收的差不多",
      "music": 0.0
    },
    {
      "from": 152.34,
      "to": 156.46,
      "sid": 82,
      "location": 2,
      "content": "就可以放上灵魂山楂出锅",
      "music": 0.0
    },
    {
      "from": 161.46,
      "to": 162.3,
      "sid": 83,
      "location": 2,
      "content": "尝一口吧",
      "music": 0.0
    },
    {
      "from": 162.3,
      "to": 164.96,
      "sid": 84,
      "location": 2,
      "content": "Lose me to get this s happen with",
      "music": 0.6808509913988384
    },
    {
      "from": 164.96,
      "to": 167.14,
      "sid": 85,
      "location": 2,
      "content": "And in the street stay",
      "music": 0.9999998387097035
    },
    {
      "from": 167.4,
      "to": 170.24,
      "sid": 86,
      "location": 2,
      "content": "嗯好啊",
      "music": 0.3970587943339232
    },
    {
      "from": 170.24,
      "to": 172.28,
      "sid": 87,
      "location": 2,
      "content": "这个锅包肉既不舒服也不脆啊",
      "music": 0.0
    },
    {
      "from": 172.28,
      "to": 172.8,
      "sid": 88,
      "location": 2,
      "content": "酸酸的",
      "music": 0.0
    },
    {
      "from": 172.8,
      "to": 174.32,
      "sid": 89,
      "location": 2,
      "content": "它更像是糖醋里脊",
      "music": 0.0
    },
    {
      "from": 174.32,
      "to": 175.32,
      "sid": 90,
      "location": 2,
      "content": "倒是也不难吃",
      "music": 0.0
    },
    {
      "from": 175.32,
      "to": 177.36,
      "sid": 91,
      "location": 2,
      "content": "但是你不能称之为锅包肉吧",
      "music": 0.0
    },
    {
      "from": 177.36,
      "to": 179.08,
      "sid": 92,
      "location": 2,
      "content": "还有我不是很明白这个山楂",
      "music": 0.0
    },
    {
      "from": 179.08,
      "to": 180.68,
      "sid": 93,
      "location": 2,
      "content": "它到底是起个什么作用啊",
      "music": 0.0
    },
    {
      "from": 180.68,
      "to": 182.26,
      "sid": 94,
      "location": 2,
      "content": "就完全也吃不出味道",
      "music": 0.0
    }
  ]
}