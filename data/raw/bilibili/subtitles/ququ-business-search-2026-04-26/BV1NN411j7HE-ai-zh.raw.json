  "body": [
    {
      "from": 0.08,
      "to": 2.3,
      "sid": 1,
      "location": 2,
      "content": "首先第一点我怎么让更多人看见我",
      "music": 0.0
    },
    {
      "from": 2.3,
      "to": 2.96,
      "sid": 2,
      "location": 2,
      "content": "这个叫流量",
      "music": 0.0
    },
    {
      "from": 2.96,
      "to": 4.01,
      "sid": 3,
      "location": 2,
      "content": "这是第一件事",
      "music": 0.0
    },
    {
      "from": 4.01,
      "to": 6.2,
      "sid": 4,
      "location": 2,
      "content": "第二件事叫转化率",
      "music": 0.0
    },
    {
      "from": 6.2,
      "to": 8.36,
      "sid": 5,
      "location": 2,
      "content": "就是我能让多少对",
      "music": 0.0
    },
    {
      "from": 8.36,
      "to": 12.04,
      "sid": 6,
      "location": 2,
      "content": "我能让多少客户看到我了之后消费",
      "music": 0.0
    },
    {
      "from": 12.5,
      "to": 14.08,
      "sid": 7,
      "location": 2,
      "content": "这个叫转化率对吧",
      "music": 0.0
    },
    {
      "from": 14.08,
      "to": 15.16,
      "sid": 8,
      "location": 2,
      "content": "就是你首先要关注流量",
      "music": 0.0
    },
    {
      "from": 15.16,
      "to": 16.24,
      "sid": 9,
      "location": 2,
      "content": "然后关注转化率",
      "music": 0.0
    },
    {
      "from": 16.24,
      "to": 17.2,
      "sid": 10,
      "location": 2,
      "content": "第三个关注什么",
      "music": 0.0
    },
    {
      "from": 17.2,
      "to": 18.88,
      "sid": 11,
      "location": 2,
      "content": "第三个关注复购",
      "music": 0.0
    },
    {
      "from": 19.22,
      "to": 20.98,
      "sid": 12,
      "location": 2,
      "content": "在转化率高的前提下",
      "music": 0.0
    },
    {
      "from": 20.98,
      "to": 22.3,
      "sid": 13,
      "location": 2,
      "content": "怎么怎么保障复购呢",
      "music": 0.0
    },
    {
      "from": 22.3,
      "to": 23.62,
      "sid": 14,
      "location": 2,
      "content": "复购有两个方面组成的",
      "music": 0.0
    },
    {
      "from": 23.62,
      "to": 25.84,
      "sid": 15,
      "location": 2,
      "content": "第一个方面就是交付的满意度",
      "music": 0.0
    },
    {
      "from": 25.84,
      "to": 28.18,
      "sid": 16,
      "location": 2,
      "content": "就是你所做的这个交付客户很满意",
      "music": 0.0
    },
    {
      "from": 28.18,
      "to": 29.29,
      "sid": 17,
      "location": 2,
      "content": "他就容易产生复购对吧",
      "music": 0.0
    },
    {
      "from": 29.29,
      "to": 30.76,
      "sid": 18,
      "location": 2,
      "content": "第二个东西产生复购的是什么呢",
      "music": 0.0
    },
    {
      "from": 30.76,
      "to": 35.39,
      "sid": 19,
      "location": 2,
      "content": "就是你给你对于客户的后续维护回访产生复购",
      "music": 0.0
    },
    {
      "from": 35.39,
      "to": 37.31,
      "sid": 20,
      "location": 2,
      "content": "就是你无非就是这几个链路",
      "music": 0.0
    },
    {
      "from": 37.31,
      "to": 38.75,
      "sid": 21,
      "location": 2,
      "content": "无非就是这几个链路的事",
      "music": 0.0
    },
    {
      "from": 38.75,
      "to": 40.37,
      "sid": 22,
      "location": 2,
      "content": "如果说我跟你说的这几个数据",
      "music": 0.0
    },
    {
      "from": 40.37,
      "to": 42.29,
      "sid": 23,
      "location": 2,
      "content": "你你你肯定是缓缓的掉链子的",
      "music": 0.0
    },
    {
      "from": 42.29,
      "to": 43.85,
      "sid": 24,
      "location": 2,
      "content": "当你的业务量起来的时候",
      "music": 0.0
    },
    {
      "from": 43.85,
      "to": 45.77,
      "sid": 25,
      "location": 2,
      "content": "他一定是每一个环节都掉链子啊",
      "music": 0.0
    },
    {
      "from": 45.77,
      "to": 47.58,
      "sid": 26,
      "location": 2,
      "content": "就是每一个环节他都有很大的提升空间",
      "music": 0.0
    },
    {
      "from": 47.58,
      "to": 49.38,
      "sid": 27,
      "location": 2,
      "content": "你把每一个环节提升空间记起来了",
      "music": 0.0
    },
    {
      "from": 49.38,
      "to": 50.97,
      "sid": 28,
      "location": 2,
      "content": "他最后业务真展才亮起来了",
      "music": 0.0
    },
    {
      "from": 50.97,
      "to": 52.44,
      "sid": 29,
      "location": 2,
      "content": "老师你建议我去上课",
      "music": 0.0
    },
    {
      "from": 52.44,
      "to": 53.88,
      "sid": 30,
      "location": 2,
      "content": "就是有MV洋课吗",
      "music": 0.0
    },
    {
      "from": 53.88,
      "to": 54.34,
      "sid": 31,
      "location": 2,
      "content": "可以啊",
      "music": 0.0
    },
    {
      "from": 54.34,
      "to": 55.72,
      "sid": 32,
      "location": 2,
      "content": "如果你觉得你现在是吧",
      "music": 0.0
    },
    {
      "from": 55.72,
      "to": 57.19,
      "sid": 33,
      "location": 2,
      "content": "手上有一定的闲散的钱",
      "music": 0.0
    },
    {
      "from": 57.19,
      "to": 59.08,
      "sid": 34,
      "location": 2,
      "content": "然后也觉得自己现在在做业务的过程当中",
      "music": 0.0
    },
    {
      "from": 59.08,
      "to": 60.52,
      "sid": 35,
      "location": 2,
      "content": "确确实实需要更加系统性的知识",
