{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.92,
      "sid": 1,
      "location": 2,
      "content": "那五分化呢五次把全身练一遍",
      "music": 0.0
    },
    {
      "from": 1.92,
      "to": 2.48,
      "sid": 2,
      "location": 2,
      "content": "很好理解",
      "music": 0.0
    },
    {
      "from": 2.48,
      "to": 3.36,
      "sid": 3,
      "location": 2,
      "content": "你能坚持六天",
      "music": 0.0
    },
    {
      "from": 3.36,
      "to": 4.44,
      "sid": 4,
      "location": 2,
      "content": "你还神采飞扬的",
      "music": 0.0
    },
    {
      "from": 4.44,
      "to": 6.26,
      "sid": 5,
      "location": 2,
      "content": "说明你的训练强度可能有问题",
      "music": 0.0
    },
    {
      "from": 6.26,
      "to": 7.46,
      "sid": 6,
      "location": 2,
      "content": "哈喽兄弟姐妹们",
      "music": 0.0
    },
    {
      "from": 7.46,
      "to": 9.1,
      "sid": 7,
      "location": 2,
      "content": "后台总是有留言问我说",
      "music": 0.0
    },
    {
      "from": 9.1,
      "to": 11.34,
      "sid": 8,
      "location": 2,
      "content": "凯哥到底是一分话好还是三分话好",
      "music": 0.0
    },
    {
      "from": 11.34,
      "to": 12.18,
      "sid": 9,
      "location": 2,
      "content": "还是五分化好",
      "music": 0.0
    },
    {
      "from": 12.18,
      "to": 13.22,
      "sid": 10,
      "location": 2,
      "content": "说我练五分化",
      "music": 0.0
    },
    {
      "from": 13.22,
      "to": 14.06,
      "sid": 11,
      "location": 2,
      "content": "我练了半年",
      "music": 0.0
    },
    {
      "from": 14.06,
      "to": 15.16,
      "sid": 12,
      "location": 2,
      "content": "为什么我没有进步",
      "music": 0.0
    },
    {
      "from": 15.16,
      "to": 16.32,
      "sid": 13,
      "location": 2,
      "content": "还是说我练一分化",
      "music": 0.0
    },
    {
      "from": 16.32,
      "to": 18.94,
      "sid": 14,
      "location": 2,
      "content": "我应该练多久才可以继续向上进阶",
      "music": 0.0
    },
    {
      "from": 18.94,
      "to": 21.3,
      "sid": 15,
      "location": 2,
      "content": "其实不同的分化呢代表着不同的模板",
      "music": 0.0
    },
    {
      "from": 21.3,
      "to": 22.22,
      "sid": 16,
      "location": 2,
      "content": "你可以理解为",
      "music": 0.0
    },
    {
      "from": 22.22,
      "to": 23.58,
      "sid": 17,
      "location": 2,
      "content": "比如说一分化一次",
      "music": 0.0
    },
    {
      "from": 23.58,
      "to": 24.88,
      "sid": 18,
      "location": 2,
      "content": "把全身都练一遍",
      "music": 0.0
    },
    {
      "from": 24.88,
      "to": 27.44,
      "sid": 19,
      "location": 2,
      "content": "三分化呢我需要三次把全身练一遍",
      "music": 0.0
    },
    {
      "from": 27.44,
      "to": 29.36,
      "sid": 20,
      "location": 2,
      "content": "那五分化呢九次把全身练一遍",
      "music": 0.0
    },
    {
      "from": 29.36,
      "to": 29.92,
      "sid": 21,
      "location": 2,
      "content": "很好理解",
      "music": 0.0
    },
    {
      "from": 29.92,
      "to": 31.46,
      "sid": 22,
      "location": 2,
      "content": "如果我同样的组数",
      "music": 0.0
    },
    {
      "from": 31.46,
      "to": 34.34,
      "sid": 23,
      "location": 2,
      "content": "比如说我们把总组数固定到24组左右",
      "music": 0.0
    },
    {
      "from": 34.34,
      "to": 35.34,
      "sid": 24,
      "location": 2,
      "content": "要一分化",
      "music": 0.0
    },
    {
      "from": 35.34,
      "to": 37.4,
      "sid": 25,
      "location": 2,
      "content": "在一天时间内把全程都练一遍",
      "music": 0.0
    },
    {
      "from": 37.4,
      "to": 39.32,
      "sid": 26,
      "location": 2,
      "content": "对于每个训练部位",
      "music": 0.0
    },
    {
      "from": 39.32,
      "to": 40.96,
      "sid": 27,
      "location": 2,
      "content": "它的容量是比较低的",
      "music": 0.0
    },
    {
      "from": 40.96,
      "to": 42.64,
      "sid": 28,
      "location": 2,
      "content": "它的强度呢也是比较低的",
      "music": 0.0
    },
    {
      "from": 42.64,
      "to": 43.72,
      "sid": 29,
      "location": 2,
      "content": "但频率会很高",
      "music": 0.0
    },
    {
      "from": 43.72,
      "to": 45.44,
      "sid": 30,
      "location": 2,
      "content": "比如说我练一天歇一天",
      "music": 0.0
    },
    {
      "from": 45.44,
      "to": 46.86,
      "sid": 31,
      "location": 2,
      "content": "那我同样一个部位",
      "music": 0.0
    },
    {
      "from": 46.86,
      "to": 48.74,
      "sid": 32,
      "location": 2,
      "content": "一礼拜可能也会练到两次",
      "music": 0.0
    },
    {
      "from": 48.74,
      "to": 50.1,
      "sid": 33,
      "location": 2,
      "content": "三次以上对吧",
      "music": 0.0
    },
    {
      "from": 50.1,
      "to": 52.2,
      "sid": 34,
      "location": 2,
      "content": "那么三分化呢拍出来一些部位",
      "music": 0.0
    },
    {
      "from": 52.2,
      "to": 54.16,
      "sid": 35,
      "location": 2,
      "content": "比如说我把胸跟肩放在一块",
      "music": 0.0
    },
    {
      "from": 54.16,
      "to": 55.4,
      "sid": 36,
      "location": 2,
      "content": "或者胸跟三头放在一块",
      "music": 0.0
    },
    {
      "from": 55.4,
      "to": 56.52,
      "sid": 37,
      "location": 2,
      "content": "背跟二头放在一块",
      "music": 0.0
    },
    {
      "from": 56.52,
      "to": 57.6,
      "sid": 38,
      "location": 2,
      "content": "腿跟上肢放在一块",
      "music": 0.0
    },
    {
      "from": 57.6,
      "to": 59.08,
      "sid": 39,
      "location": 2,
      "content": "或者说腿跟肩放在一块等等",
      "music": 0.0
    },
    {
      "from": 59.08,
      "to": 60.24,
      "sid": 40,
      "location": 2,
      "content": "它有很多种排列组合",
      "music": 0.0
    },
    {
      "from": 60.24,
      "to": 63.3,
      "sid": 41,
      "location": 2,
      "content": "因而那它最高频率呢可能就是练三天歇一天",
      "music": 0.0
    },
    {
      "from": 63.3,
      "to": 66.4,
      "sid": 42,
      "location": 2,
      "content": "我一周呢能让所有部位完成两次循环啊",
      "music": 0.0
    },
    {
      "from": 66.4,
      "to": 68.4,
      "sid": 43,
      "location": 2,
      "content": "在每一次训练里边的强度跟容量",
      "music": 0.0
    },
    {
      "from": 68.4,
      "to": 69.92,
      "sid": 44,
      "location": 2,
      "content": "就比一分化要大很多",
      "music": 0.0
    },
    {
      "from": 69.92,
      "to": 71.38,
      "sid": 45,
      "location": 2,
      "content": "但是又比五分化呢要低",
      "music": 0.0
    },
    {
      "from": 71.38,
      "to": 72.86,
      "sid": 46,
      "location": 2,
      "content": "所以说你可以把它理解为它",
      "music": 0.0
    },
    {
      "from": 72.86,
      "to": 74.58,
      "sid": 47,
      "location": 2,
      "content": "它的强度呢比较居中",
      "music": 0.0
    },
    {
      "from": 74.58,
      "to": 75.62,
      "sid": 48,
      "location": 2,
      "content": "频率呢非常高",
      "music": 0.0
    },
    {
      "from": 75.62,
      "to": 77.74,
      "sid": 49,
      "location": 2,
      "content": "五分化相当于一次只练一个部位",
      "music": 0.0
    },
    {
      "from": 77.74,
      "to": 78.5,
      "sid": 50,
      "location": 2,
      "content": "比如我今天练胸",
      "music": 0.0
    },
    {
      "from": 78.5,
      "to": 79.22,
      "sid": 51,
      "location": 2,
      "content": "我只练胸肌",
      "music": 0.0
    },
    {
      "from": 79.22,
      "to": 80.5,
      "sid": 52,
      "location": 2,
      "content": "我再练到胸的时候",
      "music": 0.0
    },
    {
      "from": 80.5,
      "to": 83.42,
      "sid": 53,
      "location": 2,
      "content": "可能已经下周有很多兄弟去执行五分化计划",
      "music": 0.0
    },
    {
      "from": 83.42,
      "to": 85.66,
      "sid": 54,
      "location": 2,
      "content": "第一个动作我的训练重量耐力都还OK的",
      "music": 0.0
    },
    {
      "from": 85.66,
      "to": 87.3,
      "sid": 55,
      "location": 2,
      "content": "第二个动作我就完全没劲儿了",
      "music": 0.0
    },
    {
      "from": 87.3,
      "to": 89.5,
      "sid": 56,
      "location": 2,
      "content": "所以这个时候是你的身体还达不到这个强度",
      "music": 0.0
    },
    {
      "from": 89.5,
      "to": 91.62,
      "sid": 57,
      "location": 2,
      "content": "我们并不能跟那些职业选手去比较",
      "music": 0.0
    },
    {
      "from": 91.62,
      "to": 93.26,
      "sid": 58,
      "location": 2,
      "content": "因为他们的训练年限非常长",
      "music": 0.0
    },
    {
      "from": 93.26,
      "to": 94.94,
      "sid": 59,
      "location": 2,
      "content": "基本功结构非常扎实",
      "music": 0.0
    },
    {
      "from": 94.94,
      "to": 97.38,
      "sid": 60,
      "location": 2,
      "content": "他们可以去使用一些高分化的训练",
      "music": 0.0
    },
    {
      "from": 97.38,
      "to": 99.98,
      "sid": 61,
      "location": 2,
      "content": "他们在单次的时候能给肌肉更好的刺激",
      "music": 0.0
    },
    {
      "from": 99.98,
      "to": 100.58,
      "sid": 62,
      "location": 2,
      "content": "像咱们一样",
      "music": 0.0
    },
    {
      "from": 100.58,
      "to": 101.78,
      "sid": 63,
      "location": 2,
      "content": "咱们都是爱好者吗",
      "music": 0.0
    },
    {
      "from": 101.78,
      "to": 103.3,
      "sid": 64,
      "location": 2,
      "content": "那这时候我们就要选择一个",
      "music": 0.0
    },
    {
      "from": 103.3,
      "to": 104.88,
      "sid": 65,
      "location": 2,
      "content": "比较适合自己的计划",
      "music": 0.0
    },
    {
      "from": 104.88,
      "to": 107.76,
      "sid": 66,
      "location": 2,
      "content": "让能让我们在训练当中比较适中的容量",
      "music": 0.0
    },
    {
      "from": 107.76,
      "to": 109.0,
      "sid": 67,
      "location": 2,
      "content": "比较适中的强度",
      "music": 0.0
    },
    {
      "from": 109.0,
      "to": 111.12,
      "sid": 68,
      "location": 2,
      "content": "然后能匹配到我们现在正好的身体",
      "music": 0.0
    },
    {
      "from": 111.12,
      "to": 113.2,
      "sid": 69,
      "location": 2,
      "content": "既不会有很疲劳的感觉",
      "music": 0.0
    },
    {
      "from": 113.2,
      "to": 114.24,
      "sid": 70,
      "location": 2,
      "content": "恢复不过来的训练",
      "music": 0.0
    },
    {
      "from": 114.24,
      "to": 116.4,
      "sid": 71,
      "location": 2,
      "content": "就像我跟一涵我们之前讲的那个一样",
      "music": 0.0
    },
    {
      "from": 116.4,
      "to": 119.02,
      "sid": 72,
      "location": 2,
      "content": "就是恢复不过来的训练其实意义不大的",
      "music": 0.0
    },
    {
      "from": 119.02,
      "to": 121.28,
      "sid": 73,
      "location": 2,
      "content": "重复强度的训练意义也是不大的",
      "music": 0.0
    },
    {
      "from": 121.28,
      "to": 123.78,
      "sid": 74,
      "location": 2,
      "content": "对于刚开始健身的兄弟们",
      "music": 0.0
    },
    {
      "from": 123.78,
      "to": 126.1,
      "sid": 75,
      "location": 2,
      "content": "我们为什么练完了之后血糖下降了对吧",
      "music": 0.0
    },
    {
      "from": 126.1,
      "to": 126.64,
      "sid": 76,
      "location": 2,
      "content": "很难受",
      "music": 0.0
    },
    {
      "from": 126.64,
      "to": 128.58,
      "sid": 77,
      "location": 2,
      "content": "时间长了以后会出现各种问题",
      "music": 0.0
    },
    {
      "from": 128.58,
      "to": 129.82,
      "sid": 78,
      "location": 2,
      "content": "比如说卡压或者弹性",
      "music": 0.0
    },
    {
      "from": 129.82,
      "to": 130.78,
      "sid": 79,
      "location": 2,
      "content": "你有没有想过",
      "music": 0.0
    },
    {
      "from": 130.78,
      "to": 132.9,
      "sid": 80,
      "location": 2,
      "content": "其实五分化的频率非常的低",
      "music": 0.0
    },
    {
      "from": 132.9,
      "to": 134.5,
      "sid": 81,
      "location": 2,
      "content": "假如说我周一练完了胸",
      "music": 0.0
    },
    {
      "from": 134.5,
      "to": 137.06,
      "sid": 82,
      "location": 2,
      "content": "那你不可能说这一周我都不休息",
      "music": 0.0
    },
    {
      "from": 137.06,
      "to": 139.02,
      "sid": 83,
      "location": 2,
      "content": "有很多兄弟说我练五天歇一天",
      "music": 0.0
    },
    {
      "from": 139.02,
      "to": 140.26,
      "sid": 84,
      "location": 2,
      "content": "或者我练六天歇一天",
      "music": 0.0
    },
    {
      "from": 140.26,
      "to": 140.96,
      "sid": 85,
      "location": 2,
      "content": "可不可以",
      "music": 0.0
    },
    {
      "from": 140.96,
      "to": 141.72,
      "sid": 86,
      "location": 2,
      "content": "完全不行",
      "music": 0.0
    },
    {
      "from": 141.72,
      "to": 142.08,
      "sid": 87,
      "location": 2,
      "content": "为什么",
      "music": 0.0
    },
    {
      "from": 142.08,
      "to": 145.12,
      "sid": 88,
      "location": 2,
      "content": "因为训练要执行的就是遵守的渐进超负荷",
      "music": 0.0
    },
    {
      "from": 145.12,
      "to": 148.16,
      "sid": 89,
      "location": 2,
      "content": "你要在你的训练计划里加入什么是代谢压力",
      "music": 0.0
    },
    {
      "from": 148.16,
      "to": 149.08,
      "sid": 90,
      "location": 2,
      "content": "什么是机械张力",
      "music": 0.0
    },
    {
      "from": 149.08,
      "to": 150.32,
      "sid": 91,
      "location": 2,
      "content": "你要去破坏你的肌肉",
      "music": 0.0
    },
    {
      "from": 150.32,
      "to": 152.04,
      "sid": 92,
      "location": 2,
      "content": "让它产生超量恢复我们的力量",
      "music": 0.0
    },
    {
      "from": 152.04,
      "to": 152.94,
      "sid": 93,
      "location": 2,
      "content": "我们的肌肉才会生长",
      "music": 0.0
    },
    {
      "from": 152.94,
      "to": 154.5,
      "sid": 94,
      "location": 2,
      "content": "那他是在什么时候长的呢",
      "music": 0.0
    },
    {
      "from": 154.5,
      "to": 155.7,
      "sid": 95,
      "location": 2,
      "content": "他是在休息的时候长的",
      "music": 0.0
    },
    {
      "from": 155.7,
      "to": 157.62,
      "sid": 96,
      "location": 2,
      "content": "如果你的训练强度真的OK的话",
      "music": 0.0
    },
    {
      "from": 157.62,
      "to": 158.26,
      "sid": 97,
      "location": 2,
      "content": "那你不休息",
      "music": 0.0
    },
    {
      "from": 158.26,
      "to": 160.46,
      "sid": 98,
      "location": 2,
      "content": "你很快你的肌肉跟神经疲劳了",
      "music": 0.0
    },
    {
      "from": 160.46,
      "to": 161.82,
      "sid": 99,
      "location": 2,
      "content": "那你会走一个下行通道",
      "music": 0.0
    },
    {
      "from": 161.82,
      "to": 162.54,
      "sid": 100,
      "location": 2,
      "content": "你也长不了",
      "music": 0.0
    },
    {
      "from": 162.54,
      "to": 164.14,
      "sid": 101,
      "location": 2,
      "content": "那如果你能坚持六天",
      "music": 0.0
    },
    {
      "from": 164.14,
      "to": 165.18,
      "sid": 102,
      "location": 2,
      "content": "你还神采飞扬的",
      "music": 0.0
    },
    {
      "from": 165.18,
      "to": 167.26,
      "sid": 103,
      "location": 2,
      "content": "说明你的训练强度可能有问题啊",
      "music": 0.0
    },
    {
      "from": 167.26,
      "to": 169.7,
      "sid": 104,
      "location": 2,
      "content": "你只是一直在热身或者说跳广场舞",
      "music": 0.0
    },
    {
      "from": 169.7,
      "to": 171.0,
      "sid": 105,
      "location": 2,
      "content": "所以你也可能无法进步",
      "music": 0.0
    },
    {
      "from": 171.0,
      "to": 171.92,
      "sid": 106,
      "location": 2,
      "content": "合理的休息",
      "music": 0.0
    },
    {
      "from": 171.92,
      "to": 173.56,
      "sid": 107,
      "location": 2,
      "content": "合理的频率是很重要的",
      "music": 0.0
    },
    {
      "from": 173.56,
      "to": 175.2,
      "sid": 108,
      "location": 2,
      "content": "但如果你是想持续进步的话",
      "music": 0.0
    },
    {
      "from": 175.2,
      "to": 178.14,
      "sid": 109,
      "location": 2,
