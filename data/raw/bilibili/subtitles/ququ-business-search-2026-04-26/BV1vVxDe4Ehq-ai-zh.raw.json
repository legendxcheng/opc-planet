{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.16,
      "to": 2.06,
      "sid": 1,
      "location": 2,
      "content": "我觉得他问的这个问题很有代表性啊",
      "music": 0.0
    },
    {
      "from": 2.06,
      "to": 3.44,
      "sid": 2,
      "location": 2,
      "content": "这个问题很有代表性啊",
      "music": 0.0
    },
    {
      "from": 3.44,
      "to": 5.82,
      "sid": 3,
      "location": 2,
      "content": "其实你们很多人都是这样的",
      "music": 0.0
    },
    {
      "from": 5.82,
      "to": 7.48,
      "sid": 4,
      "location": 2,
      "content": "我告诉你们什么概念啊",
      "music": 0.0
    },
    {
      "from": 7.48,
      "to": 12.48,
      "sid": 5,
      "location": 2,
      "content": "你们很多人都是在一个温水煮青蛙的行业里头",
      "music": 0.0
    },
    {
      "from": 12.48,
      "to": 16.309,
      "sid": 6,
      "location": 2,
      "content": "肉眼可见的看着这个行业走下坡",
      "music": 0.0
    },
    {
      "from": 16.309,
      "to": 18.789,
      "sid": 7,
      "location": 2,
      "content": "肉眼可见的看着这个行业",
      "music": 0.0
    },
    {
      "from": 18.789,
      "to": 20.949,
      "sid": 8,
      "location": 2,
      "content": "或者这个技能被时代所淘汰",
      "music": 0.0
    },
    {
      "from": 20.949,
      "to": 22.149,
      "sid": 9,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 22.149,
      "to": 24.269,
      "sid": 10,
      "location": 2,
      "content": "大家说是不是吧",
      "music": 0.0
    },
    {
      "from": 25.1,
      "to": 27.06,
      "sid": 11,
      "location": 2,
      "content": "不是你不能看见",
      "music": 0.0
    },
    {
      "from": 27.06,
      "to": 29.88,
      "sid": 12,
      "location": 2,
      "content": "不是你不能判断",
      "music": 0.0
    },
    {
      "from": 30.2,
      "to": 34.92,
      "sid": 13,
      "location": 2,
      "content": "而是你舍弃不下你打下的江山",
      "music": 0.0
    },
    {
      "from": 35.71,
      "to": 36.57,
      "sid": 14,
      "location": 2,
      "content": "知道吗",
      "music": 0.0
    },
    {
      "from": 36.57,
      "to": 38.67,
      "sid": 15,
      "location": 2,
      "content": "你就算已经看出来了",
      "music": 0.0
    },
    {
      "from": 38.67,
      "to": 41.289,
      "sid": 16,
      "location": 2,
      "content": "哎呀这个这个路子已经不行了呀",
      "music": 0.0
    },
    {
      "from": 41.289,
      "to": 42.869,
      "sid": 17,
      "location": 2,
      "content": "这个行业在走下坡了呀",
      "music": 0.0
    },
    {
      "from": 42.869,
      "to": 45.509,
      "sid": 18,
      "location": 2,
      "content": "这这这已经这现在他已经被新技术",
      "music": 0.0
    },
    {
      "from": 45.509,
      "to": 47.09,
      "sid": 19,
      "location": 2,
      "content": "新方法替代了呀",
      "music": 0.0
    },
    {
      "from": 47.09,
      "to": 47.87,
      "sid": 20,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 47.87,
      "to": 49.71,
      "sid": 21,
      "location": 2,
      "content": "我跟你们讲个打个比方啊",
      "music": 0.0
    },
    {
      "from": 49.71,
      "to": 51.89,
      "sid": 22,
      "location": 2,
      "content": "你们就看我们做媒体行业的人",
      "music": 0.0
    },
    {
      "from": 51.89,
      "to": 55.51,
      "sid": 23,
      "location": 2,
      "content": "你们说电视媒体称霸了多少年",
      "music": 0.0
    },
    {
      "from": 55.83,
      "to": 58.13,
      "sid": 24,
      "location": 2,
      "content": "你们说电视媒体该称霸了多少年",
      "music": 0.0
    },
    {
      "from": 58.13,
      "to": 61.03,
      "sid": 25,
      "location": 2,
      "content": "你们知道我前几年在做自媒体的时候",
      "music": 0.0
    },
    {
      "from": 61.03,
      "to": 63.75,
      "sid": 26,
      "location": 2,
      "content": "当时是个什么感觉吗",
      "music": 0.0
    },
    {
      "from": 64.48,
      "to": 66.0,
      "sid": 27,
      "location": 2,
      "content": "我前几年在做自媒体的时候",
      "music": 0.0
    },
    {
      "from": 66.0,
      "to": 69.53,
      "sid": 28,
      "location": 2,
      "content": "那个时候啊传统媒体的一些以前的一些大佬",
      "music": 0.0
    },
    {
      "from": 69.53,
      "to": 71.09,
      "sid": 29,
      "location": 2,
      "content": "那些大拿大咖",
      "music": 0.0
    },
    {
      "from": 71.09,
      "to": 74.4,
      "sid": 30,
      "location": 2,
      "content": "他们特别瞧不上主播",
      "music": 0.0
    },
    {
      "from": 74.4,
      "to": 76.84,
      "sid": 31,
      "location": 2,
      "content": "特别瞧不上主播这个行业",
      "music": 0.0
    },
    {
      "from": 76.84,
      "to": 80.94,
      "sid": 32,
      "location": 2,
      "content": "他们那个时候认为把网络主播称作主播",
      "music": 0.0
    },
    {
      "from": 80.94,
      "to": 84.03,
      "sid": 33,
      "location": 2,
      "content": "是对主播这个职业的一种亵渎",
      "music": 0.0
    },
    {
      "from": 84.08,
      "to": 87.6,
      "sid": 34,
      "location": 2,
      "content": "因为我是从传统媒体出来的",
      "music": 0.0
    },
    {
      "from": 88.16,
      "to": 90.14,
      "sid": 35,
      "location": 2,
      "content": "然后进入到自媒体赛道的",
      "music": 0.0
    },
    {
      "from": 90.14,
      "to": 92.28,
      "sid": 36,
      "location": 2,
      "content": "只是说我在传统媒体里头扎根不深",
      "music": 0.0
    },
    {
      "from": 92.28,
      "to": 94.87,
      "sid": 37,
      "location": 2,
      "content": "因为我总共在传统媒体里头待了不到两年",
      "music": 0.0
    },
    {
      "from": 94.87,
      "to": 96.05,
      "sid": 38,
      "location": 2,
      "content": "我先是做新闻",
      "music": 0.0
    },
    {
      "from": 96.05,
      "to": 97.15,
      "sid": 39,
      "location": 2,
      "content": "后来我又去做电影",
      "music": 0.0
    },
    {
      "from": 97.15,
      "to": 98.27,
      "sid": 40,
      "location": 2,
      "content": "做汽车我都做过",
      "music": 0.0
    },
    {
      "from": 98.27,
      "to": 100.07,
      "sid": 41,
      "location": 2,
      "content": "但我原来就是传统的电视媒体",
      "music": 0.0
    },
    {
      "from": 100.07,
      "to": 101.39,
      "sid": 42,
      "location": 2,
      "content": "我从传统的电视媒体",
      "music": 0.0
    },
    {
      "from": 101.39,
      "to": 103.39,
      "sid": 43,
      "location": 2,
      "content": "我我等于说做新闻的时候呢",
      "music": 0.0
    },
    {
      "from": 103.39,
      "to": 104.67,
      "sid": 44,
      "location": 2,
      "content": "我也是个边缘化人物",
      "music": 0.0
    },
    {
      "from": 104.67,
      "to": 105.13,
      "sid": 45,
      "location": 2,
      "content": "知道吧",
      "music": 0.0
    },
    {
      "from": 105.13,
      "to": 107.95,
      "sid": 46,
      "location": 2,
      "content": "就是被被哈哈被空降部队给挤出来了",
      "music": 0.0
    },
    {
      "from": 107.95,
      "to": 110.5,
      "sid": 47,
      "location": 2,
      "content": "然后呢我自己去做做那个电影类呀",
      "music": 0.0
    },
    {
      "from": 110.5,
      "to": 111.06,
      "sid": 48,
      "location": 2,
      "content": "做汽车类的",
      "music": 0.0
    },
    {
      "from": 111.06,
      "to": 111.58,
      "sid": 49,
      "location": 2,
      "content": "这些时候呢",
      "music": 0.0
    },
    {
      "from": 111.58,
      "to": 113.3,
      "sid": 50,
      "location": 2,
      "content": "它其实都是属于外包类的节目",
      "music": 0.0
    },
    {
      "from": 113.3,
      "to": 114.78,
      "sid": 51,
      "location": 2,
      "content": "就是它不是电视台内部的",
      "music": 0.0
    },
    {
      "from": 114.78,
      "to": 116.82,
      "sid": 52,
      "location": 2,
      "content": "它都是电视台把时段分包出来",
      "music": 0.0
    },
    {
      "from": 116.82,
      "to": 118.78,
      "sid": 53,
      "location": 2,
      "content": "然后给那些私人老板来做节目的",
      "music": 0.0
    },
    {
      "from": 118.78,
      "to": 120.46,
      "sid": 54,
      "location": 2,
      "content": "所以说我以前在传统媒体的时候",
      "music": 0.0
    },
    {
      "from": 120.46,
      "to": 121.32,
      "sid": 55,
      "location": 2,
      "content": "我扎根不深",
      "music": 0.0
    },
    {
      "from": 121.32,
      "to": 122.949,
      "sid": 56,
      "location": 2,
      "content": "我我没有根基",
      "music": 0.0
    },
    {
      "from": 123.349,
      "to": 125.109,
      "sid": 57,
      "location": 2,
      "content": "所以我们在做自媒体",
      "music": 0.0
    },
    {
      "from": 125.109,
      "to": 126.269,
      "sid": 58,
      "location": 2,
      "content": "在做新型媒体的时候呢",
      "music": 0.0
    },
    {
      "from": 126.269,
      "to": 128.569,
      "sid": 59,
      "location": 2,
      "content": "其实没有任何的这种内心内耗的",
      "music": 0.0
    },
    {
      "from": 128.569,
      "to": 129.469,
      "sid": 60,
      "location": 2,
      "content": "因为我没有",
      "music": 0.0
    },
    {
      "from": 129.469,
      "to": 132.479,
      "sid": 61,
      "location": 2,
      "content": "就因为我本来就不是原来那个行业里头的大拿",
      "music": 0.0
    },
    {
      "from": 132.479,
      "to": 132.819,
      "sid": 62,
      "location": 2,
      "content": "知道吧",
      "music": 0.0
    },
    {
      "from": 132.819,
      "to": 134.339,
      "sid": 63,
      "location": 2,
      "content": "我好不容易找到一个新兴媒体的机会",
      "music": 0.0
    },
    {
      "from": 134.339,
      "to": 136.699,
      "sid": 64,
      "location": 2,
      "content": "我觉得这对于我来说就是一个大机会",
      "music": 0.0
    },
    {
      "from": 137.44,
      "to": 140.88,
      "sid": 65,
      "location": 2,
      "content": "但是那些在传统媒体里头扎根扎的很深的人",
      "music": 0.0
    },
    {
      "from": 140.88,
      "to": 142.56,
      "sid": 66,
      "location": 2,
      "content": "拿到过大结果的人来看",
      "music": 0.0
    },
    {
      "from": 142.56,
      "to": 143.52,
      "sid": 67,
      "location": 2,
      "content": "我今天讲的这番话",
      "music": 0.0
    },
    {
      "from": 143.52,
      "to": 144.839,
      "sid": 68,
      "location": 2,
      "content": "一定会非常有感触",
      "music": 0.0
    },
    {
      "from": 144.839,
      "to": 149.6,
      "sid": 69,
      "location": 2,
      "content": "以前电视台里头的那些主播是很有光环的",
      "music": 0.0
    },
    {
      "from": 150.08,
      "to": 151.42,
      "sid": 70,
      "location": 2,
      "content": "或电视台也好",
      "music": 0.0
    },
    {
      "from": 151.42,
      "to": 152.62,
      "sid": 71,
      "location": 2,
      "content": "纸媒也好是吧",
      "music": 0.0
    },
    {
      "from": 152.62,
      "to": 154.16,
      "sid": 72,
      "location": 2,
      "content": "就是那些传统媒体人",
      "music": 0.0
    },
    {
      "from": 154.16,
      "to": 157.0,
      "sid": 73,
      "location": 2,
      "content": "其实他们第一有种铁饭碗这个性质在里头",
      "music": 0.0
    },
    {
      "from": 157.0,
      "to": 160.42,
      "sid": 74,
      "location": 2,
      "content": "再一个就是说他们是很有社会影响力的",
      "music": 0.0
    },
    {
      "from": 160.42,
      "to": 162.31,
      "sid": 75,
      "location": 2,
      "content": "很有光环的",
      "music": 0.0
    },
    {
      "from": 162.31,
      "to": 164.24,
      "sid": 76,
      "location": 2,
      "content": "那个时候你们想想看",
      "music": 0.0
    },
    {
      "from": 164.24,
      "to": 166.52,
      "sid": 77,
      "location": 2,
      "content": "那些电视媒体靠什么来营收",
      "music": 0.0
    },
    {
      "from": 166.52,
      "to": 167.68,
      "sid": 78,
      "location": 2,
      "content": "是不是靠广告啊",
      "music": 0.0
    },
    {
      "from": 167.68,
      "to": 168.62,
      "sid": 79,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 168.62,
      "to": 171.9,
      "sid": 80,
      "location": 2,
      "content": "那些广告的营收其实很大很大的",
      "music": 0.0
    },
    {
      "from": 171.9,
      "to": 172.84,
      "sid": 81,
      "location": 2,
      "content": "然后呢",
      "music": 0.0
    },
    {
      "from": 172.84,
      "to": 175.76,
      "sid": 82,
      "location": 2,
      "content": "请这些传统媒体的这样一些主播呀什么的",
      "music": 0.0
    },
    {
      "from": 175.76,
      "to": 176.77,
      "sid": 83,
      "location": 2,
      "content": "出去代言",
      "music": 0.0
    },
    {
      "from": 176.77,
      "to": 178.59,
      "sid": 84,
      "location": 2,
      "content": "他们的费用都是很高的",
      "music": 0.0
    },
    {
      "from": 178.59,
      "to": 180.57,
      "sid": 85,
      "location": 2,
      "content": "他们出去走学出去代言",
      "music": 0.0
    },
    {
      "from": 180.57,
      "to": 182.39,
      "sid": 86,
      "location": 2,
      "content": "他们的费用都是很高很高的",
      "music": 0.0
    },
    {
      "from": 182.39,
      "to": 184.57,
      "sid": 87,
      "location": 2,
      "content": "可是这些费用的高他是什么决定的",
      "music": 0.0
    },
    {
      "from": 184.57,
      "to": 186.27,
      "sid": 88,
      "location": 2,
      "content": "它是市场需求决定的",
      "music": 0.0
    },
    {
      "from": 186.27,
      "to": 188.07,
      "sid": 89,
      "location": 2,
      "content": "它是流量决定的",
      "music": 0.0
    },
    {
      "from": 188.07,
      "to": 190.17,
      "sid": 90,
      "location": 2,
      "content": "就是说因为那个时候的流量",
      "music": 0.0
    },
    {
      "from": 190.17,
      "to": 191.51,
      "sid": 91,
      "location": 2,
      "content": "它就聚集在传统媒体",
      "music": 0.0
    },
    {
      "from": 191.51,
      "to": 194.15,
      "sid": 92,
      "location": 2,
      "content": "所以说传统媒体的大量的流量",
      "music": 0.0
    },
    {
      "from": 194.15,
      "to": 197.61,
      "sid": 93,
      "location": 2,
      "content": "导致他能收到很高的广告费用",
      "music": 0.0
    },
    {
      "from": 197.61,
      "to": 201.07,
      "sid": 94,
      "location": 2,
      "content": "导致这些主播能在这样的一些环节里边",
      "music": 0.0
    },
    {
      "from": 201.07,
      "to": 203.78,
      "sid": 95,
      "location": 2,
      "content": "拿到很高的报酬",
      "music": 0.0
    },
    {
      "from": 203.78,
      "to": 205.46,
      "sid": 96,
      "location": 2,
      "content": "以及他们露脸呐",
      "music": 0.0
    },
    {
      "from": 205.46,
      "to": 206.22,
      "sid": 97,
      "location": 2,
      "content": "社会价值啊",
      "music": 0.0
    },
    {
      "from": 206.22,
      "to": 206.9,
      "sid": 98,
      "location": 2,
      "content": "社会身份呐",
      "music": 0.0
    },
    {
      "from": 206.9,
      "to": 208.17,
      "sid": 99,
      "location": 2,
      "content": "光环呐都能上去",
      "music": 0.0
    },
    {
      "from": 208.17,
      "to": 209.61,
      "sid": 100,
      "location": 2,
      "content": "那个时候在刚开始",
      "music": 0.0
    },
    {
      "from": 209.61,
      "to": 211.63,
      "sid": 101,
      "location": 2,
      "content": "其实实行主播就是网络主播的时候",
      "music": 0.0
    },
    {
      "from": 211.63,
      "to": 216.81,
      "sid": 102,
      "location": 2,
      "content": "我看到过很多传统媒体的大咖在朋友圈里头发",
      "music": 0.0
    },
    {
      "from": 216.81,
      "to": 220.18,
      "sid": 103,
      "location": 2,
      "content": "说现在是个人都能叫自己主播了",
      "music": 0.0
    },
    {
      "from": 220.18,
      "to": 221.82,
      "sid": 104,
      "location": 2,
      "content": "他们发这样的朋友圈",
      "music": 0.0
    },
    {
      "from": 221.82,
      "to": 223.1,
      "sid": 105,
      "location": 2,
      "content": "本质上是因为",
      "music": 0.0
    },
    {
      "from": 223.1,
      "to": 225.62,
      "sid": 106,
      "location": 2,
      "content": "他们对于我们的这种新型的这种类目",
      "music": 0.0
    },
    {
      "from": 225.62,
      "to": 227.75,
      "sid": 107,
      "location": 2,
      "content": "非常的不屑鄙视",
      "music": 0.0
    },
    {
      "from": 227.75,
      "to": 228.57,
