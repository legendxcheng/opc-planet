{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 2.28,
      "sid": 1,
      "location": 2,
      "content": "作为科学界小有分量的奖项",
      "music": 0.0
    },
    {
      "from": 2.28,
      "to": 4.82,
      "sid": 2,
      "location": 2,
      "content": "诺贝尔奖不仅提供几百万的奖金",
      "music": 0.0
    },
    {
      "from": 4.82,
      "to": 6.44,
      "sid": 3,
      "location": 2,
      "content": "据说要是你住通州",
      "music": 0.0
    },
    {
      "from": 6.44,
      "to": 8.2,
      "sid": 4,
      "location": 2,
      "content": "还能凭借诺奖得主身份",
      "music": 0.0
    },
    {
      "from": 8.2,
      "to": 10.46,
      "sid": 5,
      "location": 2,
      "content": "享受100平米房租减免政策呢",
      "music": 0.0
    },
    {
      "from": 10.46,
      "to": 11.62,
      "sid": 6,
      "location": 2,
      "content": "当然这就是说笑了",
      "music": 0.0
    },
    {
      "from": 11.62,
      "to": 12.42,
      "sid": 7,
      "location": 2,
      "content": "有几百万",
      "music": 0.0
    },
    {
      "from": 12.42,
      "to": 13.9,
      "sid": 8,
      "location": 2,
      "content": "我何不在北京买套房",
      "music": 0.0
    },
    {
      "from": 13.9,
      "to": 16.24,
      "sid": 9,
      "location": 2,
      "content": "剩下的钱再慢慢打工还上",
      "music": 0.0
    },
    {
      "from": 16.24,
      "to": 17.0,
      "sid": 10,
      "location": 2,
      "content": "岂不美哉",
      "music": 0.0
    },
    {
      "from": 17.0,
      "to": 19.68,
      "sid": 11,
      "location": 2,
      "content": "获得诺贝尔奖的条件似乎也没什么国籍",
      "music": 0.0
    },
    {
      "from": 19.68,
      "to": 21.02,
      "sid": 12,
      "location": 2,
      "content": "性别年龄之类的限制",
      "music": 0.0
    },
    {
      "from": 21.02,
      "to": 24.3,
      "sid": 13,
      "location": 2,
      "content": "你仅仅需要在相关领域搞出一些重大创新突破",
      "music": 0.0
    },
    {
      "from": 24.3,
      "to": 24.74,
      "sid": 14,
      "location": 2,
      "content": "就行了",
      "music": 0.0
    },
    {
      "from": 24.74,
      "to": 26.32,
      "sid": 15,
      "location": 2,
      "content": "这无疑给了我们信心",
      "music": 0.0
    },
    {
      "from": 26.32,
      "to": 27.78,
      "sid": 16,
      "location": 2,
      "content": "上班的兄弟先别上了",
      "music": 0.0
    },
    {
      "from": 27.78,
      "to": 28.94,
      "sid": 17,
      "location": 2,
      "content": "有这几百万奖金",
      "music": 0.0
    },
    {
      "from": 28.94,
      "to": 30.12,
      "sid": 18,
      "location": 2,
      "content": "咱能少受好几年",
      "music": 0.0
    },
    {
      "from": 30.12,
      "to": 31.88,
      "sid": 19,
      "location": 2,
      "content": "鸟系上学的兄弟也看看",
      "music": 0.0
    },
    {
      "from": 31.88,
      "to": 32.759,
      "sid": 20,
      "location": 2,
      "content": "要是得了奖",
      "music": 0.0
    },
    {
      "from": 32.759,
      "to": 34.219,
      "sid": 21,
      "location": 2,
      "content": "专升本本升博",
      "music": 0.0
    },
    {
      "from": 34.219,
      "to": 35.079,
      "sid": 22,
      "location": 2,
      "content": "我转院士",
      "music": 0.0
    },
    {
      "from": 35.079,
      "to": 35.839,
      "sid": 23,
      "location": 2,
      "content": "院士上墙",
      "music": 0.0
    },
    {
      "from": 35.839,
      "to": 37.519,
      "sid": 24,
      "location": 2,
      "content": "首先有个不太好的消息",
      "music": 0.0
    },
    {
      "from": 37.519,
      "to": 38.54,
      "sid": 25,
      "location": 2,
      "content": "根据我的调研",
      "music": 0.0
    },
    {
      "from": 38.54,
      "to": 40.54,
      "sid": 26,
      "location": 2,
      "content": "近几年诺贝尔物理学奖的得主",
      "music": 0.0
    },
    {
      "from": 40.54,
      "to": 41.86,
      "sid": 27,
      "location": 2,
      "content": "除了不是博士学位的",
      "music": 0.0
    },
    {
      "from": 41.86,
      "to": 43.45,
      "sid": 28,
      "location": 2,
      "content": "剩下的都是博士学位的",
      "music": 0.0
    },
    {
      "from": 43.45,
      "to": 44.89,
      "sid": 29,
      "location": 2,
      "content": "除了个别没资料的",
      "music": 0.0
    },
    {
      "from": 44.89,
      "to": 46.33,
      "sid": 30,
      "location": 2,
      "content": "能查到的都是博士",
      "music": 0.0
    },
    {
      "from": 46.33,
      "to": 49.57,
      "sid": 31,
      "location": 2,
      "content": "所以想通过诺奖实现专升本的兄弟怕是不行了",
      "music": 0.0
    },
    {
      "from": 49.57,
      "to": 50.47,
      "sid": 32,
      "location": 2,
      "content": "你得先升本",
      "music": 0.0
    },
    {
      "from": 50.47,
      "to": 52.66,
      "sid": 33,
      "location": 2,
      "content": "再研究个升研究到国才有可能",
      "music": 0.0
    },
    {
      "from": 52.66,
      "to": 53.5,
      "sid": 34,
      "location": 2,
      "content": "但不给我诺奖",
      "music": 0.0
    },
    {
      "from": 53.5,
      "to": 54.26,
      "sid": 35,
      "location": 2,
      "content": "我怎么升本",
      "music": 0.0
    },
    {
      "from": 54.26,
      "to": 54.86,
      "sid": 36,
      "location": 2,
      "content": "我不升本",
      "music": 0.0
    },
    {
      "from": 54.86,
      "to": 55.98,
      "sid": 37,
      "location": 2,
      "content": "你又不能给我发奖",
      "music": 0.0
    },
    {
      "from": 55.98,
      "to": 56.84,
      "sid": 38,
      "location": 2,
      "content": "死循环了兄弟",
      "music": 0.0
    },
    {
      "from": 56.84,
      "to": 59.28,
      "sid": 39,
      "location": 2,
      "content": "所以这第一步你得先查一查学历才行",
      "music": 0.0
    },
    {
      "from": 59.28,
      "to": 60.62,
      "sid": 40,
      "location": 2,
      "content": "不达标的也没关系",
      "music": 0.0
    },
    {
      "from": 60.62,
      "to": 61.76,
      "sid": 41,
      "location": 2,
      "content": "还可以现学嘛",
      "music": 0.0
    },
    {
      "from": 61.76,
      "to": 64.02,
      "sid": 42,
      "location": 2,
      "content": "根据过往诺贝尔奖的颁发经验来看",
      "music": 0.0
    },
    {
      "from": 64.02,
      "to": 65.98,
      "sid": 43,
      "location": 2,
      "content": "你搞的方向过于偏向应用的",
      "music": 0.0
    },
    {
      "from": 65.98,
      "to": 66.72,
      "sid": 44,
      "location": 2,
      "content": "怕是不太行",
      "music": 0.0
    },
    {
      "from": 66.72,
      "to": 69.0,
      "sid": 45,
      "location": 2,
      "content": "比如土木工程这类灰打的再好",
      "music": 0.0
    },
    {
      "from": 69.0,
      "to": 70.32,
      "sid": 46,
      "location": 2,
      "content": "也难以获得诺贝尔奖",
      "music": 0.0
    },
    {
      "from": 70.32,
      "to": 72.92,
      "sid": 47,
      "location": 2,
      "content": "从近几年诺贝尔物理学奖得主的专业来看",
      "music": 0.0
    },
    {
      "from": 72.92,
      "to": 73.66,
      "sid": 48,
      "location": 2,
      "content": "要么数学",
      "music": 0.0
    },
    {
      "from": 73.66,
      "to": 74.32,
      "sid": 49,
      "location": 2,
      "content": "要么物理",
      "music": 0.0
    },
    {
      "from": 74.32,
      "to": 74.8,
      "sid": 50,
      "location": 2,
      "content": "要么物理",
      "music": 0.0
    },
    {
      "from": 74.8,
      "to": 75.5,
      "sid": 51,
      "location": 2,
      "content": "数学双修",
      "music": 0.0
    },
    {
      "from": 75.5,
      "to": 76.88,
      "sid": 52,
      "location": 2,
      "content": "这就比较有压力了",
      "music": 0.0
    },
    {
      "from": 76.88,
      "to": 78.46,
      "sid": 53,
      "location": 2,
      "content": "学理工科的兄弟都知道",
      "music": 0.0
    },
    {
      "from": 78.46,
      "to": 80.48,
      "sid": 54,
      "location": 2,
      "content": "数学是个非常吃天赋的学科",
      "music": 0.0
    },
    {
      "from": 80.48,
      "to": 82.54,
      "sid": 55,
      "location": 2,
      "content": "当你怀疑自己有没有天赋的时候",
      "music": 0.0
    },
    {
      "from": 82.54,
      "to": 83.38,
      "sid": 56,
      "location": 2,
      "content": "那就是没有",
      "music": 0.0
    },
    {
      "from": 83.38,
      "to": 85.18,
      "sid": 57,
      "location": 2,
      "content": "因为这玩意儿就像穿着白裤衩子",
      "music": 0.0
    },
    {
      "from": 85.18,
      "to": 86.78,
      "sid": 58,
      "location": 2,
      "content": "穿西藏是藏不住的",
      "music": 0.0
    },
    {
      "from": 86.78,
      "to": 87.9,
      "sid": 59,
      "location": 2,
      "content": "据有关人士说",
      "music": 0.0
    },
    {
      "from": 87.9,
      "to": 89.26,
      "sid": 60,
      "location": 2,
      "content": "你高考数学满分",
      "music": 0.0
    },
    {
      "from": 89.26,
      "to": 91.08,
      "sid": 61,
      "location": 2,
      "content": "那都没资格去清华学数学",
      "music": 0.0
    },
    {
      "from": 91.08,
      "to": 93.66,
      "sid": 62,
      "location": 2,
      "content": "因为人家数学系的天才都不需要参加高考",
      "music": 0.0
    },
    {
      "from": 93.66,
      "to": 95.72,
      "sid": 63,
      "location": 2,
      "content": "本科的高等数学已经够难了",
      "music": 0.0
    },
    {
      "from": 95.72,
      "to": 97.54,
      "sid": 64,
      "location": 2,
      "content": "但正经的数学专业是不用学的",
      "music": 0.0
    },
    {
      "from": 97.54,
      "to": 99.52,
      "sid": 65,
      "location": 2,
      "content": "因为这高等数学吧有点太低等",
      "music": 0.0
    },
    {
      "from": 99.52,
      "to": 101.98,
      "sid": 66,
      "location": 2,
      "content": "就像咱们总说工资过万是高薪",
      "music": 0.0
    },
    {
      "from": 101.98,
      "to": 103.46,
      "sid": 67,
      "location": 2,
      "content": "这就会让富二代疑惑",
      "music": 0.0
    },
    {
      "from": 103.46,
      "to": 105.16,
      "sid": 68,
      "location": 2,
      "content": "一天挣1万很高薪吗",
      "music": 0.0
    },
    {
      "from": 105.16,
      "to": 105.68,
      "sid": 69,
      "location": 2,
      "content": "当然了",
      "music": 0.0
    },
    {
      "from": 105.68,
      "to": 107.54,
      "sid": 70,
      "location": 2,
      "content": "如果你说我不是数学天才",
      "music": 0.0
    },
    {
      "from": 107.54,
      "to": 109.14,
      "sid": 71,
      "location": 2,
      "content": "没能聪明到保送清华",
      "music": 0.0
    },
    {
      "from": 109.14,
      "to": 110.08,
      "sid": 72,
      "location": 2,
      "content": "那也没关系",
      "music": 0.0
    },
    {
      "from": 110.08,
      "to": 112.76,
      "sid": 73,
      "location": 2,
      "content": "努努力高考考个满分也是可以研究数学的",
      "music": 0.0
    },
    {
      "from": 112.76,
      "to": 114.58,
      "sid": 74,
      "location": 2,
      "content": "不过作为一个老程序员来说",
      "music": 0.0
    },
    {
      "from": 114.58,
      "to": 116.32,
      "sid": 75,
      "location": 2,
      "content": "学计算机也是个好去处",
      "music": 0.0
    },
    {
      "from": 116.32,
      "to": 118.72,
      "sid": 76,
      "location": 2,
      "content": "上限高到去研究院研究量子计算",
      "music": 0.0
    },
    {
      "from": 118.72,
      "to": 121.7,
      "sid": 77,
      "location": 2,
      "content": "下限低到看完21天学会C加加出来的外包",
      "music": 0.0
    },
    {
      "from": 121.7,
      "to": 122.24,
      "sid": 78,
      "location": 2,
      "content": "当码农",
      "music": 0.0
    },
    {
      "from": 122.24,
      "to": 124.9,
      "sid": 79,
      "location": 2,
      "content": "量子力学已经成为物理学界的基础学科",
      "music": 0.0
    },
    {
      "from": 124.9,
      "to": 127.64,
      "sid": 80,
      "location": 2,
      "content": "和计算沾边的量子计算更是科技前沿",
      "music": 0.0
    },
    {
      "from": 127.64,
      "to": 129.94,
      "sid": 81,
      "location": 2,
      "content": "要是人类在量子计算领域有所突破",
      "music": 0.0
    },
    {
      "from": 129.94,
      "to": 131.88,
      "sid": 82,
      "location": 2,
      "content": "诺贝尔奖在你眼里都犹如浮云",
      "music": 0.0
    },
    {
      "from": 131.88,
      "to": 134.84,
      "sid": 83,
      "location": 2,
      "content": "要是人类借此获得量子计算的超强算力",
      "music": 0.0
    },
    {
      "from": 134.84,
      "to": 136.34,
      "sid": 84,
      "location": 2,
      "content": "诺奖这几百万奖金",
      "music": 0.0
    },
    {
      "from": 136.34,
      "to": 138.7,
      "sid": 85,
      "location": 2,
      "content": "那就是九牛身上细菌的一根鞭毛",
      "music": 0.0
    },
    {
      "from": 138.7,
      "to": 140.5,
      "sid": 86,
      "location": 2,
      "content": "要是你对微观的量子没兴趣",
      "music": 0.0
    },
    {
      "from": 140.5,
      "to": 142.32,
      "sid": 87,
      "location": 2,
      "content": "咱们还有宏观的引力国防",
      "music": 0.0
    },
    {
      "from": 142.32,
      "to": 143.14,
      "sid": 88,
      "location": 2,
      "content": "100多年前",
      "music": 0.0
    },
    {
      "from": 143.14,
      "to": 145.46,
      "sid": 89,
      "location": 2,
      "content": "自从老艾同学预测了引力波以后",
      "music": 0.0
    },
    {
      "from": 145.46,
      "to": 147.2,
      "sid": 90,
      "location": 2,
      "content": "科学界一直在找寻这玩意",
      "music": 0.0
    },
    {
      "from": 147.2,
      "to": 148.08,
      "sid": 91,
      "location": 2,
      "content": "15年的时候",
      "music": 0.0
    },
    {
      "from": 148.08,
      "to": 150.24,
      "sid": 92,
      "location": 2,
      "content": "一个科研组织终于探测到了引力波",
      "music": 0.0
    },
    {
      "from": 150.24,
      "to": 150.86,
      "sid": 93,
      "location": 2,
      "content": "两年后",
      "music": 0.0
    },
    {
      "from": 150.86,
      "to": 153.14,
      "sid": 94,
      "location": 2,
      "content": "三位科学家因此获得了诺贝尔物理学奖",
      "music": 0.0
    },
    {
      "from": 153.14,
      "to": 155.5,
      "sid": 95,
      "location": 2,
      "content": "其中比较有名的就是星际穿越的科学顾问",
      "music": 0.0
    },
    {
      "from": 155.5,
      "to": 156.2,
      "sid": 96,
      "location": 2,
      "content": "基普索恩",
      "music": 0.0
    },
    {
      "from": 156.2,
      "to": 157.94,
      "sid": 97,
      "location": 2,
      "content": "仅仅是探测引力波就能获奖",
      "music": 0.0
    },
    {
      "from": 157.94,
      "to": 160.76,
      "sid": 98,
      "location": 2,
      "content": "那要是根据引力波搞出点划时代的理论",
      "music": 0.0
    },
    {
      "from": 160.76,
      "to": 162.76,
      "sid": 99,
      "location": 2,
      "content": "诺奖岂不是要往你家批发呀",
      "music": 0.0
    },
    {
      "from": 162.76,
      "to": 163.92,
      "sid": 100,
      "location": 2,
      "content": "对引力波的研究",
      "music": 0.0
    },
    {
      "from": 163.92,
      "to": 165.98,
      "sid": 101,
      "location": 2,
      "content": "能观察引力波源的各种信息",
      "music": 0.0
    },
    {
      "from": 165.98,
      "to": 167.04,
      "sid": 102,
      "location": 2,
      "content": "研究宇宙深空",
      "music": 0.0
    },
    {
      "from": 167.04,
      "to": 167.88,
      "sid": 103,
      "location": 2,
      "content": "观察暗物质",
      "music": 0.0
    },
    {
      "from": 167.88,
      "to": 168.4,
      "sid": 104,
      "location": 2,
      "content": "暗能量",
      "music": 0.0
    },
    {
      "from": 168.4,
      "to": 170.8,
      "sid": 105,
      "location": 2,
      "content": "这每一步都是带领整个人类的前进",
      "music": 0.0
    },
    {
      "from": 170.8,
      "to": 172.18,
      "sid": 106,
      "location": 2,
      "content": "属于是活着进课本",
      "music": 0.0
    },
    {
      "from": 172.18,
      "to": 172.48,
      "sid": 107,
      "location": 2,
      "content": "死了",
      "music": 0.0
    },
    {
      "from": 172.48,
      "to": 172.98,
      "sid": 108,
      "location": 2,
      "content": "想太庙",
      "music": 0.0
    },
    {
      "from": 172.98,
      "to": 174.42,
      "sid": 109,
      "location": 2,
      "content": "只要人类文明还存在",
      "music": 0.0
    },
    {
      "from": 174.42,
      "to": 176.64,
      "sid": 110,
      "location": 2,
      "content": "你的名字至少得挂在小学课堂墙壁上",
