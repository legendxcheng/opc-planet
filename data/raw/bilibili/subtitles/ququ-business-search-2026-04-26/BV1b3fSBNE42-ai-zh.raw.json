    },
    {
      "from": 68.28,
      "to": 69.18,
      "sid": 25,
      "location": 2,
      "content": "给你拖出来",
      "music": 0.0
    },
    {
      "from": 69.18,
      "to": 70.4,
      "sid": 26,
      "location": 2,
      "content": "我告诉你们啊",
