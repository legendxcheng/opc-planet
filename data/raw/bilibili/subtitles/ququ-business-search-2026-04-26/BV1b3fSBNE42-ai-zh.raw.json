    },
    {
      "from": 27.21,
      "to": 27.87,
      "sid": 12,
      "location": 2,
      "content": "我跟你们说",
      "music": 0.0
    },
    {
      "from": 27.87,
      "to": 31.51,
      "sid": 13,
      "location": 2,
      "content": "其实真的画的好的人还是挺多的",
