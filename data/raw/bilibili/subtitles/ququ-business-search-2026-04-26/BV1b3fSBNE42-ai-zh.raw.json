    },
    {
      "from": 77.36,
      "to": 80.28,
      "sid": 27,
      "location": 2,
      "content": "当时我有一个做地产的大哥",
      "music": 0.0
    },
    {
      "from": 80.28,
      "to": 81.28,
      "sid": 28,
      "location": 2,
      "content": "他就跟我说",
      "music": 0.0
    },
    {
      "from": 81.28,
      "to": 83.34,
      "sid": 29,
      "location": 2,
      "content": "就指着他们家一幅画",
      "music": 0.0
    },
    {
      "from": 83.34,
      "to": 84.36,
      "sid": 30,
      "location": 2,
      "content": "就跟我说",
