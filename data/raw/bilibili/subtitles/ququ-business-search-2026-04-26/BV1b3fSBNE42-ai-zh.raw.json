    },
    {
      "from": 35.99,
      "to": 42.76,
      "sid": 16,
      "location": 2,
      "content": "但是一个画真的能够被反复的被抬高价格",
      "music": 0.0
    },
    {
      "from": 42.76,
      "to": 47.79,
      "sid": 17,
      "location": 2,
      "content": "其实它这个里边是有很多的运作在里边的",
      "music": 0.0
    },
    {
      "from": 47.79,
      "to": 52.31,
      "sid": 18,
      "location": 2,
      "content": "就是有人他们有人要帮你操作这个事情",
