  "body": [
    {
      "from": 0.16,
      "to": 2.64,
      "sid": 1,
      "location": 2,
      "content": "搞艺术啊真的需要很大的财富量级",
      "music": 0.0
    },
    {
      "from": 2.64,
      "to": 5.84,
      "sid": 2,
      "location": 2,
      "content": "就不管你是搞哪一个维度的艺术",
      "music": 0.0
    },
    {
      "from": 5.84,
      "to": 10.91,
      "sid": 3,
      "location": 2,
      "content": "你想让你的作品就是像金子会发光",
      "music": 0.0
    },
    {
      "from": 10.91,
      "to": 14.33,
      "sid": 4,
      "location": 2,
      "content": "这个根本就根本就不太现实",
      "music": 0.0
    },
    {
      "from": 14.45,
      "to": 15.57,
      "sid": 5,
      "location": 2,
      "content": "知道吗",
      "music": 0.0
    },
    {
      "from": 15.57,
      "to": 18.65,
      "sid": 6,
      "location": 2,
      "content": "你们不你们不要觉得自己的才华怎么怎么样",
      "music": 0.0
    },
    {
      "from": 18.65,
      "to": 19.21,
      "sid": 7,
      "location": 2,
      "content": "我告诉你们",
      "music": 0.0
    },
    {
      "from": 19.21,
      "to": 21.33,
      "sid": 8,
      "location": 2,
      "content": "我我很喜欢看画啊",
