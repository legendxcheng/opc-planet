  "body": [
    {
      "from": 0.3,
      "to": 2.02,
      "sid": 1,
      "location": 2,
      "content": "我们学校天天拿我们说事",
      "music": 0.0
    },
    {
      "from": 2.02,
      "to": 2.78,
      "sid": 2,
      "location": 2,
      "content": "说我们挣钱了",
      "music": 0.0
    },
    {
      "from": 2.78,
      "to": 3.84,
      "sid": 3,
      "location": 2,
      "content": "说我们挣多少多少钱了",
      "music": 0.0
    },
    {
      "from": 3.84,
      "to": 4.8,
      "sid": 4,
      "location": 2,
      "content": "虽然我不认为",
      "music": 0.0
    },
    {
      "from": 4.8,
      "to": 6.66,
      "sid": 5,
      "location": 2,
      "content": "我不认为我挣的那个钱有什么很了不起的",
      "music": 0.0
    },
    {
      "from": 6.66,
      "to": 8.54,
      "sid": 6,
      "location": 2,
      "content": "因为我是一个有着宏图远志的一个人",
      "music": 0.0
    },
    {
      "from": 8.54,
      "to": 11.26,
      "sid": 7,
      "location": 2,
      "content": "我是一个报复非常之同类的人",
      "music": 0.0
    },
    {
      "from": 11.26,
      "to": 12.08,
      "sid": 8,
      "location": 2,
      "content": "所以我不认为",
      "music": 0.0
    },
    {
      "from": 12.08,
      "to": 14.26,
      "sid": 9,
      "location": 2,
      "content": "我不认为他们所谓的觉得我挣了多少多少钱",
      "music": 0.0
    },
    {
      "from": 14.26,
      "to": 16.16,
      "sid": 10,
      "location": 2,
      "content": "就是抱着那种酸葡萄的那个态度",
      "music": 0.0
    },
    {
      "from": 16.16,
      "to": 16.84,
      "sid": 11,
      "location": 2,
      "content": "觉得我挣了多少多少钱",
      "music": 0.0
    },
    {
      "from": 16.84,
      "to": 18.24,
      "sid": 12,
      "location": 2,
      "content": "就真的是让我觉得我好像很牛逼",
      "music": 0.0
    },
    {
      "from": 18.24,
      "to": 19.46,
      "sid": 13,
      "location": 2,
      "content": "我并不是这种感觉",
      "music": 0.0
    },
    {
      "from": 19.46,
      "to": 21.1,
      "sid": 14,
      "location": 2,
      "content": "因为在我看来这不算什么",
      "music": 0.0
    },
    {
      "from": 21.1,
      "to": 25.33,
      "sid": 15,
      "location": 2,
      "content": "真的我认为我认为我是有着很宏大的目标的",
      "music": 0.0
    },
    {
      "from": 25.33,
      "to": 26.17,
      "sid": 16,
      "location": 2,
      "content": "你们知道我不是",
      "music": 0.0
    },
    {
      "from": 26.17,
      "to": 29.439,
      "sid": 17,
      "location": 2,
      "content": "这两年我的slogan叫做树立更宏伟的理想",
      "music": 0.0
    },
    {
      "from": 29.439,
      "to": 30.679,
      "sid": 18,
      "location": 2,
      "content": "并做更具体的能力",
      "music": 0.0
    },
    {
      "from": 30.679,
      "to": 33.629,
      "sid": 19,
      "location": 2,
      "content": "这个是这个是我现在的微信签名",
      "music": 0.0
    },
    {
      "from": 33.909,
      "to": 34.989,
      "sid": 20,
      "location": 2,
      "content": "所以说我的内心当中",
      "music": 0.0
    },
    {
      "from": 34.989,
      "to": 37.069,
      "sid": 21,
      "location": 2,
      "content": "是有非常非常宏伟的理想的",
      "music": 0.0
    },
    {
      "from": 37.069,
      "to": 39.109,
      "sid": 22,
      "location": 2,
      "content": "但是我想说可能别人为什么会这么看",
      "music": 0.0
    },
    {
      "from": 39.109,
      "to": 39.229,
      "sid": 23,
      "location": 2,
      "content": "我",
      "music": 0.0
    },
    {
      "from": 39.229,
      "to": 40.469,
      "sid": 24,
      "location": 2,
      "content": "为什么他们会这么评价我",
      "music": 0.0
    },
    {
      "from": 40.469,
      "to": 41.909,
      "sid": 25,
      "location": 2,
      "content": "那是因为在同类型的",
      "music": 0.0
    },
    {
      "from": 41.909,
      "to": 43.78,
      "sid": 26,
      "location": 2,
      "content": "他们感觉在同同类型的这个赛道上",
      "music": 0.0
    },
    {
      "from": 43.78,
      "to": 46.26,
      "sid": 27,
      "location": 2,
      "content": "或者同类型的或这个业态的这样一些人身上",
      "music": 0.0
    },
    {
      "from": 46.26,
      "to": 49.69,
      "sid": 28,
      "location": 2,
      "content": "他们认为我的这个变现量级就是最大的对吧",
      "music": 0.0
    },
    {
      "from": 49.69,
      "to": 51.93,
      "sid": 29,
      "location": 2,
      "content": "别人看我觉得哎别人都挣不了这么多钱",
      "music": 0.0
    },
    {
      "from": 51.93,
      "to": 53.24,
      "sid": 30,
      "location": 2,
      "content": "就你挣这么多的钱",
      "music": 0.0
    },
    {
      "from": 53.24,
      "to": 55.62,
      "sid": 31,
      "location": 2,
      "content": "这个呢可能在如果说以他们的维度来看",
      "music": 0.0
    },
    {
      "from": 55.62,
      "to": 56.6,
      "sid": 32,
      "location": 2,
      "content": "以横向对比",
      "music": 0.0
    },
    {
      "from": 56.6,
      "to": 58.12,
      "sid": 33,
      "location": 2,
      "content": "所有的在这个赛道里的人来看",
      "music": 0.0
    },
    {
      "from": 58.12,
      "to": 59.24,
      "sid": 34,
      "location": 2,
      "content": "可能他们的认知也是对的",
      "music": 0.0
    },
    {
      "from": 59.24,
      "to": 61.15,
      "sid": 35,
      "location": 2,
      "content": "就他们这样看也没有问题",
      "music": 0.0
    },
    {
      "from": 61.15,
      "to": 62.67,
      "sid": 36,
      "location": 2,
      "content": "那为什么会这样呢",
      "music": 0.0
    },
    {
      "from": 62.67,
      "to": 63.67,
      "sid": 37,
      "location": 2,
      "content": "你就会发现啊",
      "music": 0.0
    },
    {
      "from": 63.67,
      "to": 65.31,
      "sid": 38,
      "location": 2,
      "content": "就是很多很多人他做事情啊",
      "music": 0.0
    },
    {
      "from": 65.31,
      "to": 66.86,
      "sid": 39,
      "location": 2,
      "content": "他打法特别的烦",
      "music": 0.0
    },
    {
      "from": 66.86,
      "to": 68.14,
      "sid": 40,
      "location": 2,
      "content": "他就这也想搞",
      "music": 0.0
    },
    {
      "from": 68.14,
      "to": 68.72,
      "sid": 41,
      "location": 2,
      "content": "那也想搞",
      "music": 0.0
    },
    {
      "from": 68.72,
      "to": 69.54,
      "sid": 42,
      "location": 2,
      "content": "那也想搞",
      "music": 0.0
    },
    {
      "from": 69.54,
      "to": 70.42,
      "sid": 43,
      "location": 2,
      "content": "他觉得什么呢",
