{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.76,
      "sid": 1,
      "location": 2,
      "content": "那你说他能不能快速的产生现金流呢",
      "music": 0.0
    },
    {
      "from": 1.76,
      "to": 2.62,
      "sid": 2,
      "location": 2,
      "content": "它当然可以",
      "music": 0.0
    },
    {
      "from": 2.62,
      "to": 5.1,
      "sid": 3,
      "location": 2,
      "content": "这个行业到底有什么核心精力吗",
      "music": 0.0
    },
    {
      "from": 5.1,
      "to": 9.23,
      "sid": 4,
      "location": 2,
      "content": "说白了就是你比如说你做你做一个灯",
      "music": 0.0
    },
    {
      "from": 9.23,
      "to": 11.69,
      "sid": 5,
      "location": 2,
      "content": "那么这个灯啊你们家已经做了很多年了",
      "music": 0.0
    },
    {
      "from": 11.69,
      "to": 12.75,
      "sid": 6,
      "location": 2,
      "content": "对于这个灯的设计",
      "music": 0.0
    },
    {
      "from": 12.75,
      "to": 13.99,
      "sid": 7,
      "location": 2,
      "content": "对于怎么去销售它什么这些东西",
      "music": 0.0
    },
    {
      "from": 13.99,
      "to": 15.57,
      "sid": 8,
      "location": 2,
      "content": "可能你们家沉淀的比较好是吧",
      "music": 0.0
    },
    {
      "from": 15.57,
      "to": 17.95,
      "sid": 9,
      "location": 2,
      "content": "它仅仅只是一个把产品卖出去的逻辑嘛",
      "music": 0.0
    },
    {
      "from": 17.95,
      "to": 20.75,
      "sid": 10,
      "location": 2,
      "content": "很简单的把产品卖出去的逻辑嘛对吧",
      "music": 0.0
    },
    {
      "from": 20.75,
      "to": 24.13,
      "sid": 11,
      "location": 2,
      "content": "那这件事情对于一个这种高级的人才",
      "music": 0.0
    },
    {
      "from": 24.13,
      "to": 27.53,
      "sid": 12,
      "location": 2,
      "content": "像她跟她老公都是属于在美国大厂",
      "music": 0.0
    },
    {
      "from": 27.53,
      "to": 28.85,
      "sid": 13,
      "location": 2,
      "content": "一个人拿150万的年薪",
      "music": 0.0
    },
    {
      "from": 28.85,
      "to": 31.32,
      "sid": 14,
      "location": 2,
      "content": "一个人拿80万的年薪的这种高级人才",
      "music": 0.0
    },
    {
      "from": 31.32,
      "to": 32.88,
      "sid": 15,
      "location": 2,
      "content": "对于这种高级人才来说",
      "music": 0.0
    },
    {
      "from": 32.88,
      "to": 34.0,
      "sid": 16,
      "location": 2,
      "content": "其实你是降维",
      "music": 0.0
    },
    {
      "from": 34.0,
      "to": 35.82,
      "sid": 17,
      "location": 2,
      "content": "而且是降了很多维",
      "music": 0.0
    },
    {
      "from": 35.82,
      "to": 37.64,
      "sid": 18,
      "location": 2,
      "content": "可是你做这个创业",
      "music": 0.0
    },
    {
      "from": 37.64,
      "to": 40.9,
      "sid": 19,
      "location": 2,
      "content": "并不能够把你们现阶段拥有的很多能力",
      "music": 0.0
    },
    {
      "from": 40.9,
      "to": 42.9,
      "sid": 20,
      "location": 2,
      "content": "用到你的这场创业里边去",
      "music": 0.0
    },
    {
      "from": 42.9,
      "to": 45.94,
      "sid": 21,
      "location": 2,
      "content": "不能够在所谓的跨境电商这个领域里",
      "music": 0.0
    },
    {
      "from": 45.94,
      "to": 48.12,
      "sid": 22,
      "location": 2,
      "content": "形成你自己非常独到的核心竞争力",
      "music": 0.0
    },
    {
      "from": 48.12,
      "to": 49.1,
      "sid": 23,
      "location": 2,
      "content": "起码在我的脑子里",
      "music": 0.0
    },
    {
      "from": 49.1,
      "to": 50.32,
      "sid": 24,
      "location": 2,
      "content": "现在构思不出来这件事",
      "music": 0.0
    },
    {
      "from": 50.32,
      "to": 53.38,
      "sid": 25,
      "location": 2,
      "content": "你跟所有做跨境电商的人都一样",
      "music": 0.0
    },
    {
      "from": 53.38,
      "to": 54.48,
      "sid": 26,
      "location": 2,
      "content": "都要去找货源",
      "music": 0.0
    },
    {
      "from": 54.48,
      "to": 55.48,
      "sid": 27,
      "location": 2,
      "content": "都要去想怎么去卖",
      "music": 0.0
    },
    {
      "from": 55.48,
      "to": 56.78,
      "sid": 28,
      "location": 2,
      "content": "都要去把一个屏打爆",
      "music": 0.0
    },
    {
      "from": 56.78,
      "to": 58.44,
      "sid": 29,
      "location": 2,
      "content": "都是去干这些事对吧",
      "music": 0.0
    },
    {
      "from": 58.44,
      "to": 63.07,
      "sid": 30,
      "location": 2,
      "content": "那显然你们就没有没有把自己的长板打到最长",
      "music": 0.0
    },
    {
      "from": 63.07,
      "to": 64.83,
      "sid": 31,
      "location": 2,
      "content": "你现在如果是很差钱",
      "music": 0.0
    },
    {
      "from": 64.83,
      "to": 65.95,
      "sid": 32,
      "location": 2,
      "content": "比如说你现在这家公司",
      "music": 0.0
    },
    {
      "from": 65.95,
      "to": 67.27,
      "sid": 33,
      "location": 2,
      "content": "你说他一年只给你8万",
      "music": 0.0
    },
    {
      "from": 67.27,
      "to": 67.87,
      "sid": 34,
      "location": 2,
      "content": "现在你去创业",
      "music": 0.0
    },
    {
      "from": 67.87,
      "to": 68.23,
      "sid": 35,
      "location": 2,
      "content": "你创不创",
      "music": 0.0
    },
    {
      "from": 68.23,
      "to": 69.03,
      "sid": 36,
      "location": 2,
      "content": "你肯定创啊",
      "music": 0.0
    },
    {
      "from": 69.03,
      "to": 71.24,
      "sid": 37,
      "location": 2,
      "content": "可是现在这家公司一年给你80万",
      "music": 0.0
    },
    {
      "from": 71.24,
      "to": 73.8,
      "sid": 38,
      "location": 2,
      "content": "你去创业第一年就一定能挣到80万吗",
      "music": 0.0
    },
    {
      "from": 73.8,
      "to": 74.97,
      "sid": 39,
      "location": 2,
      "content": "首先他不一定吧",
      "music": 0.0
    },
    {
      "from": 74.97,
      "to": 76.71,
      "sid": 40,
      "location": 2,
      "content": "他还是个积少成多的过程呢",
      "music": 0.0
    },
    {
      "from": 76.71,
      "to": 77.23,
      "sid": 41,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 77.23,
      "to": 78.75,
      "sid": 42,
      "location": 2,
      "content": "完了以后你做的这个事儿",
      "music": 0.0
    },
    {
      "from": 78.75,
      "to": 81.25,
      "sid": 43,
      "location": 2,
      "content": "其实它的天花板听起来就会矮很多",
      "music": 0.0
    },
    {
      "from": 81.25,
      "to": 82.13,
      "sid": 44,
      "location": 2,
      "content": "那我跟你们讲",
      "music": 0.0
    },
    {
      "from": 82.13,
      "to": 84.27,
      "sid": 45,
      "location": 2,
      "content": "我绝对是一个长期价值主义者",
      "music": 0.0
    },
    {
      "from": 84.27,
      "to": 85.82,
      "sid": 46,
      "location": 2,
      "content": "就是你们看啊",
      "music": 0.0
    },
    {
      "from": 85.82,
      "to": 87.08,
      "sid": 47,
      "location": 2,
      "content": "在我看来",
      "music": 0.0
    },
    {
      "from": 87.08,
      "to": 89.3,
      "sid": 48,
      "location": 2,
      "content": "我认为你们看为什么我一直做咨询",
      "music": 0.0
    },
    {
      "from": 89.3,
      "to": 89.98,
      "sid": 49,
      "location": 2,
      "content": "一直做咨询",
      "music": 0.0
    },
    {
      "from": 89.98,
      "to": 91.4,
      "sid": 50,
      "location": 2,
      "content": "做咨询是在干什么呢",
      "music": 0.0
    },
    {
      "from": 91.4,
      "to": 95.14,
      "sid": 51,
      "location": 2,
      "content": "其实很多我的所谓的类同行啊",
      "music": 0.0
    },
    {
      "from": 95.14,
      "to": 97.44,
      "sid": 52,
      "location": 2,
      "content": "他们其实都是以麦克为主的",
      "music": 0.0
    },
    {
      "from": 97.44,
      "to": 98.65,
      "sid": 53,
      "location": 2,
      "content": "大家有没有发现",
      "music": 0.0
    },
    {
      "from": 98.65,
      "to": 100.07,
      "sid": 54,
      "location": 2,
      "content": "要不就是以麦克为主",
      "music": 0.0
    },
    {
      "from": 100.07,
      "to": 103.44,
      "sid": 55,
      "location": 2,
      "content": "要不然他们的咨询团队是外包的对吧",
      "music": 0.0
    },
    {
      "from": 103.44,
      "to": 105.68,
      "sid": 56,
      "location": 2,
      "content": "他们是不愿意自己去养一个咨询团队",
      "music": 0.0
    },
    {
      "from": 105.68,
      "to": 107.54,
      "sid": 57,
      "location": 2,
      "content": "或者自己去孵化一个咨询团队的",
      "music": 0.0
    },
    {
      "from": 107.54,
      "to": 109.84,
      "sid": 58,
      "location": 2,
      "content": "因为他们认为咨询老师这个角色",
      "music": 0.0
    },
    {
      "from": 109.84,
      "to": 111.62,
      "sid": 59,
      "location": 2,
      "content": "他是一个员工嘛",
      "music": 0.0
    },
    {
      "from": 111.62,
      "to": 113.04,
      "sid": 60,
      "location": 2,
      "content": "就像一个螺丝钉一样的角色",
      "music": 0.0
    },
    {
      "from": 113.04,
      "to": 115.59,
      "sid": 61,
      "location": 2,
      "content": "那么我随随时随地是可以更换的",
      "music": 0.0
    },
    {
      "from": 115.59,
      "to": 116.33,
      "sid": 62,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 116.33,
      "to": 118.05,
      "sid": 63,
      "location": 2,
      "content": "但麦克我出一个课",
      "music": 0.0
    },
    {
      "from": 118.05,
      "to": 119.23,
      "sid": 64,
      "location": 2,
      "content": "我可以永久的卖",
      "music": 0.0
    },
    {
      "from": 119.23,
      "to": 121.41,
      "sid": 65,
      "location": 2,
      "content": "我可以不断的去产生现金流",
      "music": 0.0
    },
    {
      "from": 121.85,
      "to": 122.47,
      "sid": 66,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 122.47,
      "to": 124.23,
      "sid": 67,
      "location": 2,
      "content": "那么这是很多很多我们的同行",
      "music": 0.0
    },
    {
      "from": 124.23,
      "to": 125.43,
      "sid": 68,
      "location": 2,
      "content": "他跟我们不一样的地方",
      "music": 0.0
    },
    {
      "from": 125.43,
      "to": 127.63,
      "sid": 69,
      "location": 2,
      "content": "但是大家知道我其实我们一直以来",
      "music": 0.0
    },
    {
      "from": 127.63,
      "to": 131.28,
      "sid": 70,
      "location": 2,
      "content": "我们最大的板块就是咨询",
      "music": 0.0
    },
    {
      "from": 131.28,
      "to": 132.72,
      "sid": 71,
      "location": 2,
      "content": "就是大家所谓的伊利",
      "music": 0.0
    },
    {
      "from": 132.72,
      "to": 134.42,
      "sid": 72,
      "location": 2,
      "content": "那为什么我要做这样一件",
      "music": 0.0
    },
    {
      "from": 134.42,
      "to": 136.68,
      "sid": 73,
      "location": 2,
      "content": "被很多同行都不认可的事情呢",
      "music": 0.0
    },
    {
      "from": 136.68,
      "to": 140.54,
      "sid": 74,
      "location": 2,
      "content": "因为他们想想的更多的其实是快速的现金流",
      "music": 0.0
    },
    {
      "from": 140.54,
      "to": 142.02,
      "sid": 75,
      "location": 2,
      "content": "但是我想的更多的是",
      "music": 0.0
    },
    {
      "from": 142.02,
      "to": 144.32,
      "sid": 76,
      "location": 2,
      "content": "我如何在这样一个混沌的市场里边",
      "music": 0.0
    },
    {
      "from": 144.32,
      "to": 147.69,
      "sid": 77,
      "location": 2,
      "content": "形成我个人的非常强大的核心竞争力",
      "music": 0.0
    },
    {
      "from": 147.69,
      "to": 150.47,
      "sid": 78,
      "location": 2,
      "content": "就是我如何把我的这个门槛越做越高",
      "music": 0.0
    },
    {
      "from": 150.47,
      "to": 152.71,
      "sid": 79,
      "location": 2,
      "content": "让所有想要学我的人",
      "music": 0.0
    },
    {
      "from": 152.71,
      "to": 153.73,
      "sid": 80,
      "location": 2,
      "content": "想要抄我的人",
      "music": 0.0
    },
    {
      "from": 153.73,
      "to": 154.71,
      "sid": 81,
      "location": 2,
      "content": "或者他赚到我赚钱",
      "music": 0.0
    },
    {
      "from": 154.71,
      "to": 155.59,
      "sid": 82,
      "location": 2,
      "content": "他也想搞的人",
      "music": 0.0
    },
    {
      "from": 155.59,
      "to": 159.1,
      "sid": 83,
      "location": 2,
      "content": "他赶超我的速度没有办法变得很快",
      "music": 0.0
    },
    {
      "from": 159.1,
      "to": 161.18,
      "sid": 84,
      "location": 2,
      "content": "我如何达成这样一件事",
      "music": 0.0
    },
    {
      "from": 161.18,
      "to": 163.2,
      "sid": 85,
      "location": 2,
      "content": "这是我一直以来思考的问题",
      "music": 0.0
    },
    {
      "from": 163.2,
      "to": 164.84,
      "sid": 86,
      "location": 2,
      "content": "所以我们在做的第一天",
      "music": 0.0
    },
    {
      "from": 164.84,
      "to": 167.56,
      "sid": 87,
      "location": 2,
      "content": "我当时就想坚定不移的把咨询这件事做下去",
      "music": 0.0
    },
    {
      "from": 167.56,
      "to": 169.92,
      "sid": 88,
      "location": 2,
      "content": "而且我们的咨询导师是不换的",
      "music": 0.0
    },
    {
      "from": 169.92,
      "to": 171.28,
      "sid": 89,
      "location": 2,
      "content": "就是一直你给我在这干",
      "music": 0.0
    },
    {
      "from": 171.28,
      "to": 173.3,
      "sid": 90,
      "location": 2,
      "content": "不断的去接受各种各样的案例",
      "music": 0.0
    },
    {
      "from": 173.3,
      "to": 174.76,
      "sid": 91,
      "location": 2,
      "content": "增加你自己手上的案例以后",
      "music": 0.0
    },
    {
      "from": 174.76,
      "to": 176.18,
      "sid": 92,
      "location": 2,
      "content": "你这个人的咨询经验",
      "music": 0.0
    },
    {
      "from": 176.18,
      "to": 177.5,
      "sid": 93,
      "location": 2,
      "content": "你的识人辨人的能力",
      "music": 0.0
    },
    {
      "from": 177.5,
      "to": 178.38,
      "sid": 94,
      "location": 2,
      "content": "你解决问题的能力",
      "music": 0.0
    },
    {
      "from": 178.38,
      "to": 179.98,
      "sid": 95,
      "location": 2,
      "content": "那是不是几何数字的增长",
      "music": 0.0
    },
    {
      "from": 179.98,
      "to": 182.4,
      "sid": 96,
      "location": 2,
      "content": "就好像这些年你们看我在镜头前面对吧",
      "music": 0.0
    },
    {
      "from": 182.4,
      "to": 183.16,
      "sid": 97,
      "location": 2,
      "content": "我5年下来",
      "music": 0.0
    },
    {
      "from": 183.16,
      "to": 184.44,
      "sid": 98,
      "location": 2,
      "content": "我今天的直播感觉",
      "music": 0.0
    },
    {
      "from": 184.44,
      "to": 186.18,
      "sid": 99,
      "location": 2,
      "content": "跟我第一年的直播感觉一样吗",
      "music": 0.0
    },
    {
      "from": 186.18,
      "to": 187.98,
      "sid": 100,
      "location": 2,
      "content": "我今天那解决问题的那种精准度",
      "music": 0.0
    },
    {
      "from": 187.98,
      "to": 190.44,
      "sid": 101,
      "location": 2,
      "content": "跟我第一年的精准度它在一个水平线上吗",
      "music": 0.0
    },
    {
      "from": 190.44,
      "to": 192.39,
      "sid": 102,
      "location": 2,
      "content": "肯定不是肯定不一样",
      "music": 0.0
    },
    {
      "from": 192.39,
      "to": 194.21,
      "sid": 103,
      "location": 2,
      "content": "肯定是天翻覆地的变化对吧",
      "music": 0.0
    },
    {
      "from": 194.21,
      "to": 195.53,
      "sid": 104,
      "location": 2,
      "content": "所以不能是我一个人进步",
      "music": 0.0
    },
    {
      "from": 195.53,
      "to": 196.91,
      "sid": 105,
      "location": 2,
      "content": "而是我团队里的每一个人",
      "music": 0.0
    },
    {
      "from": 196.91,
      "to": 198.63,
      "sid": 106,
      "location": 2,
      "content": "他们都要有这样一个土壤",
      "music": 0.0
    },
    {
      "from": 198.63,
      "to": 199.71,
      "sid": 107,
      "location": 2,
      "content": "让他进步对吧",
      "music": 0.0
    },
    {
      "from": 199.71,
      "to": 201.01,
      "sid": 108,
      "location": 2,
