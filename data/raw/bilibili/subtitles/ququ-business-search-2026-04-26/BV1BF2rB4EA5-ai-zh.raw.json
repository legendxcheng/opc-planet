  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 0.36,
      "sid": 1,
      "location": 2,
      "content": "跟你们说",
      "music": 0.0
    },
    {
      "from": 0.36,
      "to": 3.0,
      "sid": 2,
      "location": 2,
      "content": "我以前就是嗯在学校里头",
      "music": 0.0
    },
    {
      "from": 3.0,
      "to": 4.74,
      "sid": 3,
      "location": 2,
      "content": "我以前在学校里头卖过化妆品",
      "music": 0.0
    },
    {
      "from": 4.74,
      "to": 5.72,
      "sid": 4,
      "location": 2,
      "content": "你们记得吗",
      "music": 0.0
    },
    {
      "from": 5.72,
      "to": 7.03,
      "sid": 5,
      "location": 2,
      "content": "我在上大学的时候",
      "music": 0.0
    },
    {
      "from": 7.03,
      "to": 8.23,
      "sid": 6,
      "location": 2,
      "content": "我在学校里卖化妆品",
      "music": 0.0
    },
    {
      "from": 8.23,
      "to": 9.87,
      "sid": 7,
      "location": 2,
      "content": "然后卖指甲油什么的",
      "music": 0.0
    },
    {
      "from": 9.87,
      "to": 13.35,
      "sid": 8,
      "location": 2,
      "content": "那个时候其实做这种小的生意特别特别的简单",
      "music": 0.0
    },
    {
      "from": 13.35,
      "to": 14.39,
      "sid": 9,
      "location": 2,
      "content": "刚开始你会觉得",
      "music": 0.0
    },
    {
      "from": 14.39,
      "to": 16.39,
      "sid": 10,
      "location": 2,
      "content": "好像好像什么事都特别的困难是吗",
      "music": 0.0
    },
    {
      "from": 16.39,
      "to": 17.43,
      "sid": 11,
      "location": 2,
      "content": "其实没有那么困难",
      "music": 0.0
    },
    {
      "from": 17.43,
      "to": 19.35,
      "sid": 12,
      "location": 2,
      "content": "我那个时候就是因为想尝试一下",
      "music": 0.0
    },
    {
      "from": 19.35,
      "to": 20.45,
      "sid": 13,
      "location": 2,
      "content": "其实我是想突破自己",
      "music": 0.0
    },
    {
      "from": 20.45,
      "to": 21.27,
      "sid": 14,
      "location": 2,
      "content": "因为我一直在学校里",
      "music": 0.0
    },
    {
      "from": 21.27,
      "to": 23.07,
      "sid": 15,
      "location": 2,
      "content": "就是像一个孔雀一样的一个女生",
      "music": 0.0
    },
    {
      "from": 23.07,
      "to": 23.71,
      "sid": 16,
      "location": 2,
      "content": "风云人物",
      "music": 0.0
    },
    {
      "from": 23.71,
      "to": 24.729,
      "sid": 17,
      "location": 2,
      "content": "走到哪都风云人物",
      "music": 0.0
    },
    {
      "from": 24.729,
      "to": 27.169,
      "sid": 18,
      "location": 2,
      "content": "可是我又觉得我自己的呃财力",
      "music": 0.0
    },
    {
      "from": 27.169,
      "to": 30.129,
      "sid": 19,
      "location": 2,
      "content": "我的经济实力跟我在大家心目当中的这种光环",
      "music": 0.0
    },
    {
      "from": 30.129,
      "to": 31.09,
      "sid": 20,
      "location": 2,
      "content": "他是不匹配的",
      "music": 0.0
    },
    {
      "from": 31.09,
      "to": 35.05,
      "sid": 21,
      "location": 2,
      "content": "我那会儿就觉得我不能够老是处在这种虚无的",
      "music": 0.0
    },
    {
      "from": 35.05,
      "to": 36.48,
      "sid": 22,
      "location": 2,
      "content": "高高在上的状态当中",
      "music": 0.0
    },
    {
      "from": 36.48,
      "to": 39.04,
      "sid": 23,
      "location": 2,
      "content": "我觉得我的实力跟我的这个状态是不匹配的",
      "music": 0.0
    },
    {
      "from": 39.04,
      "to": 41.18,
      "sid": 24,
      "location": 2,
      "content": "所以我想要刻意的把自己往下拉",
      "music": 0.0
    },
    {
      "from": 41.18,
      "to": 43.42,
      "sid": 25,
      "location": 2,
      "content": "自己把自己从神坛上拉下来",
      "music": 0.0
    },
    {
      "from": 43.42,
      "to": 45.62,
      "sid": 26,
      "location": 2,
      "content": "因为我觉得大家把我供到那个神坛上之后",
      "music": 0.0
    },
    {
      "from": 45.62,
      "to": 47.62,
      "sid": 27,
      "location": 2,
      "content": "其实对于我自己个人的发展非常不利",
      "music": 0.0
    },
    {
      "from": 47.62,
      "to": 48.9,
      "sid": 28,
      "location": 2,
      "content": "然后我为了把自己拉下来",
      "music": 0.0
    },
    {
      "from": 48.9,
      "to": 50.66,
      "sid": 29,
      "location": 2,
      "content": "所以我当时就选择去买护肤品",
      "music": 0.0
    },
    {
      "from": 50.66,
      "to": 51.18,
      "sid": 30,
      "location": 2,
      "content": "化妆品",
      "music": 0.0
    },
    {
      "from": 51.18,
      "to": 51.95,
      "sid": 31,
      "location": 2,
      "content": "买指甲油",
      "music": 0.0
    },
    {
      "from": 51.95,
      "to": 54.19,
      "sid": 32,
      "location": 2,
      "content": "而且我就摆了一个地摊儿",
      "music": 0.0
    },
    {
      "from": 54.19,
      "to": 55.92,
      "sid": 33,
      "location": 2,
      "content": "我在学校里就摆了个地摊儿",
      "music": 0.0
    },
    {
      "from": 55.92,
      "to": 57.52,
      "sid": 34,
      "location": 2,
      "content": "你们其实很难想象",
      "music": 0.0
    },
    {
      "from": 57.52,
      "to": 58.68,
      "sid": 35,
      "location": 2,
      "content": "我在学校里那个时候是什么状态",
      "music": 0.0
    },
    {
      "from": 58.68,
      "to": 59.88,
      "sid": 36,
      "location": 2,
      "content": "我真的是风云人物啊",
      "music": 0.0
    },
    {
      "from": 59.88,
      "to": 62.2,
      "sid": 37,
      "location": 2,
      "content": "因为我那个时候我们是读艺术的",
      "music": 0.0
    },
    {
      "from": 62.2,
      "to": 63.76,
      "sid": 38,
      "location": 2,
      "content": "在学校里头又常年都演出",
      "music": 0.0
    },
    {
      "from": 63.76,
      "to": 65.0,
      "sid": 39,
      "location": 2,
      "content": "学校里的人都知道啊",
      "music": 0.0
    },
    {
      "from": 65.0,
      "to": 66.52,
      "sid": 40,
      "location": 2,
      "content": "艺术系有个这样的女生是吧",
      "music": 0.0
    },
    {
      "from": 66.52,
      "to": 67.84,
      "sid": 41,
      "location": 2,
      "content": "每天感觉很耀眼的",
      "music": 0.0
    },
    {
      "from": 67.84,
      "to": 70.19,
      "sid": 42,
      "location": 2,
      "content": "打扮的也是那种一直都很华丽的那种人",
      "music": 0.0
    },
    {
      "from": 70.19,
      "to": 71.88,
      "sid": 43,
      "location": 2,
      "content": "然后就是我这样的一个人",
      "music": 0.0
    },
    {
      "from": 71.88,
      "to": 72.7,
      "sid": 44,
      "location": 2,
      "content": "大家都知道",
      "music": 0.0
    },
    {
      "from": 72.7,
      "to": 75.48,
      "sid": 45,
      "location": 2,
      "content": "我跑到我们人流量最大的那个食堂",
      "music": 0.0
    },
    {
      "from": 75.48,
      "to": 76.32,
      "sid": 46,
      "location": 2,
      "content": "门口去摆地摊",
      "music": 0.0
    },
    {
      "from": 76.32,
      "to": 78.88,
      "sid": 47,
      "location": 2,
      "content": "其实那个时候我想着赚钱还不是最重要的",
      "music": 0.0
    },
    {
      "from": 78.88,
      "to": 80.18,
      "sid": 48,
      "location": 2,
      "content": "我是为了突破自己",
      "music": 0.0
    },
    {
      "from": 80.18,
      "to": 81.72,
      "sid": 49,
      "location": 2,
      "content": "我人生当中做过很多这样的",
      "music": 0.0
    },
    {
      "from": 81.72,
      "to": 84.0,
      "sid": 50,
      "location": 2,
      "content": "就是让我自己去突破自己的自尊心",
      "music": 0.0
    },
    {
      "from": 84.0,
      "to": 85.15,
      "sid": 51,
      "location": 2,
      "content": "的这样一些行为",
      "music": 0.0
    },
    {
      "from": 85.15,
      "to": 86.71,
      "sid": 52,
      "location": 2,
      "content": "刻意的其实就是刻意为之的",
      "music": 0.0
    },
    {
      "from": 86.71,
      "to": 89.4,
      "sid": 53,
      "location": 2,
      "content": "因为我觉得我们这种从平凡的家庭出来的小孩",
      "music": 0.0
    },
    {
      "from": 89.4,
      "to": 91.56,
      "sid": 54,
      "location": 2,
      "content": "他就是会很在意自己的面子",
      "music": 0.0
    },
    {
      "from": 91.56,
      "to": 92.72,
      "sid": 55,
      "location": 2,
      "content": "很在意自己的自尊心",
      "music": 0.0
    },
    {
      "from": 92.72,
      "to": 95.14,
      "sid": 56,
      "location": 2,
      "content": "很在意自己在别人眼里是一个什么样的人设",
      "music": 0.0
    },
    {
      "from": 95.14,
      "to": 97.39,
      "sid": 57,
      "location": 2,
      "content": "我觉得这些东西他们会阻拦我的前进",
      "music": 0.0
    },
    {
      "from": 97.39,
      "to": 100.13,
      "sid": 58,
      "location": 2,
      "content": "所以我为了自己把自己的这层皮给他撕了",
      "music": 0.0
    },
    {
      "from": 100.13,
      "to": 101.15,
      "sid": 59,
      "location": 2,
      "content": "我做了一个这样的事情",
      "music": 0.0
    },
    {
      "from": 101.15,
      "to": 102.86,
      "sid": 60,
      "location": 2,
      "content": "我就到我们学校食堂门口去摆地摊",
      "music": 0.0
    },
    {
      "from": 102.86,
      "to": 104.24,
      "sid": 61,
      "location": 2,
      "content": "每天必然穿的很漂亮",
      "music": 0.0
    },
    {
      "from": 104.24,
      "to": 105.78,
      "sid": 62,
      "location": 2,
      "content": "一眼依然一看就是艺术系的",
      "music": 0.0
    },
    {
      "from": 105.78,
      "to": 107.34,
      "sid": 63,
      "location": 2,
      "content": "然后然后就在我们学校人流量最大的",
      "music": 0.0
    },
    {
      "from": 107.34,
      "to": 108.48,
      "sid": 64,
      "location": 2,
      "content": "那个食堂门口摆地摊",
      "music": 0.0
    },
    {
      "from": 108.48,
      "to": 111.26,
      "sid": 65,
      "location": 2,
      "content": "我我还记得当时我卖那个指甲有五块钱一瓶",
      "music": 0.0
    },
    {
      "from": 111.26,
      "to": 113.04,
      "sid": 66,
      "location": 2,
      "content": "然后我那个货源在哪里呢",
      "music": 0.0
    },
    {
      "from": 113.04,
      "to": 114.94,
      "sid": 67,
      "location": 2,
      "content": "我就是在网上搜的",
      "music": 0.0
    },
    {
      "from": 114.94,
      "to": 117.16,
      "sid": 68,
      "location": 2,
      "content": "我当时我不记得当时用的是什么搜索",
      "music": 0.0
    },
    {
      "from": 117.16,
      "to": 118.58,
      "sid": 69,
      "location": 2,
      "content": "是百度还是什么搜索了",
      "music": 0.0
    },
    {
      "from": 118.58,
      "to": 119.78,
      "sid": 70,
      "location": 2,
      "content": "我就在网上搜的",
      "music": 0.0
    },
    {
      "from": 119.78,
      "to": 122.24,
      "sid": 71,
      "location": 2,
      "content": "然后我就发现离我们的呃",
      "music": 0.0
    },
    {
      "from": 122.24,
      "to": 126.02,
      "sid": 72,
      "location": 2,
      "content": "那个寝室大概2km不到的一个办公楼里头",
      "music": 0.0
    },
    {
      "from": 126.02,
      "to": 128.66,
      "sid": 73,
      "location": 2,
      "content": "有一个做化妆品批发的一个办公室",
      "music": 0.0
    },
    {
      "from": 128.66,
      "to": 130.56,
      "sid": 74,
      "location": 2,
      "content": "我就每天骑着个自行车",
      "music": 0.0
    },
    {
      "from": 130.56,
      "to": 133.64,
      "sid": 75,
      "location": 2,
      "content": "然后就骑大概12km跑到那个办公楼去拿货",
      "music": 0.0
    },
    {
      "from": 133.64,
      "to": 136.6,
      "sid": 76,
      "location": 2,
      "content": "然后当时那个拿货过来好像是多少钱一瓶啊",
      "music": 0.0
    },
    {
      "from": 136.6,
      "to": 137.48,
      "sid": 77,
      "location": 2,
      "content": "我卖五块钱",
      "music": 0.0
    },
    {
      "from": 137.48,
      "to": 139.63,
      "sid": 78,
      "location": 2,
      "content": "好像好像拿货是一块五",
      "music": 0.0
    },
    {
      "from": 139.63,
      "to": 141.17,
      "sid": 79,
      "location": 2,
      "content": "好像一块五还是两块",
      "music": 0.0
    },
    {
      "from": 141.17,
      "to": 142.66,
      "sid": 80,
      "location": 2,
      "content": "然后我卖五块钱一瓶",
      "music": 0.0
    },
    {
      "from": 142.66,
      "to": 144.72,
      "sid": 81,
      "location": 2,
      "content": "我当时都觉得自己是黑心商人",
      "music": 0.0
    },
    {
      "from": 144.72,
      "to": 146.02,
      "sid": 82,
      "location": 2,
      "content": "我觉得我自己是在暴利",
      "music": 0.0
    },
    {
      "from": 146.02,
      "to": 146.66,
      "sid": 83,
      "location": 2,
      "content": "你知道吗",
      "music": 0.0
    },
    {
      "from": 146.66,
      "to": 148.66,
      "sid": 84,
      "location": 2,
      "content": "我用了哪些方式方法去卖我的货呢",
      "music": 0.0
    },
    {
      "from": 148.66,
      "to": 149.14,
      "sid": 85,
      "location": 2,
      "content": "我跟你们讲",
      "music": 0.0
    },
    {
      "from": 149.14,
      "to": 149.76,
      "sid": 86,
      "location": 2,
      "content": "那个时候啊",
      "music": 0.0
    },
    {
      "from": 149.76,
      "to": 150.22,
      "sid": 87,
      "location": 2,
      "content": "你们知道",
      "music": 0.0
    },
    {
      "from": 150.22,
      "to": 152.96,
      "sid": 88,
      "location": 2,
      "content": "现在武汉的平均收入都只有3000多块钱",
      "music": 0.0
    },
    {
      "from": 152.96,
      "to": 154.82,
      "sid": 89,
      "location": 2,
      "content": "武汉的一直是一个收入比较低的城市",
      "music": 0.0
    },
    {
      "from": 154.82,
      "to": 156.72,
      "sid": 90,
      "location": 2,
      "content": "现在武汉的平均收入都只有3000多块钱",
      "music": 0.0
    },
    {
      "from": 156.72,
      "to": 158.32,
      "sid": 91,
      "location": 2,
      "content": "我在读大学的那一年",
      "music": 0.0
    },
    {
      "from": 158.32,
      "to": 159.12,
      "sid": 92,
      "location": 2,
      "content": "我卖这个化妆品",
      "music": 0.0
    },
    {
      "from": 159.12,
      "to": 160.54,
      "sid": 93,
      "location": 2,
      "content": "我一个月也能卖出3000多块钱",
      "music": 0.0
    },
    {
      "from": 160.54,
      "to": 162.22,
      "sid": 94,
      "location": 2,
      "content": "这这已经是多少年前的事了",
      "music": 0.0
    },
    {
      "from": 162.22,
      "to": 163.4,
      "sid": 95,
      "location": 2,
      "content": "这已经真的快哦",
      "music": 0.0
    },
    {
      "from": 163.4,
      "to": 164.16,
      "sid": 96,
      "location": 2,
      "content": "十几年了",
      "music": 0.0
    },
    {
      "from": 164.16,
      "to": 165.5,
      "sid": 97,
      "location": 2,
      "content": "十十几年了",
      "music": 0.0
    },
    {
      "from": 165.5,
      "to": 167.18,
      "sid": 98,
      "location": 2,
      "content": "然后我那会儿一个月也是卖3000多块钱",
      "music": 0.0
    },
    {
      "from": 167.18,
      "to": 169.22,
      "sid": 99,
      "location": 2,
      "content": "我的销路第一个肖路就是食堂门口",
      "music": 0.0
    },
    {
      "from": 169.22,
      "to": 170.38,
      "sid": 100,
      "location": 2,
      "content": "然后第二个销路",
      "music": 0.0
    },
    {
      "from": 170.38,
      "to": 172.87,
      "sid": 101,
      "location": 2,
      "content": "我就每一个寝室逐个去敲门",
      "music": 0.0
    },
    {
      "from": 172.87,
      "to": 175.27,
      "sid": 102,
      "location": 2,
      "content": "我每一个女生寝室我逐一去敲门",
      "music": 0.0
    },
    {
      "from": 175.27,
      "to": 176.11,
      "sid": 103,
      "location": 2,
      "content": "卖照门推",
      "music": 0.0
    },
    {
      "from": 176.11,
      "to": 179.11,
      "sid": 104,
      "location": 2,
      "content": "然后基本上每一个寝室都能卖出去",
      "music": 0.0
    },
    {
      "from": 179.11,
      "to": 181.07,
      "sid": 105,
      "location": 2,
      "content": "至少一瓶至少一个东西",
      "music": 0.0
    },
    {
      "from": 181.07,
      "to": 182.03,
      "sid": 106,
      "location": 2,
      "content": "我还有一个小路",
      "music": 0.0
    },
    {
      "from": 182.03,
      "to": 184.07,
      "sid": 107,
      "location": 2,
