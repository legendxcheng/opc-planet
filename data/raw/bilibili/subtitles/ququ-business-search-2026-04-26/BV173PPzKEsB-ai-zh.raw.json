  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 1.06,
      "sid": 1,
      "location": 2,
      "content": "魔镜魔镜",
      "music": 0.0
    },
    {
      "from": 1.06,
      "to": 3.32,
      "sid": 2,
      "location": 2,
      "content": "我想变成一个美丽的公主",
      "music": 0.0
    },
    {
      "from": 3.32,
      "to": 6.13,
      "sid": 3,
      "location": 2,
      "content": "没想到有一天洒家也能当成公主",
      "music": 0.0
    },
    {
      "from": 6.13,
      "to": 9.21,
      "sid": 4,
      "location": 2,
      "content": "蹲下唱歌就唱歌",
      "music": 0.0
    },
    {
      "from": 9.21,
      "to": 11.17,
      "sid": 5,
      "location": 2,
      "content": "拒绝有偿陪侍",
      "music": 0.0
    },
    {
      "from": 11.77,
      "to": 13.61,
      "sid": 6,
      "location": 2,
      "content": "那寄东西",
      "music": 0.0
    },
    {
      "from": 15.579,
      "to": 18.759,
      "sid": 7,
      "location": 2,
      "content": "这是你丢的黄金镜子吗",
      "music": 0.0
    },
    {
      "from": 18.759,
      "to": 19.999,
      "sid": 8,
      "location": 2,
      "content": "对对对",
      "music": 0.0
    },
    {
      "from": 19.999,
      "to": 23.979,
      "sid": 9,
      "location": 2,
      "content": "我就知道不是你应该丢的是地形知识",
      "music": 0.0
    },
    {
      "from": 26.06,
      "to": 29.0,
      "sid": 10,
      "location": 2,
      "content": "你哭着对我说",
      "music": 0.9999999444444475
    },
    {
      "from": 29.0,
      "to": 31.52,
      "sid": 11,
      "location": 2,
      "content": "说好安徒生人不骗安徒生人的呢",
      "music": 0.2115384513683428
    },
    {
      "from": 31.52,
      "to": 32.34,
      "sid": 12,
      "location": 2,
      "content": "不好意思",
      "music": 0.5609755413444446
    },
    {
      "from": 32.34,
      "to": 34.08,
      "sid": 13,
      "location": 2,
      "content": "我是格林童话里骗不骗人",
      "music": 0.0
    },
    {
      "from": 34.08,
      "to": 34.64,
      "sid": 14,
      "location": 2,
      "content": "我不知道",
      "music": 0.0
    },
    {
      "from": 34.64,
      "to": 35.76,
      "sid": 15,
      "location": 2,
      "content": "但是免费给你东西",
      "music": 0.0
    },
    {
      "from": 35.76,
      "to": 37.29,
      "sid": 16,
      "location": 2,
      "content": "十有八九是骗你",
      "music": 0.0
    },
    {
      "from": 37.29,
      "to": 38.87,
      "sid": 17,
      "location": 2,
      "content": "按照原著里面设定",
      "music": 0.0
    },
    {
      "from": 38.87,
      "to": 40.21,
      "sid": 18,
      "location": 2,
      "content": "你得啃我一口",
      "music": 0.0
    },
    {
      "from": 40.21,
      "to": 42.28,
      "sid": 19,
      "location": 2,
      "content": "那是付费内容",
      "music": 0.0
    },
    {
      "from": 42.56,
      "to": 46.16,
      "sid": 20,
      "location": 2,
      "content": "点击以下境外链接可以免费下载观看哟",
      "music": 0.08588956791749813
    },
    {
      "from": 46.16,
      "to": 47.02,
      "sid": 21,
      "location": 2,
      "content": "你别逼我",
      "music": 0.0
    },
    {
      "from": 47.02,
      "to": 48.44,
      "sid": 22,
      "location": 2,
      "content": "毕竟我什么都做得出来",
      "music": 0.0
    },
    {
      "from": 48.44,
      "to": 51.47,
      "sid": 23,
      "location": 2,
      "content": "那你对男生爱花啊",
      "music": 0.0
    },
    {
      "from": 52.72,
      "to": 54.5,
      "sid": 24,
      "location": 2,
      "content": "原来你说的是这种啃呐",
      "music": 0.0
    },
    {
      "from": 54.5,
      "to": 58.1,
      "sid": 25,
      "location": 2,
      "content": "警惕不要随意点击来历不明的网址链接",
      "music": 0.0
    },
    {
      "from": 58.1,
      "to": 59.84,
      "sid": 26,
      "location": 2,
      "content": "否则他真的会啃你",
      "music": 0.0
    },
    {
      "from": 59.84,
      "to": 61.459,
      "sid": 27,
      "location": 2,
      "content": "你在教我做事",
      "music": 0.0
    },
    {
      "from": 61.92,
      "to": 65.14,
      "sid": 28,
      "location": 2,
      "content": "老板人在没电气公司就要倒闭啦",
      "music": 0.0
    },
    {
      "from": 65.14,
      "to": 66.68,
      "sid": 29,
      "location": 2,
      "content": "死心天上掉馅饼",
      "music": 0.0
    },
    {
      "from": 66.68,
      "to": 67.12,
      "sid": 30,
      "location": 2,
      "content": "在屋外",
      "music": 0.0
    },
    {
      "from": 67.12,
      "to": 70.1,
      "sid": 31,
      "location": 2,
      "content": "我快撑不住啦",
      "music": 0.0
    },
    {
      "from": 71.2,
      "to": 72.44,
      "sid": 32,
      "location": 2,
      "content": "只要你加我好友",
      "music": 0.0
    },
    {
      "from": 72.44,
      "to": 74.36,
      "sid": 33,
      "location": 2,
      "content": "你想要的皮肤应有尽有",
      "music": 0.5624999707031251
    },
    {
      "from": 74.36,
      "to": 76.26,
      "sid": 34,
      "location": 2,
      "content": "百万粉丝肯定靠谱呀",
      "music": 0.4225351815116124
    },
    {
      "from": 76.26,
      "to": 77.72,
      "sid": 35,
      "location": 2,
      "content": "主人实现皮肤自由了",
      "music": 0.0
    },
    {
      "from": 77.72,
      "to": 79.46,
      "sid": 36,
      "location": 2,
      "content": "我快给他分泌多巴胺",
      "music": 0.0
    },
    {
      "from": 80.06,
      "to": 81.96,
      "sid": 37,
      "location": 2,
      "content": "小马退货",
      "music": 0.0
    },
    {
      "from": 81.96,
      "to": 84.18,
      "sid": 38,
      "location": 2,
      "content": "双向调酒",
      "music": 0.0
    },
    {
      "from": 85.6,
      "to": 90.24,
      "sid": 39,
      "location": 2,
      "content": "哇啊短视频平台百万网红游戏福利",
      "music": 0.0
    },
    {
      "from": 90.24,
      "to": 90.86,
      "sid": 40,
      "location": 2,
      "content": "勿轻信",
      "music": 0.0
    },
    {
      "from": 90.86,
      "to": 92.97,
      "sid": 41,
      "location": 2,
      "content": "扫码加群有陷阱",
      "music": 0.0
    },
    {
      "from": 93.37,
      "to": 94.83,
      "sid": 42,
      "location": 2,
      "content": "不要生气啦",
      "music": 0.0
    },
    {
      "from": 94.83,
      "to": 96.17,
      "sid": 43,
      "location": 2,
      "content": "你上了骗子的当",
      "music": 0.0
    },
    {
      "from": 96.17,
      "to": 97.57,
      "sid": 44,
      "location": 2,
      "content": "还不是因为骗子恐吓你",
      "music": 0.0
    },
    {
      "from": 97.57,
      "to": 101.13,
      "sid": 45,
      "location": 2,
      "content": "说不处理虚假官方惩罚信息就要被我们抓",
      "music": 0.0
    },
    {
      "from": 101.13,
      "to": 104.07,
      "sid": 46,
      "location": 2,
      "content": "其实呢问题也不全出在你身上",
      "music": 0.0
    },
    {
      "from": 104.07,
      "to": 107.78,
      "sid": 47,
      "location": 2,
      "content": "还有手机让你接触这些信息呐",
      "music": 0.0
    },
    {
      "from": 107.78,
      "to": 109.02,
      "sid": 48,
      "location": 2,
      "content": "去开心一下",
      "music": 0.0
    },
    {
      "from": 109.02,
      "to": 111.68,
      "sid": 49,
      "location": 2,
      "content": "给你十本寒假作业提前做",
      "music": 0.0
    },
    {
      "from": 111.68,
      "to": 114.39,
      "sid": 50,
      "location": 2,
      "content": "这样你就没有时间被骗啦",
      "music": 0.0
    },
    {
      "from": 114.67,
      "to": 116.03,
      "sid": 51,
      "location": 2,
      "content": "你在教我做事啊",
      "music": 0.0
    },
    {
      "from": 116.03,
      "to": 116.71,
      "sid": 52,
      "location": 2,
      "content": "不是啦",
      "music": 0.0
    },
    {
      "from": 116.71,
      "to": 118.43,
      "sid": 53,
      "location": 2,
      "content": "我在宣传反诈知识",
      "music": 0.0
    },
    {
      "from": 118.43,
      "to": 121.67,
      "sid": 54,
      "location": 2,
      "content": "你可不要把我这件事给拍成短视频的",
      "music": 0.0
    },
    {
      "from": 122.19,
      "to": 123.21,
      "sid": 55,
      "location": 2,
      "content": "不仅要拍",
      "music": 0.0
    },
    {
      "from": 123.21,
      "to": 126.43,
      "sid": 56,
      "location": 2,
      "content": "还要在全国每一个学校持续轮播",
      "music": 0.0
    },
    {
      "from": 126.43,
      "to": 129.41,
      "sid": 57,
      "location": 2,
      "content": "呜呜勿信任何社交平台",
      "music": 0.087431689211382
    },
    {
      "from": 129.41,
      "to": 130.21,
      "sid": 58,
      "location": 2,
      "content": "免费游戏福利",
      "music": 0.0
    },
    {
      "from": 130.21,
      "to": 131.49,
      "sid": 59,
      "location": 2,
      "content": "凡是自称警察或游戏",
      "music": 0.0
    },
    {
      "from": 131.49,
      "to": 135.66,
      "sid": 60,
      "location": 2,
      "content": "官方要求绑定银行卡转账均为诈骗诶",
      "music": 0.0
    },
    {
      "from": 135.66,
      "to": 139.5,
      "sid": 61,
      "location": 2,
      "content": "你撞到什么情况",
      "music": 0.0
    },
    {
      "from": 140.68,
      "to": 141.88,
      "sid": 62,
      "location": 2,
      "content": "阿B啊",
      "music": 0.0
    },
    {
      "from": 141.88,
      "to": 142.72,
      "sid": 63,
      "location": 2,
      "content": "装什么呀",
      "music": 0.0
    },
    {
      "from": 142.72,
      "to": 143.86,
      "sid": 64,
      "location": 2,
      "content": "要看我咋样",
      "music": 0.0
    },
    {
      "from": 143.86,
      "to": 145.92,
      "sid": 65,
      "location": 2,
      "content": "这种人一看不是天生会装",
      "music": 0.0
    },
    {
      "from": 145.92,
      "to": 147.94,
      "sid": 66,
      "location": 2,
      "content": "高峰是什么谈那就没错了",
      "music": 0.1170212703712087
    },
    {
      "from": 147.94,
      "to": 150.13,
      "sid": 67,
      "location": 2,
      "content": "我一眼都比矫情一些",
      "music": 0.1340206116484322
    },
    {
      "from": 162.06,
      "to": 165.46,
      "sid": 68,
      "location": 2,
      "content": "哎你撞到我了",
      "music": 0.0
    },
    {
      "from": 170.8,
      "to": 172.24,
      "sid": 69,
      "location": 2,
      "content": "大哥味道不对啊",
      "music": 0.0
    },
    {
      "from": 172.24,
      "to": 173.62,
      "sid": 70,
      "location": 2,
      "content": "本地的帮派太没礼貌了",
      "music": 0.0
    },
    {
      "from": 173.62,
      "to": 175.42,
      "sid": 71,
      "location": 2,
      "content": "哇啊",
      "music": 0.0
    },
    {
      "from": 192.7,
      "to": 194.24,
      "sid": 72,
      "location": 2,
      "content": "打劫打劫",
      "music": 0.0
    },
    {
      "from": 194.24,
      "to": 195.44,
      "sid": 73,
      "location": 2,
      "content": "你知道我是谁吗",
      "music": 0.0
    },
    {
      "from": 195.44,
      "to": 196.88,
      "sid": 74,
      "location": 2,
      "content": "我滚",
      "music": 0.0
    },
    {
      "from": 212.0,
      "to": 212.87,
      "sid": 75,
      "location": 2,
      "content": "不了不了",
      "music": 0.0
    },
    {
      "from": 212.87,
      "to": 214.39,
      "sid": 76,
      "location": 2,
      "content": "We are all doing this",
      "music": 0.0
    },
    {
      "from": 214.39,
      "to": 214.95,
      "sid": 77,
      "location": 2,
      "content": "It's ok",
      "music": 0.0
    },
    {
      "from": 214.95,
      "to": 216.71,
      "sid": 78,
      "location": 2,
      "content": "We all from the same village",
      "music": 0.05681817858988851
    },
    {
      "from": 216.71,
      "to": 218.11,
      "sid": 79,
      "location": 2,
      "content": "Why are you so unsociable",
      "music": 0.0
    },
    {
      "from": 218.11,
      "to": 219.71,
      "sid": 80,
      "location": 2,
      "content": "Give it a try",
      "music": 0.0
    },
    {
      "from": 220.33,
      "to": 222.67,
      "sid": 81,
      "location": 2,
      "content": "不过那是100多年前的事了",
      "music": 0.0
    },
    {
      "from": 222.67,
      "to": 227.29,
      "sid": 82,
      "location": 2,
      "content": "他们却用这些东西轰开了我们家大门",
      "music": 0.0
    },
    {
      "from": 229.22,
      "to": 231.34,
      "sid": 83,
      "location": 2,
      "content": "那时候的我体弱多病",
      "music": 0.0
    },
    {
      "from": 233.26,
      "to": 234.12,
      "sid": 84,
      "location": 2,
      "content": "这是我家",
      "music": 0.0
    },
    {
      "from": 234.12,
      "to": 235.32,
      "sid": 85,
      "location": 2,
      "content": "你们干嘛",
      "music": 0.0
    },
    {
      "from": 235.32,
      "to": 238.88,
      "sid": 86,
      "location": 2,
      "content": "家里积累的财富全流到了这帮匪徒手里",
      "music": 0.0
    },
    {
      "from": 238.88,
      "to": 242.12,
      "sid": 87,
      "location": 2,
      "content": "祖上流传下来的宝贝也被他们掠夺抢走",
      "music": 0.0
    },
    {
      "from": 242.12,
      "to": 244.34,
      "sid": 88,
      "location": 2,
      "content": "还让我签了一堆耻辱的条约",
      "music": 0.0
    },
    {
      "from": 244.34,
      "to": 246.28,
      "sid": 89,
      "location": 2,
      "content": "夺走了我的孩子",
      "music": 0.0
    },
    {
      "from": 246.28,
      "to": 249.42,
      "sid": 90,
      "location": 2,
      "content": "最后还放火烧了我家花园",
      "music": 0.0
    },
    {
      "from": 249.42,
      "to": 252.88,
      "sid": 91,
      "location": 2,
      "content": "所以你们问我为什么对深恶痛绝",
      "music": 0.0
    },
    {
      "from": 252.88,
      "to": 254.74,
      "sid": 92,
      "location": 2,
      "content": "因为一个伟大的民族",
      "music": 0.0
    },
    {
      "from": 254.74,
      "to": 257.44,
      "sid": 93,
      "location": 2,
      "content": "不会在同一个地方跌倒两次",
      "music": 0.0
    }
  ]
}