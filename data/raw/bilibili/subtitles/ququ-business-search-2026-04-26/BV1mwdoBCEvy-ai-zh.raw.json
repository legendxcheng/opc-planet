{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 3.08,
      "sid": 1,
      "location": 2,
      "content": "今天吃几碗烧烤的总结就是两个字",
      "music": 0.0
    },
    {
      "from": 3.08,
      "to": 3.8,
      "sid": 2,
      "location": 2,
      "content": "学做菜",
      "music": 0.0
    },
    {
      "from": 3.8,
      "to": 4.24,
      "sid": 3,
      "location": 2,
      "content": "会吃菜",
      "music": 0.0
    },
    {
      "from": 4.24,
      "to": 6.52,
      "sid": 4,
      "location": 2,
      "content": "今天我们请从厦门远道而来的老瑞",
      "music": 0.0
    },
    {
      "from": 6.52,
      "to": 8.04,
      "sid": 5,
      "location": 2,
      "content": "来尝尝我们济南的烧烤",
      "music": 0.0
    },
    {
      "from": 8.04,
      "to": 9.38,
      "sid": 6,
      "location": 2,
      "content": "走着放在这里头",
      "music": 0.0
    },
    {
      "from": 9.38,
      "to": 11.34,
      "sid": 7,
      "location": 2,
      "content": "最后数签子吃了多少根棍",
      "music": 0.0
    },
    {
      "from": 12.54,
      "to": 14.84,
      "sid": 8,
      "location": 2,
      "content": "自博烧烤里面有一些烤五花肉什么的",
      "music": 0.0
    },
    {
      "from": 14.84,
      "to": 16.799,
      "sid": 9,
      "location": 2,
      "content": "这边基本上以牛羊肉为主",
      "music": 0.0
    },
    {
      "from": 16.799,
      "to": 18.319,
      "sid": 10,
      "location": 2,
      "content": "你是特别喜欢吃腊八蒜",
      "music": 0.0
    },
    {
      "from": 18.319,
      "to": 19.819,
      "sid": 11,
      "location": 2,
      "content": "哎我去福建那边的话",
      "music": 0.0
    },
    {
      "from": 19.819,
      "to": 20.919,
      "sid": 12,
      "location": 2,
      "content": "他们没有吗",
      "music": 0.0
    },
    {
      "from": 20.919,
      "to": 21.819,
      "sid": 13,
      "location": 2,
      "content": "你有啊",
      "music": 0.0
    },
    {
      "from": 21.819,
      "to": 22.479,
      "sid": 14,
      "location": 2,
      "content": "能买啊",
      "music": 0.0
    },
    {
      "from": 22.479,
      "to": 24.299,
      "sid": 15,
      "location": 2,
      "content": "买了山东的来吧",
      "music": 0.0
    },
    {
      "from": 24.299,
      "to": 24.799,
      "sid": 16,
      "location": 2,
      "content": "兄弟们",
      "music": 0.0
    },
    {
      "from": 24.799,
      "to": 26.47,
      "sid": 17,
      "location": 2,
      "content": "我们那你们走一个",
      "music": 0.0
    },
    {
      "from": 26.47,
      "to": 27.79,
      "sid": 18,
      "location": 2,
      "content": "我的颜色比较浅",
      "music": 0.0
    },
    {
      "from": 27.79,
      "to": 28.99,
      "sid": 19,
      "location": 2,
      "content": "我比较清淡",
      "music": 0.0
    },
    {
      "from": 30.21,
      "to": 31.76,
      "sid": 20,
      "location": 2,
      "content": "叔叔叔叔哈哈",
      "music": 0.0
    },
    {
      "from": 31.76,
      "to": 36.34,
      "sid": 21,
      "location": 2,
      "content": "我那天跟我叔叔探讨一下为什么叫烧烤啊",
      "music": 0.0
    },
    {
      "from": 36.48,
      "to": 37.8,
      "sid": 22,
      "location": 2,
      "content": "你觉得为啥要烧烤",
      "music": 0.0
    },
    {
      "from": 37.8,
      "to": 39.16,
      "sid": 23,
      "location": 2,
      "content": "这东西跟1+1=2",
      "music": 0.0
    },
    {
      "from": 39.16,
      "to": 42.82,
      "sid": 24,
      "location": 2,
      "content": "这还没更真没空给我们就是说这个烧啊",
      "music": 0.0
    },
    {
      "from": 42.82,
      "to": 45.06,
      "sid": 25,
      "location": 2,
      "content": "这边的它是要建火苗的嗯",
      "music": 0.0
    },
    {
      "from": 45.06,
      "to": 48.68,
      "sid": 26,
      "location": 2,
      "content": "对要见火苗的为烧不见火苗的为烤",
      "music": 0.0
    },
    {
      "from": 48.68,
      "to": 52.28,
      "sid": 27,
      "location": 2,
      "content": "烧烤呢一般像传统的都是又烧又烤",
      "music": 0.0
    },
    {
      "from": 52.28,
      "to": 54.22,
      "sid": 28,
      "location": 2,
      "content": "离着这个火有一定高度嘛",
      "music": 0.0
    },
    {
      "from": 54.22,
      "to": 54.86,
      "sid": 29,
      "location": 2,
      "content": "滴点油",
      "music": 0.0
    },
    {
      "from": 54.86,
      "to": 57.32,
      "sid": 30,
      "location": 2,
      "content": "这一见火的正正烧不见火的就是烤",
      "music": 0.0
    },
    {
      "from": 57.32,
      "to": 59.22,
      "sid": 31,
      "location": 2,
      "content": "所以叫烧烤还没毛病",
      "music": 0.0
    },
    {
      "from": 59.22,
      "to": 61.06,
      "sid": 32,
      "location": 2,
      "content": "我想说什么东西都离不开技法呀",
      "music": 0.0
    },
    {
      "from": 61.06,
      "to": 63.71,
      "sid": 33,
      "location": 2,
      "content": "还是来羊肉白条来点羊肉",
      "music": 0.0
    },
    {
      "from": 63.71,
      "to": 65.13,
      "sid": 34,
      "location": 2,
      "content": "把羊肉来点米汤圆",
      "music": 0.0
    },
    {
      "from": 65.13,
      "to": 65.85,
      "sid": 35,
      "location": 2,
      "content": "有鱼肚",
      "music": 0.0
    },
    {
      "from": 65.85,
      "to": 67.45,
      "sid": 36,
      "location": 2,
      "content": "腰斩村人",
      "music": 0.0
    },
    {
      "from": 67.45,
      "to": 68.77,
      "sid": 37,
      "location": 2,
      "content": "我脖子都抽筋了",
      "music": 0.0
    },
    {
      "from": 68.77,
      "to": 69.95,
      "sid": 38,
      "location": 2,
      "content": "那短这是三块五",
      "music": 0.0
    },
    {
      "from": 69.95,
      "to": 70.47,
      "sid": 39,
      "location": 2,
      "content": "对对对",
      "music": 0.0
    },
    {
      "from": 70.47,
      "to": 71.97,
      "sid": 40,
      "location": 2,
      "content": "这个呢这是七块的",
      "music": 0.0
    },
    {
      "from": 71.97,
      "to": 73.71,
      "sid": 41,
      "location": 2,
      "content": "这是我们济南的羊肉串",
      "music": 0.0
    },
    {
      "from": 73.71,
      "to": 74.73,
      "sid": 42,
      "location": 2,
      "content": "随便接",
      "music": 0.0
    },
    {
      "from": 74.73,
      "to": 75.15,
      "sid": 43,
      "location": 2,
      "content": "看见没有",
      "music": 0.0
    },
    {
      "from": 75.15,
      "to": 76.369,
      "sid": 44,
      "location": 2,
      "content": "同志们来吧",
      "music": 0.0
    },
    {
      "from": 76.369,
      "to": 78.329,
      "sid": 45,
      "location": 2,
      "content": "我们这个小串也有价",
      "music": 0.0
    },
    {
      "from": 78.329,
      "to": 79.089,
      "sid": 46,
      "location": 2,
      "content": "友情无价",
      "music": 0.0
    },
    {
      "from": 79.089,
      "to": 79.889,
      "sid": 47,
      "location": 2,
      "content": "来再干一个",
      "music": 0.0
    },
    {
      "from": 79.889,
      "to": 80.669,
      "sid": 48,
      "location": 2,
      "content": "来来来来",
      "music": 0.0
    },
    {
      "from": 80.669,
      "to": 81.809,
      "sid": 49,
      "location": 2,
      "content": "羊排真好吃",
      "music": 0.0
    },
    {
      "from": 81.809,
      "to": 84.34,
      "sid": 50,
      "location": 2,
      "content": "这老三的对",
      "music": 0.0
    },
    {
      "from": 84.34,
      "to": 87.56,
      "sid": 51,
      "location": 2,
      "content": "这道菜我留这烧烤做不了什么大铁盆",
      "music": 0.0
    },
    {
      "from": 87.56,
      "to": 88.34,
      "sid": 52,
      "location": 2,
      "content": "装完弄饭",
      "music": 0.0
    },
    {
      "from": 88.34,
      "to": 88.9,
      "sid": 53,
      "location": 2,
      "content": "我热了",
      "music": 0.0
    },
    {
      "from": 88.9,
      "to": 89.6,
      "sid": 54,
      "location": 2,
      "content": "好家伙啊",
      "music": 0.0
    },
    {
      "from": 89.6,
      "to": 90.52,
      "sid": 55,
      "location": 2,
      "content": "一个人就两片了",
      "music": 0.0
    },
    {
      "from": 90.52,
      "to": 91.72,
      "sid": 56,
      "location": 2,
      "content": "这是不是要便宜点哦",
      "music": 0.0
    },
    {
      "from": 91.72,
      "to": 92.56,
      "sid": 57,
      "location": 2,
      "content": "这个要短",
      "music": 0.0
    },
    {
      "from": 92.56,
      "to": 95.56,
      "sid": 58,
      "location": 2,
      "content": "你就记得这羊排感觉像炸过",
      "music": 0.0
    },
    {
      "from": 95.56,
      "to": 98.96,
      "sid": 59,
      "location": 2,
      "content": "然后再烤腌过或者是先卤过",
      "music": 0.0
    },
    {
      "from": 98.96,
      "to": 100.44,
      "sid": 60,
      "location": 2,
      "content": "要不然生烤烤成这样",
      "music": 0.0
    },
    {
      "from": 100.44,
      "to": 102.4,
      "sid": 61,
      "location": 2,
      "content": "这里面就已经干了或者柴了",
      "music": 0.0
    },
    {
      "from": 102.4,
      "to": 104.08,
      "sid": 62,
      "location": 2,
      "content": "然后肥的也就没那么润",
      "music": 0.0
    },
    {
      "from": 104.725,
      "to": 107.59,
      "sid": 63,
      "location": 2,
      "content": "看我们济南不光有卤菜也有串",
      "music": 0.0
    },
    {
      "from": 107.59,
      "to": 110.15,
      "sid": 64,
      "location": 2,
      "content": "欢迎大家都到济南过来玩",
      "music": 0.0
    },
    {
      "from": 110.15,
      "to": 111.27,
      "sid": 65,
      "location": 2,
      "content": "我们刚才吃的羊排",
      "music": 0.0
    },
    {
      "from": 111.27,
      "to": 112.15,
      "sid": 66,
      "location": 2,
      "content": "反正确实做的非常好",
      "music": 0.0
    },
    {
      "from": 112.15,
      "to": 113.27,
      "sid": 67,
      "location": 2,
      "content": "把这羊排撕开咬开",
      "music": 0.0
    },
    {
      "from": 113.27,
      "to": 114.43,
      "sid": 68,
      "location": 2,
      "content": "看看哎是怎么做的",
      "music": 0.0
    },
    {
      "from": 114.43,
      "to": 116.9,
      "sid": 69,
      "location": 2,
      "content": "老瑞的肯定作为一个淄博临淄人民啊",
      "music": 0.0
    },
    {
      "from": 116.9,
      "to": 118.22,
      "sid": 70,
      "location": 2,
      "content": "又过来尝一下鸭脚也不错",
      "music": 0.0
    },
    {
      "from": 118.22,
      "to": 118.94,
      "sid": 71,
      "location": 2,
      "content": "又要了一盘",
      "music": 0.0
    },
    {
      "from": 118.94,
      "to": 119.44,
      "sid": 72,
      "location": 2,
      "content": "继续吃",
      "music": 0.0
    },
    {
      "from": 119.44,
      "to": 121.02,
      "sid": 73,
      "location": 2,
      "content": "再研究研究研究批判一下",
      "music": 0.0
    },
    {
      "from": 121.02,
      "to": 122.66,
      "sid": 74,
      "location": 2,
      "content": "咱们吃个脆骨和那份青菜",
      "music": 0.0
    },
    {
      "from": 122.66,
      "to": 125.439,
      "sid": 75,
      "location": 2,
      "content": "我知道这哼这样吧",
      "music": 0.0
    },
    {
      "from": 125.439,
      "to": 126.519,
      "sid": 76,
      "location": 2,
      "content": "咱们这这一杯呢",
      "music": 0.0
    },
    {
      "from": 126.519,
      "to": 128.219,
      "sid": 77,
      "location": 2,
      "content": "咱们陪完下辈人都随意啊",
      "music": 0.0
    },
    {
      "from": 128.219,
      "to": 128.959,
      "sid": 78,
      "location": 2,
      "content": "你别说人家",
      "music": 0.0
    },
    {
      "from": 128.959,
      "to": 130.159,
      "sid": 79,
      "location": 2,
      "content": "你先把你裤子脱了",
      "music": 0.0
    },
    {
      "from": 130.96,
      "to": 131.98,
      "sid": 80,
      "location": 2,
      "content": "来了来了",
      "music": 0.0
    },
    {
      "from": 131.98,
      "to": 132.84,
      "sid": 81,
      "location": 2,
      "content": "他刚才他说",
      "music": 0.0
    },
    {
      "from": 132.84,
      "to": 134.16,
      "sid": 82,
      "location": 2,
      "content": "他在厦门已经很多年",
      "music": 0.0
    },
    {
      "from": 134.16,
      "to": 135.9,
      "sid": 83,
      "location": 2,
      "content": "没感受过这种人间烟火气了",
      "music": 0.0
    },
    {
      "from": 135.9,
      "to": 138.88,
      "sid": 84,
      "location": 2,
      "content": "以后那个每年来感受一回行不行",
      "music": 0.0
    },
    {
      "from": 138.88,
      "to": 139.98,
      "sid": 85,
      "location": 2,
      "content": "来来来来",
      "music": 0.0
    },
    {
      "from": 139.98,
      "to": 140.5,
      "sid": 86,
      "location": 2,
      "content": "感谢李哥",
      "music": 0.0
    },
    {
      "from": 140.5,
      "to": 141.42,
      "sid": 87,
      "location": 2,
      "content": "来来来",
      "music": 0.0
    },
    {
      "from": 141.42,
      "to": 143.02,
      "sid": 88,
      "location": 2,
      "content": "这个容积这么大的话",
      "music": 0.0
    },
    {
      "from": 143.02,
      "to": 145.14,
      "sid": 89,
      "location": 2,
      "content": "我以后下回我得偷摸来了",
      "music": 0.0
    },
    {
      "from": 145.14,
      "to": 146.02,
      "sid": 90,
      "location": 2,
      "content": "肥一肥肥的",
      "music": 0.0
    },
    {
      "from": 146.02,
      "to": 147.14,
      "sid": 91,
      "location": 2,
      "content": "别留下心理阴影",
      "music": 0.0
    },
    {
      "from": 147.14,
      "to": 147.66,
      "sid": 92,
      "location": 2,
      "content": "来来来来",
      "music": 0.0
    },
    {
      "from": 147.66,
      "to": 149.42,
      "sid": 93,
      "location": 2,
      "content": "给我给我给我老师单独拿",
      "music": 0.0
    },
    {
      "from": 149.42,
      "to": 150.68,
      "sid": 94,
      "location": 2,
      "content": "拿我拿去啊",
      "music": 0.0
    },
    {
      "from": 150.68,
      "to": 152.78,
      "sid": 95,
      "location": 2,
      "content": "这个饼给你吃的吊炉烧饼",
      "music": 0.0
    },
    {
      "from": 152.78,
      "to": 153.36,
      "sid": 96,
      "location": 2,
      "content": "老实人",
      "music": 0.0
    },
    {
      "from": 153.36,
      "to": 154.52,
      "sid": 97,
      "location": 2,
      "content": "咱们咱们俩单独合影",
      "music": 0.0
    },
    {
      "from": 154.52,
      "to": 155.96,
      "sid": 98,
      "location": 2,
      "content": "虽然联系很久了",
      "music": 0.0
    },
    {
      "from": 155.96,
      "to": 160.24,
      "sid": 99,
      "location": 2,
      "content": "但是见面一见面还是像和第一次聊天那么开心",
      "music": 0.0
    },
    {
      "from": 160.24,
      "to": 161.48,
      "sid": 100,
      "location": 2,
      "content": "不愧是老乡是吧",
      "music": 0.0
    },
    {
      "from": 162.34,
      "to": 164.48,
      "sid": 101,
      "location": 2,
      "content": "关键我们团队老刘也是来芜了",
      "music": 0.0
    },
    {
      "from": 164.48,
      "to": 167.56,
      "sid": 102,
      "location": 2,
      "content": "你说天下聚到一块皆是缘分啊",
      "music": 0.0
    },
    {
      "from": 167.56,
      "to": 169.24,
      "sid": 103,
      "location": 2,
      "content": "以后我们多多线下见面啊",
      "music": 0.0
    },
    {
      "from": 169.24,
      "to": 170.12,
      "sid": 104,
      "location": 2,
      "content": "我做这个事的时候",
      "music": 0.0
    },
    {
      "from": 170.12,
      "to": 172.38,
      "sid": 105,
      "location": 2,
      "content": "我就觉得不一定能成",
      "music": 0.0
    },
    {
      "from": 172.38,
      "to": 173.54,
      "sid": 106,
      "location": 2,
      "content": "那时候刚刚起步",
      "music": 0.0
    },
    {
      "from": 173.54,
      "to": 175.68,
      "sid": 107,
      "location": 2,
      "content": "我也不知道自己能不能做成品",
      "music": 0.0
    },
    {
      "from": 175.68,
      "to": 177.9,
      "sid": 108,
      "location": 2,
      "content": "之前我拍摄了将近3年",
      "music": 0.0
    },
    {
      "from": 177.9,
      "to": 179.66,
      "sid": 109,
      "location": 2,
      "content": "我就感觉到有点断档",
      "music": 0.0
    },
    {
      "from": 179.66,
      "to": 182.0,
      "sid": 110,
      "location": 2,
      "content": "很多这个年轻人年轻的厨师",
      "music": 0.0
    },
    {
