  "body": [
    {
      "from": 0.0,
      "to": 3.72,
      "sid": 1,
      "location": 2,
      "content": "球球他要在他要在酒吧里边做音乐疗愈",
      "music": 0.0
    },
    {
      "from": 3.72,
      "to": 5.12,
      "sid": 2,
      "location": 2,
      "content": "他要给那个敲波了",
      "music": 0.0
    },
    {
      "from": 5.12,
      "to": 8.0,
      "sid": 3,
      "location": 2,
      "content": "他酒吧里面给你敲睡着",
      "music": 0.0
    },
    {
      "from": 8.0,
      "to": 8.7,
      "sid": 4,
      "location": 2,
      "content": "知道吧",
      "music": 0.0
    },
    {
      "from": 8.7,
      "to": 10.48,
      "sid": 5,
      "location": 2,
      "content": "他怕你平时白天睡不好",
      "music": 0.0
    },
    {
      "from": 10.48,
      "to": 12.07,
      "sid": 6,
      "location": 2,
      "content": "晚上睡哈哈",
      "music": 0.0
    },
    {
      "from": 13.63,
      "to": 15.17,
      "sid": 7,
      "location": 2,
      "content": "白天睡不着",
      "music": 0.0
    },
    {
      "from": 15.17,
      "to": 17.86,
      "sid": 8,
      "location": 2,
      "content": "晚上到酒吧里面去睡觉",
      "music": 0.0
    },
    {
      "from": 18.3,
      "to": 21.14,
      "sid": 9,
      "location": 2,
      "content": "我还真是不管外面的声音多喧哗",
      "music": 0.0
    },
    {
      "from": 21.14,
      "to": 22.82,
      "sid": 10,
      "location": 2,
      "content": "我在那个卡座上绝对可以躺",
      "music": 0.0
    },
    {
      "from": 22.82,
      "to": 24.98,
      "sid": 11,
      "location": 2,
      "content": "卡哈哈哈哈",
      "music": 0.0
    },
    {
      "from": 25.58,
      "to": 28.06,
      "sid": 12,
      "location": 2,
      "content": "再动次打次动次打次都不影响我睡觉",
      "music": 0.0
    },
    {
      "from": 28.06,
      "to": 29.9,
      "sid": 13,
      "location": 2,
      "content": "哈哈都不影响我唐卡",
      "music": 0.0
    },
    {
      "from": 33.26,
      "to": 34.86,
      "sid": 14,
      "location": 2,
      "content": "都想啥呀",
      "music": 0.0
    },
    {
      "from": 34.86,
      "to": 36.1,
      "sid": 15,
      "location": 2,
      "content": "一天天的",
      "music": 0.0
    },
    {
      "from": 36.1,
      "to": 39.62,
      "sid": 16,
      "location": 2,
      "content": "你要我说你做的事要跟你自己有点关系",
      "music": 0.0
    },
    {
      "from": 39.62,
      "to": 40.32,
      "sid": 17,
      "location": 2,
      "content": "好不好",
      "music": 0.0
    },
    {
      "from": 40.32,
      "to": 41.98,
      "sid": 18,
      "location": 2,
      "content": "都不玩酒吧的人",
      "music": 0.0
    },
    {
      "from": 41.98,
      "to": 44.66,
      "sid": 19,
      "location": 2,
      "content": "我不懂他们为什么要做酒吧",
      "music": 0.0
    },
    {
      "from": 44.92,
      "to": 48.22,
      "sid": 20,
      "location": 2,
      "content": "为什么要做这种东西哈",
      "music": 0.0
    },
    {
      "from": 48.22,
      "to": 51.64,
      "sid": 21,
      "location": 2,
      "content": "不要凭空创造一个商业模式",
      "music": 0.0
    },
    {
      "from": 51.64,
      "to": 55.28,
      "sid": 22,
      "location": 2,
      "content": "真的因为你们不具备这样的智慧",
      "music": 0.0
    },
    {
      "from": 56.04,
      "to": 57.9,
      "sid": 23,
      "location": 2,
      "content": "商业模式的创建",
      "music": 0.0
    },
    {
      "from": 57.9,
      "to": 61.2,
      "sid": 24,
      "location": 2,
      "content": "这个东西是需要你在做别人已经重复了1万次",
      "music": 0.0
    },
    {
      "from": 61.2,
      "to": 64.85,
      "sid": 25,
      "location": 2,
      "content": "的商业模式的过程当中优化和迭代出来的",
      "music": 0.0
    },
    {
      "from": 64.85,
      "to": 65.57,
      "sid": 26,
      "location": 2,
      "content": "明白吗",
      "music": 0.0
    },
    {
      "from": 65.57,
      "to": 68.99,
      "sid": 27,
      "location": 2,
      "content": "就是你先去做别人已经论证过1万次了的东西",
      "music": 0.0
    },
    {
      "from": 68.99,
      "to": 72.09,
      "sid": 28,
      "location": 2,
      "content": "然后做的过程当中找手感",
      "music": 0.0
    },
    {
      "from": 72.09,
      "to": 75.25,
      "sid": 29,
      "location": 2,
      "content": "再看什么地方可以优化提升",
      "music": 0.0
    },
    {
      "from": 75.25,
      "to": 77.33,
      "sid": 30,
      "location": 2,
      "content": "然后把把你自己的商业模式",
      "music": 0.0
    },
    {
      "from": 77.33,
      "to": 80.89,
      "sid": 31,
      "location": 2,
      "content": "做出一个更新颖的东西",
      "music": 0.0
    },
    {
      "from": 81.14,
      "to": 85.69,
      "sid": 32,
      "location": 2,
      "content": "不要自己凭空想象好不好",
      "music": 0.0
    },
    {
      "from": 85.69,
      "to": 88.37,
      "sid": 33,
      "location": 2,
      "content": "你们那个是你们那个商业模式是炖出来的",
      "music": 0.0
    },
    {
      "from": 89.59,
      "to": 90.73,
      "sid": 34,
      "location": 2,
      "content": "是土遁",
      "music": 0.0
    },
    {
      "from": 90.73,
      "to": 94.499,
      "sid": 35,
      "location": 2,
      "content": "哈哈哈哈哈哈哈是吧",
      "music": 0.0
    },
    {
      "from": 94.499,
      "to": 97.739,
      "sid": 36,
      "location": 2,
      "content": "土遁你个少爷博士干啥呀",
      "music": 0.0
    },
    {
      "from": 97.739,
      "to": 101.27,
      "sid": 37,
      "location": 2,
      "content": "哈就这个世界上就你有智慧",
      "music": 0.0
    },
    {
      "from": 101.27,
      "to": 104.8,
      "sid": 38,
      "location": 2,
      "content": "别人都是大傻子呵",
      "music": 0.0
    },
    {
      "from": 104.8,
      "to": 105.38,
      "sid": 39,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 105.38,
      "to": 106.56,
      "sid": 40,
      "location": 2,
      "content": "还要还要搞",
      "music": 0.0
    },
    {
      "from": 106.56,
      "to": 107.98,
      "sid": 41,
      "location": 2,
      "content": "还要还要搞执念",
      "music": 0.0
    },
    {
      "from": 107.98,
      "to": 109.65,
      "sid": 42,
      "location": 2,
      "content": "真的我跟你们不是开玩笑",
      "music": 0.0
    },
    {
      "from": 109.65,
      "to": 111.37,
      "sid": 43,
      "location": 2,
      "content": "你们真的就跟我聊这个天",
      "music": 0.0
    },
    {
      "from": 111.37,
      "to": 113.33,
      "sid": 44,
      "location": 2,
      "content": "就等同于今天我收你们7000块钱",
      "music": 0.0
    },
    {
      "from": 113.33,
      "to": 114.53,
      "sid": 45,
      "location": 2,
      "content": "让你们来听我的演唱会",
      "music": 0.0
    },
    {
      "from": 117.42,
      "to": 118.36,
      "sid": 46,
      "location": 2,
      "content": "是吧",
      "music": 0.0
    },
    {
      "from": 118.36,
      "to": 122.16,
      "sid": 47,
      "location": 2,
      "content": "而且我还要挂一个商业演讲的幌子",
      "music": 0.0
    },
    {
      "from": 122.16,
      "to": 123.48,
      "sid": 48,
      "location": 2,
      "content": "他现在不就这样吗",
      "music": 0.0
    },
    {
      "from": 123.48,
      "to": 124.56,
      "sid": 49,
      "location": 2,
      "content": "他现在不就这样吗",
      "music": 0.0
    },
    {
      "from": 124.56,
      "to": 126.56,
      "sid": 50,
      "location": 2,
      "content": "他挂一个酒吧的幌子",
      "music": 0.0
    },
    {
      "from": 126.56,
      "to": 128.88,
      "sid": 51,
      "location": 2,
      "content": "然后让别人跑到他这个酒吧里面去",
      "music": 0.0
    },
    {
      "from": 128.88,
      "to": 132.28,
      "sid": 52,
      "location": 2,
      "content": "听他的音乐疗愈睡觉哈哈",
      "music": 0.0
    },
    {
      "from": 132.28,
      "to": 133.8,
      "sid": 53,
      "location": 2,
      "content": "因为音乐疗愈是他的梦",
      "music": 0.0
    },
    {
      "from": 134.84,
      "to": 136.12,
      "sid": 54,
      "location": 2,
      "content": "是他喜欢做的事情",
      "music": 0.0
    },
    {
      "from": 136.12,
      "to": 136.96,
      "sid": 55,
      "location": 2,
      "content": "是他的理想",
      "music": 0.0
    },
    {
      "from": 136.96,
      "to": 138.31,
      "sid": 56,
      "location": 2,
      "content": "是他的梦",
      "music": 0.0
    },
    {
      "from": 138.84,
      "to": 141.6,
      "sid": 57,
      "location": 2,
      "content": "他是不是等同于我今天在这里7000块钱卖票",
      "music": 0.0
    },
    {
      "from": 141.6,
      "to": 142.36,
      "sid": 58,
      "location": 2,
      "content": "然后跟你们讲",
      "music": 0.0
    },
    {
      "from": 142.36,
      "to": 143.12,
      "sid": 59,
      "location": 2,
      "content": "我要做商业",
      "music": 0.0
    },
    {
      "from": 143.12,
      "to": 144.16,
      "sid": 60,
      "location": 2,
      "content": "我要做商业课",
      "music": 0.0
    },
    {
      "from": 144.16,
      "to": 144.96,
      "sid": 61,
      "location": 2,
      "content": "完了以后来了以后",
      "music": 0.0
    },
    {
      "from": 144.96,
      "to": 146.46,
      "sid": 62,
      "location": 2,
      "content": "你们听了我他妈三个小时演唱会",
      "music": 0.0
    },
    {
      "from": 150.74,
      "to": 152.42,
      "sid": 63,
      "location": 2,
      "content": "是同等逻辑",
      "music": 0.0
    },
    {
      "from": 152.42,
      "to": 154.39,
      "sid": 64,
      "location": 2,
      "content": "是不是同等逻辑",
      "music": 0.0
    },
    {
      "from": 154.83,
      "to": 156.11,
      "sid": 65,
      "location": 2,
      "content": "那我真的要出圈了",
