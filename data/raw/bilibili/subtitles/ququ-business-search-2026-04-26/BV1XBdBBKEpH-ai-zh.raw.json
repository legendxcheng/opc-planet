    },
    {
      "from": 249.59,
      "to": 252.61,
      "sid": 99,
      "location": 2,
      "content": "他说你看谢娜开演唱会",
      "music": 0.0
    },
    {
      "from": 257.919,
      "to": 260.559,
      "sid": 100,
      "location": 2,
      "content": "他说你看你看不光是你谢娜",
      "music": 0.0
    },
    {
      "from": 260.559,
      "to": 263.52,
      "sid": 101,
      "location": 2,
      "content": "她是唱坏了哈哈",
      "music": 0.0
    },
    {
      "from": 265.02,
      "to": 266.22,
      "sid": 102,
      "location": 2,
      "content": "太过分了",
      "music": 0.0
    },
    {
      "from": 266.22,
      "to": 269.18,
      "sid": 103,
      "location": 2,
      "content": "就真的就真的很过分",
      "music": 0.0
    },
    {
      "from": 270.51,
      "to": 271.23,
      "sid": 104,
      "location": 2,
      "content": "好不好",
      "music": 0.0
    },
    {
      "from": 271.23,
      "to": 273.63,
      "sid": 105,
      "location": 2,
      "content": "为什么为什么要告诉我这个事情来跟我聊",
