    },
    {
      "from": 179.269,
      "to": 180.989,
      "sid": 77,
      "location": 2,
      "content": "我相信你们愿意花700块钱听",
      "music": 0.0
    },
    {
      "from": 184.16,
      "to": 187.48,
      "sid": 78,
      "location": 2,
      "content": "我相信你们愿意花700块钱听我的演唱会",
      "music": 0.0
    },
    {
      "from": 187.48,
      "to": 188.3,
      "sid": 79,
      "location": 2,
      "content": "好不好",
      "music": 0.0
    },
    {
      "from": 188.3,
      "to": 191.6,
      "sid": 80,
      "location": 2,
      "content": "但是你们要说花7000块钱听我的演唱会",
      "music": 0.0
    },
    {
      "from": 191.6,
      "to": 193.07,
      "sid": 81,
      "location": 2,
      "content": "说真的",
      "music": 0.0
    },
    {
      "from": 194.4,
      "to": 197.08,
      "sid": 82,
      "location": 2,
      "content": "我我不是不相信你们对我的爱",
      "music": 0.0
    },
    {
      "from": 202.06,
      "to": 204.28,
      "sid": 83,
      "location": 2,
      "content": "我不是不相信好不好",
      "music": 0.0
    },
    {
      "from": 204.28,
      "to": 207.56,
      "sid": 84,
      "location": 2,
      "content": "反正就是反正就是我不会干这个事啊",
      "music": 0.0
    },
    {
      "from": 207.56,
      "to": 208.78,
      "sid": 85,
      "location": 2,
      "content": "我不会干这个事的",
      "music": 0.0
    },
    {
      "from": 208.78,
      "to": 212.16,
      "sid": 86,
      "location": 2,
      "content": "你们放你们放心啊",
      "music": 0.0
    },
    {
      "from": 212.16,
      "to": 213.92,
      "sid": 87,
      "location": 2,
      "content": "2000块你可以哈哈哈",
      "music": 0.0
    },
    {
      "from": 213.92,
      "to": 214.92,
      "sid": 88,
      "location": 2,
      "content": "你蛮精准来",
      "music": 0.0
    },
    {
      "from": 214.92,
      "to": 218.1,
      "sid": 89,
      "location": 2,
      "content": "你有零有整的哈哈",
      "music": 0.0
    },
    {
      "from": 218.1,
      "to": 219.18,
      "sid": 90,
      "location": 2,
      "content": "那天把我气死了",
      "music": 0.0
    },
    {
      "from": 219.18,
      "to": 220.4,
      "sid": 91,
      "location": 2,
      "content": "我跟你们讲",
      "music": 0.0
    },
    {
      "from": 221.36,
      "to": 224.0,
      "sid": 92,
      "location": 2,
      "content": "那天不是很多人吐槽",
      "music": 0.0
    },
    {
      "from": 224.0,
      "to": 228.0,
      "sid": 93,
      "location": 2,
      "content": "很多人吐槽说你看曲曲真牛逼是吧",
      "music": 0.0
    },
    {
      "from": 228.0,
      "to": 230.72,
      "sid": 94,
      "location": 2,
      "content": "一硬是拉1000个人在这听他唱歌",
      "music": 0.0
    },
    {
      "from": 234.189,
      "to": 236.81,
      "sid": 95,
      "location": 2,
      "content": "网上网上的人天天说他唱歌不好听",
      "music": 0.0
    },
    {
      "from": 236.81,
      "to": 238.85,
      "sid": 96,
      "location": 2,
      "content": "他硬是凭着自己的一己之力",
      "music": 0.0
    },
    {
      "from": 238.85,
      "to": 241.93,
      "sid": 97,
      "location": 2,
      "content": "凭他的实力拉了1000个人坐底下听他唱歌",
      "music": 0.0
    },
    {
      "from": 244.31,
      "to": 249.59,
      "sid": 98,
      "location": 2,
      "content": "然后然后紧接着第二天我朋友就给我发",
