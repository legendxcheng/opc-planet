  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.68,
      "sid": 1,
      "location": 2,
      "content": "你们听我讲赚钱的东西",
      "music": 0.0
    },
    {
      "from": 1.68,
      "to": 3.0,
      "sid": 2,
      "location": 2,
      "content": "你们就赚大了",
      "music": 0.0
    },
    {
      "from": 3.0,
      "to": 3.7,
      "sid": 3,
      "location": 2,
      "content": "知道吗",
      "music": 0.0
    },
    {
      "from": 3.7,
      "to": 4.96,
      "sid": 4,
      "location": 2,
      "content": "搞男人这个事情",
      "music": 0.0
    },
    {
      "from": 4.96,
      "to": 8.94,
      "sid": 5,
      "location": 2,
      "content": "我觉得其在我身上是属于最不值得一提的特长",
      "music": 0.0
    },
    {
      "from": 12.24,
      "to": 14.24,
      "sid": 6,
      "location": 2,
      "content": "搞男人这个事情在我看来",
      "music": 0.0
    },
    {
      "from": 14.24,
      "to": 15.94,
      "sid": 7,
      "location": 2,
      "content": "在我的这些技能里边",
      "music": 0.0
    },
    {
      "from": 15.94,
      "to": 21.28,
      "sid": 8,
      "location": 2,
      "content": "就是属于最拿不出手的一下哈",
      "music": 0.0
    },
    {
      "from": 21.96,
      "to": 23.7,
      "sid": 9,
      "location": 2,
      "content": "这对于我们来说太基础了",
      "music": 0.0
    },
    {
      "from": 23.7,
      "to": 24.2,
      "sid": 10,
      "location": 2,
      "content": "知道吧",
      "music": 0.0
    },
    {
      "from": 24.2,
      "to": 26.32,
      "sid": 11,
      "location": 2,
      "content": "就是就是太基础了",
      "music": 0.0
    },
    {
      "from": 26.32,
      "to": 27.96,
      "sid": 12,
      "location": 2,
      "content": "太简单了",
      "music": 0.0
    },
    {
      "from": 27.96,
      "to": 30.28,
      "sid": 13,
      "location": 2,
      "content": "你们听我讲搞钱",
      "music": 0.0
    },
    {
      "from": 30.64,
      "to": 32.24,
      "sid": 14,
      "location": 2,
      "content": "我跟你们动的这个脑子",
      "music": 0.0
    },
    {
      "from": 32.24,
      "to": 34.72,
      "sid": 15,
      "location": 2,
      "content": "我帮你们想的这些搞钱的这个思路啊",
      "music": 0.0
    },
    {
      "from": 34.72,
      "to": 37.9,
      "sid": 16,
      "location": 2,
      "content": "是真的很厉害的",
      "music": 0.0
    },
    {
      "from": 37.9,
      "to": 42.3,
      "sid": 17,
      "location": 2,
      "content": "我这个人搞钱的脑子是非常厉害的",
      "music": 0.0
    },
    {
      "from": 43.26,
      "to": 47.34,
      "sid": 18,
      "location": 2,
      "content": "我是一个脑袋非常非常活的一个人",
      "music": 0.0
    },
    {
      "from": 47.34,
      "to": 49.86,
      "sid": 19,
      "location": 2,
      "content": "就在我很多年前我跟你们讲过了的",
      "music": 0.0
    },
    {
      "from": 49.86,
      "to": 51.58,
      "sid": 20,
      "location": 2,
      "content": "在我自己不怎么挣钱的时候",
      "music": 0.0
    },
    {
      "from": 51.58,
      "to": 54.12,
      "sid": 21,
      "location": 2,
      "content": "我给我身边那些身家过亿",
      "music": 0.0
    },
    {
      "from": 54.12,
      "to": 55.62,
      "sid": 22,
      "location": 2,
      "content": "过十个亿的大佬出主意",
      "music": 0.0
    },
    {
      "from": 55.62,
      "to": 56.94,
      "sid": 23,
      "location": 2,
      "content": "我都不带怂的",
      "music": 0.0
    },
    {
      "from": 56.94,
      "to": 58.3,
      "sid": 24,
      "location": 2,
      "content": "我真不骗你们",
      "music": 0.0
    },
    {
      "from": 58.3,
      "to": 59.82,
      "sid": 25,
      "location": 2,
      "content": "就是我以前不怎么挣钱",
      "music": 0.0
    },
    {
      "from": 59.82,
      "to": 61.08,
      "sid": 26,
      "location": 2,
      "content": "我天天还在吃喝玩乐",
      "music": 0.0
    },
    {
      "from": 61.08,
      "to": 62.3,
      "sid": 27,
      "location": 2,
      "content": "我天天就在混圈子",
      "music": 0.0
    },
    {
      "from": 62.3,
      "to": 63.92,
      "sid": 28,
      "location": 2,
      "content": "天天在吃喝玩乐",
      "music": 0.0
    },
    {
      "from": 64.24,
      "to": 66.56,
      "sid": 29,
      "location": 2,
      "content": "我身边那些大佬有事没事的",
      "music": 0.0
    },
    {
      "from": 66.56,
      "to": 67.42,
      "sid": 30,
      "location": 2,
      "content": "他们就跟我探讨",
      "music": 0.0
    },
    {
      "from": 67.42,
      "to": 69.52,
      "sid": 31,
      "location": 2,
      "content": "其实这个事你怎么看",
      "music": 0.0
    },
    {
      "from": 69.52,
      "to": 72.78,
      "sid": 32,
      "location": 2,
      "content": "我那个时候没有意识到我有这样的商业价值",
      "music": 0.0
    },
    {
      "from": 72.78,
      "to": 75.32,
      "sid": 33,
      "location": 2,
      "content": "要不然我不得找他们要点股份",
      "music": 0.0
    },
    {
      "from": 75.78,
      "to": 77.3,
      "sid": 34,
      "location": 2,
      "content": "我不知道我有这样的商业价值",
      "music": 0.0
    },
    {
      "from": 77.3,
      "to": 78.7,
      "sid": 35,
      "location": 2,
      "content": "我那个时候就觉得我叫童言无忌",
      "music": 0.0
    },
    {
      "from": 80.64,
      "to": 82.24,
      "sid": 36,
      "location": 2,
      "content": "叫初生牛犊不怕虎",
      "music": 0.0
    },
    {
      "from": 82.24,
      "to": 83.46,
      "sid": 37,
      "location": 2,
      "content": "知道吧",
      "music": 0.0
    },
    {
      "from": 84.51,
      "to": 87.199,
      "sid": 38,
      "location": 2,
      "content": "但我确实是一个脑子非常活的一个人",
      "music": 0.0
    },
    {
      "from": 87.199,
      "to": 91.119,
      "sid": 39,
      "location": 2,
      "content": "而且我也拿我自己这么多年的人生经验",
      "music": 0.0
    },
    {
      "from": 91.119,
      "to": 91.639,
      "sid": 40,
      "location": 2,
      "content": "告诉你们",
      "music": 0.0
    },
    {
      "from": 91.639,
      "to": 93.93,
      "sid": 41,
      "location": 2,
      "content": "赚钱靠的就是想象力",
      "music": 0.0
    },
    {
      "from": 93.93,
      "to": 97.529,
      "sid": 42,
      "location": 2,
      "content": "只要你敢想这个事他就能干",
      "music": 0.0
    },
    {
      "from": 98.809,
      "to": 101.069,
      "sid": 43,
      "location": 2,
      "content": "但是呢最重要的一个点在于",
      "music": 0.0
    },
    {
      "from": 101.069,
      "to": 103.969,
      "sid": 44,
      "location": 2,
      "content": "你不能够先想着投钱",
      "music": 0.0
    },
    {
      "from": 105.01,
      "to": 106.07,
      "sid": 45,
      "location": 2,
      "content": "明白吗",
      "music": 0.0
    },
    {
      "from": 106.07,
      "to": 108.51,
      "sid": 46,
      "location": 2,
      "content": "很多人之所以赚钱赚不明白",
      "music": 0.0
    },
    {
      "from": 108.51,
      "to": 111.11,
      "sid": 47,
      "location": 2,
      "content": "是因为你老是想先投钱",
      "music": 0.0
    },
    {
      "from": 111.51,
      "to": 112.51,
      "sid": 48,
      "location": 2,
      "content": "先投钱",
      "music": 0.0
    },
    {
      "from": 112.51,
      "to": 116.47,
      "sid": 49,
      "location": 2,
      "content": "就是你没有把其他的脑子给他冻透",
      "music": 0.0
    },
    {
      "from": 117.4,
      "to": 120.48,
      "sid": 50,
      "location": 2,
      "content": "一定是把所有你能动脑子都冻透了",
      "music": 0.0
    },
    {
      "from": 120.48,
      "to": 123.08,
      "sid": 51,
      "location": 2,
      "content": "钱是最后动的这一步",
      "music": 0.0
    },
    {
      "from": 124.28,
      "to": 126.94,
      "sid": 52,
      "location": 2,
      "content": "你什么都还没想上来就先投钱",
      "music": 0.0
    },
    {
      "from": 126.94,
      "to": 128.92,
      "sid": 53,
      "location": 2,
      "content": "这就是你脑子没动明白的表现",
      "music": 0.0
    },
    {
      "from": 129.96,
      "to": 131.47,
      "sid": 54,
      "location": 2,
      "content": "你脑子还没开机",
      "music": 0.0
    },
    {
      "from": 131.47,
      "to": 132.55,
      "sid": 55,
      "location": 2,
      "content": "懂不懂啊",
      "music": 0.0
    },
    {
      "from": 132.55,
      "to": 134.23,
      "sid": 56,
      "location": 2,
      "content": "你脑子要是开机了的话",
      "music": 0.0
    },
    {
      "from": 134.23,
      "to": 136.91,
      "sid": 57,
      "location": 2,
      "content": "他一定是在前之前有123456789十",
      "music": 0.0
    },
    {
      "from": 136.91,
      "to": 138.89,
      "sid": 58,
      "location": 2,
      "content": "有十个点已经都出来了",
      "music": 0.0
    },
    {
      "from": 138.89,
      "to": 142.229,
      "sid": 59,
      "location": 2,
      "content": "然后最后你为了去做放大财动钱",
      "music": 0.0
    },
    {
      "from": 144.749,
      "to": 146.73,
      "sid": 60,
      "location": 2,
      "content": "是不是不要",
      "music": 0.0
    },
    {
      "from": 146.73,
      "to": 147.81,
      "sid": 61,
      "location": 2,
      "content": "因为很多人呢",
      "music": 0.0
    },
    {
      "from": 147.81,
      "to": 150.85,
      "sid": 62,
      "location": 2,
      "content": "你们只能看到市场上别人是怎么在干",
      "music": 0.0
    },
    {
      "from": 150.85,
      "to": 153.47,
      "sid": 63,
      "location": 2,
      "content": "所以呢你就觉得我只能像他这么干",
      "music": 0.0
    },
    {
      "from": 153.47,
      "to": 154.85,
      "sid": 64,
      "location": 2,
      "content": "就好像他说的哎呀",
      "music": 0.0
    },
    {
      "from": 154.85,
      "to": 157.079,
      "sid": 65,
      "location": 2,
      "content": "其实我的设计能力也不是很很细",
      "music": 0.0
    },
    {
      "from": 157.079,
      "to": 159.079,
      "sid": 66,
      "location": 2,
      "content": "我的设计能力也不是很强对吧",
      "music": 0.0
    },
    {
      "from": 159.079,
      "to": 160.919,
      "sid": 67,
      "location": 2,
      "content": "所以我觉得我独立去接案子的话呢",
      "music": 0.0
    },
    {
      "from": 160.919,
      "to": 162.499,
      "sid": 68,
      "location": 2,
      "content": "我自己也觉得我有点怯",
      "music": 0.0
    },
    {
      "from": 162.499,
      "to": 164.8,
      "sid": 69,
      "location": 2,
      "content": "我可能接接客户也接不着",
      "music": 0.0
    },
    {
      "from": 165.12,
      "to": 166.42,
      "sid": 70,
      "location": 2,
      "content": "可是你想想看",
      "music": 0.0
    },
    {
      "from": 166.42,
      "to": 169.53,
      "sid": 71,
      "location": 2,
      "content": "你比平民老百姓总归是强的",
      "music": 0.0
    },
    {
      "from": 170.01,
      "to": 173.11,
      "sid": 72,
      "location": 2,
      "content": "你不跟人家那些设计师比对吧",
      "music": 0.0
    },
    {
      "from": 173.11,
      "to": 176.079,
      "sid": 73,
      "location": 2,
      "content": "你可以在夹缝当中求生存",
      "music": 0.0
    },
    {
      "from": 176.079,
      "to": 177.999,
      "sid": 74,
      "location": 2,
      "content": "是不是在夹缝当中求生存",
      "music": 0.0
    },
    {
      "from": 177.999,
      "to": 178.719,
      "sid": 75,
      "location": 2,
      "content": "我跟你们讲",
      "music": 0.0
    },
    {
      "from": 178.719,
      "to": 180.379,
      "sid": 76,
      "location": 2,
      "content": "我原来刚开始做这个事的时候",
      "music": 0.0
    },
    {
      "from": 180.379,
      "to": 183.2,
      "sid": 77,
      "location": 2,
      "content": "就是因为我看到了一个市场空白点",
      "music": 0.0
    },
    {
      "from": 183.44,
      "to": 184.78,
      "sid": 78,
      "location": 2,
      "content": "我那个时候发现啊",
      "music": 0.0
    },
    {
      "from": 184.78,
      "to": 187.0,
      "sid": 79,
      "location": 2,
      "content": "做情感这个市场的只有两类人",
      "music": 0.0
    },
    {
      "from": 187.0,
      "to": 189.89,
      "sid": 80,
      "location": 2,
      "content": "一类呢叫骗子哈",
      "music": 0.0
    },
    {
      "from": 190.045,
      "to": 193.45,
      "sid": 81,
      "location": 2,
      "content": "就是自己也没什么学历",
      "music": 0.0
    },
    {
      "from": 193.89,
      "to": 195.37,
      "sid": 82,
      "location": 2,
      "content": "特别下沉",
      "music": 0.0
    },
    {
      "from": 195.37,
      "to": 197.79,
      "sid": 83,
      "location": 2,
      "content": "然后呢上来就教挽回",
      "music": 0.0
    },
    {
      "from": 197.79,
      "to": 199.63,
      "sid": 84,
      "location": 2,
      "content": "这个是一大类",
      "music": 0.0
    },
    {
      "from": 199.63,
      "to": 201.67,
      "sid": 85,
      "location": 2,
      "content": "就当年占领情感市场的一大类",
      "music": 0.0
    },
    {
      "from": 201.67,
      "to": 203.95,
      "sid": 86,
      "location": 2,
      "content": "就是我在进这个赛道的那个时候",
      "music": 0.0
    },
    {
      "from": 203.95,
      "to": 205.75,
      "sid": 87,
      "location": 2,
      "content": "一大类是骗子",
      "music": 0.0
    },
    {
      "from": 206.359,
      "to": 208.55,
      "sid": 88,
      "location": 2,
      "content": "主要以搞挽回为主",
      "music": 0.0
    },
    {
      "from": 208.55,
      "to": 210.31,
      "sid": 89,
      "location": 2,
      "content": "自己连书都没读过几天的",
      "music": 0.0
    },
    {
      "from": 210.31,
      "to": 214.43,
      "sid": 90,
      "location": 2,
      "content": "上来就教你挽回职业职业的那种P某A啊",
      "music": 0.0
    },
    {
      "from": 214.43,
      "to": 216.12,
      "sid": 91,
      "location": 2,
      "content": "或者是职业挽回这样的",
      "music": 0.0
    },
    {
      "from": 216.12,
      "to": 219.78,
      "sid": 92,
      "location": 2,
      "content": "还有一卦呢就叫专家",
      "music": 0.0
    },
    {
      "from": 220.14,
      "to": 223.62,
      "sid": 93,
      "location": 2,
      "content": "这个专家呀就是搞心理学的这个流派",
      "music": 0.0
    },
    {
      "from": 223.62,
      "to": 226.46,
      "sid": 94,
      "location": 2,
      "content": "心理医生这个流派是吧",
      "music": 0.0
    },
    {
      "from": 226.46,
      "to": 228.98,
      "sid": 95,
      "location": 2,
      "content": "然后他们这帮子人呢就是读的书",
      "music": 0.0
    },
    {
      "from": 228.98,
      "to": 231.66,
      "sid": 96,
      "location": 2,
      "content": "很多实操的案例很少",
      "music": 0.0
    },
    {
      "from": 232.39,
      "to": 234.83,
      "sid": 97,
      "location": 2,
      "content": "我就当初我就是看见了这个市场",
      "music": 0.0
    },
    {
      "from": 234.83,
      "to": 239.43,
      "sid": 98,
      "location": 2,
      "content": "在这样的一个两两极分布的这个关系当中",
      "music": 0.0
    },
    {
      "from": 239.79,
      "to": 242.31,
      "sid": 99,
      "location": 2,
      "content": "所以我找到了我的站位",
      "music": 0.0
    },
    {
      "from": 243.04,
      "to": 247.05,
      "sid": 100,
      "location": 2,
      "content": "我的站位就是一个读了书的",
      "music": 0.0
    },
    {
      "from": 247.21,
      "to": 250.41,
      "sid": 101,
      "location": 2,
      "content": "然后呢很多实操的这么一个人",
      "music": 0.0
    },
    {
      "from": 250.41,
      "to": 251.33,
      "sid": 102,
      "location": 2,
      "content": "又读了书",
      "music": 0.0
    },
    {
      "from": 251.33,
      "to": 253.579,
      "sid": 103,
      "location": 2,
      "content": "又很多实操的这么一个人",
      "music": 0.0
    },
    {
      "from": 253.579,
      "to": 254.899,
      "sid": 104,
      "location": 2,
      "content": "这就是我的站位啊",
      "music": 0.0
    },
    {
      "from": 254.899,
      "to": 258.099,
      "sid": 105,
      "location": 2,
      "content": "你找到了一个市场的空白的一个点位",
      "music": 0.0
    },
    {
      "from": 258.099,
      "to": 261.059,
      "sid": 106,
      "location": 2,
      "content": "其实市场啊永远都有很多很多很多小的空白点",
      "music": 0.0
    },
    {
      "from": 261.059,
      "to": 262.43,
      "sid": 107,
      "location": 2,
      "content": "很多很多小的空白点",
      "music": 0.0
    },
    {
      "from": 262.43,
      "to": 265.35,
      "sid": 108,
      "location": 2,
      "content": "关键是在于你能不能找到一个",
      "music": 0.0
    },
    {
      "from": 265.35,
      "to": 268.02,
