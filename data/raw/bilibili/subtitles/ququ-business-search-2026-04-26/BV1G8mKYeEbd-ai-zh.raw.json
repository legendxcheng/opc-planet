    },
    {
      "from": 73.72,
      "to": 77.46,
      "sid": 33,
      "location": 2,
      "content": "所以他才会萌生这种想要换这种肩膀型",
      "music": 0.0
    },
    {
      "from": 77.46,
      "to": 80.38,
      "sid": 34,
      "location": 2,
      "content": "依靠型或者是共同进步型的这种男人的",
      "music": 0.0
    },
    {
      "from": 80.38,
      "to": 82.18,
      "sid": 35,
      "location": 2,
      "content": "从我现在的维度上来说啊",
      "music": 0.0
    },
    {
      "from": 82.18,
      "to": 87.81,
      "sid": 36,
      "location": 2,
      "content": "我不仅仅不想让一个男人跟我共同的去搞事业",
