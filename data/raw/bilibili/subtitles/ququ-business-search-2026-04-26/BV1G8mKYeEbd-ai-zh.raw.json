  "body": [
    {
      "from": 0.28,
      "to": 3.72,
      "sid": 1,
      "location": 2,
      "content": "我刚才刷到一个大网红叫张林超啊",
      "music": 0.0
    },
    {
      "from": 3.72,
      "to": 5.24,
      "sid": 2,
      "location": 2,
      "content": "我不知道你们认不认识",
      "music": 0.0
    },
    {
      "from": 5.24,
      "to": 6.0,
      "sid": 3,
      "location": 2,
      "content": "然后呢",
      "music": 0.0
    },
    {
      "from": 6.0,
      "to": 10.22,
      "sid": 4,
      "location": 2,
      "content": "她就说她跟她的相恋7年的男朋友分手了",
      "music": 0.0
    },
    {
      "from": 10.22,
      "to": 12.94,
      "sid": 5,
      "location": 2,
      "content": "然后我就看她在直播的时候就哭了",
      "music": 0.0
    },
    {
      "from": 12.94,
      "to": 15.5,
      "sid": 6,
      "location": 2,
      "content": "好像就是呃虽然说也很不舍",
      "music": 0.0
    },
    {
      "from": 15.5,
      "to": 18.04,
      "sid": 7,
      "location": 2,
      "content": "但是她觉得她的男朋友",
      "music": 0.0
    },
    {
      "from": 18.04,
      "to": 19.92,
      "sid": 8,
      "location": 2,
      "content": "现在已经不是她想要的那种人了",
      "music": 0.0
    },
    {
      "from": 19.92,
      "to": 22.76,
      "sid": 9,
      "location": 2,
      "content": "她就说她不想要一个享受型的男人",
      "music": 0.0
    },
    {
      "from": 22.76,
      "to": 24.49,
      "sid": 10,
      "location": 2,
      "content": "她想要一个嗯",
      "music": 0.0
    },
    {
      "from": 24.49,
      "to": 27.77,
      "sid": 11,
      "location": 2,
      "content": "能够跟她共同去打拼一番事业的男人",
      "music": 0.0
    },
    {
      "from": 27.77,
      "to": 31.01,
      "sid": 12,
      "location": 2,
      "content": "她想要一个人能够跟他去分担他的事业压力",
      "music": 0.0
    },
    {
      "from": 31.01,
      "to": 33.83,
      "sid": 13,
      "location": 2,
      "content": "然后大家有百分之1万的上进心嗯",
      "music": 0.0
    },
    {
      "from": 33.83,
      "to": 37.48,
      "sid": 14,
      "location": 2,
      "content": "共同去为公司创造一片未来的这样的人",
      "music": 0.0
    },
    {
      "from": 37.48,
      "to": 39.24,
      "sid": 15,
      "location": 2,
      "content": "然后我看到他说的这番话",
      "music": 0.0
    },
    {
      "from": 39.24,
      "to": 41.33,
      "sid": 16,
      "location": 2,
      "content": "我我特别特别的有感触",
      "music": 0.0
    },
    {
      "from": 41.33,
      "to": 42.21,
      "sid": 17,
      "location": 2,
      "content": "什么感触呢",
      "music": 0.0
    },
    {
      "from": 42.21,
      "to": 44.15,
      "sid": 18,
      "location": 2,
      "content": "就是我能够通过他这番话",
      "music": 0.0
    },
    {
      "from": 44.15,
      "to": 44.81,
      "sid": 19,
      "location": 2,
      "content": "感受到",
      "music": 0.0
    },
    {
      "from": 44.81,
      "to": 46.85,
      "sid": 20,
      "location": 2,
      "content": "他最近的业务上",
      "music": 0.0
    },
    {
      "from": 46.85,
      "to": 49.7,
      "sid": 21,
      "location": 2,
      "content": "肯定是出现了比较大的状况跟问题",
      "music": 0.0
    },
    {
      "from": 49.7,
      "to": 52.9,
      "sid": 22,
      "location": 2,
      "content": "所以他为什么可以跟一个享受型的男人",
      "music": 0.0
    },
    {
      "from": 52.9,
      "to": 53.92,
      "sid": 23,
      "location": 2,
      "content": "在一起7年",
      "music": 0.0
    },
    {
      "from": 53.92,
      "to": 57.6,
      "sid": 24,
      "location": 2,
      "content": "但是现在却突然之间180度大转变",
      "music": 0.0
    },
    {
      "from": 57.6,
      "to": 59.32,
      "sid": 25,
      "location": 2,
      "content": "觉得享受型的男人不适合自己了",
      "music": 0.0
    },
    {
      "from": 59.32,
      "to": 61.36,
      "sid": 26,
      "location": 2,
      "content": "要找一个共同事共同奋斗",
      "music": 0.0
    },
    {
      "from": 61.36,
      "to": 62.52,
      "sid": 27,
      "location": 2,
      "content": "事业解决问题的人呢",
      "music": 0.0
    },
    {
      "from": 62.52,
      "to": 64.45,
      "sid": 28,
      "location": 2,
      "content": "那一定是因为他现在遇到了问题",
      "music": 0.0
    },
    {
      "from": 64.45,
      "to": 65.05,
      "sid": 29,
      "location": 2,
      "content": "而且呢",
      "music": 0.0
    },
    {
      "from": 65.05,
      "to": 68.56,
      "sid": 30,
      "location": 2,
      "content": "他觉得自己在解决问题的过程当中很艰难",
      "music": 0.0
    },
    {
      "from": 68.56,
      "to": 70.68,
      "sid": 31,
      "location": 2,
      "content": "所以说她突然意识到说哎呀",
