{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.18,
      "to": 1.9,
      "sid": 1,
      "location": 2,
      "content": "造车技术我是不懂",
      "music": 0.0
    },
    {
      "from": 1.9,
      "to": 5.12,
      "sid": 2,
      "location": 2,
      "content": "但是如果电池向下喷火的话",
      "music": 0.0
    },
    {
      "from": 5.12,
      "to": 8.24,
      "sid": 3,
      "location": 2,
      "content": "小助理你来演示一下",
      "music": 0.0
    },
    {
      "from": 8.24,
      "to": 10.88,
      "sid": 4,
      "location": 2,
      "content": "这烧的不还是我自己吗",
      "music": 0.0
    },
    {
      "from": 10.88,
      "to": 12.82,
      "sid": 5,
      "location": 2,
      "content": "这哪个汽车底盘着火",
      "music": 0.0
    },
    {
      "from": 12.82,
      "to": 14.04,
      "sid": 6,
      "location": 2,
      "content": "火不是向下喷",
      "music": 0.0
    },
    {
      "from": 14.04,
      "to": 15.72,
      "sid": 7,
      "location": 2,
      "content": "往上烧",
      "music": 0.0
    },
    {
      "from": 35.76,
      "to": 40.04,
      "sid": 8,
      "location": 2,
      "content": "嗯火它燃烧的时候它会往上",
      "music": 0.0
    },
    {
      "from": 40.04,
      "to": 41.64,
      "sid": 9,
      "location": 2,
      "content": "这个大家都知道",
      "music": 0.0
    },
    {
      "from": 41.64,
      "to": 43.72,
      "sid": 10,
      "location": 2,
      "content": "但是呢为什么叫泄压阀呢",
      "music": 0.0
    },
    {
      "from": 43.72,
      "to": 46.03,
      "sid": 11,
      "location": 2,
      "content": "因为新能源车的电池",
      "music": 0.0
    },
    {
      "from": 46.03,
      "to": 48.99,
      "sid": 12,
      "location": 2,
      "content": "它燃烧的时候会产生很多很多的气体",
      "music": 0.0
    },
    {
      "from": 48.99,
      "to": 51.93,
      "sid": 13,
      "location": 2,
      "content": "这些气体会产生很大的压力",
      "music": 0.0
    },
    {
      "from": 52.25,
      "to": 55.01,
      "sid": 14,
      "location": 2,
      "content": "所以他这个火焰它是喷射的",
      "music": 0.0
    },
    {
      "from": 55.01,
      "to": 55.45,
      "sid": 15,
      "location": 2,
      "content": "你知道吗",
      "music": 0.0
    },
    {
      "from": 55.45,
      "to": 59.25,
      "sid": 16,
      "location": 2,
      "content": "他不是像打火机那样就拐个弯就往上了",
      "music": 0.0
    },
    {
      "from": 59.25,
      "to": 61.485,
      "sid": 17,
      "location": 2,
      "content": "他一定是往下喷射的",
      "music": 0.0
    },
    {
      "from": 61.82,
      "to": 64.24,
      "sid": 18,
      "location": 2,
      "content": "前几天有一辆小米苏七标准版",
      "music": 0.0
    },
    {
      "from": 64.24,
      "to": 66.37,
      "sid": 19,
      "location": 2,
      "content": "发生了严重的底盘磕碰",
      "music": 0.0
    },
    {
      "from": 66.37,
      "to": 69.17,
      "sid": 20,
      "location": 2,
      "content": "紧接着呢就是电池包起火了嘛",
      "music": 0.0
    },
    {
      "from": 70.17,
      "to": 71.45,
      "sid": 21,
      "location": 2,
      "content": "但是万万没想到的是",
      "music": 0.0
    },
    {
      "from": 71.45,
      "to": 74.26,
      "sid": 22,
      "location": 2,
      "content": "这个火竟然自己熄灭了啊",
      "music": 0.0
    },
    {
      "from": 74.26,
      "to": 77.5,
      "sid": 23,
      "location": 2,
      "content": "这个事好像是业界首次",
      "music": 0.0
    },
    {
      "from": 77.5,
      "to": 79.22,
      "sid": 24,
      "location": 2,
      "content": "就是电池包起火",
      "music": 0.0
    },
    {
      "from": 79.22,
      "to": 81.82,
      "sid": 25,
      "location": 2,
      "content": "没有把整个车烧掉的这个情况",
      "music": 0.0
    },
    {
      "from": 83.71,
      "to": 89.25,
      "sid": 26,
      "location": 2,
      "content": "而且小米它采用的是这个比亚迪福迪刀片电池",
      "music": 0.0
    },
    {
      "from": 89.25,
      "to": 93.11,
      "sid": 27,
      "location": 2,
      "content": "我们没有在比亚迪的车上看到这种事发生",
      "music": 0.0
    },
    {
      "from": 93.11,
      "to": 95.67,
      "sid": 28,
      "location": 2,
      "content": "反而在小米这辆车上看到了",
      "music": 0.0
    },
    {
      "from": 95.67,
      "to": 96.95,
      "sid": 29,
      "location": 2,
      "content": "说明呃",
      "music": 0.0
    },
    {
      "from": 96.95,
      "to": 99.57,
      "sid": 30,
      "location": 2,
      "content": "小米的设计就是显阀倒置啊",
      "music": 0.0
    },
    {
      "from": 100.65,
      "to": 103.43,
      "sid": 31,
      "location": 2,
      "content": "这些东西还是非常有意义的",
      "music": 0.0
    },
    {
      "from": 103.43,
      "to": 107.41,
      "sid": 32,
      "location": 2,
      "content": "也正好这个事件呢就给那些说比亚呃",
      "music": 0.0
    },
    {
      "from": 107.41,
      "to": 109.16,
      "sid": 33,
      "location": 2,
      "content": "小米被骗了啊",
      "music": 0.0
    },
    {
      "from": 109.16,
      "to": 110.08,
      "sid": 34,
      "location": 2,
      "content": "雷军被骗了",
      "music": 0.0
    },
    {
      "from": 110.08,
      "to": 111.18,
      "sid": 35,
      "location": 2,
      "content": "这个设计没有用",
      "music": 0.0
    },
    {
      "from": 111.18,
      "to": 113.04,
      "sid": 36,
      "location": 2,
      "content": "这个火还是要往上烧的",
      "music": 0.0
    },
    {
      "from": 113.04,
      "to": 116.009,
      "sid": 37,
      "location": 2,
      "content": "这些人狠狠的打脸一次",
      "music": 0.0
    },
    {
      "from": 116.009,
      "to": 117.929,
      "sid": 38,
      "location": 2,
      "content": "那至于刚开始那个视频",
      "music": 0.0
    },
    {
      "from": 117.929,
      "to": 121.64,
      "sid": 39,
      "location": 2,
      "content": "那我建议呢你就不要再收车了啊",
      "music": 0.0
    },
    {
      "from": 121.64,
      "to": 122.68,
      "sid": 40,
      "location": 2,
      "content": "毕竟你也说了",
      "music": 0.0
    },
    {
      "from": 122.68,
      "to": 123.36,
      "sid": 41,
      "location": 2,
      "content": "你不懂车嘛",
      "music": 0.0
    },
    {
      "from": 123.36,
      "to": 124.04,
      "sid": 42,
      "location": 2,
      "content": "你不懂车",
      "music": 0.0
    },
    {
      "from": 124.04,
      "to": 126.44,
      "sid": 43,
      "location": 2,
      "content": "你干嘛给自己找这么大的麻烦呢",
      "music": 0.0
    },
    {
      "from": 126.44,
      "to": 127.06,
      "sid": 44,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 127.06,
      "to": 128.3,
      "sid": 45,
      "location": 2,
      "content": "不如你先去",
      "music": 0.0
    },
    {
      "from": 128.3,
      "to": 130.22,
      "sid": 46,
      "location": 2,
      "content": "我觉得可以先去测一测打火机",
      "music": 0.0
    },
    {
      "from": 130.22,
      "to": 132.39,
      "sid": 47,
      "location": 2,
      "content": "各种各样的打火机哎",
      "music": 0.0
    },
    {
      "from": 132.39,
      "to": 134.83,
      "sid": 48,
      "location": 2,
      "content": "先把自己的这个知识啊",
      "music": 0.0
    },
    {
      "from": 134.83,
      "to": 136.67,
      "sid": 49,
      "location": 2,
      "content": "常识补充一下",
      "music": 0.0
    },
    {
      "from": 136.67,
      "to": 140.23,
      "sid": 50,
      "location": 2,
      "content": "这样也不至于以后净出这种丢脸的事",
      "music": 0.0
    },
    {
      "from": 140.23,
      "to": 141.36,
      "sid": 51,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 141.36,
      "to": 141.88,
      "sid": 52,
      "location": 2,
      "content": "呃",
      "music": 0.0
    },
    {
      "from": 141.88,
      "to": 144.94,
      "sid": 53,
      "location": 2,
      "content": "如果大家听说了某种速器的留言",
      "music": 0.0
    },
    {
      "from": 144.94,
      "to": 148.92,
      "sid": 54,
      "location": 2,
      "content": "也可以在我的视频评论区下留言告诉我",
      "music": 0.0
    },
    {
      "from": 148.92,
      "to": 150.32,
      "sid": 55,
      "location": 2,
      "content": "那就这样拜拜",
      "music": 0.0
    }
  ]
}