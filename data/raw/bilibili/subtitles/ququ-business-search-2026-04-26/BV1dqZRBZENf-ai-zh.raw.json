    },
    {
      "from": 37.4,
      "to": 38.56,
      "sid": 16,
      "location": 2,
      "content": "用餐结束后",
      "music": 0.0
    },
    {
      "from": 38.56,
      "to": 41.08,
      "sid": 17,
      "location": 2,
      "content": "我们会根据以下规则进行猜价",
      "music": 0.0
    },
    {
      "from": 41.08,
      "to": 43.6,
      "sid": 18,
      "location": 2,
      "content": "环节误差过大或足够准确",
      "music": 0.0
    },
    {
      "from": 43.6,
      "to": 46.38,
      "sid": 19,
      "location": 2,
      "content": "我们都将可能支付对方双倍价格",
      "music": 0.0
    },
    {
      "from": 46.38,
      "to": 48.44,
      "sid": 20,
      "location": 2,
      "content": "究竟是他亏还是我赚",
      "music": 0.0
    },
    {
      "from": 48.44,
      "to": 50.84,
      "sid": 21,
      "location": 2,
      "content": "让我们拭目以待吧",
      "music": 0.0
    },
    {
