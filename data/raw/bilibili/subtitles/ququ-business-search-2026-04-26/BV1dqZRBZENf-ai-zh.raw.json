    },
    {
      "from": 14.36,
      "to": 14.94,
      "sid": 8,
      "location": 2,
      "content": "对",
      "music": 0.0
    },
    {
      "from": 14.94,
      "to": 17.4,
      "sid": 9,
      "location": 2,
      "content": "据说来北京玩儿的这个福建人",
      "music": 0.0
    },
    {
      "from": 17.4,
      "to": 19.68,
      "sid": 10,
      "location": 2,
      "content": "都觉得那儿特别正嗯",
