{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 3.2,
      "sid": 1,
      "location": 2,
      "content": "就是为啥他们给我的感觉就是他们不服我",
      "music": 0.0
    },
    {
      "from": 3.2,
      "to": 4.56,
      "sid": 2,
      "location": 2,
      "content": "因为你的理由给的不足",
      "music": 0.0
    },
    {
      "from": 4.56,
      "to": 6.0,
      "sid": 3,
      "location": 2,
      "content": "就刚刚你跟这个人的对话",
      "music": 0.0
    },
    {
      "from": 6.0,
      "to": 6.64,
      "sid": 4,
      "location": 2,
      "content": "拿这个对话来说",
      "music": 0.0
    },
    {
      "from": 6.64,
      "to": 7.84,
      "sid": 5,
      "location": 2,
      "content": "那么如果你要让",
      "music": 0.0
    },
    {
      "from": 9.12,
      "to": 10.28,
      "sid": 6,
      "location": 2,
      "content": "那就说他这个东西是不好的",
      "music": 0.0
    },
    {
      "from": 10.28,
      "to": 11.58,
      "sid": 7,
      "location": 2,
      "content": "然后你要你说你怎么",
      "music": 0.0
    },
    {
      "from": 11.58,
      "to": 12.72,
      "sid": 8,
      "location": 2,
      "content": "然后你的每一句话都是反问",
      "music": 0.0
    },
    {
      "from": 12.72,
      "to": 13.6,
      "sid": 9,
      "location": 2,
      "content": "就我们是顺向表达",
      "music": 0.0
    },
    {
      "from": 13.6,
      "to": 14.28,
      "sid": 10,
      "location": 2,
      "content": "你是没有做到的",
      "music": 0.0
    },
    {
      "from": 14.28,
      "to": 15.91,
      "sid": 11,
      "location": 2,
      "content": "你说怎么都是不好的",
      "music": 0.0
    },
    {
      "from": 15.91,
      "to": 16.75,
      "sid": 12,
      "location": 2,
      "content": "我们就没有好的吗",
      "music": 0.0
    },
    {
      "from": 16.75,
      "to": 18.67,
      "sid": 13,
      "location": 2,
      "content": "这是不是就反问对我为什么要反问呢",
      "music": 0.0
    },
    {
      "from": 18.67,
      "to": 19.31,
      "sid": 14,
      "location": 2,
      "content": "就反问的时候",
      "music": 0.0
    },
    {
      "from": 19.31,
      "to": 20.59,
      "sid": 15,
      "location": 2,
      "content": "你的态度就已经是呛了",
      "music": 0.0
    },
    {
      "from": 20.59,
      "to": 23.81,
      "sid": 16,
      "location": 2,
      "content": "但这个事情他们两个嗯就是我觉得为什么",
      "music": 0.0
    },
    {
      "from": 23.81,
      "to": 24.33,
      "sid": 17,
      "location": 2,
      "content": "首先我要告诉你",
      "music": 0.0
    },
    {
      "from": 24.33,
      "to": 24.81,
      "sid": 18,
      "location": 2,
      "content": "为什么",
      "music": 0.0
    },
    {
      "from": 24.81,
      "to": 27.05,
      "sid": 19,
      "location": 2,
      "content": "你看你是不是应该在前面先写点好话",
      "music": 0.0
    },
    {
      "from": 27.05,
      "to": 28.61,
      "sid": 20,
      "location": 2,
      "content": "因为我们要怎么怎么样",
      "music": 0.0
    },
    {
      "from": 28.61,
      "to": 29.37,
      "sid": 21,
      "location": 2,
      "content": "我要给人们看",
      "music": 0.0
    },
    {
      "from": 29.37,
      "to": 31.17,
      "sid": 22,
      "location": 2,
      "content": "你得让别人知道我们是做了很多好的成绩的人",
      "music": 0.0
    },
    {
      "from": 31.17,
      "to": 33.22,
      "sid": 23,
      "location": 2,
      "content": "然后再来后面再来提问题",
      "music": 0.0
    },
    {
      "from": 33.22,
      "to": 34.64,
      "sid": 24,
      "location": 2,
      "content": "因为这是我们团队的荣誉",
      "music": 0.0
    },
    {
      "from": 34.64,
      "to": 36.12,
      "sid": 25,
      "location": 2,
      "content": "让他知道逻辑",
      "music": 0.0
    },
    {
      "from": 36.12,
      "to": 37.08,
      "sid": 26,
      "location": 2,
      "content": "他不知道逻辑",
      "music": 0.0
    },
    {
      "from": 37.08,
      "to": 37.96,
      "sid": 27,
      "location": 2,
      "content": "你上来先劈天盖",
      "music": 0.0
    },
    {
      "from": 37.96,
      "to": 38.94,
      "sid": 28,
      "location": 2,
      "content": "劈天盖脸的意思",
      "music": 0.0
    },
    {
      "from": 38.94,
      "to": 41.04,
      "sid": 29,
      "location": 2,
      "content": "然后就是马逆云对起来了",
      "music": 0.0
    },
    {
      "from": 41.04,
      "to": 41.58,
      "sid": 30,
      "location": 2,
      "content": "对对",
      "music": 0.0
    },
    {
      "from": 41.58,
      "to": 42.44,
      "sid": 31,
      "location": 2,
      "content": "这就是所",
      "music": 0.0
    },
    {
      "from": 42.44,
      "to": 42.88,
      "sid": 32,
      "location": 2,
      "content": "就是我说",
      "music": 0.0
    },
    {
      "from": 42.88,
      "to": 44.72,
      "sid": 33,
      "location": 2,
      "content": "95%以上的人都不会正向表达",
      "music": 0.0
    },
    {
      "from": 44.72,
      "to": 46.2,
      "sid": 34,
      "location": 2,
      "content": "还有你为什么这样呢",
      "music": 0.0
    },
    {
      "from": 46.2,
      "to": 47.26,
      "sid": 35,
      "location": 2,
      "content": "对其实没有必要",
      "music": 0.0
    },
    {
      "from": 47.26,
      "to": 48.84,
      "sid": 36,
      "location": 2,
      "content": "你跟他去置这个气干什么呢",
      "music": 0.0
    },
    {
      "from": 48.84,
      "to": 50.9,
      "sid": 37,
      "location": 2,
      "content": "哈哈你不就是为了把事干明白吗",
      "music": 0.0
    },
    {
      "from": 50.9,
      "to": 51.94,
      "sid": 38,
      "location": 2,
      "content": "不就是为了把事儿干好",
      "music": 0.0
    },
    {
      "from": 51.94,
      "to": 53.66,
      "sid": 39,
      "location": 2,
      "content": "如果你们的沟通屏障多了",
      "music": 0.0
    },
    {
      "from": 53.66,
      "to": 54.78,
      "sid": 40,
      "location": 2,
      "content": "你的效率会更低",
      "music": 0.0
    },
    {
      "from": 54.78,
      "to": 55.9,
      "sid": 41,
      "location": 2,
      "content": "其实你就跟他说",
      "music": 0.0
    },
    {
      "from": 55.9,
      "to": 56.34,
      "sid": 42,
      "location": 2,
      "content": "一这么干",
      "music": 0.0
    },
    {
      "from": 56.34,
      "to": 56.74,
      "sid": 43,
      "location": 2,
      "content": "二这么干",
      "music": 0.0
    },
    {
      "from": 56.74,
      "to": 57.46,
      "sid": 44,
      "location": 2,
      "content": "三怎么干这么干啊",
      "music": 0.0
    },
    {
      "from": 57.46,
      "to": 58.18,
      "sid": 45,
      "location": 2,
      "content": "好他拿去",
      "music": 0.0
    },
    {
      "from": 58.18,
      "to": 60.199,
      "sid": 46,
      "location": 2,
      "content": "他肯定做出来的效率是很高的",
      "music": 0.0
    },
    {
      "from": 60.199,
      "to": 61.879,
      "sid": 47,
      "location": 2,
      "content": "你愿问这什么意思呢",
      "music": 0.0
    },
    {
      "from": 61.879,
      "to": 62.779,
      "sid": 48,
      "location": 2,
      "content": "那这为什么这么搞呢",
      "music": 0.0
    },
    {
      "from": 62.779,
      "to": 63.539,
      "sid": 49,
      "location": 2,
      "content": "这就是你这样",
      "music": 0.0
    },
    {
      "from": 63.539,
      "to": 64.269,
      "sid": 50,
      "location": 2,
      "content": "他还得想",
      "music": 0.0
    },
    {
      "from": 64.269,
      "to": 65.229,
      "sid": 51,
      "location": 2,
      "content": "我哪知道啥意思",
      "music": 0.0
    },
    {
      "from": 65.229,
      "to": 66.669,
      "sid": 52,
      "location": 2,
      "content": "我写出来就是这个意思啊",
      "music": 0.0
    },
    {
      "from": 66.669,
      "to": 68.269,
      "sid": 53,
      "location": 2,
      "content": "你问我我哪知道",
      "music": 0.0
    },
    {
      "from": 68.269,
      "to": 69.349,
      "sid": 54,
      "location": 2,
      "content": "我要知道我就不这么写了",
      "music": 0.0
    },
    {
      "from": 69.349,
      "to": 70.04,
      "sid": 55,
      "location": 2,
      "content": "好多人是这样",
      "music": 0.0
    },
    {
      "from": 70.04,
      "to": 73.8,
      "sid": 56,
      "location": 2,
      "content": "我是通过这么多年就是学你的这个情境方面",
      "music": 0.0
    },
    {
      "from": 73.8,
      "to": 74.72,
      "sid": 57,
      "location": 2,
      "content": "一个指令清晰",
      "music": 0.0
    },
    {
      "from": 74.72,
      "to": 76.28,
      "sid": 58,
      "location": 2,
      "content": "再一个就是学会正向表达",
      "music": 0.0
    },
    {
      "from": 76.28,
      "to": 77.5,
      "sid": 59,
      "location": 2,
      "content": "摆脱低级思维",
      "music": 0.0
    }
  ]
}