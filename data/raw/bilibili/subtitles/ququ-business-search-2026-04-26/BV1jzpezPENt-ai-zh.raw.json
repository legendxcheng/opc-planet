{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.1,
      "to": 1.38,
      "sid": 1,
      "location": 2,
      "content": "就是商业区间这个事情啊",
      "music": 0.0
    },
    {
      "from": 1.38,
      "to": 2.22,
      "sid": 2,
      "location": 2,
      "content": "我可以给你们讲一下",
      "music": 0.0
    },
    {
      "from": 2.22,
      "to": 4.22,
      "sid": 3,
      "location": 2,
      "content": "就是几乎每一个人都会遇到的一些",
      "music": 0.0
    },
    {
      "from": 4.22,
      "to": 5.22,
      "sid": 4,
      "location": 2,
      "content": "遇到一些卡点",
      "music": 0.0
    },
    {
      "from": 5.22,
      "to": 5.74,
      "sid": 5,
      "location": 2,
      "content": "遇到一些坑",
      "music": 0.0
    },
    {
      "from": 5.74,
      "to": 6.62,
      "sid": 6,
      "location": 2,
      "content": "首先第一件事啊",
      "music": 0.0
    },
    {
      "from": 6.62,
      "to": 7.1,
      "sid": 7,
      "location": 2,
      "content": "我跟你说",
      "music": 0.0
    },
    {
      "from": 7.1,
      "to": 10.83,
      "sid": 8,
      "location": 2,
      "content": "如果如果说你在没有跟别人谈好",
      "music": 0.0
    },
    {
      "from": 10.83,
      "to": 13.41,
      "sid": 9,
      "location": 2,
      "content": "有任何的利益的分配之前",
      "music": 0.0
    },
    {
      "from": 13.41,
      "to": 16.11,
      "sid": 10,
      "location": 2,
      "content": "就让甲方跟乙方直接见面了",
      "music": 0.0
    },
    {
      "from": 16.11,
      "to": 17.93,
      "sid": 11,
      "location": 2,
      "content": "那么我其实就建议大家",
      "music": 0.0
    },
    {
      "from": 17.93,
      "to": 20.32,
      "sid": 12,
      "location": 2,
      "content": "首先第一件事情叫做把心态放平",
      "music": 0.0
    },
    {
      "from": 20.32,
      "to": 22.48,
      "sid": 13,
      "location": 2,
      "content": "因为大概率这件事你就赚不到钱了",
      "music": 0.0
    },
    {
      "from": 22.48,
      "to": 23.7,
      "sid": 14,
      "location": 2,
      "content": "很多人刚开始都这样",
      "music": 0.0
    },
    {
      "from": 23.7,
      "to": 25.04,
      "sid": 15,
      "location": 2,
      "content": "很多人刚开始都会觉得说我我",
      "music": 0.0
    },
    {
      "from": 25.04,
      "to": 26.32,
      "sid": 16,
      "location": 2,
      "content": "我要是让他们俩认识一下是吧",
      "music": 0.0
    },
    {
      "from": 26.32,
      "to": 27.24,
      "sid": 17,
      "location": 2,
      "content": "说不定他们就能做点生意",
      "music": 0.0
    },
    {
      "from": 27.24,
      "to": 28.66,
      "sid": 18,
      "location": 2,
      "content": "然后我也从中能挣点",
      "music": 0.0
    },
    {
      "from": 28.66,
      "to": 30.98,
      "sid": 19,
      "location": 2,
      "content": "可是如果一旦你不管通过什么样的原因",
      "music": 0.0
    },
    {
      "from": 30.98,
      "to": 32.74,
      "sid": 20,
      "location": 2,
      "content": "可能刚开始你在介绍这两个人认识的时候",
      "music": 0.0
    },
    {
      "from": 32.74,
      "to": 34.56,
      "sid": 21,
      "location": 2,
      "content": "你没有觉得他们俩之间能有什么生意往来",
      "music": 0.0
    },
    {
      "from": 34.56,
      "to": 36.34,
      "sid": 22,
      "location": 2,
      "content": "有的时候只是朋友带朋友就这么认识了",
      "music": 0.0
    },
    {
      "from": 36.34,
      "to": 36.72,
      "sid": 23,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 36.72,
      "to": 38.62,
      "sid": 24,
      "location": 2,
      "content": "但是一旦朋友带朋友这么认识了",
      "music": 0.0
    },
    {
      "from": 38.62,
      "to": 40.39,
      "sid": 25,
      "location": 2,
      "content": "后面他们要做什么事",
      "music": 0.0
    },
    {
      "from": 40.39,
      "to": 42.99,
      "sid": 26,
      "location": 2,
      "content": "你就不要觉得这个事会跟你有什么关系了",
      "music": 0.0
    },
    {
      "from": 42.99,
      "to": 44.91,
      "sid": 27,
      "location": 2,
      "content": "因为这个时候如果说你的心态不放平",
      "music": 0.0
    },
    {
      "from": 44.91,
      "to": 46.89,
      "sid": 28,
      "location": 2,
      "content": "你就老是会觉得自己有一种损失感",
      "music": 0.0
    },
    {
      "from": 46.89,
      "to": 48.92,
      "sid": 29,
      "location": 2,
      "content": "然后人就会产生损失厌恶感",
      "music": 0.0
    },
    {
      "from": 48.92,
      "to": 51.2,
      "sid": 30,
      "location": 2,
      "content": "于是就会陷入到他所说的内容",
      "music": 0.0
    },
    {
      "from": 51.2,
      "to": 52.62,
      "sid": 31,
      "location": 2,
      "content": "但是其实这个是没有必要的",
      "music": 0.0
    },
    {
      "from": 52.62,
      "to": 53.76,
      "sid": 32,
      "location": 2,
      "content": "因为这是我跟你们讲",
      "music": 0.0
    },
    {
      "from": 53.76,
      "to": 55.24,
      "sid": 33,
      "location": 2,
      "content": "就是做商业区间这件事情呢",
      "music": 0.0
    },
    {
      "from": 55.24,
      "to": 56.96,
      "sid": 34,
      "location": 2,
      "content": "他就是有概率的",
      "music": 0.0
    },
    {
      "from": 56.96,
      "to": 58.84,
      "sid": 35,
      "location": 2,
      "content": "它本身就是要看机缘的",
      "music": 0.0
    },
    {
      "from": 58.84,
      "to": 62.32,
      "sid": 36,
      "location": 2,
      "content": "你要把这件事情做得非常非常非常的专业",
      "music": 0.0
    },
    {
      "from": 62.32,
      "to": 63.28,
      "sid": 37,
      "location": 2,
      "content": "非常的妥帖",
      "music": 0.0
    },
    {
      "from": 63.28,
      "to": 66.06,
      "sid": 38,
      "location": 2,
      "content": "其实它是有很多的要素的",
      "music": 0.0
    },
    {
      "from": 66.06,
      "to": 70.0,
      "sid": 39,
      "location": 2,
      "content": "嗯第一呀你要有一个自己的资质平台",
      "music": 0.0
    },
    {
      "from": 70.0,
      "to": 72.16,
      "sid": 40,
      "location": 2,
      "content": "就比如说你本身就有一个大家都知道的",
      "music": 0.0
    },
    {
      "from": 72.16,
      "to": 73.4,
      "sid": 41,
      "location": 2,
      "content": "一个公司也好",
      "music": 0.0
    },
    {
      "from": 73.4,
      "to": 73.88,
      "sid": 42,
      "location": 2,
      "content": "会所也好",
      "music": 0.0
    },
    {
      "from": 73.88,
      "to": 74.12,
      "sid": 43,
      "location": 2,
      "content": "或者什么",
      "music": 0.0
    },
    {
      "from": 74.12,
      "to": 75.68,
      "sid": 44,
      "location": 2,
      "content": "也就是要让大家有有一个认知",
      "music": 0.0
    },
    {
      "from": 75.68,
      "to": 77.48,
      "sid": 45,
      "location": 2,
      "content": "说这个人他本来就是干这件事的",
      "music": 0.0
    },
    {
      "from": 77.48,
      "to": 80.32,
      "sid": 46,
      "location": 2,
      "content": "他专门就是在撺掇这种类型的资源",
      "music": 0.0
    },
    {
      "from": 80.32,
      "to": 81.52,
      "sid": 47,
      "location": 2,
      "content": "然后从中赚钱的",
      "music": 0.0
    },
    {
      "from": 81.52,
      "to": 82.64,
      "sid": 48,
      "location": 2,
      "content": "首先大家对你这个人",
      "music": 0.0
    },
    {
      "from": 82.64,
      "to": 84.44,
      "sid": 49,
      "location": 2,
      "content": "他要有一个这样的商业的定位",
      "music": 0.0
    },
    {
      "from": 84.44,
      "to": 86.04,
      "sid": 50,
      "location": 2,
      "content": "如果你只是一个自然人",
      "music": 0.0
    },
    {
      "from": 86.04,
      "to": 87.2,
      "sid": 51,
      "location": 2,
      "content": "或者说你说我是卖红酒的",
      "music": 0.0
    },
    {
      "from": 87.2,
      "to": 89.38,
      "sid": 52,
      "location": 2,
      "content": "我今天要去撺掇那个什么什么地产生意",
      "music": 0.0
    },
    {
      "from": 89.38,
      "to": 92.39,
      "sid": 53,
      "location": 2,
      "content": "那么大概率大家就会直接把你忽视掉",
      "music": 0.0
    },
    {
      "from": 92.39,
      "to": 93.35,
      "sid": 54,
      "location": 2,
      "content": "他会直接把你忽视掉",
      "music": 0.0
    },
    {
      "from": 93.35,
      "to": 94.65,
      "sid": 55,
      "location": 2,
      "content": "因为他觉得你不是干这事的",
      "music": 0.0
    },
    {
      "from": 94.65,
      "to": 95.65,
      "sid": 56,
      "location": 2,
      "content": "这不是你的专业",
      "music": 0.0
    },
    {
      "from": 95.65,
      "to": 96.59,
      "sid": 57,
      "location": 2,
      "content": "所以任何时候呢",
      "music": 0.0
    },
    {
      "from": 96.59,
      "to": 98.41,
      "sid": 58,
      "location": 2,
      "content": "我们如果已经起了心动了念",
      "music": 0.0
    },
    {
      "from": 98.41,
      "to": 101.56,
      "sid": 59,
      "location": 2,
      "content": "说我想做一个什么样的业务的中间人",
      "music": 0.0
    },
    {
      "from": 101.56,
      "to": 104.9,
      "sid": 60,
      "location": 2,
      "content": "那么你自己要先有一家跟这种业务相关联的",
      "music": 0.0
    },
    {
      "from": 104.9,
      "to": 105.22,
      "sid": 61,
      "location": 2,
      "content": "公司",
      "music": 0.0
    },
    {
      "from": 105.22,
      "to": 107.02,
      "sid": 62,
      "location": 2,
      "content": "主体要存在在这个地方",
      "music": 0.0
    },
    {
      "from": 107.02,
      "to": 107.84,
      "sid": 63,
      "location": 2,
      "content": "这个是必须的",
      "music": 0.0
    },
    {
      "from": 107.84,
      "to": 111.18,
      "sid": 64,
      "location": 2,
      "content": "而且你要跟每一个人都要打一个预防针",
      "music": 0.0
    },
    {
      "from": 111.18,
      "to": 112.1,
      "sid": 65,
      "location": 2,
      "content": "就是身边的每一个人",
      "music": 0.0
    },
    {
      "from": 112.1,
      "to": 112.82,
      "sid": 66,
      "location": 2,
      "content": "你都要跟他讲说",
      "music": 0.0
    },
    {
      "from": 112.82,
      "to": 114.639,
      "sid": 67,
      "location": 2,
      "content": "我现在在做一个什么什么样的事啊",
      "music": 0.0
    },
    {
      "from": 114.639,
      "to": 116.059,
      "sid": 68,
      "location": 2,
      "content": "我现在在穿着是地产方面的资源",
      "music": 0.0
    },
    {
      "from": 116.059,
      "to": 117.579,
      "sid": 69,
      "location": 2,
      "content": "因为我手上现在有非常多的这种行业大佬",
      "music": 0.0
    },
    {
      "from": 117.579,
      "to": 118.699,
      "sid": 70,
      "location": 2,
      "content": "然后甲方和乙方",
      "music": 0.0
    },
    {
      "from": 118.699,
      "to": 119.459,
      "sid": 71,
      "location": 2,
      "content": "我手上都有很多",
      "music": 0.0
    },
    {
      "from": 119.459,
      "to": 120.579,
      "sid": 72,
      "location": 2,
      "content": "如果你们有这样的项目需求的话",
      "music": 0.0
    },
    {
      "from": 120.579,
      "to": 121.239,
      "sid": 73,
      "location": 2,
      "content": "你们可以来找我",
      "music": 0.0
    },
    {
      "from": 121.239,
      "to": 122.75,
      "sid": 74,
      "location": 2,
      "content": "我可以去帮你进行一些对接",
      "music": 0.0
    },
    {
      "from": 122.75,
      "to": 123.99,
      "sid": 75,
      "location": 2,
      "content": "你有这么一个气口",
      "music": 0.0
    },
    {
      "from": 123.99,
      "to": 126.27,
      "sid": 76,
      "location": 2,
      "content": "首先要把自己的身份等于说是身份名片",
      "music": 0.0
    },
    {
      "from": 126.27,
      "to": 127.03,
      "sid": 77,
      "location": 2,
      "content": "你要给他铺进去",
      "music": 0.0
    },
    {
      "from": 127.03,
      "to": 128.199,
      "sid": 78,
      "location": 2,
      "content": "首先这个是第一件事",
      "music": 0.0
    },
    {
      "from": 128.199,
      "to": 128.979,
      "sid": 79,
      "location": 2,
      "content": "没有铺",
      "music": 0.0
    },
    {
      "from": 128.979,
      "to": 130.359,
      "sid": 80,
      "location": 2,
      "content": "前面也没有谈任何的分论",
      "music": 0.0
    },
    {
      "from": 130.359,
      "to": 131.599,
      "sid": 81,
      "location": 2,
      "content": "那后面如果人家直接认识了",
      "music": 0.0
    },
    {
      "from": 131.599,
      "to": 132.719,
      "sid": 82,
      "location": 2,
      "content": "我就建议你就是好好交朋友",
      "music": 0.0
    },
    {
      "from": 132.719,
      "to": 133.519,
      "sid": 83,
      "location": 2,
      "content": "也别想那么多了",
      "music": 0.0
    },
    {
      "from": 133.519,
      "to": 134.799,
      "sid": 84,
      "location": 2,
      "content": "想那么多搞自己最后就很痛苦",
      "music": 0.0
    },
    {
      "from": 134.799,
      "to": 136.079,
      "sid": 85,
      "location": 2,
      "content": "而且你反而会觉得别人欠你的",
      "music": 0.0
    },
    {
      "from": 136.079,
      "to": 137.31,
      "sid": 86,
      "location": 2,
      "content": "其实也没太大必要",
      "music": 0.0
    },
    {
      "from": 137.31,
      "to": 138.34,
      "sid": 87,
      "location": 2,
      "content": "是这个",
      "music": 0.0
    },
    {
      "from": 138.34,
      "to": 138.9,
      "sid": 88,
      "location": 2,
      "content": "然后呢",
      "music": 0.0
    },
    {
      "from": 138.9,
      "to": 140.26,
      "sid": 89,
      "location": 2,
      "content": "就是任何时候",
      "music": 0.0
    },
    {
      "from": 140.26,
      "to": 144.06,
      "sid": 90,
      "location": 2,
      "content": "就是你们如果要想把居间这个事做透做明白啊",
      "music": 0.0
    },
    {
      "from": 144.06,
      "to": 146.74,
      "sid": 91,
      "location": 2,
      "content": "我跟大家讲一个非常实际的一个话",
      "music": 0.0
    },
    {
      "from": 146.74,
      "to": 148.36,
      "sid": 92,
      "location": 2,
      "content": "你背后是有人的",
      "music": 0.0
    },
    {
      "from": 148.36,
      "to": 149.99,
      "sid": 93,
      "location": 2,
      "content": "你背后是有人的",
      "music": 0.0
    },
    {
      "from": 149.99,
      "to": 152.27,
      "sid": 94,
      "location": 2,
      "content": "也就是说你们在做区间的生意的时候",
      "music": 0.0
    },
    {
      "from": 152.27,
      "to": 153.79,
      "sid": 95,
      "location": 2,
      "content": "你要明白抓手是什么",
      "music": 0.0
    },
    {
      "from": 153.79,
      "to": 156.63,
      "sid": 96,
      "location": 2,
      "content": "没有几个人作为一个单纯的自然人",
      "music": 0.0
    },
    {
      "from": 156.63,
      "to": 158.829,
      "sid": 97,
      "location": 2,
      "content": "能够把区间这个钱挣到口袋里",
      "music": 0.0
    },
    {
      "from": 158.829,
      "to": 160.909,
      "sid": 98,
      "location": 2,
      "content": "除非你对这件事情有抓手",
      "music": 0.0
    },
    {
      "from": 160.909,
      "to": 162.62,
      "sid": 99,
      "location": 2,
      "content": "抓手有几个方面",
      "music": 0.0
    },
    {
      "from": 162.62,
      "to": 164.48,
      "sid": 100,
      "location": 2,
      "content": "第一个方面呢就是付款",
      "music": 0.0
    },
    {
      "from": 164.48,
      "to": 165.88,
      "sid": 101,
      "location": 2,
      "content": "付款是一个抓手对吧",
      "music": 0.0
    },
    {
      "from": 165.88,
      "to": 167.38,
      "sid": 102,
      "location": 2,
      "content": "因为一旦这个事人家签了合同了",
      "music": 0.0
    },
    {
      "from": 167.38,
      "to": 167.54,
      "sid": 103,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 167.54,
      "to": 168.5,
      "sid": 104,
      "location": 2,
      "content": "人家合同已经签上了",
      "music": 0.0
    },
    {
      "from": 168.5,
      "to": 171.05,
      "sid": 105,
      "location": 2,
      "content": "你后面还要能够保障这个人",
      "music": 0.0
    },
    {
      "from": 171.05,
      "to": 173.39,
      "sid": 106,
      "location": 2,
      "content": "把你的这部分份额给到你怎么保证",
      "music": 0.0
    },
    {
      "from": 173.39,
      "to": 174.42,
      "sid": 107,
      "location": 2,
      "content": "怎么保证",
      "music": 0.0
    },
    {
      "from": 174.42,
      "to": 175.78,
      "sid": 108,
      "location": 2,
      "content": "这是一个很难很难的卡点",
      "music": 0.0
    },
    {
      "from": 175.78,
      "to": 179.02,
      "sid": 109,
      "location": 2,
