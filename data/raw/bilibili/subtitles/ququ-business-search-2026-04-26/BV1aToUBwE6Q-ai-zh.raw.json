    },
    {
      "from": 68.1,
      "to": 69.34,
      "sid": 50,
      "location": 2,
      "content": "因为任何一个行业",
      "music": 0.0
    },
    {
      "from": 69.34,
      "to": 71.26,
      "sid": 51,
      "location": 2,
      "content": "大家核心赚钱就是两种方式",
