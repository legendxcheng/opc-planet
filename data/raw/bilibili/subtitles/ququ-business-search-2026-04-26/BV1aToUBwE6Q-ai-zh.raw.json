    },
    {
      "from": 75.7,
      "to": 79.28,
      "sid": 57,
      "location": 2,
      "content": "茶叶烟酒糖茶现在就是跟着大环境走",
      "music": 0.0
    },
    {
      "from": 79.28,
      "to": 83.71,
      "sid": 58,
      "location": 2,
      "content": "尤其是酒和茶零售这一段大环境好就是好",
      "music": 0.0
    },
    {
      "from": 83.71,
      "to": 84.87,
      "sid": 59,
      "location": 2,
      "content": "大环境不好就是不好",
