  "body": [
    {
      "from": 0.04,
      "to": 1.04,
      "sid": 1,
      "location": 2,
      "content": "我是个生意人",
      "music": 0.0
    },
    {
      "from": 1.04,
      "to": 4.18,
      "sid": 2,
      "location": 2,
      "content": "我能做的是回答各位的生意问题",
      "music": 0.0
    },
    {
      "from": 4.18,
      "to": 7.99,
      "sid": 3,
      "location": 2,
      "content": "你们有任何行业的问题可以在评论区里问我啊",
      "music": 0.0
    },
    {
      "from": 7.99,
      "to": 8.87,
      "sid": 4,
      "location": 2,
      "content": "不要问我怎么做",
      "music": 0.0
    },
    {
      "from": 8.87,
      "to": 11.43,
      "sid": 5,
      "location": 2,
      "content": "你们可以问说哎老王餐饮行业可不可以做啊",
      "music": 0.0
    },
    {
      "from": 11.43,
      "to": 12.47,
      "sid": 6,
      "location": 2,
      "content": "家政行业可不可以做",
      "music": 0.0
    },
    {
      "from": 12.47,
      "to": 13.78,
      "sid": 7,
      "location": 2,
      "content": "你们可以问类似的问题",
      "music": 0.0
    },
    {
      "from": 13.78,
      "to": 15.32,
      "sid": 8,
      "location": 2,
      "content": "我回答你们的问题",
      "music": 0.0
    },
    {
      "from": 15.32,
      "to": 17.92,
      "sid": 9,
      "location": 2,
      "content": "我的才艺就叫快问快答啊",
      "music": 0.0
    },
    {
      "from": 17.92,
      "to": 20.02,
      "sid": 10,
      "location": 2,
      "content": "无偿服务可以开始了",
      "music": 0.0
    },
    {
      "from": 20.02,
      "to": 20.68,
      "sid": 11,
      "location": 2,
      "content": "来吧",
      "music": 0.0
    },
    {
      "from": 20.68,
      "to": 21.36,
      "sid": 12,
      "location": 2,
      "content": "美甲行业",
      "music": 0.0
    },
    {
      "from": 21.36,
      "to": 22.76,
      "sid": 13,
      "location": 2,
      "content": "美甲美睫没有办法",
      "music": 0.0
    },
    {
      "from": 22.76,
      "to": 24.72,
      "sid": 14,
      "location": 2,
      "content": "现在确实是同质化竞争太严重了",
      "music": 0.0
    },
    {
      "from": 24.72,
      "to": 25.28,
      "sid": 15,
      "location": 2,
      "content": "门槛太低了",
      "music": 0.0
    },
    {
      "from": 25.28,
      "to": 27.16,
      "sid": 16,
      "location": 2,
      "content": "所以说会做流量你就玩",
      "music": 0.0
    },
    {
      "from": 27.16,
      "to": 28.48,
      "sid": 17,
      "location": 2,
      "content": "不会做流量就不要碰",
      "music": 0.0
    },
    {
      "from": 28.48,
      "to": 29.72,
      "sid": 18,
      "location": 2,
      "content": "房地产是房地产行业",
      "music": 0.0
    },
    {
      "from": 29.72,
      "to": 30.6,
      "sid": 19,
      "location": 2,
      "content": "20年之内好不了",
      "music": 0.0
    },
    {
      "from": 30.6,
      "to": 31.48,
      "sid": 20,
      "location": 2,
      "content": "建材定制",
      "music": 0.0
    },
    {
      "from": 31.48,
      "to": 33.28,
      "sid": 21,
      "location": 2,
      "content": "它是和房地产行业相关的",
      "music": 0.0
    },
    {
      "from": 33.28,
      "to": 34.44,
      "sid": 22,
      "location": 2,
      "content": "房地产行业就是不行的",
      "music": 0.0
    },
    {
      "from": 34.44,
      "to": 35.1,
      "sid": 23,
      "location": 2,
      "content": "你也不行",
      "music": 0.0
    },
    {
      "from": 35.1,
      "to": 36.72,
      "sid": 24,
      "location": 2,
      "content": "托管中心真的可以做",
      "music": 0.0
    },
    {
      "from": 36.72,
      "to": 38.28,
      "sid": 25,
      "location": 2,
      "content": "但是要看一下行业密度",
      "music": 0.0
    },
    {
      "from": 38.28,
      "to": 39.88,
      "sid": 26,
      "location": 2,
      "content": "你看一下你自己那个学校门口",
      "music": 0.0
    },
    {
      "from": 39.88,
      "to": 41.2,
      "sid": 27,
      "location": 2,
      "content": "还有没有你的市场",
      "music": 0.0
    },
    {
      "from": 41.2,
      "to": 42.46,
      "sid": 28,
      "location": 2,
      "content": "小吃摊可不可以做",
      "music": 0.0
    },
    {
      "from": 42.46,
      "to": 43.36,
      "sid": 29,
      "location": 2,
      "content": "尽量做面食",
      "music": 0.0
    },
    {
      "from": 43.36,
      "to": 44.22,
      "sid": 30,
      "location": 2,
      "content": "面食可以玩",
      "music": 0.0
    },
    {
      "from": 44.22,
      "to": 46.8,
      "sid": 31,
      "location": 2,
      "content": "餐饮行业到现在为止最大的问题只有一个",
      "music": 0.0
    },
    {
      "from": 46.8,
      "to": 48.26,
      "sid": 32,
      "location": 2,
      "content": "就是供给太多",
      "music": 0.0
    },
    {
      "from": 48.26,
      "to": 49.28,
      "sid": 33,
      "location": 2,
      "content": "但是需求有限",
      "music": 0.0
    },
    {
      "from": 49.28,
      "to": 51.26,
      "sid": 34,
      "location": 2,
      "content": "贷款中介不要做晚了啊",
      "music": 0.0
    },
    {
      "from": 51.26,
      "to": 52.679,
      "sid": 35,
      "location": 2,
      "content": "晚了说说台球",
      "music": 0.0
    },
    {
      "from": 52.679,
      "to": 53.519,
      "sid": 36,
      "location": 2,
      "content": "有人的可以干",
      "music": 0.0
    },
    {
      "from": 53.519,
      "to": 54.579,
      "sid": 37,
      "location": 2,
      "content": "没有人的不要干",
      "music": 0.0
    },
    {
      "from": 54.579,
      "to": 55.839,
      "sid": 38,
      "location": 2,
      "content": "调节近视的行业",
      "music": 0.0
    },
    {
      "from": 55.839,
      "to": 57.319,
      "sid": 39,
      "location": 2,
      "content": "你要选择你自己",
      "music": 0.0
    },
    {
      "from": 57.319,
      "to": 58.6,
      "sid": 40,
      "location": 2,
      "content": "看看你自己的专业度啊",
      "music": 0.0
    },
    {
      "from": 58.6,
      "to": 60.52,
      "sid": 41,
      "location": 2,
      "content": "注意不要配镜啊",
      "music": 0.0
    },
    {
      "from": 60.52,
      "to": 62.72,
      "sid": 42,
      "location": 2,
      "content": "配镜线下的眼镜店不要再做了",
      "music": 0.0
    },
    {
      "from": 62.72,
      "to": 64.1,
      "sid": 43,
      "location": 2,
      "content": "都在做线上美业",
      "music": 0.0
    },
    {
      "from": 64.1,
      "to": 65.06,
      "sid": 44,
      "location": 2,
      "content": "我就是不看好",
      "music": 0.0
    },
    {
      "from": 65.06,
      "to": 66.06,
      "sid": 45,
      "location": 2,
      "content": "不管你是升美也好",
      "music": 0.0
    },
    {
      "from": 66.06,
      "to": 66.5,
      "sid": 46,
      "location": 2,
      "content": "医美也好",
