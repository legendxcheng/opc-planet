    },
    {
      "from": 73.38,
      "to": 74.06,
      "sid": 54,
      "location": 2,
      "content": "要么靠认知差",
      "music": 0.0
    },
    {
      "from": 74.06,
      "to": 74.66,
      "sid": 55,
      "location": 2,
      "content": "我知道为什么",
      "music": 0.0
    },
    {
      "from": 74.66,
      "to": 75.7,
      "sid": 56,
      "location": 2,
      "content": "但是你不知道为什么",
