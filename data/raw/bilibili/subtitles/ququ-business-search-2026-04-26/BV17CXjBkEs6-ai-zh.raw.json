{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "sync-v1.7.0.4",
  "body": [
    {
      "from": 0.2,
      "to": 2.64,
      "sid": 1,
      "location": 2,
      "content": "大家大家首先要知道啊",
      "music": 0.0
    },
    {
      "from": 2.64,
      "to": 4.94,
      "sid": 2,
      "location": 2,
      "content": "商业世界它是有它的游戏规则的",
      "music": 0.0
    },
    {
      "from": 4.94,
      "to": 7.16,
      "sid": 3,
      "location": 2,
      "content": "商业世界的游戏规则就是在于我给你什么",
      "music": 0.0
    },
    {
      "from": 7.16,
      "to": 7.84,
      "sid": 4,
      "location": 2,
      "content": "你给我什么嘛",
      "music": 0.0
    },
    {
      "from": 7.84,
      "to": 8.6,
      "sid": 5,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 8.6,
      "to": 10.52,
      "sid": 6,
      "location": 2,
      "content": "我要给你创造效益",
      "music": 0.0
    },
    {
      "from": 10.52,
      "to": 11.88,
      "sid": 7,
      "location": 2,
      "content": "你就应该给我收入",
      "music": 0.0
    },
    {
      "from": 13.2,
      "to": 16.379,
      "sid": 8,
      "location": 2,
      "content": "现在是你想你想啊",
      "music": 0.0
    },
    {
      "from": 16.379,
      "to": 19.98,
      "sid": 9,
      "location": 2,
      "content": "他的亲戚为什么也会主动跟他聊到",
      "music": 0.0
    },
    {
      "from": 19.98,
      "to": 22.9,
      "sid": 10,
      "location": 2,
      "content": "说哎我们还想在深圳再去落一个公司",
      "music": 0.0
    },
    {
      "from": 22.9,
      "to": 23.66,
      "sid": 11,
      "location": 2,
      "content": "落一个项目",
      "music": 0.0
    },
    {
      "from": 23.66,
      "to": 27.119,
      "sid": 12,
      "location": 2,
      "content": "要不然你们你去帮我们搞那个他聊到这个点",
      "music": 0.0
    },
    {
      "from": 27.119,
      "to": 28.879,
      "sid": 13,
      "location": 2,
      "content": "但是呢他又没有深聊",
      "music": 0.0
    },
    {
      "from": 28.879,
      "to": 29.399,
      "sid": 14,
      "location": 2,
      "content": "为什么",
      "music": 0.0
    },
    {
      "from": 29.399,
      "to": 31.039,
      "sid": 15,
      "location": 2,
      "content": "你知道为什么吗",
      "music": 0.0
    },
    {
      "from": 32.12,
      "to": 33.12,
      "sid": 16,
      "location": 2,
      "content": "你知道为什么吗",
      "music": 0.0
    },
    {
      "from": 34.16,
      "to": 36.32,
      "sid": 17,
      "location": 2,
      "content": "因为就算他身家十几个亿",
      "music": 0.0
    },
    {
      "from": 36.32,
      "to": 38.76,
      "sid": 18,
      "location": 2,
      "content": "他也没想明白他去深圳干啥",
      "music": 0.0
    },
    {
      "from": 40.64,
      "to": 42.2,
      "sid": 19,
      "location": 2,
      "content": "听得懂吗",
      "music": 0.0
    },
    {
      "from": 42.55,
      "to": 45.31,
      "sid": 20,
      "location": 2,
      "content": "哪怕他身家十几个亿",
      "music": 0.0
    },
    {
      "from": 45.31,
      "to": 50.91,
      "sid": 21,
      "location": 2,
      "content": "他也没想明白他到底到深圳怎么开展业务",
      "music": 0.0
    },
    {
      "from": 51.77,
      "to": 53.33,
      "sid": 22,
      "location": 2,
      "content": "这就是我跟大家讲的",
      "music": 0.0
    },
    {
      "from": 53.33,
      "to": 56.93,
      "sid": 23,
      "location": 2,
      "content": "所有的人要对大佬去媚",
      "music": 0.0
    },
    {
      "from": 58.18,
      "to": 61.98,
      "sid": 24,
      "location": 2,
      "content": "你们要对所谓的赚到钱的人去媚",
      "music": 0.0
    },
    {
      "from": 62.96,
      "to": 67.88,
      "sid": 25,
      "location": 2,
      "content": "赚得到钱是因为当时基于他那个时候的一个天时地利人和",
      "music": 0.0
    },
    {
      "from": 68.96,
      "to": 70.33,
      "sid": 26,
      "location": 2,
      "content": "所以他赚到钱了",
      "music": 0.0
    },
    {
      "from": 70.33,
      "to": 72.05,
      "sid": 27,
      "location": 2,
      "content": "任何一个赚到钱的人",
      "music": 0.0
    },
    {
      "from": 72.05,
      "to": 73.87,
      "sid": 28,
      "location": 2,
      "content": "当他要去开辟一个新的市场",
      "music": 0.0
    },
    {
      "from": 73.87,
      "to": 76.11,
      "sid": 29,
      "location": 2,
      "content": "要去开辟一个新的领域的时候",
      "music": 0.0
    },
    {
      "from": 76.11,
      "to": 78.7,
      "sid": 30,
      "location": 2,
      "content": "他都会遇到自己的心理卡点",
      "music": 0.0
    },
    {
      "from": 78.7,
      "to": 83.11,
      "sid": 31,
      "location": 2,
      "content": "他都觉得好像我没有办法从零开始干",
      "music": 0.0
    },
    {
      "from": 83.11,
      "to": 85.03,
      "sid": 32,
      "location": 2,
      "content": "我都要高举高打",
      "music": 0.0
    },
    {
      "from": 85.03,
      "to": 87.09,
      "sid": 33,
      "location": 2,
      "content": "每个人想的都是高举高打",
      "music": 0.0
    },
    {
      "from": 87.09,
      "to": 89.97,
      "sid": 34,
      "location": 2,
      "content": "每个人想的都是盘资源",
      "music": 0.0
    },
    {
      "from": 89.97,
      "to": 93.01,
      "sid": 35,
      "location": 2,
      "content": "好像我一上来我进入这个市场的时候",
      "music": 0.0
    },
    {
      "from": 93.01,
      "to": 95.93,
      "sid": 36,
      "location": 2,
      "content": "我就应该是一个牛逼的选手",
      "music": 0.0
    },
    {
      "from": 96.53,
      "to": 98.53,
      "sid": 37,
      "location": 2,
      "content": "如果你让我去做那个下沉的事情",
      "music": 0.0
    },
    {
      "from": 98.53,
      "to": 100.39,
      "sid": 38,
      "location": 2,
      "content": "我我我做不了",
      "music": 0.0
    },
    {
      "from": 100.75,
      "to": 103.23,
      "sid": 39,
      "location": 2,
      "content": "但是真正的出路在哪里呢",
      "music": 0.0
    },
    {
      "from": 104.47,
      "to": 107.27,
      "sid": 40,
      "location": 2,
      "content": "出路就在下沉动作里",
      "music": 0.0
    },
    {
      "from": 108.42,
      "to": 113.7,
      "sid": 41,
      "location": 2,
      "content": "出路就是每一个客户我都要像我原来没有做这个生意一样",
      "music": 0.0
    },
    {
      "from": 113.7,
      "to": 115.9,
      "sid": 42,
      "location": 2,
      "content": "一个一个一个的去找",
      "music": 0.0
    },
    {
      "from": 116.4,
      "to": 118.46,
      "sid": 43,
      "location": 2,
      "content": "我的优势",
      "music": 0.0
    },
    {
      "from": 118.46,
      "to": 123.39,
      "sid": 44,
      "location": 2,
      "content": "仅仅只是来自于我原来已经在这个行业里做了很多年",
      "music": 0.0
    },
    {
      "from": 123.39,
      "to": 124.89,
      "sid": 45,
      "location": 2,
      "content": "所以我的供应链",
      "music": 0.0
    },
    {
      "from": 124.89,
      "to": 127.979,
      "sid": 46,
      "location": 2,
      "content": "我的服务体系这些东西都是完善的",
      "music": 0.0
    },
    {
      "from": 127.979,
      "to": 130.959,
      "sid": 47,
      "location": 2,
      "content": "但是但凡到涉及到新的市场",
      "music": 0.0
    },
    {
      "from": 130.959,
      "to": 134.09,
      "sid": 48,
      "location": 2,
      "content": "打开新的客户的这个领域",
      "music": 0.0
    },
    {
      "from": 134.09,
      "to": 140.18,
      "sid": 49,
      "location": 2,
      "content": "我就是得一个一个的去做的经销商",
      "music": 0.0
    },
    {
      "from": 140.18,
      "to": 142.38,
      "sid": 50,
      "location": 2,
      "content": "我就得一个一个的去找的货",
      "music": 0.0
    },
    {
      "from": 142.38,
      "to": 145.22,
      "sid": 51,
      "location": 2,
      "content": "我就是得一个一个的去卖的",
      "music": 0.0
    },
    {
      "from": 147.2,
      "to": 149.12,
      "sid": 52,
      "location": 2,
      "content": "你你你们要知道啊",
      "music": 0.0
    },
    {
      "from": 149.12,
      "to": 155.69,
      "sid": 53,
      "location": 2,
      "content": "很多东西它就是很看似很小的一条线打通",
      "music": 0.0
    },
    {
      "from": 156.17,
      "to": 161.56,
      "sid": 54,
      "location": 2,
      "content": "但是其实你已经把后面无限的潜力全部拖出来了",
      "music": 0.0
    },
    {
      "from": 161.96,
      "to": 163.6,
      "sid": 55,
      "location": 2,
      "content": "之所以你们做不出来",
      "music": 0.0
    },
    {
      "from": 163.6,
      "to": 167.24,
      "sid": 56,
      "location": 2,
      "content": "是因为你前面那个最小最小的那个事你没干",
      "music": 0.0
    },
    {
      "from": 170.34,
      "to": 171.54,
      "sid": 57,
      "location": 2,
      "content": "我跟大家说啊",
      "music": 0.0
    },
    {
      "from": 171.54,
      "to": 176.94,
      "sid": 58,
      "location": 2,
      "content": "我前几天跟一个知识付费的一个老牌操盘手啊",
      "music": 0.0
    },
    {
      "from": 176.94,
      "to": 177.8,
      "sid": 59,
      "location": 2,
      "content": "见了个面",
      "music": 0.0
    },
    {
      "from": 177.8,
      "to": 180.24,
      "sid": 60,
      "location": 2,
      "content": "因为人家现在想想跟我合作",
      "music": 0.0
    },
    {
      "from": 180.24,
      "to": 182.32,
      "sid": 61,
      "location": 2,
      "content": "但是呢我们一般不跟别人合作",
      "music": 0.0
    },
    {
      "from": 182.32,
      "to": 182.96,
      "sid": 62,
      "location": 2,
      "content": "你们知道的啊",
      "music": 0.0
    },
    {
      "from": 182.96,
      "to": 184.54,
      "sid": 63,
      "location": 2,
      "content": "我们一般是不跟别人合作的",
      "music": 0.0
    },
    {
      "from": 184.54,
      "to": 187.84,
      "sid": 64,
      "location": 2,
      "content": "然后他就聊到一个老牌的操盘手啊",
      "music": 0.0
    },
    {
      "from": 187.84,
      "to": 189.16,
      "sid": 65,
      "location": 2,
      "content": "他问我一个问题",
      "music": 0.0
    },
    {
      "from": 189.16,
      "to": 193.329,
      "sid": 66,
      "location": 2,
      "content": "他说我就是想面对面的听你跟我讲",
      "music": 0.0
    },
    {
      "from": 193.329,
      "to": 198.28,
      "sid": 67,
      "location": 2,
      "content": "你们的麦到底是真的还是假的",
      "music": 0.0
    },
    {
      "from": 200.14,
      "to": 203.62,
      "sid": 68,
      "location": 2,
      "content": "我说我们的麦全部是真的",
      "music": 0.0
    },
    {
      "from": 203.62,
      "to": 206.66,
      "sid": 69,
      "location": 2,
      "content": "6年下来没有一个假卖",
      "music": 0.0
    },
    {
      "from": 206.66,
      "to": 209.019,
      "sid": 70,
      "location": 2,
      "content": "6年下来没有一个假卖",
      "music": 0.0
    },
    {
      "from": 209.72,
      "to": 211.34,
      "sid": 71,
      "location": 2,
      "content": "他非常震惊",
      "music": 0.0
    },
    {
      "from": 211.34,
      "to": 213.06,
      "sid": 72,
      "location": 2,
      "content": "他非常震惊",
      "music": 0.0
    },
    {
      "from": 213.06,
      "to": 215.06,
      "sid": 73,
      "location": 2,
      "content": "就他们是一个知识付费圈子",
      "music": 0.0
    },
    {
      "from": 215.06,
      "to": 216.64,
      "sid": 74,
      "location": 2,
      "content": "一个非常老牌的操盘手",
      "music": 0.0
    },
    {
      "from": 216.64,
      "to": 218.68,
      "sid": 75,
      "location": 2,
      "content": "有很多很多大V",
      "music": 0.0
    },
    {
      "from": 218.68,
      "to": 222.45,
      "sid": 76,
      "location": 2,
      "content": "很多很多大的知识付费博主都是他们孵化的",
      "music": 0.0
    },
    {
      "from": 222.859,
      "to": 224.059,
      "sid": 77,
      "location": 2,
      "content": "他就告诉我",
      "music": 0.0
    },
    {
      "from": 224.059,
      "to": 228.209,
      "sid": 78,
      "location": 2,
      "content": "每一个博主一年要在麦手这个事情上面花多少钱",
      "music": 0.0
    },
    {
      "from": 228.569,
      "to": 229.609,
      "sid": 79,
      "location": 2,
      "content": "你知道吧",
      "music": 0.0
    },
    {
      "from": 229.609,
      "to": 232.37,
      "sid": 80,
      "location": 2,
      "content": "因为直播间都是假卖",
      "music": 0.0
    },
    {
      "from": 232.37,
      "to": 234.25,
      "sid": 81,
      "location": 2,
      "content": "就都是一个一个卖多少钱",
      "music": 0.0
    },
    {
      "from": 234.25,
      "to": 235.31,
      "sid": 82,
      "location": 2,
      "content": "一个卖多少钱这样",
      "music": 0.0
    },
    {
      "from": 235.31,
      "to": 239.28,
      "sid": 83,
      "location": 2,
      "content": "所以他们每年有多少的费用是在头流上的",
      "music": 0.0
    },
    {
      "from": 239.28,
      "to": 242.81,
      "sid": 84,
      "location": 2,
      "content": "每年有多少的费用是在这个给my手上面的",
      "music": 0.0
    },
    {
      "from": 243.29,
      "to": 245.09,
      "sid": 85,
      "location": 2,
      "content": "然后他就来问我",
      "music": 0.0
    },
    {
      "from": 245.09,
      "to": 248.73,
      "sid": 86,
      "location": 2,
      "content": "因为我呢是一个在这个圈子里不露面的一个人",
      "music": 0.0
    },
    {
      "from": 248.73,
      "to": 251.25,
      "sid": 87,
      "location": 2,
      "content": "其实你们别看我平时咋咋呼呼的",
      "music": 0.0
    },
    {
      "from": 251.25,
      "to": 256.93,
      "sid": 88,
      "location": 2,
      "content": "但是我在这个圈子里边其实完全是一个非常隐蔽的存在",
      "music": 0.0
    },
    {
      "from": 256.93,
      "to": 259.64,
      "sid": 89,
      "location": 2,
      "content": "就我是不跟同行交流的",
      "music": 0.0
    },
    {
      "from": 260.04,
      "to": 263.88,
      "sid": 90,
      "location": 2,
      "content": "同行很难在所谓的任何一个商业分享啊",
      "music": 0.0
    },
    {
      "from": 263.88,
      "to": 265.08,
      "sid": 91,
      "location": 2,
      "content": "或者什么一个场域里边",
      "music": 0.0
    },
    {
      "from": 265.08,
      "to": 266.5,
      "sid": 92,
      "location": 2,
      "content": "那能看到我",
      "music": 0.0
    },
    {
      "from": 266.5,
      "to": 267.28,
      "sid": 93,
      "location": 2,
      "content": "看不到我的",
      "music": 0.0
    },
    {
      "from": 267.28,
      "to": 269.12,
      "sid": 94,
      "location": 2,
      "content": "我是不参加这种活动的",
      "music": 0.0
    },
    {
      "from": 269.12,
      "to": 272.289,
      "sid": 95,
      "location": 2,
      "content": "我是不参加这种群体性的这种活动的",
      "music": 0.0
    },
    {
      "from": 272.289,
      "to": 274.409,
      "sid": 96,
      "location": 2,
      "content": "所以他们对我非常非常好奇",
      "music": 0.0
    },
    {
      "from": 274.409,
      "to": 276.83,
      "sid": 97,
      "location": 2,
      "content": "因为我在这个行业里面肯定是标杆嘛",
      "music": 0.0
    },
    {
      "from": 276.83,
      "to": 279.09,
      "sid": 98,
      "location": 2,
      "content": "所有的人都会拿着我的东西去拆解嘛",
      "music": 0.0
    },
    {
      "from": 279.09,
      "to": 280.53,
      "sid": 99,
      "location": 2,
      "content": "拿着我的直播间去拆嘛",
      "music": 0.0
    },
    {
      "from": 280.53,
      "to": 282.31,
      "sid": 100,
      "location": 2,
      "content": "看看我们的直播间是怎么打爆的嘛",
      "music": 0.0
    },
    {
      "from": 282.31,
      "to": 284.74,
      "sid": 101,
      "location": 2,
      "content": "我们的那些故事为什么会出彩嘛",
      "music": 0.0
    },
    {
      "from": 284.74,
      "to": 286.96,
      "sid": 102,
      "location": 2,
      "content": "然后我的这些解读的逐字稿是什么嘛",
      "music": 0.0
    },
    {
      "from": 286.96,
      "to": 291.22,
      "sid": 103,
      "location": 2,
      "content": "所有的人都会拿着我的直播间出去出去复刻",
      "music": 0.0
    },
    {
      "from": 292.13,
      "to": 294.27,
      "sid": 104,
      "location": 2,
      "content": "所以他们都不敢相信",
      "music": 0.0
    },
    {
      "from": 294.27,
      "to": 295.85,
      "sid": 105,
      "location": 2,
      "content": "因为他们觉得很奇怪的点",
      "music": 0.0
    },
    {
      "from": 295.85,
      "to": 299.17,
      "sid": 106,
      "location": 2,
      "content": "就是他们也觉得我的麦的内容太炸裂了",
      "music": 0.0
    },
    {
      "from": 299.17,
      "to": 304.05,
