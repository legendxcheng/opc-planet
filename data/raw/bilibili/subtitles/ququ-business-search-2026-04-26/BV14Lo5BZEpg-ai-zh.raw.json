  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 2.58,
      "sid": 1,
      "location": 2,
      "content": "能不能帮我测试下帕尼尼减肥法的效果",
      "music": 0.0
    },
    {
      "from": 2.58,
      "to": 5.08,
      "sid": 2,
      "location": 2,
      "content": "我会让我全寝室都给你点赞的",
      "music": 0.0
    },
    {
      "from": 5.08,
      "to": 7.7,
      "sid": 3,
      "location": 2,
      "content": "嗯刚好最近吃的有点放纵",
      "music": 0.0
    },
    {
      "from": 7.7,
      "to": 9.24,
      "sid": 4,
      "location": 2,
      "content": "咱们教练是三天帕尼尼",
      "music": 0.0
    },
    {
      "from": 9.24,
      "to": 10.76,
      "sid": 5,
      "location": 2,
      "content": "但体重会是变化",
      "music": 0.0
    },
    {
      "from": 10.76,
      "to": 12.14,
      "sid": 6,
      "location": 2,
      "content": "中午11.40分",
      "music": 0.0
    },
    {
      "from": 12.14,
      "to": 14.42,
      "sid": 7,
      "location": 2,
      "content": "这里啊就是我们这三天的口粮了",
      "music": 0.0
    },
    {
      "from": 14.42,
      "to": 15.6,
      "sid": 8,
      "location": 2,
      "content": "这里啊一共24个",
      "music": 0.0
    },
    {
      "from": 15.6,
      "to": 17.48,
      "sid": 9,
      "location": 2,
      "content": "咱们一共是花了八十四",
      "music": 0.0
    },
    {
      "from": 17.48,
      "to": 19.79,
      "sid": 10,
      "location": 2,
      "content": "平均下来只要三块五个",
      "music": 0.0
    },
    {
      "from": 19.79,
      "to": 21.91,
      "sid": 11,
      "location": 2,
      "content": "汤里面大概就是这样的身体状态",
      "music": 0.0
    },
    {
      "from": 21.91,
      "to": 22.87,
      "sid": 12,
      "location": 2,
      "content": "一块鸡肉",
      "music": 0.0
    },
    {
      "from": 22.87,
      "to": 23.69,
      "sid": 13,
      "location": 2,
      "content": "一片芝士",
      "music": 0.0
    },
    {
      "from": 23.69,
      "to": 25.3,
      "sid": 14,
      "location": 2,
      "content": "加上外面的面包皮儿",
      "music": 0.0
    },
    {
      "from": 25.3,
      "to": 27.52,
      "sid": 15,
      "location": 2,
      "content": "咱们今天早饭就简单吃这么三个",
      "music": 0.0
    },
    {
      "from": 27.52,
      "to": 29.64,
      "sid": 16,
      "location": 2,
      "content": "其他都放到冰箱里面冷冻起来",
      "music": 0.0
    },
    {
      "from": 29.64,
      "to": 31.3,
      "sid": 17,
      "location": 2,
      "content": "小尝一口",
      "music": 0.0
    },
    {
      "from": 32.58,
      "to": 36.88,
      "sid": 18,
      "location": 2,
      "content": "嗯它里面的鸡肉跟原味鸡块的调味是一样的",
      "music": 0.0
    },
    {
      "from": 36.88,
      "to": 38.02,
      "sid": 19,
      "location": 2,
      "content": "虽然尺寸小",
      "music": 0.0
    },
    {
      "from": 38.02,
      "to": 39.46,
      "sid": 20,
      "location": 2,
      "content": "但是味道还是不错的",
      "music": 0.0
    },
    {
      "from": 39.46,
      "to": 41.3,
      "sid": 21,
      "location": 2,
      "content": "这么一个大概是277大卡",
      "music": 0.0
    },
    {
      "from": 41.3,
      "to": 43.64,
      "sid": 22,
      "location": 2,
      "content": "我大概的计划就是一天吃八个左右",
      "music": 0.0
    },
    {
      "from": 43.64,
      "to": 45.96,
      "sid": 23,
      "location": 2,
      "content": "具体啊就看它的饱腹感怎么样了",
      "music": 0.0
    },
    {
      "from": 45.96,
      "to": 46.64,
      "sid": 24,
      "location": 2,
      "content": "先不管了",
      "music": 0.0
    },
    {
      "from": 46.64,
      "to": 47.56,
      "sid": 25,
      "location": 2,
      "content": "饱腹感怎么样",
      "music": 0.0
    },
    {
      "from": 47.56,
      "to": 48.68,
      "sid": 26,
      "location": 2,
      "content": "肝是真肝啊",
      "music": 0.0
    },
    {
      "from": 48.68,
      "to": 51.29,
      "sid": 27,
      "location": 2,
      "content": "包括我呢喝个水饱也是饱",
      "music": 0.0
    },
    {
      "from": 51.29,
      "to": 53.89,
      "sid": 28,
      "location": 2,
      "content": "下午02:17分练前餐",
      "music": 0.0
    },
    {
      "from": 53.89,
      "to": 54.87,
      "sid": 29,
      "location": 2,
      "content": "还是一个帕尼尼",
      "music": 0.0
    },
    {
      "from": 54.87,
      "to": 56.17,
      "sid": 30,
      "location": 2,
      "content": "我还点了一杯抹茶",
      "music": 0.0
    },
    {
      "from": 56.17,
      "to": 57.54,
      "sid": 31,
      "location": 2,
      "content": "补充一下膳食纤维",
      "music": 0.0
    },
    {
      "from": 57.54,
      "to": 59.0,
      "sid": 32,
      "location": 2,
      "content": "吃完就去练个背",
      "music": 0.0
    },
    {
      "from": 59.0,
      "to": 60.98,
      "sid": 33,
      "location": 2,
      "content": "今天的训练状态感觉还是很不错的",
      "music": 0.0
    },
    {
      "from": 60.98,
      "to": 62.44,
      "sid": 34,
      "location": 2,
      "content": "目前感觉切良好",
      "music": 0.0
    },
    {
      "from": 62.44,
      "to": 64.9,
      "sid": 35,
      "location": 2,
      "content": "练完咱们再来半个小时的有氧到家",
      "music": 0.0
    },
    {
      "from": 64.9,
      "to": 67.72,
      "sid": 36,
      "location": 2,
      "content": "六点钟练后餐跟晚餐咱们就一起吃了",
      "music": 0.0
    },
    {
      "from": 67.72,
      "to": 70.56,
      "sid": 37,
      "location": 2,
      "content": "我只能说这个量吧好像有点少",
      "music": 0.0
    },
    {
      "from": 70.56,
      "to": 72.54,
      "sid": 38,
      "location": 2,
      "content": "我们来给它稍微的加工一下",
      "music": 0.0
    },
    {
      "from": 72.54,
      "to": 73.78,
      "sid": 39,
      "location": 2,
      "content": "扯成这样的状态",
      "music": 0.0
    },
    {
      "from": 73.78,
      "to": 76.8,
      "sid": 40,
      "location": 2,
      "content": "是不是瞬间感觉就变多了",
      "music": 0.0
    },
    {
      "from": 77.0,
      "to": 78.8,
      "sid": 41,
      "location": 2,
      "content": "嗯总量没变",
      "music": 0.0
    },
    {
      "from": 78.8,
      "to": 81.94,
      "sid": 42,
      "location": 2,
      "content": "但是看着这一盘满足感瞬间就变强了",
      "music": 0.0
    },
    {
      "from": 81.94,
      "to": 84.24,
      "sid": 43,
      "location": 2,
      "content": "那么再搭配上一部好看的动漫",
      "music": 0.0
    },
    {
      "from": 84.24,
      "to": 86.44,
      "sid": 44,
      "location": 2,
      "content": "那真的是无敌了",
      "music": 0.0
    },
    {
      "from": 86.44,
      "to": 87.2,
      "sid": 45,
      "location": 2,
      "content": "早上起床",
      "music": 0.0
    },
    {
      "from": 87.2,
      "to": 88.8,
      "sid": 46,
      "location": 2,
      "content": "咱们先是做了半个小时的有氧",
      "music": 0.0
    },
    {
      "from": 88.8,
      "to": 90.32,
      "sid": 47,
      "location": 2,
      "content": "11:40分到家",
      "music": 0.0
    },
    {
      "from": 90.32,
      "to": 92.38,
      "sid": 48,
      "location": 2,
      "content": "这里啊是四个加热过的帕尼尼",
      "music": 0.0
    },
    {
      "from": 92.38,
      "to": 94.9,
      "sid": 49,
      "location": 2,
      "content": "这一加热它的芝士味会更明显一点",
      "music": 0.0
    },
    {
      "from": 94.9,
      "to": 96.26,
      "sid": 50,
      "location": 2,
      "content": "肌肉水润水润的",
      "music": 0.0
    },
    {
      "from": 96.26,
      "to": 97.46,
      "sid": 51,
      "location": 2,
      "content": "因为今天要练腿啊",
      "music": 0.0
    },
    {
      "from": 97.46,
      "to": 99.8,
      "sid": 52,
      "location": 2,
      "content": "所以我就把早餐和练前餐一起吃了",
      "music": 0.0
    },
    {
      "from": 99.8,
      "to": 100.9,
      "sid": 53,
      "location": 2,
      "content": "吃完休息会儿",
      "music": 0.0
    },
    {
      "from": 100.9,
      "to": 102.68,
      "sid": 54,
      "location": 2,
      "content": "咱们就开始痛苦的练腿日",
      "music": 0.0
    },
    {
      "from": 102.68,
      "to": 106.24,
      "sid": 55,
      "location": 2,
      "content": "说真的腿这个东西啊真的有人爱练吗",
      "music": 0.0
    },
    {
      "from": 106.24,
      "to": 107.84,
      "sid": 56,
      "location": 2,
      "content": "晚上七点钟到家",
      "music": 0.0
    },
    {
      "from": 107.84,
      "to": 110.08,
      "sid": 57,
      "location": 2,
      "content": "这个东西啊已经激不起我的食欲了",
      "music": 0.0
    },
    {
      "from": 110.08,
      "to": 112.0,
      "sid": 58,
      "location": 2,
      "content": "咱们把它成双成对的叠在一起啊",
      "music": 0.0
    },
    {
      "from": 112.0,
      "to": 113.68,
      "sid": 59,
      "location": 2,
      "content": "看看能不能产生一点新鲜感",
      "music": 0.0
    },
    {
      "from": 113.68,
      "to": 118.8,
      "sid": 60,
      "location": 2,
      "content": "哇嘶嗯就像是原本是普通汉堡",
      "music": 0.0
    },
    {
      "from": 118.8,
      "to": 121.52,
      "sid": 61,
      "location": 2,
      "content": "现在吃的是那个巨无霸一样",
      "music": 0.0
    },
    {
      "from": 121.52,
      "to": 122.64,
      "sid": 62,
      "location": 2,
      "content": "嗯死贵",
      "music": 0.0
    },
    {
      "from": 122.64,
      "to": 123.86,
      "sid": 63,
      "location": 2,
      "content": "味道还是那个味道",
      "music": 0.0
    },
    {
      "from": 123.86,
      "to": 125.04,
      "sid": 64,
      "location": 2,
      "content": "从营养方面分析啊",
      "music": 0.0
    },
    {
      "from": 125.04,
      "to": 126.82,
      "sid": 65,
      "location": 2,
      "content": "这么一个除了维生素少了一点",
      "music": 0.0
    },
    {
      "from": 126.82,
      "to": 127.98,
      "sid": 66,
      "location": 2,
      "content": "其他都还是不错的",
      "music": 0.0
    },
    {
      "from": 127.98,
      "to": 130.0,
      "sid": 67,
      "location": 2,
      "content": "所以我这两天也会搭配一点青汁",
      "music": 0.0
    },
    {
      "from": 130.0,
      "to": 131.52,
      "sid": 68,
      "location": 2,
      "content": "或者抹茶粉来吃它",
      "music": 0.0
    },
    {
      "from": 131.52,
      "to": 132.44,
      "sid": 69,
      "location": 2,
      "content": "早点睡觉",
      "music": 0.0
    },
    {
      "from": 132.44,
      "to": 133.58,
      "sid": 70,
      "location": 2,
      "content": "抑制食欲",
      "music": 0.0
    },
    {
      "from": 133.58,
      "to": 135.36,
      "sid": 71,
      "location": 2,
      "content": "早了一得later",
      "music": 0.0
    },
    {
      "from": 135.36,
      "to": 137.24,
      "sid": 72,
      "location": 2,
      "content": "现在是挑战第三天到05:30",
      "music": 0.0
    },
    {
      "from": 137.24,
      "to": 138.64,
      "sid": 73,
      "location": 2,
      "content": "为了让时间过得快一点",
      "music": 0.0
    },
    {
      "from": 138.64,
      "to": 139.78,
      "sid": 74,
      "location": 2,
      "content": "我就睡了个懒觉",
      "music": 0.0
    },
    {
      "from": 139.78,
      "to": 141.86,
      "sid": 75,
      "location": 2,
      "content": "刚刚起床去健身房简单练了个胸",
      "music": 0.0
    },
    {
      "from": 141.86,
      "to": 142.9,
      "sid": 76,
      "location": 2,
      "content": "这么三天吃下来",
      "music": 0.0
    },
    {
      "from": 142.9,
      "to": 144.86,
      "sid": 77,
      "location": 2,
      "content": "我感觉训练的状态还是挺好的",
      "music": 0.0
    },
    {
      "from": 144.86,
      "to": 146.62,
      "sid": 78,
      "location": 2,
      "content": "这里啊我就先吃四个帕尼尼亚",
      "music": 0.0
    },
    {
      "from": 146.62,
      "to": 147.5,
      "sid": 79,
      "location": 2,
      "content": "作为练后补充",
      "music": 0.0
    },
    {
      "from": 147.5,
      "to": 148.84,
      "sid": 80,
      "location": 2,
      "content": "从食物数据方面来看",
      "music": 0.0
    },
    {
      "from": 148.84,
      "to": 150.16,
      "sid": 81,
      "location": 2,
      "content": "一天吃八个帕尼尼亚",
      "music": 0.0
    },
    {
      "from": 150.16,
      "to": 152.42,
      "sid": 82,
      "location": 2,
      "content": "我的热量缺口大概是在300大卡左右",
      "music": 0.0
    },
    {
      "from": 152.42,
      "to": 153.84,
      "sid": 83,
      "location": 2,
      "content": "2216大卡",
      "music": 0.0
    },
    {
      "from": 153.84,
      "to": 156.5,
      "sid": 84,
      "location": 2,
      "content": "相当于汉堡王的两个三层皇堡",
      "music": 0.0
    },
    {
      "from": 156.5,
      "to": 158.26,
      "sid": 85,
      "location": 2,
      "content": "相比较之下",
      "music": 0.0
    },
    {
      "from": 158.26,
      "to": 160.34,
      "sid": 86,
      "location": 2,
      "content": "我好像更想吃汉堡王",
      "music": 0.0
    },
    {
      "from": 160.34,
      "to": 161.78,
      "sid": 87,
      "location": 2,
      "content": "但是再看看价格",
      "music": 0.0
    },
    {
      "from": 161.78,
      "to": 163.5,
      "sid": 88,
      "location": 2,
      "content": "这个性价比是真高啊",
      "music": 0.0
    },
    {
      "from": 163.5,
      "to": 166.3,
      "sid": 89,
      "location": 2,
      "content": "剩下的三个咱们就边看电视边慢慢吃啊",
      "music": 0.0
    },
    {
      "from": 166.3,
      "to": 168.78,
      "sid": 90,
      "location": 2,
      "content": "咱们期待一下明天的结果",
      "music": 0.0
    },
    {
      "from": 168.78,
      "to": 170.86,
      "sid": 91,
      "location": 2,
      "content": "Thousand years later",
      "music": 0.0
    },
    {
      "from": 170.86,
      "to": 173.32,
      "sid": 92,
      "location": 2,
      "content": "来看一下挑战题",
      "music": 0.0
    },
    {
      "from": 173.32,
      "to": 179.28,
      "sid": 93,
      "location": 2,
      "content": "诶诶诶93.4km才掉了这么一点",
      "music": 0.0
    }
  ]
}