{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 2.56,
      "sid": 1,
      "location": 2,
      "content": "我说的东西是很就很现实的对吧",
      "music": 0.0
    },
    {
      "from": 2.56,
      "to": 4.02,
      "sid": 2,
      "location": 2,
      "content": "尤其在超一线城市",
      "music": 0.0
    },
    {
      "from": 4.02,
      "to": 5.6,
      "sid": 3,
      "location": 2,
      "content": "帅哥这个物种啊",
      "music": 0.0
    },
    {
      "from": 5.6,
      "to": 8.98,
      "sid": 4,
      "location": 2,
      "content": "没有一个人是帅而不自知的",
      "music": 0.0
    },
    {
      "from": 8.98,
      "to": 10.1,
      "sid": 5,
      "location": 2,
      "content": "知道吗",
      "music": 0.0
    },
    {
      "from": 10.1,
      "to": 13.96,
      "sid": 6,
      "location": 2,
      "content": "他能在一个外美行业里边人都能称得上帅",
      "music": 0.0
    },
    {
      "from": 13.96,
      "to": 16.409,
      "sid": 7,
      "location": 2,
      "content": "他不可能是一个帅而不自知的人",
      "music": 0.0
    },
    {
      "from": 16.409,
      "to": 19.429,
      "sid": 8,
      "location": 2,
      "content": "那天啊我们去看了一个房子",
      "music": 0.0
    },
    {
      "from": 19.429,
      "to": 23.2,
      "sid": 9,
      "location": 2,
      "content": "然后呢就看到隔壁有一组客户接",
      "music": 0.0
    },
    {
      "from": 23.2,
      "to": 24.08,
      "sid": 10,
      "location": 2,
      "content": "就是接他们客户",
      "music": 0.0
    },
    {
      "from": 24.08,
      "to": 27.04,
      "sid": 11,
      "location": 2,
      "content": "就是一个超级帅的一个外国的男生",
      "music": 0.0
    },
    {
      "from": 27.04,
      "to": 28.29,
      "sid": 12,
      "location": 2,
      "content": "很帅",
      "music": 0.0
    },
    {
      "from": 28.29,
      "to": 29.31,
      "sid": 13,
      "location": 2,
      "content": "金头发",
      "music": 0.0
    },
    {
      "from": 29.31,
      "to": 30.71,
      "sid": 14,
      "location": 2,
      "content": "然后是白人",
      "music": 0.0
    },
    {
      "from": 30.71,
      "to": 32.19,
      "sid": 15,
      "location": 2,
      "content": "五官特别的精致",
      "music": 0.0
    },
    {
      "from": 32.19,
      "to": 34.15,
      "sid": 16,
      "location": 2,
      "content": "穿着一套定制西装",
      "music": 0.0
    },
    {
      "from": 34.15,
      "to": 35.27,
      "sid": 17,
      "location": 2,
      "content": "他是个销售",
      "music": 0.0
    },
    {
      "from": 35.27,
      "to": 36.77,
      "sid": 18,
      "location": 2,
      "content": "然后他就在给别人介绍",
      "music": 0.0
    },
    {
      "from": 36.77,
      "to": 39.09,
      "sid": 19,
      "location": 2,
      "content": "然后当时我们这个这个闺蜜联盟的团队里",
      "music": 0.0
    },
    {
      "from": 39.09,
      "to": 40.55,
      "sid": 20,
      "location": 2,
      "content": "有个女孩子非常漂亮",
      "music": 0.0
    },
    {
      "from": 40.55,
      "to": 41.77,
      "sid": 21,
      "location": 2,
      "content": "就是那天那个女孩子",
      "music": 0.0
    },
    {
      "from": 41.77,
      "to": 42.73,
      "sid": 22,
      "location": 2,
      "content": "我们把她照片一发出来",
      "music": 0.0
    },
    {
      "from": 42.73,
      "to": 43.37,
      "sid": 23,
      "location": 2,
      "content": "所有人都在说",
      "music": 0.0
    },
    {
      "from": 43.37,
      "to": 43.57,
      "sid": 24,
      "location": 2,
      "content": "天哪",
      "music": 0.0
    },
    {
      "from": 43.57,
      "to": 44.49,
      "sid": 25,
      "location": 2,
      "content": "这个女孩好漂亮",
      "music": 0.0
    },
    {
      "from": 44.49,
      "to": 45.83,
      "sid": 26,
      "location": 2,
      "content": "是非常漂亮",
      "music": 0.0
    },
    {
      "from": 45.83,
      "to": 47.239,
      "sid": 27,
      "location": 2,
      "content": "明星脸的",
      "music": 0.0
    },
    {
      "from": 47.239,
      "to": 48.619,
      "sid": 28,
      "location": 2,
      "content": "那个女孩子跟我说",
      "music": 0.0
    },
    {
      "from": 48.619,
      "to": 52.119,
      "sid": 29,
      "location": 2,
      "content": "她说她说曲姐如果是那个男的",
      "music": 0.0
    },
    {
      "from": 52.119,
      "to": 53.599,
      "sid": 30,
      "location": 2,
      "content": "她过来给我介绍房子",
      "music": 0.0
    },
    {
      "from": 53.599,
      "to": 58.39,
      "sid": 31,
      "location": 2,
      "content": "我今天高低都要买一套那么漂亮的一个美女啊",
      "music": 0.0
    },
    {
      "from": 58.39,
      "to": 61.2,
      "sid": 32,
      "location": 2,
      "content": "每天被那些大佬趋之若鹜的美女",
      "music": 0.0
    },
    {
      "from": 61.2,
      "to": 62.48,
      "sid": 33,
      "location": 2,
      "content": "他就看到那个帅哥",
      "music": 0.0
    },
    {
      "from": 62.48,
      "to": 62.84,
      "sid": 34,
      "location": 2,
      "content": "他跟我说",
      "music": 0.0
    },
    {
      "from": 62.84,
      "to": 64.8,
      "sid": 35,
      "location": 2,
      "content": "他说他要是来给我买房子",
      "music": 0.0
    },
    {
      "from": 64.8,
      "to": 66.22,
      "sid": 36,
      "location": 2,
      "content": "我真的我高低我要买一套",
      "music": 0.0
    },
    {
      "from": 66.22,
      "to": 67.44,
      "sid": 37,
      "location": 2,
      "content": "他都会觉得不好意思",
      "music": 0.0
    },
    {
      "from": 67.44,
      "to": 70.73,
      "sid": 38,
      "location": 2,
      "content": "因为他很想享受这个帅哥对他认可的目光嘛",
      "music": 0.0
    },
    {
      "from": 71.3,
      "to": 72.16,
      "sid": 39,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 72.16,
      "to": 73.16,
      "sid": 40,
      "location": 2,
      "content": "你们想想看",
      "music": 0.0
    },
    {
      "from": 73.16,
      "to": 76.86,
      "sid": 41,
      "location": 2,
      "content": "她还是一个自己平常那么受追捧的一个大美女",
      "music": 0.0
    },
    {
      "from": 76.86,
      "to": 79.28,
      "sid": 42,
      "location": 2,
      "content": "你再想想那些没有",
      "music": 0.0
    },
    {
      "from": 79.28,
      "to": 81.86,
      "sid": 43,
      "location": 2,
      "content": "平常没有找过什么帅哥的是吧",
      "music": 0.0
    },
    {
      "from": 81.86,
      "to": 84.02,
      "sid": 44,
      "location": 2,
      "content": "完了以后又觉得这个男孩子哎呀",
      "music": 0.0
    },
    {
      "from": 84.02,
      "to": 85.12,
      "sid": 45,
      "location": 2,
      "content": "服务我服务的又好",
      "music": 0.0
    },
    {
      "from": 85.12,
      "to": 86.7,
      "sid": 46,
      "location": 2,
      "content": "人家又是干又是个正经人",
      "music": 0.0
    },
    {
      "from": 86.7,
      "to": 87.26,
      "sid": 47,
      "location": 2,
      "content": "什么叫正经人呢",
      "music": 0.0
    },
    {
      "from": 87.26,
      "to": 87.94,
      "sid": 48,
      "location": 2,
      "content": "这不是嘎子",
      "music": 0.0
    },
    {
      "from": 87.94,
      "to": 88.9,
      "sid": 49,
      "location": 2,
      "content": "都不是干夜场的",
      "music": 0.0
    },
    {
      "from": 88.9,
      "to": 89.58,
      "sid": 50,
      "location": 2,
      "content": "是个正经人哎",
      "music": 0.0
    },
    {
      "from": 89.58,
      "to": 90.58,
      "sid": 51,
      "location": 2,
      "content": "在这正经上班",
      "music": 0.0
    },
    {
      "from": 90.58,
      "to": 91.3,
      "sid": 52,
      "location": 2,
      "content": "正经工作",
      "music": 0.0
    },
    {
      "from": 91.3,
      "to": 94.08,
      "sid": 53,
      "location": 2,
      "content": "这些个富婆里头单身的多不多",
      "music": 0.0
    },
    {
      "from": 94.44,
      "to": 95.56,
      "sid": 54,
      "location": 2,
      "content": "单身的多不多",
      "music": 0.0
    },
    {
      "from": 95.56,
      "to": 99.21,
      "sid": 55,
      "location": 2,
      "content": "我告诉你们在外美圈里面啊",
      "music": 0.0
    },
    {
      "from": 99.21,
      "to": 102.55,
      "sid": 56,
      "location": 2,
      "content": "不管是里头的这些顾问销售",
      "music": 0.0
    },
    {
      "from": 102.55,
      "to": 107.285,
      "sid": 57,
      "location": 2,
      "content": "还是客户这个里边大把大把的单身",
      "music": 0.0
    },
    {
      "from": 108.21,
      "to": 111.17,
      "sid": 58,
      "location": 2,
      "content": "怎么你以为人家这些富婆都是这么有老公的",
      "music": 0.0
    },
    {
      "from": 111.17,
      "to": 112.23,
      "sid": 59,
      "location": 2,
      "content": "不是吧",
      "music": 0.0
    },
    {
      "from": 112.23,
      "to": 113.63,
      "sid": 60,
      "location": 2,
      "content": "你知道在中国的超一线",
      "music": 0.0
    },
    {
      "from": 113.63,
      "to": 115.07,
      "sid": 61,
      "location": 2,
      "content": "就是呈现一个这样的状态的呀",
      "music": 0.0
    },
    {
      "from": 115.07,
      "to": 116.75,
      "sid": 62,
      "location": 2,
      "content": "很多女的都非常会赚钱",
      "music": 0.0
    },
    {
      "from": 116.75,
      "to": 118.91,
      "sid": 63,
      "location": 2,
      "content": "但是这些女的她们都单身找",
      "music": 0.0
    },
    {
      "from": 118.91,
      "to": 119.47,
      "sid": 64,
      "location": 2,
      "content": "找不到老公",
      "music": 0.0
    },
    {
      "from": 119.47,
      "to": 120.699,
      "sid": 65,
      "location": 2,
      "content": "对男人要求太高",
      "music": 0.0
    },
    {
      "from": 120.699,
      "to": 123.559,
      "sid": 66,
      "location": 2,
      "content": "但是他们在这种场合里面认识这男的呀",
      "music": 0.0
    },
    {
      "from": 123.559,
      "to": 124.779,
      "sid": 67,
      "location": 2,
      "content": "为了去消化他",
      "music": 0.0
    },
    {
      "from": 124.779,
      "to": 128.209,
      "sid": 68,
      "location": 2,
      "content": "是不是会给她无微不至的这种体验",
      "music": 0.0
    },
    {
      "from": 128.529,
      "to": 129.809,
      "sid": 69,
      "location": 2,
      "content": "他说他的道德底线高",
      "music": 0.0
    },
    {
      "from": 129.809,
      "to": 130.609,
      "sid": 70,
      "location": 2,
      "content": "他的道德底线高",
      "music": 0.0
    },
    {
      "from": 130.609,
      "to": 132.809,
      "sid": 71,
      "location": 2,
      "content": "他是不是最后还是跟一个比她大15岁的",
      "music": 0.0
    },
    {
      "from": 132.809,
      "to": 134.57,
      "sid": 72,
      "location": 2,
      "content": "一个女客户劈叉了呢",
      "music": 0.0
    },
    {
      "from": 134.97,
      "to": 137.62,
      "sid": 73,
      "location": 2,
      "content": "这还仅仅只是一个开头嘛",
      "music": 0.0
    },
    {
      "from": 137.9,
      "to": 141.02,
      "sid": 74,
      "location": 2,
      "content": "他仅仅只是他从业半年的一个开头嘛",
      "music": 0.0
    },
    {
      "from": 141.02,
      "to": 143.94,
      "sid": 75,
      "location": 2,
      "content": "他在这个里面拿不拿得到好处",
      "music": 0.0
    },
    {
      "from": 143.94,
      "to": 147.2,
      "sid": 76,
      "location": 2,
      "content": "你不会告诉我说他绝对一分钱好处没拿着吧",
      "music": 0.0
    },
    {
      "from": 147.4,
      "to": 148.44,
      "sid": 77,
      "location": 2,
      "content": "不是实实在在的",
      "music": 0.0
    },
    {
      "from": 148.44,
      "to": 150.36,
      "sid": 78,
      "location": 2,
      "content": "只给绝对也是业绩",
      "music": 0.0
    },
    {
      "from": 150.36,
      "to": 152.08,
      "sid": 79,
      "location": 2,
      "content": "大家同不同意啊",
      "music": 0.0
    },
    {
      "from": 153.15,
      "to": 156.83,
      "sid": 80,
      "location": 2,
      "content": "本来人家只准备一次性搞一个地方",
      "music": 0.0
    },
    {
      "from": 157.83,
      "to": 159.75,
      "sid": 81,
      "location": 2,
      "content": "有些东西呢它可搞可不搞",
      "music": 0.0
    },
    {
      "from": 159.75,
      "to": 160.66,
      "sid": 82,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 160.66,
      "to": 162.9,
      "sid": 83,
      "location": 2,
      "content": "但是由于这个帅哥把我服务的非常好",
      "music": 0.0
    },
    {
      "from": 162.9,
      "to": 163.92,
      "sid": 84,
      "location": 2,
      "content": "我对他非常感兴趣",
      "music": 0.0
    },
    {
      "from": 163.92,
      "to": 164.82,
      "sid": 85,
      "location": 2,
      "content": "我就跟他说",
      "music": 0.0
    },
    {
      "from": 164.82,
      "to": 165.62,
      "sid": 86,
      "location": 2,
      "content": "哎没事嘛",
      "music": 0.0
    },
    {
      "from": 165.62,
      "to": 167.04,
      "sid": 87,
      "location": 2,
      "content": "我现在你就充个100万",
      "music": 0.0
    },
    {
      "from": 167.04,
      "to": 169.51,
      "sid": 88,
      "location": 2,
      "content": "反正我养护总是要花钱的",
      "music": 0.0
    },
    {
      "from": 169.75,
      "to": 170.45,
      "sid": 89,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 170.45,
      "to": 171.55,
      "sid": 90,
      "location": 2,
      "content": "我100万完了以后",
      "music": 0.0
    },
    {
      "from": 171.55,
      "to": 172.57,
      "sid": 91,
      "location": 2,
      "content": "我先充着呗",
      "music": 0.0
    },
    {
      "from": 172.57,
      "to": 173.79,
      "sid": 92,
      "location": 2,
      "content": "可不可能",
      "music": 0.0
    },
    {
      "from": 173.79,
      "to": 175.57,
      "sid": 93,
      "location": 2,
      "content": "然后我再约一约你呗",
      "music": 0.0
    },
    {
      "from": 175.57,
      "to": 178.11,
      "sid": 94,
      "location": 2,
      "content": "啊我再勾搭勾搭你呗",
      "music": 0.0
    },
    {
      "from": 179.18,
      "to": 181.86,
      "sid": 95,
      "location": 2,
      "content": "冲进去的都是我自己的钱对吧",
      "music": 0.0
    },
    {
      "from": 181.86,
      "to": 183.78,
      "sid": 96,
      "location": 2,
      "content": "都是我要用在我自己脸上的钱",
      "music": 0.0
    },
    {
      "from": 183.78,
      "to": 184.9,
      "sid": 97,
      "location": 2,
      "content": "这个钱又没有人发这个钱",
      "music": 0.0
    },
    {
      "from": 184.9,
      "to": 186.36,
      "sid": 98,
      "location": 2,
      "content": "他总不是放在那个地方",
      "music": 0.0
    },
    {
      "from": 186.36,
      "to": 188.34,
      "sid": 99,
      "location": 2,
      "content": "我一年到头我在哪消费都是消费",
      "music": 0.0
    },
    {
      "from": 188.34,
      "to": 190.16,
      "sid": 100,
      "location": 2,
      "content": "但是我今天我就看中你这个小帅哥了",
      "music": 0.0
    },
    {
      "from": 190.16,
      "to": 193.7,
      "sid": 101,
      "location": 2,
      "content": "我就愿意在你这给你搞业绩行不行",
      "music": 0.0
    },
    {
      "from": 193.98,
      "to": 195.64,
      "sid": 102,
      "location": 2,
      "content": "我也不是直接划给你的呀",
      "music": 0.0
    },
    {
      "from": 195.64,
      "to": 197.88,
      "sid": 103,
      "location": 2,
      "content": "我并不是说一上来我就哐哐哐给你买",
      "music": 0.0
    },
    {
      "from": 197.88,
      "to": 198.58,
      "sid": 104,
      "location": 2,
      "content": "今天给你买表",
      "music": 0.0
    },
    {
      "from": 198.58,
      "to": 199.98,
      "sid": 105,
      "location": 2,
      "content": "明天给你买车也不是吧",
      "music": 0.0
    },
    {
      "from": 199.98,
      "to": 201.62,
      "sid": 106,
      "location": 2,
      "content": "这个事情大家都乐意的",
      "music": 0.0
    },
    {
      "from": 201.62,
      "to": 203.94,
      "sid": 107,
      "location": 2,
      "content": "这个事情不都两方都合算吗",
      "music": 0.0
    },
    {
      "from": 203.94,
      "to": 206.1,
      "sid": 108,
      "location": 2,
      "content": "男孩子也会觉得我没有出卖我的灵魂",
      "music": 0.0
    },
    {
      "from": 207.38,
      "to": 208.11,
      "sid": 109,
      "location": 2,
      "content": "对不对",
      "music": 0.0
    },
    {
      "from": 208.11,
      "to": 209.35,
      "sid": 110,
      "location": 2,
