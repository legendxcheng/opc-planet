{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "sync-v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.52,
      "sid": 1,
      "location": 2,
      "content": "对于我们这个商业的这一块",
      "music": 0.0
    },
    {
      "from": 1.52,
      "to": 3.54,
      "sid": 2,
      "location": 2,
      "content": "你们也可以全盘的去听一下",
      "music": 0.0
    },
    {
      "from": 3.54,
      "to": 4.68,
      "sid": 3,
      "location": 2,
      "content": "咳咳咳",
      "music": 0.0
    },
    {
      "from": 4.68,
      "to": 8.02,
      "sid": 4,
      "location": 2,
      "content": "这个就是其实我经常跟你们讲短视频带货这个事嘛",
      "music": 0.0
    },
    {
      "from": 8.02,
      "to": 13.79,
      "sid": 5,
      "location": 2,
      "content": "我说其实短视频带货这个事是很多人呢相对来说上手会快一点的东西",
      "music": 0.0
    },
    {
      "from": 13.79,
      "to": 21.66,
      "sid": 6,
      "location": 2,
      "content": "你们不要相信市面上很多人动不动上来就跟你们讲做IP",
      "music": 0.0
    },
    {
      "from": 22.7,
      "to": 26.08,
      "sid": 7,
      "location": 2,
      "content": "你们不要动不动就想做个人IP",
      "music": 0.0
    },
    {
      "from": 26.08,
      "to": 26.94,
      "sid": 8,
      "location": 2,
      "content": "知道吗",
      "music": 0.0
    },
    {
      "from": 26.94,
      "to": 29.7,
      "sid": 9,
      "location": 2,
      "content": "个人IP它不是谁都能干的",
      "music": 0.0
    },
    {
      "from": 29.7,
      "to": 36.38,
      "sid": 10,
      "location": 2,
      "content": "个人IP它意味着是你这个个人有非常强大的个人魅力",
      "music": 0.0
    },
    {
      "from": 36.38,
      "to": 39.43,
      "sid": 11,
      "location": 2,
      "content": "不可复制的人生经历",
      "music": 0.0
    },
    {
      "from": 39.43,
      "to": 42.45,
      "sid": 12,
      "location": 2,
      "content": "就是你这个人一说话你就发光",
      "music": 0.0
    },
    {
      "from": 42.45,
      "to": 43.91,
      "sid": 13,
      "location": 2,
      "content": "你站在台前",
      "music": 0.0
    },
    {
      "from": 43.91,
      "to": 46.83,
      "sid": 14,
      "location": 2,
      "content": "别人就是只想看你这个东西",
      "music": 0.0
    },
    {
      "from": 46.83,
      "to": 48.64,
      "sid": 15,
      "location": 2,
      "content": "他叫个人IP",
      "music": 0.0
    },
    {
      "from": 49.16,
      "to": 52.42,
      "sid": 16,
      "location": 2,
      "content": "很多人他们说哎我们帮你打造个人IP",
      "music": 0.0
    },
    {
      "from": 52.42,
      "to": 54.32,
      "sid": 17,
      "location": 2,
      "content": "这个东西就就就有点扯淡",
      "music": 0.0
    },
    {
      "from": 54.32,
      "to": 56.48,
      "sid": 18,
      "location": 2,
      "content": "你就不如叫短视频带货",
      "music": 0.0
    },
    {
      "from": 56.48,
      "to": 58.64,
      "sid": 19,
      "location": 2,
      "content": "你也可以叫短视频带服务",
      "music": 0.0
    },
    {
      "from": 58.64,
      "to": 59.82,
      "sid": 20,
      "location": 2,
      "content": "短视频带货",
      "music": 0.0
    },
    {
      "from": 59.82,
      "to": 62.8,
      "sid": 21,
      "location": 2,
      "content": "短视频做起宣对吧",
      "music": 0.0
    },
    {
      "from": 62.8,
      "to": 66.52,
      "sid": 22,
      "location": 2,
      "content": "以我通过短视频的方式给我们做企业宣传",
      "music": 0.0
    },
    {
      "from": 66.52,
      "to": 68.68,
      "sid": 23,
      "location": 2,
      "content": "给我的业务做推广对吧",
      "music": 0.0
    },
    {
      "from": 68.68,
      "to": 69.74,
      "sid": 24,
      "location": 2,
      "content": "这个是没有问题的",
      "music": 0.0
    },
    {
      "from": 69.74,
      "to": 71.52,
      "sid": 25,
      "location": 2,
      "content": "但你们不要动不动就谈什么",
      "music": 0.0
    },
    {
      "from": 71.52,
      "to": 74.14,
      "sid": 26,
      "location": 2,
      "content": "我要去做个人IP",
      "music": 0.0
    },
    {
      "from": 74.98,
      "to": 77.52,
      "sid": 27,
      "location": 2,
      "content": "那个东西叫舍近求远",
      "music": 0.0
    },
    {
      "from": 77.52,
      "to": 79.26,
      "sid": 28,
      "location": 2,
      "content": "你做不起来个人IP",
      "music": 0.0
    },
    {
      "from": 79.26,
      "to": 81.98,
      "sid": 29,
      "location": 2,
      "content": "最后你发现你没有变现的产品",
      "music": 0.0
    },
    {
      "from": 81.98,
      "to": 83.18,
      "sid": 30,
      "location": 2,
      "content": "在后端",
      "music": 0.0
    },
    {
      "from": 83.18,
      "to": 84.94,
      "sid": 31,
      "location": 2,
      "content": "你天天在前台说啊",
      "music": 0.0
    },
    {
      "from": 84.94,
      "to": 87.82,
      "sid": 32,
      "location": 2,
      "content": "我也想给大家展示我的生活啊",
      "music": 0.0
    },
    {
      "from": 87.82,
      "to": 89.18,
      "sid": 33,
      "location": 2,
      "content": "给大家讲我的价值观",
      "music": 0.0
    },
    {
      "from": 89.18,
      "to": 90.949,
      "sid": 34,
      "location": 2,
      "content": "你那个生活有什么好展示的呢",
      "music": 0.0
    },
    {
      "from": 90.949,
      "to": 93.149,
      "sid": 35,
      "location": 2,
      "content": "你那个价值观有什么特别的呢",
      "music": 0.0
    },
    {
      "from": 93.149,
      "to": 96.81,
      "sid": 36,
      "location": 2,
      "content": "你不就是芸芸众生当中的普通一个对吧",
      "music": 0.0
    },
    {
      "from": 96.81,
      "to": 97.95,
      "sid": 37,
      "location": 2,
      "content": "卖书书吧",
      "music": 0.0
    },
    {
      "from": 97.95,
      "to": 99.45,
      "sid": 38,
      "location": 2,
      "content": "原来也没好好读台台嘛",
      "music": 0.0
    },
    {
      "from": 99.45,
      "to": 100.25,
      "sid": 39,
      "location": 2,
      "content": "也没上过几个",
      "music": 0.0
    },
    {
      "from": 100.25,
      "to": 102.45,
      "sid": 40,
      "location": 2,
      "content": "你这你也没有得过什么奖",
      "music": 0.0
    },
    {
      "from": 102.45,
      "to": 105.07,
      "sid": 41,
      "location": 2,
      "content": "你自己没有什么人说哎呀",
      "music": 0.0
    },
    {
      "from": 105.07,
      "to": 105.99,
      "sid": 42,
      "location": 2,
      "content": "我觉得你好厉害",
      "music": 0.0
    },
    {
      "from": 105.99,
      "to": 106.47,
      "sid": 43,
      "location": 2,
      "content": "没有",
      "music": 0.0
    },
    {
      "from": 106.47,
      "to": 110.52,
      "sid": 44,
      "location": 2,
      "content": "你一直就是这样平平凡凡的这样走过来的",
      "music": 0.0
    },
    {
      "from": 110.52,
      "to": 112.96,
      "sid": 45,
      "location": 2,
      "content": "你上来就动不动就我要个人IP",
      "music": 0.0
    },
    {
      "from": 112.96,
      "to": 114.9,
      "sid": 46,
      "location": 2,
      "content": "别IP你就带货",
      "music": 0.0
    },
    {
      "from": 114.9,
      "to": 116.4,
      "sid": 47,
      "location": 2,
      "content": "你就是搞钱",
      "music": 0.0
    },
    {
      "from": 116.4,
      "to": 118.04,
      "sid": 48,
      "location": 2,
      "content": "懂不懂你就赚钱",
      "music": 0.0
    },
    {
      "from": 118.04,
      "to": 120.84,
      "sid": 49,
      "location": 2,
      "content": "你卖一单就是一单的钱就完事了",
      "music": 0.0
    },
    {
      "from": 122.0,
      "to": 123.24,
      "sid": 50,
      "location": 2,
      "content": "你看我不是老说我妈",
      "music": 0.0
    },
    {
      "from": 123.24,
      "to": 124.41,
      "sid": 51,
      "location": 2,
      "content": "我妈不是",
      "music": 0.0
    },
    {
      "from": 124.41,
      "to": 127.37,
      "sid": 52,
      "location": 2,
      "content": "前两天我们那个朋友带他跑到我们家来",
      "music": 0.0
    },
    {
      "from": 127.37,
      "to": 128.39,
      "sid": 53,
      "location": 2,
      "content": "非要让他带火",
      "music": 0.0
    },
    {
      "from": 128.39,
      "to": 129.45,
      "sid": 54,
      "location": 2,
      "content": "让她拍短视频",
      "music": 0.0
    },
    {
      "from": 129.45,
      "to": 130.99,
      "sid": 55,
      "location": 2,
      "content": "他啥也不会说",
      "music": 0.0
    },
    {
      "from": 130.99,
      "to": 135.03,
      "sid": 56,
      "location": 2,
      "content": "他们他嗯拿着个麦片在那跳舞呵",
      "music": 0.0
    },
    {
      "from": 135.03,
      "to": 139.63,
      "sid": 57,
      "location": 2,
      "content": "人家跳舞就那还能带个300多块钱哈哈赚300多块钱啊",
      "music": 0.0
    },
    {
      "from": 139.63,
      "to": 140.87,
      "sid": 58,
      "location": 2,
      "content": "不是带300多块钱",
      "music": 0.0
    },
    {
      "from": 140.87,
      "to": 142.27,
      "sid": 59,
      "location": 2,
      "content": "就那拍个视频",
      "music": 0.0
    },
    {
      "from": 142.27,
      "to": 145.7,
      "sid": 60,
      "location": 2,
      "content": "他还他还整个300多块钱的收入呢",
      "music": 0.0
    },
    {
      "from": 146.45,
      "to": 149.69,
      "sid": 61,
      "location": 2,
      "content": "他打一个麻将不也就赢个三五百对吧",
      "music": 0.0
    },
    {
      "from": 149.69,
      "to": 150.41,
      "sid": 62,
      "location": 2,
      "content": "他带个饼干",
      "music": 0.0
    },
    {
      "from": 150.41,
      "to": 154.3,
      "sid": 63,
      "location": 2,
      "content": "他也是挣个三五百哈哈哈",
      "music": 0.0
    },
    {
      "from": 154.3,
      "to": 157.63,
      "sid": 64,
      "location": 2,
      "content": "他还让他还让开心出镜",
      "music": 0.0
    },
    {
      "from": 157.63,
      "to": 160.43,
      "sid": 65,
      "location": 2,
      "content": "帮他把个那个麦片拿着在他手上",
      "music": 0.0
    },
    {
      "from": 160.43,
      "to": 161.19,
      "sid": 66,
      "location": 2,
      "content": "在那绝局的",
      "music": 0.0
    },
    {
      "from": 161.19,
      "to": 162.97,
      "sid": 67,
      "location": 2,
      "content": "我说你跟人开心给钱没啊",
      "music": 0.0
    },
    {
      "from": 162.97,
      "to": 165.415,
      "sid": 68,
      "location": 2,
      "content": "你天天亲犯别人肖像权",
      "music": 0.0
    },
    {
      "from": 166.94,
      "to": 167.76,
      "sid": 69,
      "location": 2,
      "content": "是吧",
      "music": 0.0
    },
    {
      "from": 167.76,
      "to": 168.7,
      "sid": 70,
      "location": 2,
      "content": "商业这个东西",
      "music": 0.0
    },
    {
      "from": 168.7,
      "to": 171.9,
      "sid": 71,
      "location": 2,
      "content": "所以我说你们要打到最后一个标点符号上",
      "music": 0.0
    },
    {
      "from": 171.9,
      "to": 174.42,
      "sid": 72,
      "location": 2,
      "content": "打到最后一个动作上",
      "music": 0.0
    },
    {
      "from": 175.71,
      "to": 177.47,
      "sid": 73,
      "location": 2,
      "content": "你能赚到钱",
      "music": 0.0
    },
    {
      "from": 177.47,
      "to": 180.33,
      "sid": 74,
      "location": 2,
      "content": "一单赚了赚十单",
      "music": 0.0
    },
    {
      "from": 180.33,
      "to": 182.89,
      "sid": 75,
      "location": 2,
      "content": "十单赚了赚100单",
      "music": 0.0
    },
    {
      "from": 182.89,
      "to": 184.53,
      "sid": 76,
      "location": 2,
      "content": "这样的一个逻辑",
      "music": 0.0
    },
    {
      "from": 184.53,
      "to": 185.43,
      "sid": 77,
      "location": 2,
      "content": "她就对了",
      "music": 0.0
    },
    {
      "from": 185.43,
      "to": 187.21,
      "sid": 78,
      "location": 2,
      "content": "像这个女孩子尤其如此",
      "music": 0.0
    },
    {
      "from": 187.21,
      "to": 189.69,
      "sid": 79,
      "location": 2,
      "content": "她是可以通过先做短视频",
      "music": 0.0
    },
    {
      "from": 189.69,
      "to": 191.35,
      "sid": 80,
      "location": 2,
      "content": "短视频已经赚了这么多钱",
      "music": 0.0
    },
    {
      "from": 191.35,
      "to": 193.769,
      "sid": 81,
      "location": 2,
      "content": "然后再去找上端的供应链",
      "music": 0.0
    },
    {
      "from": 193.769,
      "to": 196.169,
      "sid": 82,
      "location": 2,
      "content": "然后拿到供应链更低的价格",
      "music": 0.0
    },
    {
      "from": 196.169,
      "to": 197.309,
      "sid": 83,
      "location": 2,
      "content": "更优惠的政策",
      "music": 0.0
    },
    {
      "from": 197.309,
      "to": 200.189,
      "sid": 84,
      "location": 2,
      "content": "然后再作用到自己的这个短视频带货里边是吧",
      "music": 0.0
    },
    {
      "from": 200.189,
      "to": 201.569,
      "sid": 85,
      "location": 2,
      "content": "哪怕他带同样的货",
      "music": 0.0
    },
    {
      "from": 201.569,
      "to": 202.89,
      "sid": 86,
      "location": 2,
      "content": "但它的利润率提高",
      "music": 0.0
    },
    {
      "from": 202.89,
      "to": 205.65,
      "sid": 87,
      "location": 2,
      "content": "然后再拿到这些供应链的资源之后",
      "music": 0.0
    },
    {
      "from": 205.65,
      "to": 208.85,
      "sid": 88,
      "location": 2,
      "content": "再去做他的直播带货",
      "music": 0.0
    },
    {
      "from": 209.44,
      "to": 211.24,
      "sid": 89,
      "location": 2,
      "content": "他的直播带货再做起来了",
      "music": 0.0
    },
    {
      "from": 211.24,
      "to": 213.769,
      "sid": 90,
      "location": 2,
      "content": "这个时候他形成了一个完整的一个IP形象",
      "music": 0.0
    },
    {
      "from": 213.769,
      "to": 215.909,
      "sid": 91,
      "location": 2,
      "content": "就是它既能短视频带货成功",
      "music": 0.0
    },
    {
      "from": 215.909,
      "to": 217.289,
      "sid": 92,
      "location": 2,
      "content": "它也能直播带货成功",
      "music": 0.0
    },
    {
      "from": 217.289,
      "to": 219.82,
      "sid": 93,
      "location": 2,
      "content": "同时它还有比较好的供应链资源",
      "music": 0.0
    },
    {
      "from": 219.82,
      "to": 222.54,
      "sid": 94,
      "location": 2,
      "content": "这样一个三位一体的东西",
      "music": 0.0
    },
    {
      "from": 222.54,
      "to": 224.62,
      "sid": 95,
      "location": 2,
      "content": "再来把他这个人推出来",
      "music": 0.0
    },
    {
      "from": 224.62,
      "to": 227.22,
      "sid": 96,
      "location": 2,
      "content": "形成他的个人IP",
      "music": 0.0
    },
    {
      "from": 227.5,
      "to": 229.4,
      "sid": 97,
      "location": 2,
      "content": "再有了这个个人IP",
      "music": 0.0
    },
    {
      "from": 229.4,
      "to": 231.3,
      "sid": 98,
      "location": 2,
      "content": "下一步才叫品牌",
      "music": 0.0
    },
    {
      "from": 232.58,
      "to": 233.38,
      "sid": 99,
      "location": 2,
      "content": "没有什么东西",
      "music": 0.0
    },
    {
      "from": 233.38,
      "to": 235.32,
      "sid": 100,
      "location": 2,
      "content": "它是一步登天干出来的",
      "music": 0.0
    },
    {
      "from": 235.32,
      "to": 237.43,
      "sid": 101,
      "location": 2,
      "content": "一步登天是干不出来的",
      "music": 0.0
    },
    {
      "from": 237.43,
      "to": 240.15,
      "sid": 102,
      "location": 2,
      "content": "一想一上来就想着我要做多大个生意",
      "music": 0.0
    },
    {
      "from": 240.15,
      "to": 241.19,
      "sid": 103,
      "location": 2,
      "content": "我要做多大个买卖",
      "music": 0.0
    },
    {
      "from": 241.19,
      "to": 245.16,
      "sid": 104,
      "location": 2,
      "content": "然后那个小钱看不起不想挣的那大钱都挣不明白啊",
      "music": 0.0
    },
    {
      "from": 245.16,
      "to": 247.24,
      "sid": 105,
      "location": 2,
      "content": "他为什么不能找别人直播",
      "music": 0.0
    },
    {
      "from": 247.24,
      "to": 249.03,
      "sid": 106,
      "location": 2,
      "content": "因为",
      "music": 0.0
    },
    {
      "from": 249.95,
      "to": 252.25,
      "sid": 107,
      "location": 2,
      "content": "嗯你们现在可以去刷一下啊",
      "music": 0.0
    },
    {
      "from": 252.25,
      "to": 254.39,
