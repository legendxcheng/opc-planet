{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.14,
      "sid": 1,
      "location": 2,
      "content": "你见过这样的国家吗",
      "music": 0.0
    },
    {
      "from": 1.14,
      "to": 3.72,
      "sid": 2,
      "location": 2,
      "content": "他高喊着人民当家做主的口号",
      "music": 0.0
    },
    {
      "from": 6.76,
      "to": 9.44,
      "sid": 3,
      "location": 2,
      "content": "宣称自己是人类历史上第一个",
      "music": 0.0
    },
    {
      "from": 11.72,
      "to": 13.4,
      "sid": 4,
      "location": 2,
      "content": "他们却用一道严苛的法令",
      "music": 0.0
    },
    {
      "from": 13.4,
      "to": 15.6,
      "sid": 5,
      "location": 2,
      "content": "将国家的主人禁锢在流水线上",
      "music": 0.0
    },
    {
      "from": 15.6,
      "to": 17.56,
      "sid": 6,
      "location": 2,
      "content": "沦为国家工业发展上的奴隶",
      "music": 0.0
    },
    {
      "from": 17.56,
      "to": 19.08,
      "sid": 7,
      "location": 2,
      "content": "这可不是什么反乌托邦",
      "music": 0.0
    },
    {
      "from": 19.08,
      "to": 19.99,
      "sid": 8,
      "location": 2,
      "content": "电影里的情节",
      "music": 0.0
    },
    {
      "from": 19.99,
      "to": 22.17,
      "sid": 9,
      "location": 2,
      "content": "而是真真切切发生过的现实",
      "music": 0.0
    },
    {
      "from": 22.17,
      "to": 23.39,
      "sid": 10,
      "location": 2,
      "content": "1940年6月",
      "music": 0.0
    },
    {
      "from": 23.39,
      "to": 26.62,
      "sid": 11,
      "location": 2,
      "content": "一道荒唐的劳动法在苏联横空出世",
      "music": 0.0
    },
    {
      "from": 26.62,
      "to": 28.48,
      "sid": 12,
      "location": 2,
      "content": "在延长工作时间的同时",
      "music": 0.0
    },
    {
      "from": 28.48,
      "to": 31.72,
      "sid": 13,
      "location": 2,
      "content": "还将矿工和离职列入到刑事犯罪的范畴",
      "music": 0.0
    },
    {
      "from": 35.42,
      "to": 38.92,
      "sid": 14,
      "location": 2,
      "content": "这事儿从里到外都透着一股诡异的荒唐",
      "music": 0.0
    },
    {
      "from": 38.92,
      "to": 41.08,
      "sid": 15,
      "location": 2,
      "content": "一个标榜解放全人类的国家",
      "music": 0.0
    },
    {
      "from": 41.08,
      "to": 43.08,
      "sid": 16,
      "location": 2,
      "content": "为何要用最严苛的法律",
      "music": 0.0
    },
    {
      "from": 43.08,
      "to": 45.28,
      "sid": 17,
      "location": 2,
      "content": "把自己的工人控制在工厂里",
      "music": 0.0
    },
    {
      "from": 45.28,
      "to": 47.74,
      "sid": 18,
      "location": 2,
      "content": "一个本应是国家主人的阶级",
      "music": 0.0
    },
    {
      "from": 47.74,
      "to": 50.46,
      "sid": 19,
      "location": 2,
      "content": "为何连迟到一分钟的自由都没有",
      "music": 0.0
    },
    {
      "from": 50.46,
      "to": 53.98,
      "sid": 20,
      "location": 2,
      "content": "甚至连生病照顾家人都成了犯罪的前提",
      "music": 0.0
    },
    {
      "from": 53.98,
      "to": 56.74,
      "sid": 21,
      "location": 2,
      "content": "今天我们就来聊聊这条荒唐的劳动法",
      "music": 0.0
    },
    {
      "from": 56.74,
      "to": 59.9,
      "sid": 22,
      "location": 2,
      "content": "看看他是如何把国家的主人逼成了行尸走肉",
      "music": 0.0
    },
    {
      "from": 59.9,
      "to": 62.98,
      "sid": 23,
      "location": 2,
      "content": "又如何为帝国的崩塌埋下最深的伏笔",
      "music": 0.0
    },
    {
      "from": 62.98,
      "to": 64.86,
      "sid": 24,
      "location": 2,
      "content": "1924年1月21日",
      "music": 0.0
    },
    {
      "from": 64.86,
      "to": 66.82,
      "sid": 25,
      "location": 2,
      "content": "伟大的无产阶级革命家",
      "music": 0.0
    },
    {
      "from": 66.82,
      "to": 70.63,
      "sid": 26,
      "location": 2,
      "content": "苏联的缔造者列宁因中风突然离世",
      "music": 0.0
    },
    {
      "from": 70.63,
      "to": 72.41,
      "sid": 27,
      "location": 2,
      "content": "享年54岁",
      "music": 0.0
    },
    {
      "from": 72.41,
      "to": 73.43,
      "sid": 28,
      "location": 2,
      "content": "列宁死后",
      "music": 0.0
    },
    {
      "from": 73.43,
      "to": 75.42,
      "sid": 29,
      "location": 2,
      "content": "苏联内部的矛盾迅速激化",
      "music": 0.0
    },
    {
      "from": 78.14,
      "to": 80.14,
      "sid": 30,
      "location": 2,
      "content": "后来自格鲁吉亚的暴脾气",
      "music": 0.0
    },
    {
      "from": 80.14,
      "to": 81.0,
      "sid": 31,
      "location": 2,
      "content": "斯大林上位",
      "music": 0.0
    },
    {
      "from": 81.0,
      "to": 82.83,
      "sid": 32,
      "location": 2,
      "content": "成为苏联第二代话事人",
      "music": 0.0
    },
    {
      "from": 82.83,
      "to": 85.53,
      "sid": 33,
      "location": 2,
      "content": "这位主张国家至上的格鲁吉亚人掌权后",
      "music": 0.0
    },
    {
      "from": 85.53,
      "to": 87.21,
      "sid": 34,
      "location": 2,
      "content": "立刻就对列宁留下的遗产",
      "music": 0.0
    },
    {
      "from": 87.21,
      "to": 88.9,
      "sid": 35,
      "location": 2,
      "content": "展开了大刀阔斧的改革",
      "music": 0.0
    },
    {
      "from": 88.9,
      "to": 91.1,
      "sid": 36,
      "location": 2,
      "content": "他废除了列宁时代的新经济政策",
      "music": 0.0
    },
    {
      "from": 91.1,
      "to": 93.74,
      "sid": 37,
      "location": 2,
      "content": "将市场机制彻底赶出了苏联社会",
      "music": 0.0
    },
    {
      "from": 93.74,
      "to": 95.58,
      "sid": 38,
      "location": 2,
      "content": "而为了应对外来势力的威胁",
      "music": 0.0
    },
    {
      "from": 95.58,
      "to": 98.56,
      "sid": 39,
      "location": 2,
      "content": "他将国家重心放在了军事产业和重工业上",
      "music": 0.0
    },
    {
      "from": 98.56,
      "to": 102.04,
      "sid": 40,
      "location": 2,
      "content": "誓要用10年时间走完资本主义世界100年的路",
      "music": 0.0
    },
    {
      "from": 102.04,
      "to": 105.72,
      "sid": 41,
      "location": 2,
      "content": "于是一场轰轰烈烈又近乎疯狂的工业化运动",
      "music": 0.0
    },
    {
      "from": 105.72,
      "to": 106.26,
      "sid": 42,
      "location": 2,
      "content": "开始了",
      "music": 0.0
    },
    {
      "from": 106.26,
      "to": 107.78,
      "sid": 43,
      "location": 2,
      "content": "在5年计划的框架下",
      "music": 0.0
    },
    {
      "from": 107.78,
      "to": 110.1,
      "sid": 44,
      "location": 2,
      "content": "苏联工业规模迎来火箭般的提升",
      "music": 0.0
    },
    {
      "from": 110.1,
      "to": 113.479,
      "sid": 45,
      "location": 2,
      "content": "乌拉尔工业区的工厂如雨后春笋一般拔地而起",
      "music": 0.0
    },
    {
      "from": 113.479,
      "to": 115.399,
      "sid": 46,
      "location": 2,
      "content": "顿巴斯的煤矿彻夜运作",
      "music": 0.0
    },
    {
      "from": 115.399,
      "to": 117.719,
      "sid": 47,
      "location": 2,
      "content": "煤炭钢铁产量迅速翻倍",
      "music": 0.0
    },
    {
      "from": 117.719,
      "to": 120.039,
      "sid": 48,
      "location": 2,
      "content": "在短时间内实现了弯道超车",
      "music": 0.0
    },
    {
      "from": 120.039,
      "to": 122.25,
      "sid": 49,
      "location": 2,
      "content": "一跃成为欧洲第一工业国",
      "music": 0.0
    },
    {
      "from": 124.41,
      "to": 126.27,
      "sid": 50,
      "location": 2,
      "content": "背后是看不见的牺牲",
      "music": 0.0
    },
    {
      "from": 126.27,
      "to": 128.75,
      "sid": 51,
      "location": 2,
      "content": "那些投身国家工业建设的工人们",
      "music": 0.0
    },
    {
      "from": 128.75,
      "to": 130.519,
      "sid": 52,
      "location": 2,
      "content": "他们的生活是什么样的",
      "music": 0.0
    },
    {
      "from": 130.519,
      "to": 131.919,
      "sid": 53,
      "location": 2,
      "content": "首先在待遇上",
      "music": 0.0
    },
    {
      "from": 131.919,
      "to": 134.12,
      "sid": 54,
      "location": 2,
      "content": "苏联工人的薪水微薄的可怜",
      "music": 0.0
    },
    {
      "from": 134.12,
      "to": 136.28,
      "sid": 55,
      "location": 2,
      "content": "大部分工人拿到的薪水仅仅够",
      "music": 0.0
    },
    {
      "from": 136.28,
      "to": 138.06,
      "sid": 56,
      "location": 2,
      "content": "勉强维持一家人的基本生存",
      "music": 0.0
    },
    {
      "from": 138.06,
      "to": 139.2,
      "sid": 57,
      "location": 2,
      "content": "食品配给的不足",
      "music": 0.0
    },
    {
      "from": 139.2,
      "to": 142.38,
      "sid": 58,
      "location": 2,
      "content": "让饥饿成为那个时代苏联工人们最熟悉的朋友",
      "music": 0.0
    },
    {
      "from": 142.38,
      "to": 145.32,
      "sid": 59,
      "location": 2,
      "content": "其次工作环境与也是恶劣到了极点",
      "music": 0.0
    },
    {
      "from": 145.32,
      "to": 147.32,
      "sid": 60,
      "location": 2,
      "content": "为了追求更有效的生产方式",
      "music": 0.0
    },
    {
      "from": 147.32,
      "to": 150.08,
      "sid": 61,
      "location": 2,
      "content": "苏联官方几乎将所有工业经费都用在了",
      "music": 0.0
    },
    {
      "from": 150.08,
      "to": 152.22,
      "sid": 62,
      "location": 2,
      "content": "购买海外机械和雇佣专家身上",
      "music": 0.0
    },
    {
      "from": 152.22,
      "to": 153.96,
      "sid": 63,
      "location": 2,
      "content": "安全建设基本没有",
      "music": 0.0
    },
    {
      "from": 153.96,
      "to": 155.04,
      "sid": 64,
      "location": 2,
      "content": "车间里的噪音",
      "music": 0.0
    },
    {
      "from": 155.04,
      "to": 155.8,
      "sid": 65,
      "location": 2,
      "content": "震耳欲聋",
      "music": 0.0
    },
    {
      "from": 155.8,
      "to": 156.76,
      "sid": 66,
      "location": 2,
      "content": "空气污浊",
      "music": 0.0
    },
    {
      "from": 156.76,
      "to": 158.56,
      "sid": 67,
      "location": 2,
      "content": "工伤事故频繁发生",
      "music": 0.0
    },
    {
      "from": 158.56,
      "to": 161.68,
      "sid": 68,
      "location": 2,
      "content": "不少工人连爽像样的劳保手套都没有",
      "music": 0.0
    },
    {
      "from": 161.68,
      "to": 163.88,
      "sid": 69,
      "location": 2,
      "content": "于是在各种负面因素的影响下",
      "music": 0.0
    },
    {
      "from": 163.88,
      "to": 165.18,
      "sid": 70,
      "location": 2,
      "content": "一条最朴素",
      "music": 0.0
    },
    {
      "from": 165.18,
      "to": 168.26,
      "sid": 71,
      "location": 2,
      "content": "最直接的反抗之路摆在了苏联工人面前",
      "music": 0.0
    },
    {
      "from": 168.26,
      "to": 169.36,
      "sid": 72,
      "location": 2,
      "content": "那就是一个字",
      "music": 0.0
    },
    {
      "from": 169.36,
      "to": 171.379,
      "sid": 73,
      "location": 2,
      "content": "跑工人不是傻子",
      "music": 0.0
    },
    {
      "from": 171.379,
      "to": 172.679,
      "sid": 74,
      "location": 2,
      "content": "在工厂累死累活",
      "music": 0.0
    },
    {
      "from": 172.679,
      "to": 173.439,
      "sid": 75,
      "location": 2,
      "content": "还吃不饱",
      "music": 0.0
    },
    {
      "from": 173.439,
      "to": 175.67,
      "sid": 76,
      "location": 2,
      "content": "还有受伤没命的风险不跑",
      "music": 0.0
    },
    {
      "from": 175.67,
      "to": 177.59,
      "sid": 77,
      "location": 2,
      "content": "等着领导给家里人发抚恤金啊",
      "music": 0.0
    },
    {
      "from": 179.61,
      "to": 181.55,
      "sid": 78,
      "location": 2,
      "content": "苏联的劳动力是相对自由的",
      "music": 0.0
    },
    {
      "from": 181.55,
      "to": 183.99,
      "sid": 79,
      "location": 2,
      "content": "企业没有权利阻止工人辞职",
      "music": 0.0
    },
    {
      "from": 183.99,
      "to": 187.63,
      "sid": 80,
      "location": 2,
      "content": "于是劳动力流失的风在苏联工业体系内刮起来",
      "music": 0.0
    },
    {
      "from": 187.63,
      "to": 189.35,
      "sid": 81,
      "location": 2,
      "content": "工人们开始货比三家",
      "music": 0.0
    },
    {
      "from": 189.35,
      "to": 190.38,
      "sid": 82,
      "location": 2,
      "content": "骑驴找马",
      "music": 0.0
    },
    {
      "from": 190.38,
      "to": 193.22,
      "sid": 83,
      "location": 2,
      "content": "要么向环境待遇好的厂子那边讨生活",
      "music": 0.0
    },
    {
      "from": 193.22,
      "to": 194.9,
      "sid": 84,
      "location": 2,
      "content": "要么干脆跑到乡下",
      "music": 0.0
    },
    {
      "from": 194.9,
      "to": 196.34,
      "sid": 85,
      "location": 2,
      "content": "甚至向东拓荒",
      "music": 0.0
    },
    {
      "from": 196.34,
      "to": 198.93,
      "sid": 86,
      "location": 2,
      "content": "然而这种大规模的劳动力流失",
      "music": 0.0
    },
    {
      "from": 198.93,
      "to": 200.79,
      "sid": 87,
      "location": 2,
      "content": "对于苏联而言是致命的",
      "music": 0.0
    },
    {
      "from": 200.79,
      "to": 203.81,
      "sid": 88,
      "location": 2,
      "content": "我们都知道苏联的经济模式是指令性的",
      "music": 0.0
    },
    {
      "from": 203.81,
      "to": 206.29,
      "sid": 89,
      "location": 2,
      "content": "国家计划委员会负责制定生产计划",
      "music": 0.0
    },
    {
      "from": 206.29,
      "to": 209.49,
      "sid": 90,
      "location": 2,
      "content": "用人话来讲就是今年要造多少工业品",
      "music": 0.0
    },
    {
      "from": 209.49,
      "to": 210.65,
      "sid": 91,
      "location": 2,
      "content": "大致需要多少",
      "music": 0.0
    },
    {
      "from": 210.65,
      "to": 211.14,
      "sid": 92,
      "location": 2,
      "content": "工人",
      "music": 0.0
    },
    {
      "from": 211.14,
      "to": 212.94,
      "sid": 93,
      "location": 2,
      "content": "都是根据计算来的",
      "music": 0.0
    },
    {
      "from": 212.94,
      "to": 215.0,
      "sid": 94,
      "location": 2,
      "content": "结果赶上劳动力流失的风潮",
      "music": 0.0
    },
    {
      "from": 215.0,
      "to": 215.98,
      "sid": 95,
      "location": 2,
      "content": "工人跑了",
      "music": 0.0
    },
    {
      "from": 215.98,
      "to": 217.62,
      "sid": 96,
      "location": 2,
      "content": "计划自然就落空了",
      "music": 0.0
    },
    {
      "from": 217.62,
      "to": 220.48,
      "sid": 97,
      "location": 2,
      "content": "宏伟的工业蓝图瞬间就成了一纸空文",
      "music": 0.0
    },
    {
      "from": 220.48,
      "to": 222.52,
      "sid": 98,
      "location": 2,
      "content": "那些坐镇中央和地方政府",
      "music": 0.0
    },
    {
      "from": 222.52,
      "to": 224.56,
      "sid": 99,
      "location": 2,
      "content": "整日指点江山的职业官僚们",
      "music": 0.0
    },
    {
      "from": 224.56,
      "to": 226.5,
      "sid": 100,
      "location": 2,
      "content": "看着如雪片般飞来的报告",
      "music": 0.0
    },
    {
      "from": 226.5,
      "to": 228.06,
      "sid": 101,
      "location": 2,
      "content": "可谓是心急如焚",
      "music": 0.0
    },
    {
      "from": 228.06,
      "to": 228.85,
      "sid": 102,
      "location": 2,
      "content": "怎么办",
      "music": 0.0
    },
    {
      "from": 228.85,
      "to": 230.45,
      "sid": 103,
      "location": 2,
      "content": "给工人改善待遇",
      "music": 0.0
    },
    {
      "from": 230.45,
      "to": 232.53,
      "sid": 104,
      "location": 2,
      "content": "加工资那可不行",
      "music": 0.0
    },
    {
      "from": 232.53,
      "to": 234.53,
      "sid": 105,
      "location": 2,
      "content": "加工资要花真金白银",
      "music": 0.0
    },
    {
      "from": 234.53,
      "to": 236.43,
