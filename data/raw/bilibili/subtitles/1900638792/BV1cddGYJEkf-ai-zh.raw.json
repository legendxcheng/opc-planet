{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.1,
      "to": 2.94,
      "sid": 1,
      "location": 2,
      "content": "现在有很多招聘类的博主在教别人",
      "music": 0.0
    },
    {
      "from": 2.94,
      "to": 4.08,
      "sid": 2,
      "location": 2,
      "content": "面试技巧的时候",
      "music": 0.0
    },
    {
      "from": 4.08,
      "to": 7.1,
      "sid": 3,
      "location": 2,
      "content": "他们会建议大家把自我介绍的时长",
      "music": 0.0
    },
    {
      "from": 7.1,
      "to": 8.2,
      "sid": 4,
      "location": 2,
      "content": "控制在3分钟",
      "music": 0.0
    },
    {
      "from": 8.2,
      "to": 9.879,
      "sid": 5,
      "location": 2,
      "content": "或者说5分钟以内",
      "music": 0.0
    },
    {
      "from": 9.879,
      "to": 12.999,
      "sid": 6,
      "location": 2,
      "content": "但是根据我自己面试别人的经验来看",
      "music": 0.0
    },
    {
      "from": 12.999,
      "to": 13.999,
      "sid": 7,
      "location": 2,
      "content": "不是这样的",
      "music": 0.0
    },
    {
      "from": 13.999,
      "to": 15.539,
      "sid": 8,
      "location": 2,
      "content": "5分钟远远不够",
      "music": 0.0
    },
    {
      "from": 15.539,
      "to": 17.08,
      "sid": 9,
      "location": 2,
      "content": "至少要8分钟",
      "music": 0.0
    },
    {
      "from": 17.08,
      "to": 19.5,
      "sid": 10,
      "location": 2,
      "content": "甚至对于案例丰富的人来讲",
      "music": 0.0
    },
    {
      "from": 19.5,
      "to": 22.479,
      "sid": 11,
      "location": 2,
      "content": "要准备10分钟左右的自我介绍",
      "music": 0.0
    },
    {
      "from": 22.479,
      "to": 26.119,
      "sid": 12,
      "location": 2,
      "content": "网上比较普遍的3分钟自我介绍的模板",
      "music": 0.0
    },
    {
      "from": 26.119,
      "to": 27.73,
      "sid": 13,
      "location": 2,
      "content": "它其实格式没错",
      "music": 0.0
    },
    {
      "from": 27.73,
      "to": 30.59,
      "sid": 14,
      "location": 2,
      "content": "他的第一部分也就是前30秒",
      "music": 0.0
    },
    {
      "from": 30.59,
      "to": 32.439,
      "sid": 15,
      "location": 2,
      "content": "先介绍你的背景信息",
      "music": 0.0
    },
    {
      "from": 32.439,
      "to": 34.459,
      "sid": 16,
      "location": 2,
      "content": "比如说什么学校毕业的",
      "music": 0.0
    },
    {
      "from": 34.459,
      "to": 35.999,
      "sid": 17,
      "location": 2,
      "content": "过去主要的工作岗位",
      "music": 0.0
    },
    {
      "from": 35.999,
      "to": 36.93,
      "sid": 18,
      "location": 2,
      "content": "工作年限",
      "music": 0.0
    },
    {
      "from": 36.93,
      "to": 39.25,
      "sid": 19,
      "location": 2,
      "content": "第二部分就是一分钟的时间",
      "music": 0.0
    },
    {
      "from": 39.25,
      "to": 41.3,
      "sid": 20,
      "location": 2,
      "content": "盘点过去每一家的工作经历",
      "music": 0.0
    },
    {
      "from": 41.3,
      "to": 43.62,
      "sid": 21,
      "location": 2,
      "content": "比如说在A公司担任什么岗位",
      "music": 0.0
    },
    {
      "from": 43.62,
      "to": 44.76,
      "sid": 22,
      "location": 2,
      "content": "工作内容是什么",
      "music": 0.0
    },
    {
      "from": 44.76,
      "to": 46.3,
      "sid": 23,
      "location": 2,
      "content": "B公司是什么岗位",
      "music": 0.0
    },
    {
      "from": 46.3,
      "to": 47.209,
      "sid": 24,
      "location": 2,
      "content": "主要做什么",
      "music": 0.0
    },
    {
      "from": 47.209,
      "to": 48.169,
      "sid": 25,
      "location": 2,
      "content": "第三部分",
      "music": 0.0
    },
    {
      "from": 48.169,
      "to": 51.79,
      "sid": 26,
      "location": 2,
      "content": "再用一分钟的时间介绍你做过的不错的案例",
      "music": 0.0
    },
    {
      "from": 51.79,
      "to": 54.35,
      "sid": 27,
      "location": 2,
      "content": "以及呢这个案例对应了你哪个技能",
      "music": 0.0
    },
    {
      "from": 54.35,
      "to": 57.65,
      "sid": 28,
      "location": 2,
      "content": "最后第四部分用30秒的时间总结陈词",
      "music": 0.0
    },
    {
      "from": 57.65,
      "to": 59.05,
      "sid": 29,
      "location": 2,
      "content": "比如未来3年规划",
      "music": 0.0
    },
    {
      "from": 59.05,
      "to": 60.61,
      "sid": 30,
      "location": 2,
      "content": "为什么面试这个岗位",
      "music": 0.0
    },
    {
      "from": 60.61,
      "to": 63.39,
      "sid": 31,
      "location": 2,
      "content": "这个模板就是四段式开头经历",
      "music": 0.0
    },
    {
      "from": 63.39,
      "to": 64.5,
      "sid": 32,
      "location": 2,
      "content": "案例结尾",
      "music": 0.0
    },
    {
      "from": 64.5,
      "to": 66.54,
      "sid": 33,
      "location": 2,
      "content": "而案例是最重点的部分",
      "music": 0.0
    },
    {
      "from": 66.54,
      "to": 68.58,
      "sid": 34,
      "location": 2,
      "content": "那如果是5分钟的自我介绍",
      "music": 0.0
    },
    {
      "from": 68.58,
      "to": 71.25,
      "sid": 35,
      "location": 2,
      "content": "就会把案例的部分再展开讲2分钟",
      "music": 0.0
    },
    {
      "from": 71.25,
      "to": 73.13,
      "sid": 36,
      "location": 2,
      "content": "但是实际情况是",
      "music": 0.0
    },
    {
      "from": 73.13,
      "to": 76.07,
      "sid": 37,
      "location": 2,
      "content": "案例部分应该花更多的时间去展示",
      "music": 0.0
    },
    {
      "from": 76.07,
      "to": 80.27,
      "sid": 38,
      "location": 2,
      "content": "因为自我介绍环节是你在整个面试过程当中",
      "music": 0.0
    },
    {
      "from": 80.27,
      "to": 83.289,
      "sid": 39,
      "location": 2,
      "content": "唯一可以主动展示自己的环节",
      "music": 0.0
    },
    {
      "from": 83.289,
      "to": 86.609,
      "sid": 40,
      "location": 2,
      "content": "自我介绍的时候没有展示出来的案例和能力",
      "music": 0.0
    },
    {
      "from": 86.609,
      "to": 88.9,
      "sid": 41,
      "location": 2,
      "content": "后面就很难再穿插展示了",
      "music": 0.0
    },
    {
      "from": 88.9,
      "to": 92.5,
      "sid": 42,
      "location": 2,
      "content": "虽然自我介绍环节之后还有问答环节",
      "music": 0.0
    },
    {
      "from": 92.5,
      "to": 95.3,
      "sid": 43,
      "location": 2,
      "content": "但问答环节基本上是面试官问你",
      "music": 0.0
    },
    {
      "from": 95.3,
      "to": 96.77,
      "sid": 44,
      "location": 2,
      "content": "而不是你去问面试官",
      "music": 0.0
    },
    {
      "from": 96.77,
      "to": 100.35,
      "sid": 45,
      "location": 2,
      "content": "那如果对方没有问到你某个技能或者案例",
      "music": 0.0
    },
    {
      "from": 100.35,
      "to": 101.85,
      "sid": 46,
      "location": 2,
      "content": "你就只能打断对方",
      "music": 0.0
    },
    {
      "from": 101.85,
      "to": 104.42,
      "sid": 47,
      "location": 2,
      "content": "然后又重新开始做起自我介绍",
      "music": 0.0
    },
    {
      "from": 104.42,
      "to": 108.12,
      "sid": 48,
      "location": 2,
      "content": "所以你不如把你想介绍的案例和技能",
      "music": 0.0
    },
    {
      "from": 108.12,
      "to": 110.68,
      "sid": 49,
      "location": 2,
      "content": "全都在自我介绍环节展示完",
      "music": 0.0
    },
    {
      "from": 110.68,
      "to": 114.69,
      "sid": 50,
      "location": 2,
      "content": "在刚才那个自我介绍模板不变的情况下",
      "music": 0.0
    },
    {
      "from": 114.69,
      "to": 116.15,
      "sid": 51,
      "location": 2,
      "content": "继续增加案例",
      "music": 0.0
    },
    {
      "from": 116.15,
      "to": 117.89,
      "sid": 52,
      "location": 2,
      "content": "这个部分的时长就可以",
      "music": 0.0
    },
    {
      "from": 117.89,
      "to": 119.57,
      "sid": 53,
      "location": 2,
      "content": "比如展开讲三个案例",
      "music": 0.0
    },
    {
      "from": 119.57,
      "to": 121.17,
      "sid": 54,
      "location": 2,
      "content": "然后每个案例2分钟",
      "music": 0.0
    },
    {
      "from": 121.17,
      "to": 122.34,
      "sid": 55,
      "location": 2,
      "content": "那就是6分钟",
      "music": 0.0
    },
    {
      "from": 122.34,
      "to": 124.04,
      "sid": 56,
      "location": 2,
      "content": "再加上开头经历",
      "music": 0.0
    },
    {
      "from": 124.04,
      "to": 126.53,
      "sid": 57,
      "location": 2,
      "content": "结尾差不多就是8分钟的时间",
      "music": 0.0
    },
    {
      "from": 126.53,
      "to": 128.57,
      "sid": 58,
      "location": 2,
      "content": "那有些人可能不太清楚",
      "music": 0.0
    },
    {
      "from": 128.57,
      "to": 130.73,
      "sid": 59,
      "location": 2,
      "content": "要怎么展示自己的案例和能力",
      "music": 0.0
    },
    {
      "from": 130.73,
      "to": 133.27,
      "sid": 60,
      "location": 2,
      "content": "我在上一期内容里有总结过",
      "music": 0.0
    },
    {
      "from": 133.27,
      "to": 136.29,
      "sid": 61,
      "location": 2,
      "content": "面试的时候怎么展示自己能力的公式",
      "music": 0.0
    },
    {
      "from": 136.29,
      "to": 139.03,
      "sid": 62,
      "location": 2,
      "content": "也就是契机动作困难",
      "music": 0.0
    },
    {
      "from": 139.03,
      "to": 142.21,
      "sid": 63,
      "location": 2,
      "content": "结果它其实是一个讲故事的公式",
      "music": 0.0
    },
    {
      "from": 142.21,
      "to": 146.05,
      "sid": 64,
      "location": 2,
      "content": "这个公式是根据SCQA模型演变过来的",
      "music": 0.0
    },
    {
      "from": 146.05,
      "to": 148.39,
      "sid": 65,
      "location": 2,
      "content": "ICQA模型是写作模型",
      "music": 0.0
    },
    {
      "from": 148.39,
      "to": 151.81,
      "sid": 66,
      "location": 2,
      "content": "一般给领导画饼的时候也会用到这个模型",
      "music": 0.0
    },
    {
      "from": 151.81,
      "to": 154.23,
      "sid": 67,
      "location": 2,
      "content": "总之契机动作困难",
      "music": 0.0
    },
    {
      "from": 154.23,
      "to": 158.2,
      "sid": 68,
      "location": 2,
      "content": "结果这个公式能够让一个没有参与过项目的人",
      "music": 0.0
    },
    {
      "from": 158.2,
      "to": 160.46,
      "sid": 69,
      "location": 2,
      "content": "或者不了解你方案专业性的人",
      "music": 0.0
    },
    {
      "from": 160.46,
      "to": 161.74,
      "sid": 70,
      "location": 2,
      "content": "首先愿意听",
      "music": 0.0
    },
    {
      "from": 161.74,
      "to": 162.54,
      "sid": 71,
      "location": 2,
      "content": "愿意信",
      "music": 0.0
    },
    {
      "from": 162.54,
      "to": 166.32,
      "sid": 72,
      "location": 2,
      "content": "其次你在描述是怎么解决困难的这个过程中",
      "music": 0.0
    },
    {
      "from": 166.32,
      "to": 168.22,
      "sid": 73,
      "location": 2,
      "content": "他也能让面试官了解到",
      "music": 0.0
    },
    {
      "from": 168.22,
      "to": 170.42,
      "sid": 74,
      "location": 2,
      "content": "你的这个能力是真的有价值",
      "music": 0.0
    },
    {
      "from": 170.42,
      "to": 173.84,
      "sid": 75,
      "location": 2,
      "content": "因为哪怕面试官跟你是同个部门的人",
      "music": 0.0
    },
    {
      "from": 173.84,
      "to": 176.09,
      "sid": 76,
      "location": 2,
      "content": "你们细分岗位可能也不一样",
      "music": 0.0
    },
    {
      "from": 176.09,
      "to": 177.53,
      "sid": 77,
      "location": 2,
      "content": "比如我做的新媒体",
      "music": 0.0
    },
    {
      "from": 177.53,
      "to": 181.269,
      "sid": 78,
      "location": 2,
      "content": "一般在市场部市场负责人基本都是品牌出身",
      "music": 0.0
    },
    {
      "from": 181.269,
      "to": 184.769,
      "sid": 79,
      "location": 2,
      "content": "而新媒体是最近几年的一个新型岗位",
      "music": 0.0
    },
    {
      "from": 184.769,
      "to": 187.61,
      "sid": 80,
      "location": 2,
      "content": "所以品牌出身的人大概率不懂新媒体",
      "music": 0.0
    },
    {
      "from": 187.61,
      "to": 189.33,
      "sid": 81,
      "location": 2,
      "content": "那你就要通过这个公式",
      "music": 0.0
    },
    {
      "from": 189.33,
      "to": 192.43,
      "sid": 82,
      "location": 2,
      "content": "让对方知道你岗位和技能的重要性",
      "music": 0.0
    },
    {
      "from": 192.43,
      "to": 196.269,
      "sid": 83,
      "location": 2,
      "content": "我拿我之前在美团外卖做过的案例来举个例子",
      "music": 0.0
    },
    {
      "from": 196.269,
      "to": 199.789,
      "sid": 84,
      "location": 2,
      "content": "契机是我刚接手美团外卖的抖音",
      "music": 0.0
    },
    {
      "from": 199.789,
      "to": 202.769,
      "sid": 85,
      "location": 2,
      "content": "发现账号只要不投放就没有自然流",
      "music": 0.0
    },
    {
      "from": 202.769,
      "to": 206.85,
      "sid": 86,
      "location": 2,
      "content": "后来我发现刚发布就投流的行为会挤压自然流",
      "music": 0.0
    },
    {
      "from": 206.85,
      "to": 208.25,
      "sid": 87,
      "location": 2,
      "content": "为了解决这个问题",
      "music": 0.0
    },
    {
      "from": 208.25,
      "to": 212.08,
      "sid": 88,
      "location": 2,
      "content": "我们决定减少投放来降低负面效果",
      "music": 0.0
    },
    {
      "from": 212.08,
      "to": 216.76,
      "sid": 89,
      "location": 2,
      "content": "并且呢更换内容类型来寻求更高的自然流量",
      "music": 0.0
    },
    {
      "from": 216.76,
      "to": 220.32,
      "sid": 90,
      "location": 2,
      "content": "总之你做任何一件事情都是有原因的",
      "music": 0.0
    },
    {
      "from": 220.32,
      "to": 222.78,
      "sid": 91,
      "location": 2,
      "content": "契机环节就是在解释原因",
      "music": 0.0
    },
    {
      "from": 222.78,
      "to": 226.079,
      "sid": 92,
      "location": 2,
      "content": "然后动作是进行内容改版",
      "music": 0.0
    },
    {
      "from": 226.079,
      "to": 229.699,
      "sid": 93,
      "location": 2,
      "content": "我们在网上看到万能的外卖小哥这个话题很火",
      "music": 0.0
    },
    {
      "from": 229.699,
      "to": 232.05,
      "sid": 94,
      "location": 2,
      "content": "所以就把它作为一个内容类型",
      "music": 0.0
    },
    {
      "from": 232.05,
      "to": 234.45,
      "sid": 95,
      "location": 2,
      "content": "然后招募会做饭的小哥",
      "music": 0.0
    },
    {
      "from": 234.45,
      "to": 236.67,
      "sid": 96,
      "location": 2,
      "content": "会跑酷的小哥来拍摄视频",
      "music": 0.0
    },
    {
      "from": 236.67,
      "to": 239.789,
      "sid": 97,
      "location": 2,
      "content": "困难是拍摄和剪辑过程中发现",
      "music": 0.0
    },
    {
      "from": 239.789,
      "to": 241.909,
      "sid": 98,
      "location": 2,
      "content": "第一摆拍痕迹太明显",
      "music": 0.0
    },
    {
      "from": 241.909,
      "to": 243.569,
      "sid": 99,
      "location": 2,
      "content": "让观众缺少代入感",
      "music": 0.0
    },
    {
      "from": 243.569,
      "to": 246.289,
      "sid": 100,
      "location": 2,
      "content": "第二真实的外卖小哥不是专业演员",
      "music": 0.0
    },
    {
      "from": 246.289,
      "to": 247.64,
      "sid": 101,
      "location": 2,
      "content": "表演能力有限",
      "music": 0.0
    },
    {
      "from": 247.64,
      "to": 250.46,
      "sid": 102,
      "location": 2,
      "content": "所以我们调试了很多不同的拍摄视角",
      "music": 0.0
    },
    {
      "from": 250.46,
      "to": 254.26,
      "sid": 103,
      "location": 2,
      "content": "并且尽量规避拍摄外卖小哥的正脸",
      "music": 0.0
    },
    {
      "from": 254.26,
      "to": 257.14,
      "sid": 104,
      "location": 2,
      "content": "最后结果是内容专栏上线一个月",
      "music": 0.0
    },
    {
      "from": 257.14,
      "to": 260.17,
      "sid": 105,
      "location": 2,
      "content": "就出了好几支播放量几百万的小爆款",
