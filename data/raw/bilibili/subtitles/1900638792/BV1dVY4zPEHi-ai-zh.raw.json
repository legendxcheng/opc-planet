{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 2.56,
      "sid": 1,
      "location": 2,
      "content": "恐怖直立猿的性情总是神挡杀神",
      "music": 0.0
    },
    {
      "from": 2.56,
      "to": 3.4,
      "sid": 2,
      "location": 2,
      "content": "佛挡杀佛的",
      "music": 0.0
    },
    {
      "from": 3.4,
      "to": 4.92,
      "sid": 3,
      "location": 2,
      "content": "尽管敌人已尽数消灭",
      "music": 0.0
    },
    {
      "from": 4.92,
      "to": 6.4,
      "sid": 4,
      "location": 2,
      "content": "人类种族仅存一脉",
      "music": 0.0
    },
    {
      "from": 6.4,
      "to": 7.9,
      "sid": 5,
      "location": 2,
      "content": "但总是让人拔刀四顾",
      "music": 0.0
    },
    {
      "from": 7.9,
      "to": 10.58,
      "sid": 6,
      "location": 2,
      "content": "这地球真的只有咱们一种智慧生物吗",
      "music": 0.0
    },
    {
      "from": 10.58,
      "to": 13.06,
      "sid": 7,
      "location": 2,
      "content": "人眼只能看到电磁波中的可见光",
      "music": 0.0
    },
    {
      "from": 13.06,
      "to": 14.02,
      "sid": 8,
      "location": 2,
      "content": "却看不到红外线",
      "music": 0.0
    },
    {
      "from": 14.02,
      "to": 15.22,
      "sid": 9,
      "location": 2,
      "content": "所以当你晚上出门",
      "music": 0.0
    },
    {
      "from": 15.22,
      "to": 15.9,
      "sid": 10,
      "location": 2,
      "content": "两眼一黑",
      "music": 0.0
    },
    {
      "from": 15.9,
      "to": 17.58,
      "sid": 11,
      "location": 2,
      "content": "并不是人家藏在夜色里",
      "music": 0.0
    },
    {
      "from": 17.58,
      "to": 19.14,
      "sid": 12,
      "location": 2,
      "content": "只是自己的眼睛观察不到",
      "music": 0.0
    },
    {
      "from": 19.14,
      "to": 21.9,
      "sid": 13,
      "location": 2,
      "content": "那就有一种可能地球上还有别的智慧生物",
      "music": 0.0
    },
    {
      "from": 21.9,
      "to": 23.94,
      "sid": 14,
      "location": 2,
      "content": "人类任何器官和机器都感觉不到",
      "music": 0.0
    },
    {
      "from": 23.94,
      "to": 26.66,
      "sid": 15,
      "location": 2,
      "content": "人家都拉到你卧室2米八大床上了",
      "music": 0.0
    },
    {
      "from": 26.66,
      "to": 28.06,
      "sid": 16,
      "location": 2,
      "content": "而你人类还嘎嘎傻乐呢",
      "music": 0.0
    },
    {
      "from": 28.06,
      "to": 30.98,
      "sid": 17,
      "location": 2,
      "content": "不过这种脑洞多少有点违反奥卡姆剃刀原则",
      "music": 0.0
    },
    {
      "from": 30.98,
      "to": 33.32,
      "sid": 18,
      "location": 2,
      "content": "就好比你说你床头有个银发魅魔",
      "music": 0.0
    },
    {
      "from": 33.32,
      "to": 34.22,
      "sid": 19,
      "location": 2,
      "content": "但是看不到",
      "music": 0.0
    },
    {
      "from": 34.22,
      "to": 34.74,
      "sid": 20,
      "location": 2,
      "content": "摸不着",
      "music": 0.0
    },
    {
      "from": 34.74,
      "to": 35.38,
      "sid": 21,
      "location": 2,
      "content": "无法感知",
      "music": 0.0
    },
    {
      "from": 35.38,
      "to": 36.04,
      "sid": 22,
      "location": 2,
      "content": "不能触及",
      "music": 0.0
    },
    {
      "from": 36.04,
      "to": 37.8,
      "sid": 23,
      "location": 2,
      "content": "那你小子压根就没有魅魔",
      "music": 0.0
    },
    {
      "from": 37.8,
      "to": 39.78,
      "sid": 24,
      "location": 2,
      "content": "而在宇宙中确实存在这种可能",
      "music": 0.0
    },
    {
      "from": 39.78,
      "to": 42.24,
      "sid": 25,
      "location": 2,
      "content": "所有的文明并不是分散在整个空间",
      "music": 0.0
    },
    {
      "from": 42.24,
      "to": 44.34,
      "sid": 26,
      "location": 2,
      "content": "反而像一栋大楼重叠在一起",
      "music": 0.0
    },
    {
      "from": 44.34,
      "to": 45.48,
      "sid": 27,
      "location": 2,
      "content": "你压我我压你",
      "music": 0.0
    },
    {
      "from": 45.48,
      "to": 47.62,
      "sid": 28,
      "location": 2,
      "content": "互相之间进进出出却毫无交集",
      "music": 0.0
    },
    {
      "from": 47.62,
      "to": 50.0,
      "sid": 29,
      "location": 2,
      "content": "而这就解释了为什么总是找不到外星人",
      "music": 0.0
    },
    {
      "from": 50.0,
      "to": 51.78,
      "sid": 30,
      "location": 2,
      "content": "他们很可能来自于其他维度",
      "music": 0.0
    },
    {
      "from": 51.78,
      "to": 52.46,
      "sid": 31,
      "location": 2,
      "content": "多维空间",
      "music": 0.0
    },
    {
      "from": 52.46,
      "to": 53.22,
      "sid": 32,
      "location": 2,
      "content": "咱们是知道的",
      "music": 0.0
    },
    {
      "from": 53.22,
      "to": 54.94,
      "sid": 33,
      "location": 2,
      "content": "现在假设我身着24号",
      "music": 0.0
    },
    {
      "from": 54.94,
      "to": 56.86,
      "sid": 34,
      "location": 2,
      "content": "在篮球场上一个暴扣入篮",
      "music": 0.0
    },
    {
      "from": 56.86,
      "to": 58.22,
      "sid": 35,
      "location": 2,
      "content": "这个非常帅气的事儿",
      "music": 0.0
    },
    {
      "from": 58.22,
      "to": 61.48,
      "sid": 36,
      "location": 2,
      "content": "在篮筐入口平面的二维生物来看却非常恐怖",
      "music": 0.0
    },
    {
      "from": 61.48,
      "to": 63.34,
      "sid": 37,
      "location": 2,
      "content": "二维宇宙中突然出现了个圆",
      "music": 0.0
    },
    {
      "from": 63.34,
      "to": 64.3,
      "sid": 38,
      "location": 2,
      "content": "它很快增大",
      "music": 0.0
    },
    {
      "from": 64.3,
      "to": 65.06,
      "sid": 39,
      "location": 2,
      "content": "又很快缩小",
      "music": 0.0
    },
    {
      "from": 65.06,
      "to": 65.66,
      "sid": 40,
      "location": 2,
      "content": "然后消失",
      "music": 0.0
    },
    {
      "from": 65.66,
      "to": 66.7,
      "sid": 41,
      "location": 2,
      "content": "这在二维世界里",
      "music": 0.0
    },
    {
      "from": 66.7,
      "to": 68.84,
      "sid": 42,
      "location": 2,
      "content": "当晚就得上走进科学连播三集",
      "music": 0.0
    },
    {
      "from": 68.84,
      "to": 71.42,
      "sid": 43,
      "location": 2,
      "content": "那一个四维生物不小心进入三维世界",
      "music": 0.0
    },
    {
      "from": 71.42,
      "to": 72.16,
      "sid": 44,
      "location": 2,
      "content": "然后离开",
      "music": 0.0
    },
    {
      "from": 72.16,
      "to": 72.56,
      "sid": 45,
      "location": 2,
      "content": "在你",
      "music": 0.0
    },
    {
      "from": 72.56,
      "to": 74.04,
      "sid": 46,
      "location": 2,
      "content": "我看来就是个突然出现",
      "music": 0.0
    },
    {
      "from": 74.04,
      "to": 75.54,
      "sid": 47,
      "location": 2,
      "content": "又突然消失的灵异事件了",
      "music": 0.0
    },
    {
      "from": 75.54,
      "to": 76.28,
      "sid": 48,
      "location": 2,
      "content": "维度越高",
      "music": 0.0
    },
    {
      "from": 76.28,
      "to": 77.12,
      "sid": 49,
      "location": 2,
      "content": "结构越复杂",
      "music": 0.0
    },
    {
      "from": 77.12,
      "to": 78.86,
      "sid": 50,
      "location": 2,
      "content": "在微观粒子的超高维度中",
      "music": 0.0
    },
    {
      "from": 78.86,
      "to": 79.96,
      "sid": 51,
      "location": 2,
      "content": "可能包含一个宇宙",
      "music": 0.0
    },
    {
      "from": 79.96,
      "to": 83.58,
      "sid": 52,
      "location": 2,
      "content": "仅仅是在咱们身体上就有万亿亿亿亿亿个文明",
      "music": 0.0
    },
    {
      "from": 83.58,
      "to": 84.58,
      "sid": 53,
      "location": 2,
      "content": "随便抠点鼻屎",
      "music": 0.0
    },
    {
      "from": 84.58,
      "to": 86.1,
      "sid": 54,
      "location": 2,
      "content": "可能都有千万亿个文明",
      "music": 0.0
    },
    {
      "from": 86.1,
      "to": 87.28,
      "sid": 55,
      "location": 2,
      "content": "尽管它们就在那里",
      "music": 0.0
    },
    {
      "from": 87.28,
      "to": 88.12,
      "sid": 56,
      "location": 2,
      "content": "但你觉察不到",
      "music": 0.0
    },
    {
      "from": 88.12,
      "to": 88.9,
      "sid": 57,
      "location": 2,
      "content": "也互不影响",
      "music": 0.0
    },
    {
      "from": 88.9,
      "to": 90.46,
      "sid": 58,
      "location": 2,
      "content": "不管你是把它嚼给吃了",
      "music": 0.0
    },
    {
      "from": 90.46,
      "to": 91.7,
      "sid": 59,
      "location": 2,
      "content": "还是漫在桌子底下",
      "music": 0.0
    },
    {
      "from": 91.7,
      "to": 93.26,
      "sid": 60,
      "location": 2,
      "content": "对他们也造不成任何影响",
      "music": 0.0
    },
    {
      "from": 93.26,
      "to": 94.42,
      "sid": 61,
      "location": 2,
      "content": "唯独之间能够接触",
      "music": 0.0
    },
    {
      "from": 94.42,
      "to": 95.4,
      "sid": 62,
      "location": 2,
      "content": "也就能够交流",
      "music": 0.0
    },
    {
      "from": 95.4,
      "to": 96.64,
      "sid": 63,
      "location": 2,
      "content": "交流方式也很简单",
      "music": 0.0
    },
    {
      "from": 96.64,
      "to": 99.74,
      "sid": 64,
      "location": 2,
      "content": "就是投影球穿过二维平面会投影出圆形",
      "music": 0.0
    },
    {
      "from": 99.74,
      "to": 102.08,
      "sid": 65,
      "location": 2,
      "content": "一个三维优秀的三维人站在灯下面",
      "music": 0.0
    },
    {
      "from": 102.08,
      "to": 103.9,
      "sid": 66,
      "location": 2,
      "content": "也会在二维墙面上投射出影子",
      "music": 0.0
    },
    {
      "from": 103.9,
      "to": 106.02,
      "sid": 67,
      "location": 2,
      "content": "要是这个二维平面有智慧生物",
      "music": 0.0
    },
    {
      "from": 106.02,
      "to": 107.3,
      "sid": 68,
      "location": 2,
      "content": "他们就能观察到你了",
      "music": 0.0
    },
    {
      "from": 107.3,
      "to": 109.44,
      "sid": 69,
      "location": 2,
      "content": "那二维又怎么投影信息到三维呢",
      "music": 0.0
    },
    {
      "from": 109.44,
      "to": 111.18,
      "sid": 70,
      "location": 2,
      "content": "平面投射信息到空中",
      "music": 0.0
    },
    {
      "from": 111.18,
      "to": 112.84,
      "sid": 71,
      "location": 2,
      "content": "这不就是空气投影吗",
      "music": 0.0
    },
    {
      "from": 112.84,
      "to": 114.36,
      "sid": 72,
      "location": 2,
      "content": "不拍那些大片特效的时候",
      "music": 0.0
    },
    {
      "from": 114.36,
      "to": 115.3,
      "sid": 73,
      "location": 2,
      "content": "会用到动作捕捉",
      "music": 0.0
    },
    {
      "from": 115.3,
      "to": 117.9,
      "sid": 74,
      "location": 2,
      "content": "就是一台机器打出一堆激光到人脸上",
      "music": 0.0
    },
    {
      "from": 117.9,
      "to": 119.72,
      "sid": 75,
      "location": 2,
      "content": "就能记录下人脸的高低起伏",
      "music": 0.0
    },
    {
      "from": 119.72,
      "to": 122.2,
      "sid": 76,
      "location": 2,
      "content": "无论是运动输入电脑就能还原出这张脸",
      "music": 0.0
    },
    {
      "from": 122.2,
      "to": 123.74,
      "sid": 77,
      "location": 2,
      "content": "然后再在上面加特技",
      "music": 0.0
    },
    {
      "from": 123.74,
      "to": 124.42,
      "sid": 78,
      "location": 2,
      "content": "Duang duang duang",
      "music": 0.0
    },
    {
      "from": 124.42,
      "to": 125.1,
      "sid": 79,
      "location": 2,
      "content": "除此之外",
      "music": 0.0
    },
    {
      "from": 125.1,
      "to": 126.7,
      "sid": 80,
      "location": 2,
      "content": "比如无人机精准识别物体",
      "music": 0.0
    },
    {
      "from": 126.7,
      "to": 128.68,
      "sid": 81,
      "location": 2,
      "content": "雷达搜寻东西都是差不多的原理",
      "music": 0.0
    },
    {
      "from": 128.68,
      "to": 129.62,
      "sid": 82,
      "location": 2,
      "content": "先发出激光",
      "music": 0.0
    },
    {
      "from": 129.62,
      "to": 131.98,
      "sid": 83,
      "location": 2,
      "content": "再根据不同激光反射回来的距离位置",
      "music": 0.0
    },
    {
      "from": 131.98,
      "to": 133.24,
      "sid": 84,
      "location": 2,
      "content": "再模拟出对应的形状",
      "music": 0.0
    },
    {
      "from": 133.24,
      "to": 134.9,
      "sid": 85,
      "location": 2,
      "content": "那咱们把这玩意反过来",
      "music": 0.0
    },
    {
      "from": 134.9,
      "to": 136.98,
      "sid": 86,
      "location": 2,
      "content": "二维平面直接发射长短不一",
      "music": 0.0
    },
    {
      "from": 136.98,
      "to": 138.38,
      "sid": 87,
      "location": 2,
      "content": "位置不同的激光阵列",
      "music": 0.0
    },
    {
      "from": 138.38,
      "to": 140.58,
      "sid": 88,
      "location": 2,
      "content": "岂不是就能在三维空间投射画面啦",
      "music": 0.0
    },
    {
      "from": 140.58,
      "to": 141.06,
      "sid": 89,
      "location": 2,
      "content": "当然了",
      "music": 0.0
    },
    {
      "from": 141.06,
      "to": 141.58,
      "sid": 90,
      "location": 2,
      "content": "吹归吹",
      "music": 0.0
    },
    {
      "from": 141.58,
      "to": 142.1,
      "sid": 91,
      "location": 2,
      "content": "闹归闹",
      "music": 0.0
    },
    {
      "from": 142.1,
      "to": 143.38,
      "sid": 92,
      "location": 2,
      "content": "别拿高科技开玩笑",
      "music": 0.0
    },
    {
      "from": 143.38,
      "to": 145.44,
      "sid": 93,
      "location": 2,
      "content": "这类技术放电影里那叫科幻",
      "music": 0.0
    },
    {
      "from": 145.44,
      "to": 146.94,
      "sid": 94,
      "location": 2,
      "content": "但在生活中也是常态了",
      "music": 0.0
    },
    {
      "from": 146.94,
      "to": 149.02,
      "sid": 95,
      "location": 2,
      "content": "不只是前面说的雷达和电影特效",
      "music": 0.0
    },
    {
      "from": 149.02,
      "to": 150.12,
      "sid": 96,
      "location": 2,
      "content": "还有热成像勘探",
      "music": 0.0
    },
    {
      "from": 150.12,
      "to": 150.8,
      "sid": 97,
      "location": 2,
      "content": "红外侦察",
      "music": 0.0
    },
    {
      "from": 150.8,
      "to": 151.54,
      "sid": 98,
      "location": 2,
      "content": "无人机定位",
      "music": 0.0
    },
    {
      "from": 151.54,
      "to": 152.58,
      "sid": 99,
      "location": 2,
      "content": "人脸解锁之类的",
      "music": 0.0
    },
    {
      "from": 152.58,
      "to": 153.98,
      "sid": 100,
      "location": 2,
      "content": "都是这种很牛逼的技术",
      "music": 0.0
    },
    {
      "from": 153.98,
      "to": 154.42,
      "sid": 101,
      "location": 2,
      "content": "就拿这个",
      "music": 0.0
    },
    {
      "from": 154.42,
      "to": 156.52,
      "sid": 102,
      "location": 2,
      "content": "我从大学用到现在的电动牙刷品牌来说",
      "music": 0.0
    },
    {
      "from": 156.52,
      "to": 158.24,
      "sid": 103,
      "location": 2,
      "content": "像是拍科幻片的动捕技术",
      "music": 0.0
    },
    {
      "from": 158.24,
      "to": 159.68,
      "sid": 104,
      "location": 2,
      "content": "智能汽车的雷达定位系统",
      "music": 0.0
    },
    {
      "from": 159.68,
      "to": 162.04,
      "sid": 105,
      "location": 2,
      "content": "都应用到了这最新款的智能屏牙刷上了",
      "music": 0.0
    },
    {
      "from": 162.04,
      "to": 164.36,
      "sid": 106,
      "location": 2,
      "content": "瞬间就跟别的牙刷拉开了时代差距",
      "music": 0.0
    },
    {
      "from": 164.36,
      "to": 166.92,
      "sid": 107,
      "location": 2,
      "content": "就这个Y20里面的芯片和无人机的姿态",
      "music": 0.0
    },
    {
      "from": 166.92,
      "to": 169.76,
      "sid": 108,
