{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.22,
      "to": 1.96,
      "sid": 1,
      "location": 2,
      "content": "我发现职场中有些人",
      "music": 0.0
    },
    {
      "from": 1.96,
      "to": 3.98,
      "sid": 2,
      "location": 2,
      "content": "他们多多少少都遇到过那种",
      "music": 0.0
    },
    {
      "from": 3.98,
      "to": 5.67,
      "sid": 3,
      "location": 2,
      "content": "平常什么都不管的领导",
      "music": 0.0
    },
    {
      "from": 5.67,
      "to": 6.83,
      "sid": 4,
      "location": 2,
      "content": "甩手掌柜嘛",
      "music": 0.0
    },
    {
      "from": 6.83,
      "to": 8.15,
      "sid": 5,
      "location": 2,
      "content": "等你做出了成绩",
      "music": 0.0
    },
    {
      "from": 8.15,
      "to": 9.42,
      "sid": 6,
      "location": 2,
      "content": "就抢你的功劳",
      "music": 0.0
    },
    {
      "from": 9.42,
      "to": 10.68,
      "sid": 7,
      "location": 2,
      "content": "如果出了问题",
      "music": 0.0
    },
    {
      "from": 10.68,
      "to": 12.2,
      "sid": 8,
      "location": 2,
      "content": "还会把锅甩给你",
      "music": 0.0
    },
    {
      "from": 12.2,
      "to": 13.9,
      "sid": 9,
      "location": 2,
      "content": "这种纯纯的利己主义者",
      "music": 0.0
    },
    {
      "from": 13.9,
      "to": 16.38,
      "sid": 10,
      "location": 2,
      "content": "甚至还在公司里面越混越好",
      "music": 0.0
    },
    {
      "from": 16.38,
      "to": 17.72,
      "sid": 11,
      "location": 2,
      "content": "混得风生水起",
      "music": 0.0
    },
    {
      "from": 17.72,
      "to": 21.86,
      "sid": 12,
      "location": 2,
      "content": "而你可能就是一个在职场中兢兢业业的人",
      "music": 0.0
    },
    {
      "from": 21.86,
      "to": 24.189,
      "sid": 13,
      "location": 2,
      "content": "当你和这样的领导越处越久",
      "music": 0.0
    },
    {
      "from": 24.189,
      "to": 26.429,
      "sid": 14,
      "location": 2,
      "content": "它会让你的价值观发生转变",
      "music": 0.0
    },
    {
      "from": 26.429,
      "to": 29.789,
      "sid": 15,
      "location": 2,
      "content": "你会开始怀疑你在职场中发展平平",
      "music": 0.0
    },
    {
      "from": 29.789,
      "to": 31.609,
      "sid": 16,
      "location": 2,
      "content": "就是因为你太老实",
      "music": 0.0
    },
    {
      "from": 31.609,
      "to": 33.05,
      "sid": 17,
      "location": 2,
      "content": "太有同理心对吧",
      "music": 0.0
    },
    {
      "from": 33.05,
      "to": 34.89,
      "sid": 18,
      "location": 2,
      "content": "然后你痛下决心说",
      "music": 0.0
    },
    {
      "from": 34.89,
      "to": 37.6,
      "sid": 19,
      "location": 2,
      "content": "那我也要变成一个利己主义者",
      "music": 0.0
    },
    {
      "from": 37.6,
      "to": 39.98,
      "sid": 20,
      "location": 2,
      "content": "我在职场中就遇见过这样的人",
      "music": 0.0
    },
    {
      "from": 39.98,
      "to": 42.62,
      "sid": 21,
      "location": 2,
      "content": "他开始和同组的同事抢资源",
      "music": 0.0
    },
    {
      "from": 42.62,
      "to": 43.62,
      "sid": 22,
      "location": 2,
      "content": "用人朝前",
      "music": 0.0
    },
    {
      "from": 43.62,
      "to": 44.69,
      "sid": 23,
      "location": 2,
      "content": "不用人朝后",
      "music": 0.0
    },
    {
      "from": 44.69,
      "to": 47.03,
      "sid": 24,
      "location": 2,
      "content": "我们所有的同事都对他避之不及",
      "music": 0.0
    },
    {
      "from": 47.03,
      "to": 48.67,
      "sid": 25,
      "location": 2,
      "content": "但就是因为他利己",
      "music": 0.0
    },
    {
      "from": 48.67,
      "to": 49.41,
      "sid": 26,
      "location": 2,
      "content": "他自私",
      "music": 0.0
    },
    {
      "from": 49.41,
      "to": 52.63,
      "sid": 27,
      "location": 2,
      "content": "他后面真的在一次晋升中晋升成功了",
      "music": 0.0
    },
    {
      "from": 52.63,
      "to": 55.15,
      "sid": 28,
      "location": 2,
      "content": "然后他的职级就比我们高一级",
      "music": 0.0
    },
    {
      "from": 55.15,
      "to": 57.13,
      "sid": 29,
      "location": 2,
      "content": "当然这是很多年前的事了",
      "music": 0.0
    },
    {
      "from": 57.13,
      "to": 60.11,
      "sid": 30,
      "location": 2,
      "content": "但现在他的发展远远不如我们",
      "music": 0.0
    },
    {
      "from": 60.11,
      "to": 62.489,
      "sid": 31,
      "location": 2,
      "content": "当时同组的其他几个人",
      "music": 0.0
    },
    {
      "from": 62.489,
      "to": 63.689,
      "sid": 32,
      "location": 2,
      "content": "之所以会这样",
      "music": 0.0
    },
    {
      "from": 63.689,
      "to": 65.229,
      "sid": 33,
      "location": 2,
      "content": "是因为在职场中",
      "music": 0.0
    },
    {
      "from": 65.229,
      "to": 69.15,
      "sid": 34,
      "location": 2,
      "content": "利己思维并不适用于中层以下的员工",
      "music": 0.0
    },
    {
      "from": 69.15,
      "to": 72.85,
      "sid": 35,
      "location": 2,
      "content": "你看到你的领导在对待你的时候很利己",
      "music": 0.0
    },
    {
      "from": 72.85,
      "to": 75.89,
      "sid": 36,
      "location": 2,
      "content": "但你没看到这个领导在对待他的领导时",
      "music": 0.0
    },
    {
      "from": 75.89,
      "to": 77.55,
      "sid": 37,
      "location": 2,
      "content": "变成了一个利他的人",
      "music": 0.0
    },
    {
      "from": 77.55,
      "to": 80.19,
      "sid": 38,
      "location": 2,
      "content": "你看到的只是他对待你的方式",
      "music": 0.0
    },
    {
      "from": 80.19,
      "to": 83.1,
      "sid": 39,
      "location": 2,
      "content": "而不是他对待所有人的方式",
      "music": 0.0
    },
    {
      "from": 83.1,
      "to": 85.3,
      "sid": 40,
      "location": 2,
      "content": "不知道你们有没有听说过这样一句话",
      "music": 0.0
    },
    {
      "from": 85.3,
      "to": 86.78,
      "sid": 41,
      "location": 2,
      "content": "叫做群体合作",
      "music": 0.0
    },
    {
      "from": 86.78,
      "to": 88.71,
      "sid": 42,
      "location": 2,
      "content": "更利于个体生存",
      "music": 0.0
    },
    {
      "from": 88.71,
      "to": 92.27,
      "sid": 43,
      "location": 2,
      "content": "这句话适用于职场里的所有执行岗",
      "music": 0.0
    },
    {
      "from": 92.27,
      "to": 93.449,
      "sid": 44,
      "location": 2,
      "content": "包括小组长",
      "music": 0.0
    },
    {
      "from": 93.449,
      "to": 96.429,
      "sid": 45,
      "location": 2,
      "content": "因为对于职场的基层员工来说",
      "music": 0.0
    },
    {
      "from": 96.429,
      "to": 98.549,
      "sid": 46,
      "location": 2,
      "content": "在这个巨大的关系网里",
      "music": 0.0
    },
    {
      "from": 98.549,
      "to": 101.949,
      "sid": 47,
      "location": 2,
      "content": "能够影响你们利益的人和事儿太多了",
      "music": 0.0
    },
    {
      "from": 101.949,
      "to": 105.589,
      "sid": 48,
      "location": 2,
      "content": "当一个环境中有很多人可以左右你利益的时候",
      "music": 0.0
    },
    {
      "from": 105.589,
      "to": 107.94,
      "sid": 49,
      "location": 2,
      "content": "群体合作是最优解",
      "music": 0.0
    },
    {
      "from": 107.94,
      "to": 112.06,
      "sid": 50,
      "location": 2,
      "content": "而你的领导之所以可以如此的利己和自私",
      "music": 0.0
    },
    {
      "from": 112.06,
      "to": 115.32,
      "sid": 51,
      "location": 2,
      "content": "是因为他早就评估过利己的后果",
      "music": 0.0
    },
    {
      "from": 115.32,
      "to": 118.61,
      "sid": 52,
      "location": 2,
      "content": "他知道你们没办法影响到他的利益",
      "music": 0.0
    },
    {
      "from": 118.61,
      "to": 120.95,
      "sid": 53,
      "location": 2,
      "content": "他并不是一个纯粹的利己主义者",
      "music": 0.0
    },
    {
      "from": 120.95,
      "to": 122.07,
      "sid": 54,
      "location": 2,
      "content": "对于他来说",
      "music": 0.0
    },
    {
      "from": 122.07,
      "to": 122.93,
      "sid": 55,
      "location": 2,
      "content": "利己还是利",
      "music": 0.0
    },
    {
      "from": 122.93,
      "to": 124.55,
      "sid": 56,
      "location": 2,
      "content": "他也不是一种价值观",
      "music": 0.0
    },
    {
      "from": 124.55,
      "to": 126.05,
      "sid": 57,
      "location": 2,
      "content": "而是一种手段",
      "music": 0.0
    },
    {
      "from": 126.05,
      "to": 129.72,
      "sid": 58,
      "location": 2,
      "content": "是一种风险评估之后采取的手段",
      "music": 0.0
    },
    {
      "from": 129.72,
      "to": 133.92,
      "sid": 59,
      "location": 2,
      "content": "所以这种手段才会随着他遇到的人和事的不同",
      "music": 0.0
    },
    {
      "from": 133.92,
      "to": 135.38,
      "sid": 60,
      "location": 2,
      "content": "而产生变化",
      "music": 0.0
    },
    {
      "from": 135.38,
      "to": 137.86,
      "sid": 61,
      "location": 2,
      "content": "当一个人不能影响他利益的时候",
      "music": 0.0
    },
    {
      "from": 137.86,
      "to": 139.14,
      "sid": 62,
      "location": 2,
      "content": "他就是利己的",
      "music": 0.0
    },
    {
      "from": 139.14,
      "to": 141.58,
      "sid": 63,
      "location": 2,
      "content": "当一个人可以左右他利益的时候",
      "music": 0.0
    },
    {
      "from": 141.58,
      "to": 143.79,
      "sid": 64,
      "location": 2,
      "content": "他就变成了一个利益他的人",
      "music": 0.0
    },
    {
      "from": 143.79,
      "to": 145.47,
      "sid": 65,
      "location": 2,
      "content": "那我的第一个结论就是",
      "music": 0.0
    },
    {
      "from": 145.47,
      "to": 148.43,
      "sid": 66,
      "location": 2,
      "content": "在职场中利己不应该是一种价值观",
      "music": 0.0
    },
    {
      "from": 148.43,
      "to": 150.589,
      "sid": 67,
      "location": 2,
      "content": "也不应该是一种思考方式",
      "music": 0.0
    },
    {
      "from": 150.589,
      "to": 154.289,
      "sid": 68,
      "location": 2,
      "content": "它只是一种风险评估之后采取的手段",
      "music": 0.0
    },
    {
      "from": 154.289,
      "to": 156.92,
      "sid": 69,
      "location": 2,
      "content": "而对于职场基层员工来说",
      "music": 0.0
    },
    {
      "from": 156.92,
      "to": 159.16,
      "sid": 70,
      "location": 2,
      "content": "相比于争抢和甩锅",
      "music": 0.0
    },
    {
      "from": 159.16,
      "to": 161.43,
      "sid": 71,
      "location": 2,
      "content": "合作才是最好的出路",
      "music": 0.0
    },
    {
      "from": 161.43,
      "to": 163.65,
      "sid": 72,
      "location": 2,
      "content": "之前我遇到过一个大厂中高层",
      "music": 0.0
    },
    {
      "from": 163.65,
      "to": 165.27,
      "sid": 73,
      "location": 2,
      "content": "他每天都在PUA",
      "music": 0.0
    },
    {
      "from": 165.27,
      "to": 169.2,
      "sid": 74,
      "location": 2,
      "content": "他下面的人甚至搞那种零成本裁员的拙劣手段",
      "music": 0.0
    },
    {
      "from": 169.2,
      "to": 171.14,
      "sid": 75,
      "location": 2,
      "content": "对他不满的员工非常多",
      "music": 0.0
    },
    {
      "from": 171.14,
      "to": 174.54,
      "sid": 76,
      "location": 2,
      "content": "但是他现在依然还在那个位置上",
      "music": 0.0
    },
    {
      "from": 174.54,
      "to": 176.68,
      "sid": 77,
      "location": 2,
      "content": "之前有人质疑他做法的时候",
      "music": 0.0
    },
    {
      "from": 176.68,
      "to": 177.64,
      "sid": 78,
      "location": 2,
      "content": "他说过一句话",
      "music": 0.0
    },
    {
      "from": 177.64,
      "to": 179.26,
      "sid": 79,
      "location": 2,
      "content": "给我的印象非常深刻",
      "music": 0.0
    },
    {
      "from": 179.26,
      "to": 181.98,
      "sid": 80,
      "location": 2,
      "content": "他说就算我零成本裁掉他们",
      "music": 0.0
    },
    {
      "from": 181.98,
      "to": 183.86,
      "sid": 81,
      "location": 2,
      "content": "他们也压根儿拿我没办法",
      "music": 0.0
    },
    {
      "from": 183.86,
      "to": 188.16,
      "sid": 82,
      "location": 2,
      "content": "就算这些人里面有一两个能混得比我高",
      "music": 0.0
    },
    {
      "from": 188.16,
      "to": 189.82,
      "sid": 83,
      "location": 2,
      "content": "我倒是早都退休了",
      "music": 0.0
    },
    {
      "from": 189.82,
      "to": 191.28,
      "sid": 84,
      "location": 2,
      "content": "我人都跑到国外去了",
      "music": 0.0
    },
    {
      "from": 191.28,
      "to": 192.88,
      "sid": 85,
      "location": 2,
      "content": "他们根本找不着我",
      "music": 0.0
    },
    {
      "from": 192.88,
      "to": 194.68,
      "sid": 86,
      "location": 2,
      "content": "我当时听完这句话",
      "music": 0.0
    },
    {
      "from": 194.68,
      "to": 195.98,
      "sid": 87,
      "location": 2,
      "content": "我就知道了哦",
      "music": 0.0
    },
    {
      "from": 195.98,
      "to": 199.26,
      "sid": 88,
      "location": 2,
      "content": "原来他当时做出这些动作之前",
      "music": 0.0
    },
    {
      "from": 199.26,
      "to": 200.92,
      "sid": 89,
      "location": 2,
      "content": "心里早都盘算好了",
      "music": 0.0
    },
    {
      "from": 200.92,
      "to": 204.12,
      "sid": 90,
      "location": 2,
      "content": "他断定他做出的这些利己行为",
      "music": 0.0
    },
    {
      "from": 204.12,
      "to": 205.96,
      "sid": 91,
      "location": 2,
      "content": "起码在他在职期间",
      "music": 0.0
    },
    {
      "from": 205.96,
      "to": 208.4,
      "sid": 92,
      "location": 2,
      "content": "不会对他产生任何负面后果",
      "music": 0.0
    },
    {
      "from": 208.4,
      "to": 209.97,
      "sid": 93,
      "location": 2,
      "content": "他才敢这么做",
      "music": 0.0
    },
    {
      "from": 209.97,
      "to": 210.89,
      "sid": 94,
      "location": 2,
      "content": "你们想啊",
      "music": 0.0
    },
    {
      "from": 210.89,
      "to": 212.53,
      "sid": 95,
      "location": 2,
      "content": "一般私企外企",
      "music": 0.0
    },
    {
      "from": 212.53,
      "to": 215.019,
      "sid": 96,
      "location": 2,
      "content": "大公司的中高层基本都40多岁了",
      "music": 0.0
    },
    {
      "from": 215.019,
      "to": 217.139,
      "sid": 97,
      "location": 2,
      "content": "再干10年他们都能退休了",
      "music": 0.0
    },
    {
      "from": 217.139,
      "to": 219.779,
      "sid": 98,
      "location": 2,
      "content": "而你10年之内能坐到他的位置上",
      "music": 0.0
    },
    {
      "from": 219.779,
      "to": 221.079,
      "sid": 99,
      "location": 2,
      "content": "或者超过他吗",
      "music": 0.0
    },
    {
      "from": 221.079,
      "to": 225.15,
      "sid": 100,
      "location": 2,
      "content": "很难我开头说到的那个和同事抢资源的人",
      "music": 0.0
    },
    {
      "from": 225.15,
      "to": 227.61,
      "sid": 101,
      "location": 2,
      "content": "他错就错在盲目利己",
      "music": 0.0
    },
    {
      "from": 227.61,
      "to": 231.13,
      "sid": 102,
      "location": 2,
      "content": "而你看到的那些在职场里混得越来越好的",
      "music": 0.0
    },
    {
      "from": 231.13,
      "to": 233.13,
      "sid": 103,
      "location": 2,
      "content": "利己主义者是有针对性的",
      "music": 0.0
    },
    {
      "from": 233.13,
      "to": 235.18,
      "sid": 104,
      "location": 2,
      "content": "利己是分人分事儿的",
      "music": 0.0
    },
    {
      "from": 235.18,
      "to": 239.17,
      "sid": 105,
      "location": 2,
      "content": "利己是在心里已经盘算过利害关系的利己",
      "music": 0.0
    },
    {
      "from": 239.17,
      "to": 242.86,
      "sid": 106,
      "location": 2,
      "content": "当然利他也是建立在利己上的结果",
      "music": 0.0
    },
    {
      "from": 242.86,
      "to": 246.06,
      "sid": 107,
      "location": 2,
      "content": "所以你们可以把我今天这期内容里面提到的",
      "music": 0.0
    },
    {
      "from": 246.06,
      "to": 249.9,
      "sid": 108,
      "location": 2,
      "content": "利他和利己解读成合作和利己的区别",
      "music": 0.0
    },
    {
      "from": 249.9,
      "to": 252.74,
      "sid": 109,
      "location": 2,
      "content": "当你处在一个巨大的关系网里面",
