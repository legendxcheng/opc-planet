  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.28,
      "to": 2.28,
      "sid": 1,
      "location": 2,
      "content": "现在大环境不好的情况下",
      "music": 0.0
    },
    {
      "from": 2.28,
      "to": 5.3,
      "sid": 2,
      "location": 2,
      "content": "很多公司会选择去发展一门新的业务",
      "music": 0.0
    },
    {
      "from": 5.3,
      "to": 8.4,
      "sid": 3,
      "location": 2,
      "content": "来解决原有业务发展见顶的窘境",
      "music": 0.0
    },
    {
      "from": 8.4,
      "to": 10.02,
      "sid": 4,
      "location": 2,
      "content": "比如说规模见顶",
      "music": 0.0
    },
    {
      "from": 10.02,
      "to": 12.19,
      "sid": 5,
      "location": 2,
      "content": "用户鉴定或者收入见顶",
      "music": 0.0
    },
    {
      "from": 12.19,
      "to": 15.03,
      "sid": 6,
      "location": 2,
      "content": "确实原有业务很难突破的时候",
      "music": 0.0
    },
    {
      "from": 15.03,
      "to": 18.259,
      "sid": 7,
      "location": 2,
      "content": "好像只剩下拓展新业务这一个办法了",
      "music": 0.0
    },
    {
      "from": 18.259,
      "to": 21.619,
      "sid": 8,
      "location": 2,
      "content": "但是几乎没有任何一家公司能够",
      "music": 0.0
    },
    {
      "from": 21.619,
      "to": 24.53,
      "sid": 9,
      "location": 2,
      "content": "在新的业务上拿到突出成绩",
      "music": 0.0
    },
    {
      "from": 24.53,
      "to": 26.23,
      "sid": 10,
      "location": 2,
      "content": "尤其对于很多大厂来讲",
      "music": 0.0
    },
    {
      "from": 26.23,
      "to": 29.07,
      "sid": 11,
      "location": 2,
      "content": "他明明在A业务上能够拿到结果",
      "music": 0.0
    },
    {
      "from": 29.07,
      "to": 32.709,
      "sid": 12,
      "location": 2,
      "content": "但是他在拓展B业务的时候却屡屡受挫",
      "music": 0.0
    },
    {
      "from": 32.709,
      "to": 34.189,
      "sid": 13,
      "location": 2,
      "content": "甚至有些大厂领导",
      "music": 0.0
    },
    {
      "from": 34.189,
      "to": 37.32,
      "sid": 14,
      "location": 2,
      "content": "会在新业务一直没进展的时候去责怪员工",
      "music": 0.0
    },
    {
      "from": 37.32,
      "to": 38.28,
      "sid": 15,
      "location": 2,
      "content": "对员工说",
      "music": 0.0
    },
    {
      "from": 38.28,
      "to": 40.4,
      "sid": 16,
      "location": 2,
      "content": "你看看你们昨天到点就下班",
      "music": 0.0
    },
    {
      "from": 40.4,
      "to": 42.1,
      "sid": 17,
      "location": 2,
      "content": "那新业务肯定做不起来呀",
      "music": 0.0
    },
    {
      "from": 42.1,
      "to": 44.44,
      "sid": 18,
      "location": 2,
      "content": "做新业务要有创业精神",
      "music": 0.0
    },
    {
      "from": 44.44,
      "to": 46.31,
      "sid": 19,
      "location": 2,
      "content": "别老想着到点下班",
      "music": 0.0
    },
    {
      "from": 46.31,
      "to": 49.35,
      "sid": 20,
      "location": 2,
      "content": "或者你们不能每天只坐在办公室里面",
      "music": 0.0
    },
    {
      "from": 49.35,
      "to": 50.21,
      "sid": 21,
      "location": 2,
      "content": "对着电脑啊",
      "music": 0.0
    },
    {
      "from": 50.21,
      "to": 51.43,
      "sid": 22,
      "location": 2,
      "content": "你们要走出去",
      "music": 0.0
    },
    {
      "from": 51.43,
      "to": 53.03,
      "sid": 23,
      "location": 2,
      "content": "要多了解用户心态",
      "music": 0.0
    },
    {
      "from": 53.03,
      "to": 54.04,
      "sid": 24,
      "location": 2,
      "content": "要开放",
      "music": 0.0
    },
    {
      "from": 54.04,
      "to": 57.52,
      "sid": 25,
      "location": 2,
      "content": "但其实这些领导也每天坐在办公室里面",
      "music": 0.0
    },
    {
      "from": 57.52,
      "to": 58.32,
      "sid": 26,
      "location": 2,
      "content": "对着电脑",
      "music": 0.0
    },
    {
      "from": 58.32,
      "to": 59.48,
      "sid": 27,
      "location": 2,
      "content": "他们还会对员工说",
      "music": 0.0
    },
    {
      "from": 59.48,
      "to": 62.58,
      "sid": 28,
      "location": 2,
      "content": "我们现在在做的新业务是有挑战",
      "music": 0.0
    },
    {
      "from": 62.58,
      "to": 64.08,
      "sid": 29,
      "location": 2,
      "content": "但我们能做成A业务",
      "music": 0.0
    },
    {
      "from": 64.08,
      "to": 65.96,
      "sid": 30,
      "location": 2,
      "content": "就一定能够拿下B业务",
      "music": 0.0
    },
    {
      "from": 65.96,
      "to": 67.64,
      "sid": 31,
      "location": 2,
      "content": "大家得有信念",
      "music": 0.0
    },
    {
      "from": 67.64,
      "to": 71.36,
      "sid": 32,
      "location": 2,
      "content": "总之大厂领导在总结一个业务做不起来的时候",
      "music": 0.0
    },
    {
      "from": 71.36,
      "to": 75.54,
      "sid": 33,
      "location": 2,
      "content": "会把一部分原因归结为团队缺少开放的心态",
      "music": 0.0
    },
    {
      "from": 75.54,
      "to": 76.96,
      "sid": 34,
      "location": 2,
      "content": "缺少创业的精神",
      "music": 0.0
    },
    {
      "from": 76.96,
      "to": 78.36,
      "sid": 35,
      "location": 2,
      "content": "缺少成功的信念",
      "music": 0.0
    },
    {
      "from": 78.36,
      "to": 80.54,
      "sid": 36,
      "location": 2,
      "content": "首先这个结论肯定是不正确的",
      "music": 0.0
    },
    {
      "from": 80.54,
      "to": 83.12,
      "sid": 37,
      "location": 2,
      "content": "因为根据经济学常识来讲",
      "music": 0.0
    },
    {
      "from": 83.12,
      "to": 84.64,
      "sid": 38,
      "location": 2,
      "content": "利润就是责任",
      "music": 0.0
    },
    {
      "from": 84.64,
      "to": 86.46,
      "sid": 39,
      "location": 2,
      "content": "谁获取的利润更多",
      "music": 0.0
    },
    {
      "from": 86.46,
      "to": 87.94,
      "sid": 40,
      "location": 2,
      "content": "谁拿的工资更高",
      "music": 0.0
    },
    {
      "from": 87.94,
      "to": 89.37,
      "sid": 41,
      "location": 2,
      "content": "谁的责任就越大",
      "music": 0.0
    },
    {
      "from": 89.37,
      "to": 91.17,
      "sid": 42,
      "location": 2,
      "content": "管理层比员工责任大",
      "music": 0.0
    },
    {
      "from": 91.17,
      "to": 93.009,
      "sid": 43,
      "location": 2,
      "content": "CEO比管理层责任大",
      "music": 0.0
    },
    {
      "from": 93.009,
      "to": 95.209,
      "sid": 44,
      "location": 2,
      "content": "而且站在客户的角度",
      "music": 0.0
    },
    {
      "from": 95.209,
      "to": 97.089,
      "sid": 45,
      "location": 2,
      "content": "客户购买企业的产品",
      "music": 0.0
    },
    {
      "from": 97.089,
      "to": 99.64,
      "sid": 46,
      "location": 2,
      "content": "是因为他相信CEO和高管团队",
      "music": 0.0
    },
    {
      "from": 99.64,
      "to": 101.84,
      "sid": 47,
      "location": 2,
      "content": "你买小米汽车是因为你相信雷军",
      "music": 0.0
    },
    {
      "from": 101.84,
      "to": 104.38,
      "sid": 48,
      "location": 2,
      "content": "还是因为你相信小米的某个实习生呢",
      "music": 0.0
    },
    {
      "from": 104.38,
      "to": 105.91,
      "sid": 49,
      "location": 2,
      "content": "那肯定是前者啊",
      "music": 0.0
    },
    {
      "from": 105.91,
      "to": 108.79,
      "sid": 50,
      "location": 2,
      "content": "所以大厂面对新业务屡屡受挫的",
      "music": 0.0
    },
    {
      "from": 108.79,
      "to": 110.36,
      "sid": 51,
      "location": 2,
      "content": "原因到底是什么呢",
      "music": 0.0
    },
    {
      "from": 110.36,
      "to": 111.56,
      "sid": 52,
      "location": 2,
      "content": "有些人分析说",
      "music": 0.0
    },
    {
      "from": 114.66,
      "to": 116.9,
      "sid": 53,
      "location": 2,
      "content": "只会每天不停的开会讨论",
      "music": 0.0
    },
    {
      "from": 116.9,
      "to": 120.61,
      "sid": 54,
      "location": 2,
      "content": "他们不像打天下的创始人团队那样会深入一线",
      "music": 0.0
    },
    {
      "from": 120.61,
      "to": 123.91,
      "sid": 55,
      "location": 2,
      "content": "所以大厂领导对新业务有很多的意向",
      "music": 0.0
    },
    {
      "from": 123.91,
      "to": 125.71,
      "sid": 56,
      "location": 2,
      "content": "才导致业务做不起来",
      "music": 0.0
    },
    {
      "from": 125.71,
      "to": 127.35,
      "sid": 57,
      "location": 2,
      "content": "这当然是其中一个原因",
      "music": 0.0
    },
    {
      "from": 127.35,
      "to": 129.29,
      "sid": 58,
      "location": 2,
      "content": "但这不是最根本的原因",
      "music": 0.0
    },
    {
      "from": 129.29,
      "to": 133.13,
      "sid": 59,
      "location": 2,
      "content": "最根本的原因其实是拿到过巨大结果的企业",
      "music": 0.0
    },
    {
      "from": 133.13,
      "to": 137.05,
      "sid": 60,
      "location": 2,
      "content": "往往会想要挑战能力有边界的这个商业常识",
      "music": 0.0
    },
    {
      "from": 137.05,
      "to": 139.09,
      "sid": 61,
      "location": 2,
      "content": "这是很多大厂的通病",
      "music": 0.0
    },
    {
      "from": 139.09,
      "to": 142.23,
      "sid": 62,
      "location": 2,
      "content": "他们在某件事情上获得巨大成功之后",
      "music": 0.0
    },
    {
      "from": 142.23,
      "to": 144.6,
      "sid": 63,
      "location": 2,
      "content": "就会认为自己无所不能",
      "music": 0.0
    },
    {
      "from": 144.6,
      "to": 147.5,
      "sid": 64,
      "location": 2,
      "content": "进而把商业常识都抛诸脑后",
      "music": 0.0
    },
    {
      "from": 147.5,
      "to": 149.38,
      "sid": 65,
      "location": 2,
      "content": "巴菲特投资股票的时候",
      "music": 0.0
    },
    {
      "from": 149.38,
      "to": 151.2,
      "sid": 66,
      "location": 2,
      "content": "他不会买科技行业的股票",
      "music": 0.0
    },
    {
      "from": 151.2,
      "to": 153.97,
      "sid": 67,
      "location": 2,
      "content": "因为他看不懂科技行业的规律",
      "music": 0.0
    },
    {
      "from": 153.97,
      "to": 155.79,
      "sid": 68,
      "location": 2,
      "content": "他说自己能力有边界",
      "music": 0.0
    },
    {
      "from": 155.79,
      "to": 157.95,
      "sid": 69,
      "location": 2,
      "content": "所以不懂的东西他不会去碰",
      "music": 0.0
    },
    {
      "from": 157.95,
      "to": 160.25,
      "sid": 70,
      "location": 2,
      "content": "连巴菲特都觉得能力有边界",
      "music": 0.0
    },
    {
      "from": 160.25,
      "to": 162.07,
      "sid": 71,
      "location": 2,
      "content": "为什么你一个公司的管理层",
      "music": 0.0
    },
    {
      "from": 162.07,
      "to": 163.899,
      "sid": 72,
      "location": 2,
      "content": "会觉得自己无所不能呢",
      "music": 0.0
    },
    {
      "from": 163.899,
      "to": 167.299,
      "sid": 73,
      "location": 2,
      "content": "其实企业的新机会不只是发展新业务",
      "music": 0.0
    },
    {
      "from": 167.299,
      "to": 169.92,
      "sid": 74,
      "location": 2,
      "content": "还包括新技术和新形势",
      "music": 0.0
    },
    {
      "from": 169.92,
      "to": 171.9,
      "sid": 75,
      "location": 2,
      "content": "这三种的区别是什么呢",
      "music": 0.0
    },
    {
      "from": 171.9,
      "to": 175.18,
      "sid": 76,
      "location": 2,
      "content": "做家电的跑去做手机叫做发展新业务",
      "music": 0.0
    },
    {
      "from": 175.18,
      "to": 178.079,
      "sid": 77,
      "location": 2,
      "content": "一家公司开始搞AI叫做新技术",
      "music": 0.0
    },
    {
      "from": 178.079,
      "to": 180.779,
      "sid": 78,
      "location": 2,
      "content": "一家电商公司从淘宝上买流量",
      "music": 0.0
    },
    {
      "from": 180.779,
      "to": 182.439,
      "sid": 79,
      "location": 2,
      "content": "到跑去抖音上拍短视频",
      "music": 0.0
    },
    {
      "from": 182.439,
      "to": 183.87,
      "sid": 80,
      "location": 2,
      "content": "叫做新形势",
      "music": 0.0
    },
    {
      "from": 183.87,
      "to": 185.57,
      "sid": 81,
      "location": 2,
      "content": "新业务是一种跨界",
      "music": 0.0
    },
    {
      "from": 185.57,
      "to": 187.09,
      "sid": 82,
      "location": 2,
      "content": "但能力有边界",
      "music": 0.0
    },
    {
      "from": 187.09,
      "to": 188.91,
      "sid": 83,
      "location": 2,
      "content": "新技术是一种纵深",
      "music": 0.0
    },
    {
      "from": 188.91,
      "to": 190.31,
      "sid": 84,
      "location": 2,
      "content": "但是能力有高度",
      "music": 0.0
    },
    {
      "from": 190.31,
      "to": 191.43,
      "sid": 85,
      "location": 2,
      "content": "只有新形式",
      "music": 0.0
    },
    {
      "from": 191.43,
      "to": 192.65,
      "sid": 86,
      "location": 2,
      "content": "它是一种玩法",
      "music": 0.0
    },
    {
      "from": 192.65,
      "to": 195.07,
      "sid": 87,
      "location": 2,
      "content": "对能力的边界和高度没有要求",
      "music": 0.0
    },
    {
      "from": 195.07,
      "to": 196.39,
      "sid": 88,
      "location": 2,
      "content": "他只需要一个人",
      "music": 0.0
    },
    {
      "from": 196.39,
      "to": 198.11,
      "sid": 89,
      "location": 2,
      "content": "有好奇心和执行力",
      "music": 0.0
    },
    {
      "from": 198.11,
      "to": 199.49,
      "sid": 90,
      "location": 2,
      "content": "后两种机会当中",
      "music": 0.0
    },
    {
      "from": 199.49,
      "to": 201.31,
      "sid": 91,
      "location": 2,
      "content": "很少有公司有资本",
      "music": 0.0
    },
    {
      "from": 201.31,
      "to": 204.66,
      "sid": 92,
      "location": 2,
      "content": "能够花费很长的时间周期去钻研新技术",
      "music": 0.0
    },
    {
      "from": 204.66,
      "to": 205.46,
      "sid": 93,
      "location": 2,
      "content": "另一方面",
      "music": 0.0
    },
    {
      "from": 205.46,
      "to": 206.79,
      "sid": 94,
      "location": 2,
      "content": "投资人也不允许",
      "music": 0.0
    },
    {
      "from": 206.79,
      "to": 209.31,
      "sid": 95,
      "location": 2,
      "content": "其实了解deep sick发展史的人就知道",
      "music": 0.0
    },
    {
      "from": 209.31,
      "to": 213.24,
      "sid": 96,
      "location": 2,
      "content": "deep sk创始人梁文峰同时在做其他的业务",
      "music": 0.0
    },
    {
      "from": 213.24,
      "to": 217.29,
      "sid": 97,
      "location": 2,
      "content": "他在用他其他业务的利润去支撑deep sick的研发",
      "music": 0.0
    },
    {
      "from": 217.29,
      "to": 220.21,
      "sid": 98,
      "location": 2,
      "content": "并且deep sick虽然是23年成立的",
      "music": 0.0
    },
    {
      "from": 220.21,
      "to": 223.68,
      "sid": 99,
      "location": 2,
      "content": "但是梁文峰对AI的研究从18年就开始了",
      "music": 0.0
    },
    {
      "from": 223.68,
      "to": 225.54,
      "sid": 100,
      "location": 2,
      "content": "但现在的投资人都要求",
      "music": 0.0
    },
    {
      "from": 225.54,
      "to": 227.78,
      "sid": 101,
      "location": 2,
      "content": "创始人在短期内就产生利益",
      "music": 0.0
    },
    {
      "from": 227.78,
      "to": 231.519,
      "sid": 102,
      "location": 2,
      "content": "所以能实现新技术的企业少之又少",
      "music": 0.0
    },
    {
      "from": 231.519,
      "to": 233.839,
      "sid": 103,
      "location": 2,
      "content": "而新形势的机会多",
      "music": 0.0
    },
    {
      "from": 233.839,
      "to": 234.699,
      "sid": 104,
      "location": 2,
      "content": "成本少",
      "music": 0.0
    },
    {
      "from": 234.699,
      "to": 235.63,
      "sid": 105,
      "location": 2,
      "content": "成功率高",
      "music": 0.0
    },
    {
      "from": 235.63,
      "to": 237.73,
      "sid": 106,
      "location": 2,
      "content": "18年短视频是新形势",
      "music": 0.0
    },
    {
      "from": 237.73,
      "to": 239.87,
      "sid": 107,
      "location": 2,
      "content": "20年直播带货是新形势",
