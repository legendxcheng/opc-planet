{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "eng-1.2.0-index-lite",
  "body": [
    {
      "from": 0.76,
      "to": 1.7,
      "content": "大家好",
      "music": 0.0,
      "sid": 1,
      "location": 2
    },
    {
      "from": 1.7,
      "to": 2.96,
      "content": "我的名字是亚历克斯",
      "music": 0.0,
      "sid": 2,
      "location": 2
    },
    {
      "from": 2.96,
      "to": 5.18,
      "content": "我二十二岁",
      "music": 0.0,
      "sid": 3,
      "location": 2
    },
    {
      "from": 5.18,
      "to": 7.4,
      "content": "现在我必须独自抚养孩子",
      "music": 0.0,
      "sid": 4,
      "location": 2
    },
    {
      "from": 7.4,
      "to": 11.01,
      "content": "因为我失去了所有对我重要的人",
      "music": 0.0,
      "sid": 5,
      "location": 2
    },
    {
      "from": 11.01,
      "to": 15.39,
      "content": "我做了一件冲动的事情，和一个大学教授有了外遇",
      "music": 0.0,
      "sid": 6,
      "location": 2
    },
    {
      "from": 15.39,
      "to": 17.86,
      "content": "当我在和另一个男生约会的时候",
      "music": 0.0,
      "sid": 7,
      "location": 2
    },
    {
      "from": 17.86,
      "to": 19.72,
      "content": "我深深地后悔",
      "music": 0.0,
      "sid": 8,
      "location": 2
    },
    {
      "from": 19.72,
      "to": 23.599,
      "content": "现在我要为三年前的事情付出代价",
      "music": 0.0,
      "sid": 9,
      "location": 2
    },
    {
      "from": 23.599,
      "to": 25.959,
      "content": "我搬到另一个城市去上大学",
      "music": 0.0,
      "sid": 10,
      "location": 2
    },
    {
      "from": 25.959,
      "to": 29.319,
      "content": "那是我生活中一个负责任的重要阶段",
      "music": 0.0,
      "sid": 11,
      "location": 2
    },
    {
      "from": 29.319,
      "to": 31.95,
      "content": "当然，我也有些害怕",
      "music": 0.0,
      "sid": 12,
      "location": 2
    },
    {
      "from": 31.95,
      "to": 35.73,
      "content": "但有一个男生总是在我身边支持我，爱我",
      "music": 0.0,
      "sid": 13,
      "location": 2
    },
    {
      "from": 35.73,
      "to": 36.53,
      "content": "他是迈克",
      "music": 0.0,
      "sid": 14,
      "location": 2
    },
    {
      "from": 36.53,
      "to": 39.18,
      "content": "我男朋友，我一生的爱人",
      "music": 0.0,
      "sid": 15,
      "location": 2
    },
    {
      "from": 39.18,
      "to": 39.94,
      "content": "那个时候",
      "music": 0.0,
      "sid": 16,
      "location": 2
    },
    {
      "from": 39.94,
      "to": 42.96,
      "content": "我们已经在一起两年了",
      "music": 0.0,
      "sid": 17,
      "location": 2
    },
    {
      "from": 42.96,
      "to": 45.66,
      "content": "所以高中毕业后，我们没有像情侣那样分手",
      "music": 0.0,
      "sid": 18,
      "location": 2
    },
    {
      "from": 45.66,
      "to": 46.56,
      "content": "通常都会",
      "music": 0.0,
      "sid": 19,
      "location": 2
    },
    {
      "from": 46.56,
      "to": 50.85,
      "content": "我们决定去同一所大学，以继续在一起",
      "music": 0.0,
      "sid": 20,
      "location": 2
    },
    {
      "from": 50.85,
      "to": 52.39,
      "content": "一切都很完美",
      "music": 0.0,
      "sid": 21,
      "location": 2
    },
    {
      "from": 52.39,
      "to": 55.27,
      "content": "直到迈克在一个晚上搞砸了",
      "music": 0.0,
      "sid": 22,
      "location": 2
    },
    {
      "from": 55.27,
      "to": 57.35,
      "content": "我正在努力学习考试",
      "music": 0.0,
      "sid": 23,
      "location": 2
    },
    {
      "from": 57.35,
      "to": 60.17,
      "content": "我 literally 沉浸在书中",
      "music": 0.0,
      "sid": 24,
      "location": 2
    },
    {
      "from": 60.17,
      "to": 62.73,
      "content": "突然，我的朋友冲进我的房间",
      "music": 0.0,
      "sid": 25,
      "location": 2
    },
    {
      "from": 62.73,
      "to": 64.39,
      "content": "她手里拿着一部手机",
      "music": 0.0,
      "sid": 26,
      "location": 2
    },
    {
      "from": 64.39,
      "to": 67.44,
      "content": "她说我需要紧急去看一些东西",
      "music": 0.0,
      "sid": 27,
      "location": 2
    },
    {
      "from": 67.44,
      "to": 69.16,
      "content": "然后她把手机递给我",
      "music": 0.0,
      "sid": 28,
      "location": 2
    },
    {
      "from": 69.16,
      "to": 73.03,
      "content": "在Instagram上，有我们校园某个地方的故事",
      "music": 0.0,
      "sid": 29,
      "location": 2
    },
    {
      "from": 73.03,
      "to": 76.35,
      "content": "有人在拍摄一个充满欢笑的房间",
      "music": 0.0,
      "sid": 30,
      "location": 2
    },
    {
      "from": 76.35,
      "to": 78.05,
      "content": "在故事的最后",
      "music": 0.0,
      "sid": 31,
      "location": 2
    },
    {
      "from": 78.05,
      "to": 80.74,
      "content": "你可以看到角落里的一对情侣在接吻",
      "music": 0.0,
      "sid": 32,
      "location": 2
    },
    {
      "from": 80.74,
      "to": 83.02,
      "content": "不幸的是，那是迈克",
      "music": 0.0,
      "sid": 33,
      "location": 2
    },
    {
      "from": 83.02,
      "to": 85.88,
      "content": "我立即拿起手机给他打电话",
      "music": 0.0,
      "sid": 34,
      "location": 2
    },
    {
      "from": 85.88,
      "to": 87.47,
      "content": "但他没有接听",
      "music": 0.0,
      "sid": 35,
      "location": 2
    },
    {
      "from": 87.47,
      "to": 89.57,
      "content": "我整晚都在流泪",
      "music": 0.0,
      "sid": 36,
      "location": 2
    },
    {
      "from": 89.57,
      "to": 92.82,
      "content": "我甚至无法在早晨思考学习",
      "music": 0.0,
      "sid": 37,
      "location": 2
    },
    {
      "from": 92.82,
      "to": 93.92,
      "content": "我去了考试",
      "music": 0.0,
      "sid": 38,
      "location": 2
    },
    {
      "from": 93.92,
      "to": 95.64,
      "content": "苍白而疲惫",
      "music": 0.0,
      "sid": 39,
      "location": 2
    },
    {
      "from": 95.64,
      "to": 97.31,
      "content": "我失败了",
      "music": 0.0,
      "sid": 40,
      "location": 2
    },
    {
      "from": 97.31,
      "to": 99.45,
      "content": "但老师看到我精神不振",
      "music": 0.0,
      "sid": 41,
      "location": 2
    },
    {
      "from": 99.45,
      "to": 101.9,
      "content": "同意帮我改正错误",
      "music": 0.0,
      "sid": 42,
      "location": 2
    },
    {
      "from": 101.9,
      "to": 104.0,
      "content": "所以我得到了平均分",
      "music": 0.0,
      "sid": 43,
      "location": 2
    },
    {
      "from": 104.0,
      "to": 107.34,
      "content": "我需要在这里停下来，告诉你关于这个老师的事情",
      "music": 0.0,
      "sid": 44,
      "location": 2
    },
    {
      "from": 107.34,
      "to": 108.89,
      "content": "杰弗里先生",
      "music": 0.0,
      "sid": 45,
      "location": 2
    },
    {
      "from": 108.89,
      "to": 109.63,
      "content": "实际上",
      "music": 0.0,
      "sid": 46,
      "location": 2
    },
    {
      "from": 109.63,
      "to": 111.88,
      "content": "他让我叫他大卫",
      "music": 0.0,
      "sid": 47,
      "location": 2
    },
    {
      "from": 111.88,
      "to": 117.74,
      "content": "他是一位年轻的老师，刚刚完成了他的奖学金，开始教历史给学生",
      "music": 0.0,
      "sid": 48,
      "location": 2
    },
    {
      "from": 117.74,
      "to": 118.28,
      "content": "哦",
      "music": 0.0,
      "sid": 49,
      "location": 2
    },
    {
      "from": 118.28,
      "to": 120.74,
      "content": "我们组的所有女孩都深深地爱上了他",
      "music": 0.0,
      "sid": 50,
      "location": 2
    },
    {
      "from": 120.74,
      "to": 121.62,
      "content": "他爱我",
      "music": 0.0,
      "sid": 51,
      "location": 2
    },
    {
      "from": 121.62,
      "to": 124.2,
      "content": "他吸引人的原因显而易见",
      "music": 0.0,
      "sid": 52,
      "location": 2
    },
    {
      "from": 124.2,
      "to": 126.75,
      "content": "魅力四溢，非常甜蜜",
      "music": 0.0,
      "sid": 53,
      "location": 2
    },
    {
      "from": 126.75,
      "to": 130.259,
      "content": "他总是尊重并关心他的学生",
      "music": 0.0,
      "sid": 54,
      "location": 2
    },
    {
      "from": 130.259,
      "to": 132.719,
      "content": "我肯定这就是他为什么同意帮我的原因",
      "music": 0.0,
      "sid": 55,
      "location": 2
    },
    {
      "from": 132.719,
      "to": 135.159,
      "content": "他不仅帮我复习考试，还继续帮助我",
      "music": 0.0,
      "sid": 56,
      "location": 2
    },
    {
      "from": 135.159,
      "to": 137.96,
      "content": "那天我与大卫发生了一场大争吵",
      "music": 0.0,
      "sid": 57,
      "location": 2
    },
    {
      "from": 137.96,
      "to": 140.94,
      "content": "我无法接受他亲吻另一个女孩的事实",
      "music": 0.0,
      "sid": 58,
      "location": 2
    },
    {
      "from": 140.94,
      "to": 142.2,
      "content": "我们分手了",
      "music": 0.0,
      "sid": 59,
      "location": 2
    },
    {
      "from": 142.2,
      "to": 145.49,
      "content": "我感到非常痛苦，因为我爱他",
      "music": 0.0,
      "sid": 60,
      "location": 2
    },
    {
      "from": 145.49,
      "to": 149.25,
      "content": "我无法相信那天晚上他竟然对我做了这样的事",
      "music": 0.0,
      "sid": 61,
      "location": 2
    },
    {
      "from": 149.25,
      "to": 151.15,
      "content": "我坐在家里，只是在哭泣",
      "music": 0.0,
      "sid": 62,
      "location": 2
    },
    {
      "from": 151.15,
      "to": 153.67,
      "content": "突然我收到了一条消息",
      "music": 0.0,
      "sid": 63,
      "location": 2
    },
    {
      "from": 153.67,
      "to": 155.42,
      "content": "它是来自大卫的",
      "music": 0.0,
      "sid": 64,
      "location": 2
    },
    {
      "from": 155.42,
      "to": 160.82,
      "content": "他担心我早上的精神状态，问我感觉如何",
      "music": 0.0,
      "sid": 65,
      "location": 2
    },
    {
      "from": 160.82,
      "to": 163.72,
      "content": "你不应该向陌生人分享个人感受",
      "music": 0.0,
      "sid": 66,
      "location": 2
    },
    {
      "from": 163.72,
      "to": 166.94,
      "content": "但杰斐逊先生不仅仅是一个普通的老师",
      "music": 0.0,
      "sid": 67,
      "location": 2
    },
    {
      "from": 166.94,
      "to": 169.16,
      "content": "我感觉他更像是一个朋友",
      "music": 0.0,
      "sid": 68,
      "location": 2
    },
    {
      "from": 169.16,
      "to": 171.26,
      "content": "我决定信任他",
      "music": 0.0,
      "sid": 69,
      "location": 2
    },
    {
      "from": 171.26,
      "to": 175.15,
      "content": "所以我告诉他我的两年关系刚刚结束",
      "music": 0.0,
      "sid": 70,
      "location": 2
    },
    {
      "from": 175.15,
      "to": 176.51,
      "content": "他为我感到难过",
      "music": 0.0,
      "sid": 71,
      "location": 2
    },
    {
      "from": 176.51,
      "to": 178.19,
      "content": "他试图安慰我",
      "music": 0.0,
      "sid": 72,
      "location": 2
    },
    {
      "from": 178.19,
      "to": 180.75,
      "content": "我和他聊到几乎天亮",
      "music": 0.0,
      "sid": 73,
      "location": 2
    },
    {
      "from": 180.75,
      "to": 182.94,
      "content": "他邀请我去喝咖啡",
      "music": 0.0,
      "sid": 74,
      "location": 2
    },
    {
      "from": 182.94,
      "to": 184.9,
      "content": "他分散了我的注意力",
      "music": 0.0,
      "sid": 75,
      "location": 2
    },
    {
      "from": 184.9,
      "to": 187.78,
      "content": "他甚至成功地让我笑了几次",
      "music": 0.0,
      "sid": 76,
      "location": 2
    },
    {
      "from": 187.78,
      "to": 191.16,
      "content": "我甚至没有注意到有一天他握住了我的手",
      "music": 0.0,
      "sid": 77,
      "location": 2
    },
    {
      "from": 191.16,
      "to": 193.81,
      "content": "我在他的眼神中看到了一切",
      "music": 0.0,
      "sid": 78,
      "location": 2
    },
    {
      "from": 193.81,
      "to": 195.99,
      "content": "说实话，我也有同样的感觉",
      "music": 0.0,
      "sid": 79,
      "location": 2
    },
    {
      "from": 195.99,
      "to": 196.71,
      "content": "是的",
      "music": 0.0,
      "sid": 80,
      "location": 2
    },
    {
      "from": 196.71,
      "to": 199.17,
      "content": "我想那就是我们坠入爱情的时候",
      "music": 0.0,
      "sid": 81,
      "location": 2
    },
    {
      "from": 199.17,
      "to": 200.55,
      "content": "它自然发生",
      "music": 0.0,
      "sid": 82,
      "location": 2
    },
    {
      "from": 200.55,
      "to": 201.97,
      "content": "它是美丽的",
      "music": 0.0,
      "sid": 83,
      "location": 2
    },
    {
      "from": 201.97,
      "to": 203.97,
      "content": "我的心痛停止了",
      "music": 0.0,
      "sid": 84,
      "location": 2
    },
    {
      "from": 203.97,
      "to": 206.34,
      "content": "我感觉我可以再次快乐起来",
      "music": 0.0,
      "sid": 85,
      "location": 2
    },
    {
      "from": 206.34,
      "to": 207.98,
      "content": "所以我们开始约会",
      "music": 0.0,
      "sid": 86,
      "location": 2
    },
    {
      "from": 207.98,
      "to": 208.9,
      "content": "当然",
      "music": 0.0,
      "sid": 87,
      "location": 2
    },
    {
      "from": 208.9,
      "to": 211.28,
      "content": "师生关系是禁止的",
      "music": 0.0,
      "sid": 88,
      "location": 2
    },
    {
      "from": 211.28,
      "to": 212.589,
      "content": "我们知道",
      "music": 0.0,
      "sid": 89,
      "location": 2
    },
    {
      "from": 212.589,
      "to": 214.549,
      "content": "所以我们采取了所有的预防措施",
      "music": 0.0,
      "sid": 90,
      "location": 2
    },
    {
      "from": 214.549,
      "to": 217.509,
      "content": "我们在课堂上或在校园里不表现出我们的感情",
      "music": 0.0,
      "sid": 91,
      "location": 2
    },
    {
      "from": 217.509,
      "to": 221.38,
      "content": "我们只在远离校园的另一个城市的地方见面",
      "music": 0.0,
      "sid": 92,
      "location": 2
    },
    {
      "from": 221.38,
      "to": 223.76,
      "content": "但秘密总会被揭示",
      "music": 0.0,
      "sid": 93,
      "location": 2
    },
    {
      "from": 223.76,
      "to": 226.1,
      "content": "我们像往常一样坐在咖啡店",
      "music": 0.0,
      "sid": 94,
      "location": 2
    },
    {
      "from": 226.1,
      "to": 228.02,
      "content": "在角落里的桌子上接吻",
      "music": 0.0,
      "sid": 95,
      "location": 2
    },
    {
      "from": 228.02,
      "to": 230.51,
      "content": "但突然我的同学们进来了",
      "music": 0.0,
      "sid": 96,
      "location": 2
    },
    {
      "from": 230.51,
      "to": 232.03,
      "content": "他们看到了一切",
      "music": 0.0,
      "sid": 97,
      "location": 2
    },
    {
      "from": 232.03,
      "to": 233.23,
      "content": "不仅看到了",
      "music": 0.0,
      "sid": 98,
      "location": 2
    },
    {
      "from": 233.23,
      "to": 235.959,
      "content": "他们还开始笑和窃窃私语",
      "music": 0.0,
      "sid": 99,
      "location": 2
    },
    {
      "from": 235.959,
      "to": 236.379,
      "content": "哦",
      "music": 0.0,
      "sid": 100,
      "location": 2
    },
    {
      "from": 236.379,
      "to": 239.09,
      "content": "那之后我们的约会变得如此尴尬",
      "music": 0.0,
      "sid": 101,
      "location": 2
    },
    {
      "from": 239.09,
      "to": 240.71,
      "content": "我正在通过校园走回家",
      "music": 0.0,
      "sid": 102,
      "location": 2
    },
    {
      "from": 240.71,
      "to": 242.41,
      "content": "我想和我的朋友们谈谈",
      "music": 0.0,
      "sid": 103,
      "location": 2
    },
    {
      "from": 242.41,
      "to": 245.35,
      "content": "以便我可以问他们不要透露我的秘密",
      "music": 0.0,
      "sid": 104,
      "location": 2
    },
    {
      "from": 245.35,
      "to": 247.19,
      "content": "但是迈克突然出现了",
      "music": 0.0,
      "sid": 105,
      "location": 2
    },
    {
      "from": 247.19,
      "to": 248.61,
      "content": "他跑向我",
      "music": 0.0,
      "sid": 106,
      "location": 2
    },
    {
      "from": 248.61,
      "to": 250.59,
      "content": "看起来他在等我",
      "music": 0.0,
      "sid": 107,
      "location": 2
    },
    {
      "from": 250.59,
      "to": 251.49,
      "content": "在宿舍附近",
      "music": 0.0,
      "sid": 108,
      "location": 2
    },
    {
      "from": 251.49,
      "to": 253.45,
      "content": "他拿着一大束百合花",
      "music": 0.0,
      "sid": 109,
      "location": 2
    },
    {
      "from": 253.45,
      "to": 256.38,
      "content": "他泪流满面地向我求原谅",
      "music": 0.0,
      "sid": 110,
      "location": 2
    },
    {
      "from": 256.38,
      "to": 258.82,
      "content": "迈克说他和那个女孩没有任何关系",
      "music": 0.0,
      "sid": 111,
      "location": 2
    },
    {
      "from": 258.82,
      "to": 260.4,
      "content": "他说他爱我",
      "music": 0.0,
      "sid": 112,
      "location": 2
    },
    {
      "from": 260.4,
      "to": 262.14,
      "content": "我可能对他生气",
      "music": 0.0,
      "sid": 113,
      "location": 2
    },
    {
      "from": 262.14,
      "to": 264.61,
      "content": "但我最喜欢的百合花让我平静下来",
      "music": 0.0,
      "sid": 114,
      "location": 2
    },
    {
      "from": 264.61,
      "to": 267.47,
      "content": "他记得那个之后",
      "music": 0.0,
      "sid": 115,
      "location": 2
    },
    {
      "from": 267.47,
      "to": 268.89,
      "content": "我们谈了很长时间",
      "music": 0.0,
      "sid": 116,
      "location": 2
    },
    {
      "from": 268.89,
      "to": 270.97,
      "content": "并回忆起我们多么好在一起",
      "music": 0.0,
      "sid": 117,
      "location": 2
    },
    {
      "from": 270.97,
      "to": 275.33,
      "content": "迈克问我不要让他的错误破坏我们的未来",
      "music": 0.0,
      "sid": 118,
      "location": 2
    },
    {
      "from": 275.49,
      "to": 278.53,
      "content": "我必须说，这基本上融化了我的心",
      "music": 0.0,
      "sid": 119,
      "location": 2
    },
    {
      "from": 278.53,
      "to": 280.91,
      "content": "我们一起经历了很多事情",
      "music": 0.0,
      "sid": 120,
      "location": 2
    },
    {
      "from": 280.91,
      "to": 283.53,
      "content": "显然我还对他有感情",
      "music": 0.0,
      "sid": 121,
      "location": 2
    },
    {
      "from": 283.53,
      "to": 287.77,
      "content": "我意识到我可能与大卫的短暂关系是一个错误",
      "music": 0.0,
      "sid": 122,
      "location": 2
    },
    {
      "from": 287.77,
      "to": 291.49,
      "content": "他正在正确的时间和正确的地方出现",
      "music": 0.0,
      "sid": 123,
      "location": 2
    },
    {
      "from": 291.49,
      "to": 294.73,
      "content": "毕竟我们都会陷入很多麻烦",
      "music": 0.0,
      "sid": 124,
      "location": 2
    },
    {
      "from": 294.73,
      "to": 298.85,
      "content": "如果大学的当局发现我们的关系",
      "music": 0.0,
      "sid": 125,
      "location": 2
    },
    {
      "from": 300.64,
      "to": 303.3,
      "content": "所以第二天早上我去见了大卫",
      "music": 0.0,
      "sid": 126,
      "location": 2
    },
    {
      "from": 303.3,
      "to": 305.94,
      "content": "我想要说我们需要分手",
      "music": 0.0,
      "sid": 127,
      "location": 2
    },
    {
      "from": 305.94,
      "to": 308.65,
      "content": "但他告诉我的话让我目瞪口呆",
      "music": 0.0,
      "sid": 128,
      "location": 2
    },
    {
      "from": 308.65,
      "to": 310.33,
      "content": "大卫有未婚妻",
      "music": 0.0,
      "sid": 129,
      "location": 2
    },
    {
      "from": 310.33,
      "to": 315.18,
      "content": "六个月前她去欧洲在一所大学做实习",
      "music": 0.0,
      "sid": 130,
      "location": 2
    },
    {
      "from": 315.18,
      "to": 318.92,
      "content": "他们一直在保持长距离关系",
      "music": 0.0,
      "sid": 131,
      "location": 2
    },
    {
      "from": 318.92,
      "to": 320.48,
      "content": "但现在他遇到了我",
      "music": 0.0,
      "sid": 132,
      "location": 2
    },
    {
      "from": 320.48,
      "to": 323.409,
      "content": "他决定不能等待她回来",
      "music": 0.0,
      "sid": 133,
      "location": 2
    },
    {
      "from": 323.409,
      "to": 325.369,
      "content": "今晚他解除了他们的订婚",
      "music": 0.0,
      "sid": 134,
      "location": 2
    },
    {
      "from": 326.369,
      "to": 328.349,
      "content": "我站在完全的呆滞中",
      "music": 0.0,
      "sid": 135,
      "location": 2
    },
    {
      "from": 328.349,
      "to": 330.81,
      "content": "他用另一条震惊的消息震惊我",
      "music": 0.0,
      "sid": 136,
      "location": 2
    },
    {
      "from": 330.81,
      "to": 331.81,
      "content": "他不在乎",
      "music": 0.0,
      "sid": 137,
      "location": 2
    },
    {
      "from": 331.81,
      "to": 333.73,
      "content": "大学当局对我们怎么看",
      "music": 0.0,
      "sid": 138,
      "location": 2
    },
    {
      "from": 333.73,
      "to": 336.64,
      "content": "他是愿意为我辞职的",
      "music": 0.0,
      "sid": 139,
      "location": 2
    },
    {
      "from": 336.84,
      "to": 339.42,
      "content": "你应该知道，在他这个自白之后",
      "music": 0.0,
      "sid": 140,
      "location": 2
    },
    {
      "from": 339.42,
      "to": 342.21,
      "content": "我无法告诉他我们要分手",
      "music": 0.0,
      "sid": 141,
      "location": 2
    },
    {
      "from": 342.21,
      "to": 343.95,
      "content": "我会毁了他的生活",
      "music": 0.0,
      "sid": 142,
      "location": 2
    },
    {
      "from": 343.95,
      "to": 345.69,
      "content": "但我也爱迈克",
      "music": 0.0,
      "sid": 143,
      "location": 2
    },
    {
      "from": 345.69,
      "to": 347.659,
      "content": "我想要和他在一起",
      "music": 0.0,
      "sid": 144,
      "location": 2
    },
    {
      "from": 347.659,
      "to": 350.179,
      "content": "所以我处于一个非常困难的位置",
      "music": 0.0,
      "sid": 145,
      "location": 2
    },
    {
      "from": 350.179,
      "to": 351.959,
      "content": "我无法做出决定",
      "music": 0.0,
      "sid": 146,
      "location": 2
    },
    {
      "from": 351.959,
      "to": 355.68,
      "content": "从那一刻起我开始和他们两个约会",
      "music": 0.0,
      "sid": 147,
      "location": 2
    },
    {
      "from": 355.68,
      "to": 357.18,
      "content": "我整天都和迈克在一起",
      "music": 0.0,
      "sid": 148,
      "location": 2
    },
    {
      "from": 357.18,
      "to": 360.24,
      "content": "然后我会说我需要跟我的历史导师学习",
      "music": 0.0,
      "sid": 149,
      "location": 2
    },
    {
      "from": 360.24,
      "to": 362.12,
      "content": "然后我会去大卫家",
      "music": 0.0,
      "sid": 150,
      "location": 2
    },
    {
      "from": 362.12,
      "to": 363.46,
      "content": "这持续了几个月",
      "music": 0.0,
      "sid": 151,
      "location": 2
    },
    {
      "from": 363.46,
      "to": 365.62,
      "content": "我对自己做的事情感到羞愧",
      "music": 0.0,
      "sid": 152,
      "location": 2
    },
    {
      "from": 365.62,
      "to": 369.13,
      "content": "但我无法找出如何摆脱这个困境",
      "music": 0.0,
      "sid": 153,
      "location": 2
    },
    {
      "from": 369.13,
      "to": 371.43,
      "content": "我不知道它会持续多久",
      "music": 0.0,
      "sid": 154,
      "location": 2
    },
    {
      "from": 371.43,
      "to": 373.99,
      "content": "但一个意想不到的情况出现了",
      "music": 0.0,
      "sid": 155,
      "location": 2
    },
    {
      "from": 373.99,
      "to": 376.36,
      "content": "我不得不在两者之间做出选择",
      "music": 0.0,
      "sid": 156,
      "location": 2
    },
    {
      "from": 376.36,
      "to": 378.84,
      "content": "这个情况是我的怀孕",
      "music": 0.0,
      "sid": 157,
      "location": 2
    },
    {
      "from": 379.92,
      "to": 383.85,
      "content": "我花了很长时间思考应该选择米克还是大卫",
      "music": 0.0,
      "sid": 158,
      "location": 2
    },
    {
      "from": 383.85,
      "to": 385.55,
      "content": "但这对我来说太难了",
      "music": 0.0,
      "sid": 159,
      "location": 2
    },
    {
      "from": 385.55,
      "to": 386.37,
      "content": "有一天",
      "music": 0.0,
      "sid": 160,
      "location": 2
    },
    {
      "from": 386.37,
      "to": 388.79,
      "content": "我完全崩溃了，决定掷硬币",
      "music": 0.0,
      "sid": 161,
      "location": 2
    },
    {
      "from": 388.79,
      "to": 391.549,
      "content": "我深深地呼吸，然后抛起了硬币",
      "music": 0.0,
      "sid": 162,
      "location": 2
    },
    {
      "from": 391.549,
      "to": 392.769,
      "content": "然后我抓住了硬币",
      "music": 0.0,
      "sid": 163,
      "location": 2
    },
    {
      "from": 392.769,
      "to": 395.549,
      "content": "很长一段时间我都不想看到结果",
      "music": 0.0,
      "sid": 164,
      "location": 2
    },
    {
      "from": 395.549,
      "to": 396.789,
      "content": "我张开手",
      "music": 0.0,
      "sid": 165,
      "location": 2
    },
    {
      "from": 396.789,
      "to": 398.43,
      "content": "是大卫",
      "music": 0.0,
      "sid": 166,
      "location": 2
    },
    {
      "from": 398.43,
      "to": 400.13,
      "content": "那天我去见了米克",
      "music": 0.0,
      "sid": 167,
      "location": 2
    },
    {
      "from": 400.13,
      "to": 402.93,
      "content": "我告诉他我怀孕了另一个男人的孩子",
      "music": 0.0,
      "sid": 168,
      "location": 2
    },
    {
      "from": 402.93,
      "to": 405.45,
      "content": "不要问我在那个时刻的感觉",
      "music": 0.0,
      "sid": 169,
      "location": 2
    },
    {
      "from": 405.45,
      "to": 407.38,
      "content": "那真是太糟糕了",
      "music": 0.0,
      "sid": 170,
      "location": 2
    },
    {
      "from": 407.62,
      "to": 410.08,
      "content": "然后我告诉了大卫这个喜讯",
      "music": 0.0,
      "sid": 171,
      "location": 2
    },
    {
      "from": 410.08,
      "to": 412.61,
      "content": "我们开始改变我们的生活",
      "music": 0.0,
      "sid": 172,
      "location": 2
    },
    {
      "from": 412.61,
      "to": 415.65,
      "content": "他因为计划结婚而辍学了",
      "music": 0.0,
      "sid": 173,
      "location": 2
    },
    {
      "from": 415.65,
      "to": 418.03,
      "content": "我每个月都在变胖",
      "music": 0.0,
      "sid": 174,
      "location": 2
    },
    {
      "from": 418.03,
      "to": 420.23,
      "content": "这可能只是荷尔蒙的作用",
      "music": 0.0,
      "sid": 175,
      "location": 2
    },
    {
      "from": 420.23,
      "to": 422.51,
      "content": "但我感到安全和快乐",
      "music": 0.0,
      "sid": 176,
      "location": 2
    },
    {
      "from": 422.51,
      "to": 424.71,
      "content": "大卫总是关心我",
      "music": 0.0,
      "sid": 177,
      "location": 2
    },
    {
      "from": 424.71,
      "to": 427.37,
      "content": "我知道我做出了正确的选择",
      "music": 0.0,
      "sid": 178,
      "location": 2
    },
    {
      "from": 427.37,
      "to": 431.16,
      "content": "但当我们的儿子出生时，一切发生了变化",
      "music": 0.0,
      "sid": 179,
      "location": 2
    },
    {
      "from": 431.16,
      "to": 432.46,
      "content": "一切都很好",
      "music": 0.0,
      "sid": 180,
      "location": 2
    },
    {
      "from": 432.46,
      "to": 436.81,
      "content": "我们几乎无法满足对自己的幸福",
      "music": 0.0,
      "sid": 181,
      "location": 2
    },
    {
      "from": 436.81,
      "to": 440.039,
      "content": "然后我开始注意到大卫的奇怪行为",
      "music": 0.0,
      "sid": 182,
      "location": 2
    },
    {
      "from": 440.039,
      "to": 442.359,
      "content": "他试图假装一切都正常",
      "music": 0.0,
      "sid": 183,
      "location": 2
    },
    {
      "from": 442.359,
      "to": 445.59,
      "content": "但我可以看到他担心着什么",
      "music": 0.0,
      "sid": 184,
      "location": 2
    },
    {
      "from": 445.59,
      "to": 448.83,
      "content": "不久他就告诉我了一切",
      "music": 0.0,
      "sid": 185,
      "location": 2
    },
    {
      "from": 449.17,
      "to": 454.02,
      "content": "我的丈夫担心孩子的外貌与他完全不同",
      "music": 0.0,
      "sid": 186,
      "location": 2
    },
    {
      "from": 454.02,
      "to": 456.6,
      "content": "当然，他不意味着孩子的特征",
      "music": 0.0,
      "sid": 187,
      "location": 2
    },
    {
      "from": 456.6,
      "to": 458.5,
      "content": "但他指的是手腕上的胎记",
      "music": 0.0,
      "sid": 188,
      "location": 2
    },
    {
      "from": 458.5,
      "to": 461.58,
      "content": "大卫有一个淡紫色的非洲形状的标记",
      "music": 0.0,
      "sid": 189,
      "location": 2
    },
    {
      "from": 461.58,
      "to": 464.87,
      "content": "他说他的父亲和祖父也有同样的",
      "music": 0.0,
      "sid": 190,
      "location": 2
    },
    {
      "from": 464.87,
      "to": 467.21,
      "content": "但我们的孩子没有",
      "music": 0.0,
      "sid": 191,
      "location": 2
    },
    {
      "from": 467.21,
      "to": 469.91,
      "content": "当然，胎记并不总是可转移的",
      "music": 0.0,
      "sid": 192,
      "location": 2
    },
    {
      "from": 469.91,
      "to": 471.97,
      "content": "其缺失并不能证明什么",
      "music": 0.0,
      "sid": 193,
      "location": 2
    },
    {
      "from": 471.97,
      "to": 474.45,
      "content": "但它仍然足够让大卫担心",
      "music": 0.0,
      "sid": 194,
      "location": 2
    },
    {
      "from": 474.45,
      "to": 476.39,
      "content": "这也让我开始思考",
      "music": 0.0,
      "sid": 195,
      "location": 2
    },
    {
      "from": 476.39,
      "to": 479.93,
      "content": "因为我同时与大卫和米克约会",
      "music": 0.0,
      "sid": 196,
      "location": 2
    },
    {
      "from": 479.93,
      "to": 483.49,
      "content": "所以孩子可能是前男友的",
      "music": 0.0,
      "sid": 197,
      "location": 2
    },
    {
      "from": 483.49,
      "to": 488.42,
      "content": "我把这个想法推开，试图说服我的丈夫一切都很好",
      "music": 0.0,
      "sid": 198,
      "location": 2
    },
    {
      "from": 488.42,
      "to": 491.2,
      "content": "但他对这个问题非常执着",
      "music": 0.0,
      "sid": 199,
      "location": 2
    },
    {
      "from": 491.2,
      "to": 494.58,
      "content": "不久，他以忧郁的表情走进了我们的卧室",
      "music": 0.0,
      "sid": 200,
      "location": 2
    },
    {
      "from": 494.58,
      "to": 498.17,
      "content": "他说他想做亲子鉴定",
      "music": 0.0,
      "sid": 201,
      "location": 2
    },
    {
      "from": 498.37,
      "to": 498.91,
      "content": "是的",
      "music": 0.0,
      "sid": 202,
      "location": 2
    },
    {
      "from": 498.91,
      "to": 501.09,
      "content": "我们必须解决这个问题",
      "music": 0.0,
      "sid": 203,
      "location": 2
    },
    {
      "from": 501.09,
      "to": 504.09,
      "content": "所以我们做了测试并等待结果",
      "music": 0.0,
      "sid": 204,
      "location": 2
    },
    {
      "from": 504.09,
      "to": 507.61,
      "content": "那是我生命中最糟糕的两天",
      "music": 0.0,
      "sid": 205,
      "location": 2
    },
    {
      "from": 507.93,
      "to": 510.05,
      "content": "房子里充满了紧张",
      "music": 0.0,
      "sid": 206,
      "location": 2
    },
    {
      "from": 510.05,
      "to": 512.7,
      "content": "我们甚至几乎不说话",
      "music": 0.0,
      "sid": 207,
      "location": 2
    },
    {
      "from": 512.7,
      "to": 516.6,
      "content": "然后我收到了通知说结果准备好了",
      "music": 0.0,
      "sid": 208,
      "location": 2
    },
    {
      "from": 516.6,
      "to": 518.549,
      "content": "手里颤抖着",
      "music": 0.0,
      "sid": 209,
      "location": 2
    },
    {
      "from": 518.549,
      "to": 522.509,
      "content": "我登录了我的电子邮件并打开了信函中的文件",
      "music": 0.0,
      "sid": 210,
      "location": 2
    },
    {
      "from": 522.509,
      "to": 524.35,
      "content": "真相的时刻",
      "music": 0.0,
      "sid": 211,
      "location": 2
    },
    {
      "from": 524.35,
      "to": 526.41,
      "content": "大卫不是父亲",
      "music": 0.0,
      "sid": 212,
      "location": 2
    },
    {
      "from": 526.41,
      "to": 527.05,
      "content": "哦",
      "music": 0.0,
      "sid": 213,
      "location": 2
    },
    {
      "from": 527.05,
      "to": 529.98,
      "content": "这看起来完全出乎意料",
      "music": 0.0,
      "sid": 214,
      "location": 2
    },
    {
      "from": 529.98,
      "to": 535.24,
      "content": "从那一刻起，我的生活开始以疯狂的速度崩溃",
      "music": 0.0,
      "sid": 215,
      "location": 2
    },
    {
      "from": 535.36,
      "to": 537.28,
      "content": "大卫不能原谅我撒谎",
      "music": 0.0,
      "sid": 216,
      "location": 2
    },
    {
      "from": 537.28,
      "to": 539.19,
      "content": "所以他提出了离婚",
      "music": 0.0,
      "sid": 217,
      "location": 2
    },
    {
      "from": 539.19,
      "to": 541.63,
      "content": "我对他没有任何责怪",
      "music": 0.0,
      "sid": 218,
      "location": 2
    },
    {
      "from": 541.63,
      "to": 544.01,
      "content": "我必须和一个朋友一起住一段时间",
      "music": 0.0,
      "sid": 219,
      "location": 2
    },
    {
      "from": 544.01,
      "to": 546.44,
      "content": "因为我根本就没有地方住",
      "music": 0.0,
      "sid": 220,
      "location": 2
    },
    {
      "from": 546.44,
      "to": 549.04,
      "content": "我不能带着婴儿回宿舍",
      "music": 0.0,
      "sid": 221,
      "location": 2
    },
    {
      "from": 549.04,
      "to": 551.7,
      "content": "而且我有严重的金钱问题",
      "music": 0.0,
      "sid": 222,
      "location": 2
    },
    {
      "from": 551.7,
      "to": 554.27,
      "content": "因为我没有在任何地方工作",
      "music": 0.0,
      "sid": 223,
      "location": 2
    },
    {
      "from": 554.27,
      "to": 555.41,
      "content": "在绝望中",
      "music": 0.0,
      "sid": 224,
      "location": 2
    },
    {
      "from": 555.41,
      "to": 557.55,
      "content": "我决定去找迈克寻求帮助",
      "music": 0.0,
      "sid": 225,
      "location": 2
    },
    {
      "from": 557.55,
      "to": 558.91,
      "content": "那是他的孩子",
      "music": 0.0,
      "sid": 226,
      "location": 2
    },
    {
      "from": 558.91,
      "to": 561.07,
      "content": "毕竟这么久了",
      "music": 0.0,
      "sid": 227,
      "location": 2
    },
    {
      "from": 561.07,
      "to": 562.63,
      "content": "我决定不再撒谎",
      "music": 0.0,
      "sid": 228,
      "location": 2
    },
    {
      "from": 562.63,
      "to": 565.0,
      "content": "而是直接告诉他真相",
      "music": 0.0,
      "sid": 229,
      "location": 2
    },
    {
      "from": 565.4,
      "to": 570.17,
      "content": "遗憾的是，真相如此苦涩，以至于无法承受",
      "music": 0.0,
      "sid": 230,
      "location": 2
    },
    {
      "from": 570.17,
      "to": 572.65,
      "content": "我对米克隐瞒了我们的关系",
      "music": 0.0,
      "sid": 231,
      "location": 2
    },
    {
      "from": 572.65,
      "to": 574.819,
      "content": "我也隐瞒了孩子的事情",
      "music": 0.0,
      "sid": 232,
      "location": 2
    },
    {
      "from": 574.819,
      "to": 576.639,
      "content": "结果适得其反",
      "music": 0.0,
      "sid": 233,
      "location": 2
    },
    {
      "from": 576.639,
      "to": 578.599,
      "content": "他让我别再伤害他",
      "music": 0.0,
      "sid": 234,
      "location": 2
    },
    {
      "from": 578.599,
      "to": 581.1,
      "content": "就让我从他的生活中消失",
      "music": 0.0,
      "sid": 235,
      "location": 2
    },
    {
      "from": 581.1,
      "to": 583.38,
      "content": "看起来我孤零零的",
      "music": 0.0,
      "sid": 236,
      "location": 2
    },
    {
      "from": 583.38,
      "to": 587.1,
      "content": "我不得不退学回家和我父母一起",
      "music": 0.0,
      "sid": 237,
      "location": 2
    },
    {
      "from": 587.26,
      "to": 589.3,
      "content": "告诉他们一切都很困难",
      "music": 0.0,
      "sid": 238,
      "location": 2
    },
    {
      "from": 589.3,
      "to": 590.02,
      "content": "也是",
      "music": 0.0,
      "sid": 239,
      "location": 2
    },
    {
      "from": 590.02,
      "to": 593.9,
      "content": "现在我在抚养一个让我回想起错误的孩子",
      "music": 0.0,
      "sid": 240,
      "location": 2
    },
    {
      "from": 593.9,
      "to": 595.48,
      "content": "但是我还是爱他",
      "music": 0.0,
      "sid": 241,
      "location": 2
    },
    {
      "from": 595.48,
      "to": 598.92,
      "content": "即使他现在只是在摇篮曲中沉睡",
      "music": 0.0,
      "sid": 242,
      "location": 2
    },
    {
      "from": 598.92,
      "to": 601.54,
      "content": "对将来一无所知",
      "music": 0.0,
      "sid": 243,
      "location": 2
    },
    {
      "from": 601.54,
      "to": 604.26,
      "content": "我一定会培养他成为一个好人",
      "music": 0.0,
      "sid": 244,
      "location": 2
    },
    {
      "from": 604.26,
      "to": 605.76,
      "content": "谁永远不会撒谎",
      "music": 0.0,
      "sid": 245,
      "location": 2
    }
  ]
}