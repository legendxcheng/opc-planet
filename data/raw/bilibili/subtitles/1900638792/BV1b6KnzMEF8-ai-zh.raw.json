{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.16,
      "to": 1.7,
      "sid": 1,
      "location": 2,
      "content": "我最近刷到一个直播",
      "music": 0.0
    },
    {
      "from": 1.7,
      "to": 5.25,
      "sid": 2,
      "location": 2,
      "content": "是一个00年的奶茶店主和一个餐饮博主连线",
      "music": 0.0
    },
    {
      "from": 5.25,
      "to": 7.85,
      "sid": 3,
      "location": 2,
      "content": "他说自己以前在奶茶店打过工",
      "music": 0.0
    },
    {
      "from": 7.85,
      "to": 9.57,
      "sid": 4,
      "location": 2,
      "content": "可能觉得奶茶店赚钱吧",
      "music": 0.0
    },
    {
      "from": 9.57,
      "to": 12.6,
      "sid": 5,
      "location": 2,
      "content": "就用父母贷款来的40多万开了这家店",
      "music": 0.0
    },
    {
      "from": 12.6,
      "to": 15.1,
      "sid": 6,
      "location": 2,
      "content": "但是开业半个月就做不下去了",
      "music": 0.0
    },
    {
      "from": 15.1,
      "to": 16.46,
      "sid": 7,
      "location": 2,
      "content": "每天都在亏钱",
      "music": 0.0
    },
    {
      "from": 16.46,
      "to": 18.65,
      "sid": 8,
      "location": 2,
      "content": "他后面还在直播间里面哭了",
      "music": 0.0
    },
    {
      "from": 18.65,
      "to": 22.27,
      "sid": 9,
      "location": 2,
      "content": "后来直播切片的评论区里面有人说他住在附近",
      "music": 0.0
    },
    {
      "from": 22.27,
      "to": 23.41,
      "sid": 10,
      "location": 2,
      "content": "想过去支持一下",
      "music": 0.0
    },
    {
      "from": 23.41,
      "to": 25.77,
      "sid": 11,
      "location": 2,
      "content": "但去的时候发现已经关店了",
      "music": 0.0
    },
    {
      "from": 25.77,
      "to": 27.21,
      "sid": 12,
      "location": 2,
      "content": "因为这个奶茶店主",
      "music": 0.0
    },
    {
      "from": 27.21,
      "to": 30.619,
      "sid": 13,
      "location": 2,
      "content": "他刚好命中了所有不适合创业的人物特质",
      "music": 0.0
    },
    {
      "from": 30.619,
      "to": 33.099,
      "sid": 14,
      "location": 2,
      "content": "所以今天就从他来切入讲讲",
      "music": 0.0
    },
    {
      "from": 33.099,
      "to": 35.44,
      "sid": 15,
      "location": 2,
      "content": "到底什么样的人不适合创业",
      "music": 0.0
    },
    {
      "from": 35.44,
      "to": 38.72,
      "sid": 16,
      "location": 2,
      "content": "首先我想说打工不行的人未必不适合创业",
      "music": 0.0
    },
    {
      "from": 38.72,
      "to": 42.26,
      "sid": 17,
      "location": 2,
      "content": "因为我身边很多连续创业者从来就没打过工",
      "music": 0.0
    },
    {
      "from": 42.26,
      "to": 44.4,
      "sid": 18,
      "location": 2,
      "content": "毕业之后就一直在当老板",
      "music": 0.0
    },
    {
      "from": 44.4,
      "to": 46.96,
      "sid": 19,
      "location": 2,
      "content": "但是这两年做什么赔什么",
      "music": 0.0
    },
    {
      "from": 46.96,
      "to": 49.89,
      "sid": 20,
      "location": 2,
      "content": "有些家境一般的创业者就只能去上班了",
      "music": 0.0
    },
    {
      "from": 49.89,
      "to": 52.23,
      "sid": 21,
      "location": 2,
      "content": "我身边有一个八零后创业者",
      "music": 0.0
    },
    {
      "from": 52.23,
      "to": 54.73,
      "sid": 22,
      "location": 2,
      "content": "去年去了一家知名企业做总监",
      "music": 0.0
    },
    {
      "from": 54.73,
      "to": 56.45,
      "sid": 23,
      "location": 2,
      "content": "今年他实在干不下去了",
      "music": 0.0
    },
    {
      "from": 56.45,
      "to": 57.48,
      "sid": 24,
      "location": 2,
      "content": "就提了离职",
      "music": 0.0
    },
    {
      "from": 57.48,
      "to": 60.66,
      "sid": 25,
      "location": 2,
      "content": "他说他领导作为整个业务部的负责人",
      "music": 0.0
    },
    {
      "from": 60.66,
      "to": 63.0,
      "sid": 26,
      "location": 2,
      "content": "却连基本的商业模式都搞不懂",
      "music": 0.0
    },
    {
      "from": 63.0,
      "to": 64.52,
      "sid": 27,
      "location": 2,
      "content": "天天只会开会",
      "music": 0.0
    },
    {
      "from": 64.52,
      "to": 66.11,
      "sid": 28,
      "location": 2,
      "content": "做PPT和甩锅",
      "music": 0.0
    },
    {
      "from": 66.11,
      "to": 67.45,
      "sid": 29,
      "location": 2,
      "content": "我之前分享过",
      "music": 0.0
    },
    {
      "from": 67.45,
      "to": 70.63,
      "sid": 30,
      "location": 2,
      "content": "打工需要的是搞定人或者搞定事儿的能力",
      "music": 0.0
    },
    {
      "from": 70.63,
      "to": 72.29,
      "sid": 31,
      "location": 2,
      "content": "甚至在某些大公司里面",
      "music": 0.0
    },
    {
      "from": 72.29,
      "to": 76.0,
      "sid": 32,
      "location": 2,
      "content": "你只需要掌握汇报这一项技能就能够升职加薪",
      "music": 0.0
    },
    {
      "from": 76.0,
      "to": 78.54,
      "sid": 33,
      "location": 2,
      "content": "但创业需要的是搞定钱的能力",
      "music": 0.0
    },
    {
      "from": 78.54,
      "to": 79.74,
      "sid": 34,
      "location": 2,
      "content": "要关注市场",
      "music": 0.0
    },
    {
      "from": 79.74,
      "to": 80.76,
      "sid": 35,
      "location": 2,
      "content": "控制成本",
      "music": 0.0
    },
    {
      "from": 80.76,
      "to": 81.7,
      "sid": 36,
      "location": 2,
      "content": "维持利润",
      "music": 0.0
    },
    {
      "from": 81.7,
      "to": 82.759,
      "sid": 37,
      "location": 2,
      "content": "保证现金流",
      "music": 0.0
    },
    {
      "from": 82.759,
      "to": 86.18,
      "sid": 38,
      "location": 2,
      "content": "所以本身这就是两条不同赛道上的人",
      "music": 0.0
    },
    {
      "from": 86.18,
      "to": 89.72,
      "sid": 39,
      "location": 2,
      "content": "但确实现在很多创业项目都是稳赔不赚",
      "music": 0.0
    },
    {
      "from": 89.72,
      "to": 90.96,
      "sid": 40,
      "location": 2,
      "content": "这个环境之下",
      "music": 0.0
    },
    {
      "from": 90.96,
      "to": 93.3,
      "sid": 41,
      "location": 2,
      "content": "多数创业者不鼓励大家创业",
      "music": 0.0
    },
    {
      "from": 93.3,
      "to": 97.14,
      "sid": 42,
      "location": 2,
      "content": "但有些做艺人创业公司的自由职业者鼓励创业",
      "music": 0.0
    },
    {
      "from": 97.14,
      "to": 99.88,
      "sid": 43,
      "location": 2,
      "content": "因为有些行业一个人做能赚钱",
      "music": 0.0
    },
    {
      "from": 99.88,
      "to": 101.45,
      "sid": 44,
      "location": 2,
      "content": "三个人做就一定赔钱",
      "music": 0.0
    },
    {
      "from": 101.45,
      "to": 102.77,
      "sid": 45,
      "location": 2,
      "content": "比如招聘行业",
      "music": 0.0
    },
    {
      "from": 102.77,
      "to": 103.87,
      "sid": 46,
      "location": 2,
      "content": "知识付费行业",
      "music": 0.0
    },
    {
      "from": 103.87,
      "to": 104.91,
      "sid": 47,
      "location": 2,
      "content": "自媒体行业",
      "music": 0.0
    },
    {
      "from": 104.91,
      "to": 108.59,
      "sid": 48,
      "location": 2,
      "content": "所以一没有任何一个定论适用于所有人",
      "music": 0.0
    },
    {
      "from": 108.59,
      "to": 110.91,
      "sid": 49,
      "location": 2,
      "content": "二没有任何一件事情只有利好",
      "music": 0.0
    },
    {
      "from": 110.91,
      "to": 111.73,
      "sid": 50,
      "location": 2,
      "content": "没有代价",
      "music": 0.0
    },
    {
      "from": 111.73,
      "to": 113.25,
      "sid": 51,
      "location": 2,
      "content": "那我划分情况",
      "music": 0.0
    },
    {
      "from": 113.25,
      "to": 114.31,
      "sid": 52,
      "location": 2,
      "content": "你对号入座",
      "music": 0.0
    },
    {
      "from": 114.31,
      "to": 115.25,
      "sid": 53,
      "location": 2,
      "content": "我说利弊",
      "music": 0.0
    },
    {
      "from": 115.25,
      "to": 116.68,
      "sid": 54,
      "location": 2,
      "content": "你做选择",
      "music": 0.0
    },
    {
      "from": 116.68,
      "to": 119.04,
      "sid": 55,
      "location": 2,
      "content": "真正不适合创业的有三类人",
      "music": 0.0
    },
    {
      "from": 119.04,
      "to": 121.72,
      "sid": 56,
      "location": 2,
      "content": "第一类人是误会了什么叫做all in",
      "music": 0.0
    },
    {
      "from": 121.72,
      "to": 122.68,
      "sid": 57,
      "location": 2,
      "content": "创业的人",
      "music": 0.0
    },
    {
      "from": 122.68,
      "to": 125.2,
      "sid": 58,
      "location": 2,
      "content": "大多数人以为是要在钱上all in",
      "music": 0.0
    },
    {
      "from": 125.2,
      "to": 127.18,
      "sid": 59,
      "location": 2,
      "content": "但其实是要在事情上all in",
      "music": 0.0
    },
    {
      "from": 127.18,
      "to": 128.72,
      "sid": 60,
      "location": 2,
      "content": "所以钱上all in",
      "music": 0.0
    },
    {
      "from": 128.72,
      "to": 131.16,
      "sid": 61,
      "location": 2,
      "content": "但是事情不all in的人不适合创业",
      "music": 0.0
    },
    {
      "from": 131.16,
      "to": 134.18,
      "sid": 62,
      "location": 2,
      "content": "你看这个奶茶店主在没有任何经验的情况下",
      "music": 0.0
    },
    {
      "from": 134.18,
      "to": 136.04,
      "sid": 63,
      "location": 2,
      "content": "竟然敢跑去贷款创业",
      "music": 0.0
    },
    {
      "from": 136.04,
      "to": 139.26,
      "sid": 64,
      "location": 2,
      "content": "当然是有少数贷款创业做成的人",
      "music": 0.0
    },
    {
      "from": 139.26,
      "to": 141.55,
      "sid": 65,
      "location": 2,
      "content": "但他们要不然就是背景特别好",
      "music": 0.0
    },
    {
      "from": 141.55,
      "to": 144.01,
      "sid": 66,
      "location": 2,
      "content": "名校大厂高职技出来的",
      "music": 0.0
    },
    {
      "from": 144.01,
      "to": 145.29,
      "sid": 67,
      "location": 2,
      "content": "哪怕这次失败了",
      "music": 0.0
    },
    {
      "from": 145.29,
      "to": 146.97,
      "sid": 68,
      "location": 2,
      "content": "下次依然能拉到融资",
      "music": 0.0
    },
    {
      "from": 146.97,
      "to": 149.48,
      "sid": 69,
      "location": 2,
      "content": "所以他们其实不太担心钱的问题",
      "music": 0.0
    },
    {
      "from": 149.48,
      "to": 151.42,
      "sid": 70,
      "location": 2,
      "content": "要不然就是一无所有的人",
      "music": 0.0
    },
    {
      "from": 151.42,
      "to": 152.7,
      "sid": 71,
      "location": 2,
      "content": "比如没考上大学",
      "music": 0.0
    },
    {
      "from": 152.7,
      "to": 154.55,
      "sid": 72,
      "location": 2,
      "content": "然后借钱出来创业",
      "music": 0.0
    },
    {
      "from": 154.55,
      "to": 155.39,
      "sid": 73,
      "location": 2,
      "content": "你就想吧",
      "music": 0.0
    },
    {
      "from": 155.39,
      "to": 156.35,
      "sid": 74,
      "location": 2,
      "content": "一个没学历",
      "music": 0.0
    },
    {
      "from": 156.35,
      "to": 157.01,
      "sid": 75,
      "location": 2,
      "content": "没经验",
      "music": 0.0
    },
    {
      "from": 157.01,
      "to": 158.47,
      "sid": 76,
      "location": 2,
      "content": "家庭条件也不好的人",
      "music": 0.0
    },
    {
      "from": 158.47,
      "to": 160.81,
      "sid": 77,
      "location": 2,
      "content": "他有10万存款还是10万负债",
      "music": 0.0
    },
    {
      "from": 160.81,
      "to": 162.339,
      "sid": 78,
      "location": 2,
      "content": "对他来讲没区别",
      "music": 0.0
    },
    {
      "from": 162.339,
      "to": 164.92,
      "sid": 79,
      "location": 2,
      "content": "他们也不介意身上再多背点儿债",
      "music": 0.0
    },
    {
      "from": 164.92,
      "to": 167.48,
      "sid": 80,
      "location": 2,
      "content": "但大多数人不适合贷款创业",
      "music": 0.0
    },
    {
      "from": 167.48,
      "to": 168.52,
      "sid": 81,
      "location": 2,
      "content": "在钱这方面",
      "music": 0.0
    },
    {
      "from": 168.52,
      "to": 170.08,
      "sid": 82,
      "location": 2,
      "content": "我建议把钱五等分",
      "music": 0.0
    },
    {
      "from": 170.08,
      "to": 172.459,
      "sid": 83,
      "location": 2,
      "content": "这样你起码有五次试错机会",
      "music": 0.0
    },
    {
      "from": 172.459,
      "to": 174.959,
      "sid": 84,
      "location": 2,
      "content": "其实更理性的决策是把钱十等分",
      "music": 0.0
    },
    {
      "from": 174.959,
      "to": 176.859,
      "sid": 85,
      "location": 2,
      "content": "这样你就有十次试错机会",
      "music": 0.0
    },
    {
      "from": 176.859,
      "to": 178.279,
      "sid": 86,
      "location": 2,
      "content": "但如果存款20万",
      "music": 0.0
    },
    {
      "from": 178.279,
      "to": 179.099,
      "sid": 87,
      "location": 2,
      "content": "每次十等分",
      "music": 0.0
    },
    {
      "from": 179.099,
      "to": 181.51,
      "sid": 88,
      "location": 2,
      "content": "相当于每次创业资金只有2万",
      "music": 0.0
    },
    {
      "from": 181.51,
      "to": 182.27,
      "sid": 89,
      "location": 2,
      "content": "2万块钱",
      "music": 0.0
    },
    {
      "from": 182.27,
      "to": 183.43,
      "sid": 90,
      "location": 2,
      "content": "确实干不了什么事",
      "music": 0.0
    },
    {
      "from": 183.43,
      "to": 185.99,
      "sid": 91,
      "location": 2,
      "content": "所以把前十等分是更理性的决策",
      "music": 0.0
    },
    {
      "from": 185.99,
      "to": 187.95,
      "sid": 92,
      "location": 2,
      "content": "但也是一个没用的决策",
      "music": 0.0
    },
    {
      "from": 187.95,
      "to": 191.09,
      "sid": 93,
      "location": 2,
      "content": "真正的all in创业是指你要在事情上all in",
      "music": 0.0
    },
    {
      "from": 191.09,
      "to": 193.45,
      "sid": 94,
      "location": 2,
      "content": "投入全部的精力做好一件事儿",
      "music": 0.0
    },
    {
      "from": 193.45,
      "to": 194.61,
      "sid": 95,
      "location": 2,
      "content": "这个奶茶店主",
      "music": 0.0
    },
    {
      "from": 194.61,
      "to": 197.01,
      "sid": 96,
      "location": 2,
      "content": "之所以开个奶茶店都能亏40多万",
      "music": 0.0
    },
    {
      "from": 197.01,
      "to": 199.87,
      "sid": 97,
      "location": 2,
      "content": "他在直播间说是因为他连合同都没怎么看",
      "music": 0.0
    },
    {
      "from": 199.87,
      "to": 200.93,
      "sid": 98,
      "location": 2,
      "content": "他是加盟店",
      "music": 0.0
    },
    {
      "from": 200.93,
      "to": 203.49,
      "sid": 99,
      "location": 2,
      "content": "他觉得总部会帮他把所有事搞定",
      "music": 0.0
    },
    {
      "from": 203.49,
      "to": 204.37,
      "sid": 100,
      "location": 2,
      "content": "这个叫什么",
      "music": 0.0
    },
    {
      "from": 204.37,
      "to": 206.75,
      "sid": 101,
      "location": 2,
      "content": "这个叫用钱解决懒的问题",
      "music": 0.0
    },
    {
      "from": 206.75,
      "to": 209.33,
      "sid": 102,
      "location": 2,
      "content": "现在很多人都说懒是第一生产力",
      "music": 0.0
    },
    {
      "from": 209.33,
      "to": 211.39,
      "sid": 103,
      "location": 2,
      "content": "但懒是资本的第一生产力",
      "music": 0.0
    },
    {
      "from": 211.39,
      "to": 213.39,
      "sid": 104,
      "location": 2,
      "content": "不是消费者的第一生产力",
      "music": 0.0
    },
    {
      "from": 213.39,
      "to": 215.93,
      "sid": 105,
      "location": 2,
      "content": "当然很多有钱人以及有脑子的人",
      "music": 0.0
    },
    {
      "from": 215.93,
      "to": 217.62,
      "sid": 106,
      "location": 2,
      "content": "也会花钱解决问题",
      "music": 0.0
    },
    {
      "from": 217.62,
      "to": 220.62,
      "sid": 107,
      "location": 2,
      "content": "但他们花钱解决的问题是效率问题",
      "music": 0.0
    },
    {
      "from": 220.62,
