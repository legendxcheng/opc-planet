{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.2,
      "sid": 1,
      "location": 2,
      "content": "good good li加me",
      "music": 0.0
    },
    {
      "from": 1.2,
      "to": 3.46,
      "sid": 2,
      "location": 2,
      "content": "我觉得这个问题我特别适合来回答",
      "music": 0.0
    },
    {
      "from": 3.46,
      "to": 4.059,
      "sid": 3,
      "location": 2,
      "content": "为什么",
      "music": 0.0
    },
    {
      "from": 4.059,
      "to": 7.259,
      "sid": 4,
      "location": 2,
      "content": "因为我从小到大还没见过兴趣比我还广泛的人",
      "music": 0.0
    },
    {
      "from": 7.259,
      "to": 8.339,
      "sid": 5,
      "location": 2,
      "content": "关注我很久的观众",
      "music": 0.0
    },
    {
      "from": 8.339,
      "to": 9.659,
      "sid": 6,
      "location": 2,
      "content": "朋友们来快问快答",
      "music": 0.0
    },
    {
      "from": 9.659,
      "to": 11.28,
      "sid": 7,
      "location": 2,
      "content": "我都有什么兴趣爱好",
      "music": 0.0
    },
    {
      "from": 11.28,
      "to": 13.18,
      "sid": 8,
      "location": 2,
      "content": "我上小学的时候喜欢画画",
      "music": 0.0
    },
    {
      "from": 13.18,
      "to": 14.49,
      "sid": 9,
      "location": 2,
      "content": "看书写作",
      "music": 0.0
    },
    {
      "from": 14.49,
      "to": 16.87,
      "sid": 10,
      "location": 2,
      "content": "初中的时候爱上了外语音乐",
      "music": 0.0
    },
    {
      "from": 16.87,
      "to": 18.61,
      "sid": 11,
      "location": 2,
      "content": "高中时候爱上了摄影",
      "music": 0.0
    },
    {
      "from": 18.61,
      "to": 21.03,
      "sid": 12,
      "location": 2,
      "content": "大学时候爱上了电影哲学",
      "music": 0.0
    },
    {
      "from": 21.03,
      "to": 22.51,
      "sid": 13,
      "location": 2,
      "content": "我这辈子学过的外语",
      "music": 0.0
    },
    {
      "from": 22.51,
      "to": 24.41,
      "sid": 14,
      "location": 2,
      "content": "最基础的英语就不说了",
      "music": 0.0
    },
    {
      "from": 24.41,
      "to": 26.71,
      "sid": 15,
      "location": 2,
      "content": "再包括现在大家熟知的法语",
      "music": 0.0
    },
    {
      "from": 26.71,
      "to": 28.51,
      "sid": 16,
      "location": 2,
      "content": "其实我初中毕业那个暑假",
      "music": 0.0
    },
    {
      "from": 28.51,
      "to": 30.63,
      "sid": 17,
      "location": 2,
      "content": "短暂的学过两个月的西班牙语",
      "music": 0.0
    },
    {
      "from": 30.63,
      "to": 32.55,
      "sid": 18,
      "location": 2,
      "content": "我每天还学的挺系统化的",
      "music": 0.0
    },
    {
      "from": 32.55,
      "to": 33.95,
      "sid": 19,
      "location": 2,
      "content": "但是高中开课之后",
      "music": 0.0
    },
    {
      "from": 33.95,
      "to": 35.27,
      "sid": 20,
      "location": 2,
      "content": "我就再也没学过了",
      "music": 0.0
    },
    {
      "from": 35.27,
      "to": 37.39,
      "sid": 21,
      "location": 2,
      "content": "但是我知道如果我当时继续学下去",
      "music": 0.0
    },
    {
      "from": 37.39,
      "to": 39.97,
      "sid": 22,
      "location": 2,
      "content": "掌握这门语言肯定是没有问题的",
      "music": 0.0
    },
    {
      "from": 39.97,
      "to": 42.05,
      "sid": 23,
      "location": 2,
      "content": "大学的时候选修课学德语",
      "music": 0.0
    },
    {
      "from": 42.05,
      "to": 42.95,
      "sid": 24,
      "location": 2,
      "content": "学了一个学期",
      "music": 0.0
    },
    {
      "from": 42.95,
      "to": 45.02,
      "sid": 25,
      "location": 2,
      "content": "是班里的最高分乐器",
      "music": 0.0
    },
    {
      "from": 45.02,
      "to": 46.66,
      "sid": 26,
      "location": 2,
      "content": "我也是学过很多种吉他",
      "music": 0.0
    },
    {
      "from": 46.66,
      "to": 47.3,
      "sid": 27,
      "location": 2,
      "content": "尤克里里",
      "music": 0.0
    },
    {
      "from": 47.3,
      "to": 47.82,
      "sid": 28,
      "location": 2,
      "content": "架子鼓",
      "music": 0.0
    },
    {
      "from": 47.82,
      "to": 49.04,
      "sid": 29,
      "location": 2,
      "content": "入门级别口琴",
      "music": 0.0
    },
    {
      "from": 49.04,
      "to": 51.12,
      "sid": 30,
      "location": 2,
      "content": "我到现在都对乐器特别感兴趣",
      "music": 0.0
    },
    {
      "from": 51.12,
      "to": 53.46,
      "sid": 31,
      "location": 2,
      "content": "但是这个爱好暂时被我搁浅了",
      "music": 0.0
    },
    {
      "from": 53.46,
      "to": 55.68,
      "sid": 32,
      "location": 2,
      "content": "因为我把时间都放到了其他",
      "music": 0.0
    },
    {
      "from": 55.68,
      "to": 57.56,
      "sid": 33,
      "location": 2,
      "content": "目前来说更重要的事情上",
      "music": 0.0
    },
    {
      "from": 57.56,
      "to": 59.38,
      "sid": 34,
      "location": 2,
      "content": "所以我妈经常批评我",
      "music": 0.0
    },
    {
      "from": 59.38,
      "to": 60.48,
      "sid": 35,
      "location": 2,
      "content": "兴趣广泛",
      "music": 0.0
    },
    {
      "from": 60.48,
      "to": 61.52,
      "sid": 36,
      "location": 2,
      "content": "样样不精",
      "music": 0.0
    },
    {
      "from": 61.52,
      "to": 62.8,
      "sid": 37,
      "location": 2,
      "content": "毫无意义",
      "music": 0.0
    },
    {
      "from": 62.8,
      "to": 63.56,
      "sid": 38,
      "location": 2,
      "content": "说实话",
      "music": 0.0
    },
    {
      "from": 63.56,
      "to": 65.54,
      "sid": 39,
      "location": 2,
      "content": "我上学的时候还真的怀疑过自己",
      "music": 0.0
    },
    {
      "from": 65.54,
      "to": 67.4,
      "sid": 40,
      "location": 2,
      "content": "是不是我太3分钟热度了",
      "music": 0.0
    },
    {
      "from": 67.4,
      "to": 70.13,
      "sid": 41,
      "location": 2,
      "content": "是不是什么都坚持不下去才会这样",
      "music": 0.0
    },
    {
      "from": 70.13,
      "to": 72.47,
      "sid": 42,
      "location": 2,
      "content": "但现在我完全不这样想了",
      "music": 0.0
    },
    {
      "from": 72.47,
      "to": 75.31,
      "sid": 43,
      "location": 2,
      "content": "我觉得人类总是喜欢歌颂坚持的意义",
      "music": 0.0
    },
    {
      "from": 75.31,
      "to": 77.11,
      "sid": 44,
      "location": 2,
      "content": "包括我自己也是如此",
      "music": 0.0
    },
    {
      "from": 77.11,
      "to": 77.91,
      "sid": 45,
      "location": 2,
      "content": "但不同的是",
      "music": 0.0
    },
    {
      "from": 77.91,
      "to": 81.51,
      "sid": 46,
      "location": 2,
      "content": "我在视频当中强调的坚持是顺其自然的",
      "music": 0.0
    },
    {
      "from": 81.51,
      "to": 83.39,
      "sid": 47,
      "location": 2,
      "content": "而不是为了坚持而坚持",
      "music": 0.0
    },
    {
      "from": 83.39,
      "to": 85.32,
      "sid": 48,
      "location": 2,
      "content": "坚持不了就感到羞耻",
      "music": 0.0
    },
    {
      "from": 85.32,
      "to": 87.3,
      "sid": 49,
      "location": 2,
      "content": "人的时间和精力只有那么多",
      "music": 0.0
    },
    {
      "from": 87.3,
      "to": 89.8,
      "sid": 50,
      "location": 2,
      "content": "每个时间段都有不同的侧重点",
      "music": 0.0
    },
    {
      "from": 89.8,
      "to": 91.5,
      "sid": 51,
      "location": 2,
      "content": "没有坚持下去的爱好",
      "music": 0.0
    },
    {
      "from": 91.5,
      "to": 92.98,
      "sid": 52,
      "location": 2,
      "content": "有可能是一粒种子",
      "music": 0.0
    },
    {
      "from": 92.98,
      "to": 94.36,
      "sid": 53,
      "location": 2,
      "content": "在你的心里默默发芽",
      "music": 0.0
    },
    {
      "from": 94.36,
      "to": 95.88,
      "sid": 54,
      "location": 2,
      "content": "我从小到大每一个兴趣",
      "music": 0.0
    },
    {
      "from": 95.88,
      "to": 97.44,
      "sid": 55,
      "location": 2,
      "content": "哪怕我现在没在坚持",
      "music": 0.0
    },
    {
      "from": 97.44,
      "to": 99.44,
      "sid": 56,
      "location": 2,
      "content": "但不代表被我彻底遗忘了",
      "music": 0.0
    },
    {
      "from": 99.44,
      "to": 101.26,
      "sid": 57,
      "location": 2,
      "content": "我知道等我之后有时间了",
      "music": 0.0
    },
    {
      "from": 101.26,
      "to": 103.68,
      "sid": 58,
      "location": 2,
      "content": "我一定会再重拾起每一个爱好",
      "music": 0.0
    },
    {
      "from": 103.68,
      "to": 106.98,
      "sid": 59,
      "location": 2,
      "content": "我想自己的老年生活光是学各种乐器",
      "music": 0.0
    },
    {
      "from": 106.98,
      "to": 109.48,
      "sid": 60,
      "location": 2,
      "content": "比如说钢琴萨克斯都已经忙不过来了",
      "music": 0.0
    },
    {
      "from": 109.48,
      "to": 110.5,
      "sid": 61,
      "location": 2,
      "content": "我妈也老喜欢问我",
      "music": 0.0
    },
    {
      "from": 110.5,
      "to": 111.64,
      "sid": 62,
      "location": 2,
      "content": "你这么爱折腾",
      "music": 0.0
    },
    {
      "from": 111.64,
      "to": 113.34,
      "sid": 63,
      "location": 2,
      "content": "你折腾出什么名堂来的呢",
      "music": 0.0
    },
    {
      "from": 113.34,
      "to": 116.64,
      "sid": 64,
      "location": 2,
      "content": "不是我说怎么现在社会都这么浮躁",
      "music": 0.0
    },
    {
      "from": 116.64,
      "to": 118.98,
      "sid": 65,
      "location": 2,
      "content": "你指望一个23岁的年轻人",
      "music": 0.0
    },
    {
      "from": 118.98,
      "to": 120.64,
      "sid": 66,
      "location": 2,
      "content": "折腾出什么名堂来",
      "music": 0.0
    },
    {
      "from": 120.64,
      "to": 122.04,
      "sid": 67,
      "location": 2,
      "content": "我可以自豪的说",
      "music": 0.0
    },
    {
      "from": 122.04,
      "to": 124.71,
      "sid": 68,
      "location": 2,
      "content": "我现在什么家都不是",
      "music": 0.0
    },
    {
      "from": 124.71,
      "to": 126.57,
      "sid": 69,
      "location": 2,
      "content": "但5年后10年后呢",
      "music": 0.0
    },
    {
      "from": 126.57,
      "to": 129.59,
      "sid": 70,
      "location": 2,
      "content": "不要拿莫扎特那种七岁成名的天才少年",
      "music": 0.0
    },
    {
      "from": 129.59,
      "to": 130.74,
      "sid": 71,
      "location": 2,
      "content": "来和自己比较",
      "music": 0.0
    },
    {
      "from": 130.74,
      "to": 132.2,
      "sid": 72,
      "location": 2,
      "content": "咱们比上不足",
      "music": 0.0
    },
    {
      "from": 132.2,
      "to": 132.98,
      "sid": 73,
      "location": 2,
      "content": "比下有余",
      "music": 0.0
    },
    {
      "from": 132.98,
      "to": 136.6,
      "sid": 74,
      "location": 2,
      "content": "你看看咱北野武导演50几岁才开始拍电影",
      "music": 0.0
    },
    {
      "from": 136.6,
      "to": 139.92,
      "sid": 75,
      "location": 2,
      "content": "人的前半生都应该拿来摸索自己到底喜欢什么",
      "music": 0.0
    },
    {
      "from": 139.92,
      "to": 140.79,
      "sid": 76,
      "location": 2,
      "content": "适合什么",
      "music": 0.0
    },
    {
      "from": 140.79,
      "to": 143.53,
      "sid": 77,
      "location": 2,
      "content": "现在社会就是没有给人一个发现期",
      "music": 0.0
    },
    {
      "from": 143.53,
      "to": 144.51,
      "sid": 78,
      "location": 2,
      "content": "缓冲期",
      "music": 0.0
    },
    {
      "from": 144.51,
      "to": 147.05,
      "sid": 79,
      "location": 2,
      "content": "沉静期做什么都很功利",
      "music": 0.0
    },
    {
      "from": 147.05,
      "to": 148.25,
      "sid": 80,
      "location": 2,
      "content": "刚开始一个兴趣",
      "music": 0.0
    },
    {
      "from": 148.25,
      "to": 151.47,
      "sid": 81,
      "location": 2,
      "content": "就想着要通过这个事儿做成什么大事儿",
      "music": 0.0
    },
    {
      "from": 151.47,
      "to": 152.33,
      "sid": 82,
      "location": 2,
      "content": "赚多少钱",
      "music": 0.0
    },
    {
      "from": 152.33,
      "to": 153.3,
      "sid": 83,
      "location": 2,
      "content": "出多少名",
      "music": 0.0
    },
    {
      "from": 153.3,
      "to": 156.56,
      "sid": 84,
      "location": 2,
      "content": "我现在所做的每一件事都不是为了成为什么家",
      "music": 0.0
    },
    {
      "from": 156.56,
      "to": 157.86,
      "sid": 85,
      "location": 2,
      "content": "第一是没有那么容易",
      "music": 0.0
    },
    {
      "from": 157.86,
      "to": 159.18,
      "sid": 86,
      "location": 2,
      "content": "第二是成为什么",
      "music": 0.0
    },
    {
      "from": 159.18,
      "to": 160.95,
      "sid": 87,
      "location": 2,
      "content": "是我的兴趣",
      "music": 0.0
    },
    {
      "from": 160.95,
      "to": 163.53,
      "sid": 88,
      "location": 2,
      "content": "在未来会给我带来的额外惊喜",
      "music": 0.0
    },
    {
      "from": 163.53,
      "to": 165.81,
      "sid": 89,
      "location": 2,
      "content": "很多人会觉得说兴趣是无用的",
      "music": 0.0
    },
    {
      "from": 165.81,
      "to": 167.72,
      "sid": 90,
      "location": 2,
      "content": "不就是用来打发时间的吗",
      "music": 0.0
    },
    {
      "from": 167.72,
      "to": 168.76,
      "sid": 91,
      "location": 2,
      "content": "但你想一想",
      "music": 0.0
    },
    {
      "from": 168.76,
      "to": 170.6,
      "sid": 92,
      "location": 2,
      "content": "人这一辈子是不是无用的",
      "music": 0.0
    },
    {
      "from": 170.6,
      "to": 171.66,
      "sid": 93,
      "location": 2,
      "content": "时间才最珍贵",
      "music": 0.0
    },
    {
      "from": 171.66,
      "to": 174.47,
      "sid": 94,
      "location": 2,
      "content": "我有一句话我也特别想用来问我自己",
      "music": 0.0
    },
    {
      "from": 174.47,
      "to": 175.75,
      "sid": 95,
      "location": 2,
      "content": "因为我最近45年",
      "music": 0.0
    },
    {
      "from": 175.75,
      "to": 178.63,
      "sid": 96,
      "location": 2,
      "content": "都陷入了一种害怕浪费时间的怪圈里边儿",
      "music": 0.0
    },
    {
      "from": 178.63,
      "to": 179.67,
      "sid": 97,
      "location": 2,
      "content": "今年年初的时候",
      "music": 0.0
    },
    {
      "from": 179.67,
      "to": 182.16,
      "sid": 98,
      "location": 2,
      "content": "甚至让我有一些情绪崩溃了",
      "music": 0.0
    },
    {
      "from": 182.16,
      "to": 186.6,
      "sid": 99,
      "location": 2,
      "content": "我想问我自己人的时间到底能有用到哪里去呢",
      "music": 0.0
    },
    {
      "from": 186.6,
      "to": 188.14,
      "sid": 100,
      "location": 2,
      "content": "我之前看过一个纪录片",
      "music": 0.0
    },
    {
      "from": 188.14,
      "to": 188.82,
      "sid": 101,
      "location": 2,
      "content": "In degree",
      "music": 0.0
    },
    {
      "from": 188.82,
      "to": 191.7,
      "sid": 102,
      "location": 2,
      "content": "Hurry thirteen lessons in life is so letter",
      "music": 0.0
    },
    {
      "from": 191.7,
      "to": 193.16,
      "sid": 103,
      "location": 2,
      "content": "老爷子说了一段话",
      "music": 0.0
    },
    {
      "from": 193.16,
      "to": 194.26,
      "sid": 104,
      "location": 2,
      "content": "让我印象深刻",
      "music": 0.0
    },
    {
      "from": 194.26,
      "to": 195.34,
      "sid": 105,
      "location": 2,
      "content": "我摘抄了下来",
      "music": 0.0
    },
    {
      "from": 195.34,
      "to": 198.18,
      "sid": 106,
      "location": 2,
      "content": "I see no reason for being in iraq",
      "music": 0.0
    },
    {
      "from": 198.18,
      "to": 199.84,
      "sid": 107,
      "location": 2,
      "content": "When you consider",
      "music": 0.0
    },
    {
      "from": 199.84,
      "to": 203.97,
      "sid": 108,
      "location": 2,
      "content": "Many of the things that people treat very seriously",
      "music": 0.0
    },
    {
      "from": 203.97,
      "to": 207.35,
      "sid": 109,
      "location": 2,
      "content": "And you realize that they don't deserve to be",
      "music": 0.0
    },
    {
      "from": 207.35,
      "to": 209.57,
      "sid": 110,
      "location": 2,
      "content": "Treated that seriously",
      "music": 0.0
    },
    {
      "from": 209.57,
      "to": 211.59,
      "sid": 111,
      "location": 2,
      "content": "And when you consider that",
      "music": 0.0
    },
    {
      "from": 211.59,
      "to": 214.55,
      "sid": 112,
      "location": 2,
      "content": "Many of the things that people think are important",
      "music": 0.0
    },
    {
      "from": 214.55,
      "to": 217.54,
      "sid": 113,
      "location": 2,
      "content": "Are not really terribly important",
      "music": 0.0
    },
    {
      "from": 217.86,
      "to": 220.9,
      "sid": 114,
      "location": 2,
      "content": "And many of the things that people worry about",
      "music": 0.0
    },
    {
      "from": 220.9,
      "to": 223.769,
      "sid": 115,
      "location": 2,
      "content": "Or not really worth worrying about",
      "music": 0.0
    },
    {
      "from": 223.769,
      "to": 224.629,
      "sid": 116,
      "location": 2,
      "content": "Do you think",
      "music": 0.0
    },
    {
      "from": 224.629,
      "to": 226.589,
      "sid": 117,
      "location": 2,
      "content": "Thinking about things like that",
      "music": 0.0
    },
    {
      "from": 226.589,
      "to": 229.449,
      "sid": 118,
      "location": 2,
      "content": "Delayed you doing your work",
      "music": 0.0
    },
    {
      "from": 230.23,
      "to": 231.43,
      "sid": 119,
      "location": 2,
      "content": "Delayed me",
      "music": 0.0
    },
    {
      "from": 231.43,
      "to": 232.01,
      "sid": 120,
      "location": 2,
      "content": "Yeah",
      "music": 0.0
    },
    {
      "from": 232.01,
      "to": 233.63,
      "sid": 121,
      "location": 2,
      "content": "I wasn't today",
      "music": 0.0
    },
    {
      "from": 233.63,
      "to": 237.33,
      "sid": 122,
      "location": 2,
      "content": "What was i supposed to do if i didn't do anything",
      "music": 0.0
    },
    {
      "from": 237.33,
      "to": 239.15,
      "sid": 123,
      "location": 2,
      "content": "More than my little book",
      "music": 0.0
    },
    {
      "from": 239.15,
      "to": 241.03,
      "sid": 124,
      "location": 2,
      "content": "Wouldn't there have been enough",
      "music": 0.0
    },
    {
      "from": 241.03,
      "to": 245.45,
      "sid": 125,
      "location": 2,
      "content": "How much do you have to do to satisfy people",
      "music": 0.0
    },
    {
      "from": 245.45,
      "to": 247.33,
      "sid": 126,
      "location": 2,
      "content": "Who don't care anyway",
      "music": 0.0
    },
    {
      "from": 247.33,
      "to": 248.29,
      "sid": 127,
      "location": 2,
      "content": "所以老爷子",
      "music": 0.0
    },
    {
      "from": 248.29,
      "to": 251.01,
      "sid": 128,
      "location": 2,
      "content": "他显然没有把这个摄影当成自己的事业",
      "music": 0.0
    },
    {
      "from": 251.01,
      "to": 252.57,
      "sid": 129,
      "location": 2,
      "content": "更多的是一种爱好",
      "music": 0.0
    },
    {
      "from": 252.57,
      "to": 254.63,
      "sid": 130,
      "location": 2,
      "content": "谁说事业就比爱好伟大",
      "music": 0.0
    },
    {
      "from": 254.63,
      "to": 257.17,
      "sid": 131,
      "location": 2,
      "content": "如果把一件事形容成是自己的事业",
      "music": 0.0
    },
    {
      "from": 257.17,
      "to": 258.63,
      "sid": 132,
      "location": 2,
      "content": "就听着更有意义吗",
      "music": 0.0
    },
    {
      "from": 258.63,
      "to": 260.03,
      "sid": 133,
      "location": 2,
      "content": "如果称其为爱好",
      "music": 0.0
    },
    {
      "from": 260.03,
      "to": 261.23,
      "sid": 134,
      "location": 2,
      "content": "就什么都不是吗",
      "music": 0.0
    },
    {
      "from": 261.23,
      "to": 263.43,
      "sid": 135,
      "location": 2,
      "content": "其次兴趣的作用并不在于",
      "music": 0.0
    },
    {
      "from": 263.43,
      "to": 265.35,
      "sid": 136,
      "location": 2,
      "content": "帮助我们达到任何目的",
      "music": 0.0
    },
    {
      "from": 265.35,
      "to": 268.169,
      "sid": 137,
      "location": 2,
      "content": "拥有兴趣不等同于拥有才华",
      "music": 0.0
    },
    {
      "from": 268.169,
      "to": 268.929,
      "sid": 138,
      "location": 2,
      "content": "对我来说",
      "music": 0.0
    },
    {
      "from": 268.929,
      "to": 270.009,
      "sid": 139,
      "location": 2,
      "content": "才华即正义",
      "music": 0.0
    },
    {
      "from": 270.009,
      "to": 272.669,
      "sid": 140,
      "location": 2,
      "content": "很多人他自己的兴趣上不一定有才华",
      "music": 0.0
    },
    {
      "from": 272.669,
      "to": 274.629,
      "sid": 141,
      "location": 2,
      "content": "比方说很多人画一辈子的画",
      "music": 0.0
    },
    {
      "from": 274.629,
      "to": 276.209,
      "sid": 142,
      "location": 2,
      "content": "但那不代表他是艺术家",
      "music": 0.0
    },
    {
      "from": 276.209,
      "to": 278.34,
      "sid": 143,
      "location": 2,
      "content": "或者说他能够成为艺术家",
      "music": 0.0
    },
    {
      "from": 278.34,
      "to": 281.82,
      "sid": 144,
      "location": 2,
      "content": "很多朋友你就会觉得说那这样一生感觉好可悲",
      "music": 0.0
    },
    {
      "from": 281.82,
      "to": 283.32,
      "sid": 145,
      "location": 2,
      "content": "朋友在这一点上",
      "music": 0.0
    },
    {
      "from": 283.32,
      "to": 285.919,
      "sid": 146,
      "location": 2,
      "content": "我觉得咱们应该拥有大局观",
      "music": 0.0
    },
    {
      "from": 285.919,
      "to": 287.259,
      "sid": 147,
      "location": 2,
      "content": "我经常在想",
      "music": 0.0
    },
    {
      "from": 287.259,
      "to": 290.559,
      "sid": 148,
      "location": 2,
      "content": "我们不应该老想着我们要成为什么",
      "music": 0.0
    },
    {
      "from": 290.559,
      "to": 293.01,
      "sid": 149,
      "location": 2,
      "content": "而是这个世界需要什么",
      "music": 0.0
    },
    {
      "from": 293.01,
      "to": 295.83,
      "sid": 150,
      "location": 2,
      "content": "老嚷嚷着我要成为什么什么家",
      "music": 0.0
    },
    {
      "from": 295.83,
      "to": 297.17,
      "sid": 151,
      "location": 2,
      "content": "如果真有才华",
      "music": 0.0
    },
    {
      "from": 297.17,
      "to": 298.69,
      "sid": 152,
      "location": 2,
      "content": "那么确实是应该的",
      "music": 0.0
    },
    {
      "from": 298.69,
      "to": 301.34,
      "sid": 153,
      "location": 2,
      "content": "我非常希望有才的人发光发亮",
      "music": 0.0
    },
    {
      "from": 301.34,
      "to": 302.98,
      "sid": 154,
      "location": 2,
      "content": "但如果没有才华",
      "music": 0.0
    },
    {
      "from": 302.98,
      "to": 304.1,
      "sid": 155,
      "location": 2,
      "content": "成为不了什么",
      "music": 0.0
    },
    {
      "from": 304.1,
      "to": 305.54,
      "sid": 156,
      "location": 2,
      "content": "就是你的宿命",
      "music": 0.0
    },
    {
      "from": 305.54,
      "to": 306.68,
      "sid": 157,
      "location": 2,
      "content": "不要难过",
      "music": 0.0
    },
    {
      "from": 306.68,
      "to": 310.68,
      "sid": 158,
      "location": 2,
      "content": "正义就是让有才华的人去绽放他们的才华",
      "music": 0.0
    },
    {
      "from": 310.68,
      "to": 313.789,
      "sid": 159,
      "location": 2,
      "content": "没有才华的人就默默的享受自己的乐趣",
      "music": 0.0
    },
    {
      "from": 313.789,
      "to": 316.069,
      "sid": 160,
      "location": 2,
      "content": "和欣赏有才华的人的作品",
      "music": 0.0
    },
    {
      "from": 316.069,
      "to": 319.549,
      "sid": 161,
      "location": 2,
      "content": "那么你问我如何判断自己到底有没有才华",
      "music": 0.0
    },
    {
      "from": 319.549,
      "to": 321.37,
      "sid": 162,
      "location": 2,
      "content": "这个需要你自己去探索",
      "music": 0.0
    },
    {
      "from": 321.37,
      "to": 322.93,
      "sid": 163,
      "location": 2,
      "content": "以及通过外界的反馈",
      "music": 0.0
    },
    {
      "from": 322.93,
      "to": 325.53,
      "sid": 164,
      "location": 2,
      "content": "在自我和外界之间取得一个平衡",
      "music": 0.0
    },
    {
      "from": 325.53,
      "to": 328.61,
      "sid": 165,
      "location": 2,
      "content": "我只知道才华掌握在少数人手上",
      "music": 0.0
    },
    {
      "from": 328.61,
      "to": 332.49,
      "sid": 166,
      "location": 2,
      "content": "我这一辈子见过的真正有才华的人屈指可数",
      "music": 0.0
    },
    {
      "from": 332.49,
      "to": 335.899,
      "sid": 167,
      "location": 2,
      "content": "我有一个朋友对自己的定位非常准确",
      "music": 0.0
    },
    {
      "from": 335.899,
      "to": 337.909,
      "sid": 168,
      "location": 2,
      "content": "他说自己很喜欢艺术",
      "music": 0.0
    },
    {
      "from": 337.909,
      "to": 342.27,
      "sid": 169,
      "location": 2,
      "content": "但他很清楚地知道自己没有创作艺术的才能",
      "music": 0.0
    },
    {
      "from": 342.27,
      "to": 345.45,
      "sid": 170,
      "location": 2,
      "content": "就只是单纯的喜欢观看艺术作品",
      "music": 0.0
    },
    {
      "from": 345.45,
      "to": 346.99,
      "sid": 171,
      "location": 2,
      "content": "这也没有什么可惜的",
      "music": 0.0
    },
    {
      "from": 346.99,
      "to": 347.71,
      "sid": 172,
      "location": 2,
      "content": "但难就难在",
      "music": 0.0
    },
    {
      "from": 347.71,
      "to": 351.61,
      "sid": 173,
      "location": 2,
      "content": "现在很多人把兴趣和喜欢当成了才华",
      "music": 0.0
    },
    {
      "from": 351.61,
      "to": 355.31,
      "sid": 174,
      "location": 2,
      "content": "这也来源于社会嗯给我们的一个压力",
      "music": 0.0
    },
    {
      "from": 355.31,
      "to": 359.09,
      "sid": 175,
      "location": 2,
      "content": "就是一旦你在某件事上花费了时间",
      "music": 0.0
    },
    {
      "from": 359.09,
      "to": 362.3,
      "sid": 176,
      "location": 2,
      "content": "那么你就得在这件事上取得什么成就",
      "music": 0.0
    },
    {
      "from": 362.3,
      "to": 364.96,
      "sid": 177,
      "location": 2,
      "content": "这样一种还是急功近利的想法",
      "music": 0.0
    },
    {
      "from": 364.96,
      "to": 365.74,
      "sid": 178,
      "location": 2,
      "content": "我举个例子",
      "music": 0.0
    },
    {
      "from": 365.74,
      "to": 368.08,
      "sid": 179,
      "location": 2,
      "content": "我当初申请法国美院的时候",
      "music": 0.0
    },
    {
      "from": 368.08,
      "to": 371.2,
      "sid": 180,
      "location": 2,
      "content": "我没有花钱去找机构帮我做作品集",
      "music": 0.0
    },
    {
      "from": 371.2,
      "to": 373.64,
      "sid": 181,
      "location": 2,
      "content": "第一个原因是因为我确实没钱",
      "music": 0.0
    },
    {
      "from": 373.64,
      "to": 374.76,
      "sid": 182,
      "location": 2,
      "content": "第二个原因是因为",
      "music": 0.0
    },
    {
      "from": 374.76,
      "to": 377.88,
      "sid": 183,
      "location": 2,
      "content": "我想看看自己到底有没有那个搞艺术的才华",
      "music": 0.0
    },
    {
      "from": 377.88,
      "to": 378.96,
      "sid": 184,
      "location": 2,
      "content": "或者说潜力",
      "music": 0.0
    },
    {
      "from": 378.96,
      "to": 382.27,
      "sid": 185,
      "location": 2,
      "content": "当时有朋友觉得不找机构的话不太靠谱",
      "music": 0.0
    },
    {
      "from": 382.27,
      "to": 384.17,
      "sid": 186,
      "location": 2,
      "content": "他觉得我没有好好准备",
      "music": 0.0
    },
    {
      "from": 384.17,
      "to": 387.45,
      "sid": 187,
      "location": 2,
      "content": "但我想意识这种东西除开才华之外",
      "music": 0.0
    },
    {
      "from": 387.45,
      "to": 388.81,
      "sid": 188,
      "location": 2,
      "content": "还需要准备什么呢",
      "music": 0.0
    },
    {
      "from": 388.81,
      "to": 389.63,
      "sid": 189,
      "location": 2,
      "content": "他问我这样",
      "music": 0.0
    },
    {
      "from": 389.63,
      "to": 390.91,
      "sid": 190,
      "location": 2,
      "content": "你如果没有被录取",
      "music": 0.0
    },
    {
      "from": 390.91,
      "to": 392.05,
      "sid": 191,
      "location": 2,
      "content": "你不会难过吗",
      "music": 0.0
    },
    {
      "from": 392.05,
      "to": 393.37,
      "sid": 192,
      "location": 2,
      "content": "我说我会难过",
      "music": 0.0
    },
    {
      "from": 393.37,
      "to": 395.13,
      "sid": 193,
      "location": 2,
      "content": "但我只会难过一小会儿",
      "music": 0.0
    },
    {
      "from": 395.13,
      "to": 395.85,
      "sid": 194,
      "location": 2,
      "content": "自信来说",
      "music": 0.0
    },
    {
      "from": 395.85,
      "to": 398.27,
      "sid": 195,
      "location": 2,
      "content": "我确实很想自己能够被录取",
      "music": 0.0
    },
    {
      "from": 398.27,
      "to": 400.51,
      "sid": 196,
      "location": 2,
      "content": "但如果我申请那么多个学校",
      "music": 0.0
    },
    {
      "from": 400.51,
      "to": 402.18,
      "sid": 197,
      "location": 2,
      "content": "没有一个能让我进",
      "music": 0.0
    },
    {
      "from": 402.18,
      "to": 404.38,
      "sid": 198,
      "location": 2,
      "content": "那么说明我的才华确实不够",
      "music": 0.0
    },
    {
      "from": 404.38,
      "to": 406.85,
      "sid": 199,
      "location": 2,
      "content": "那么我为什么挤破头皮要进去呢",
      "music": 0.0
    },
    {
      "from": 406.85,
      "to": 407.81,
      "sid": 200,
      "location": 2,
      "content": "所以我不明白",
      "music": 0.0
    },
    {
      "from": 407.81,
      "to": 410.47,
      "sid": 201,
      "location": 2,
      "content": "为什么有人花钱去买别人的作品集",
      "music": 0.0
    },
    {
      "from": 410.47,
      "to": 413.65,
      "sid": 202,
      "location": 2,
      "content": "连做一个被学院录取的作品集的能力都没有",
      "music": 0.0
    },
    {
      "from": 413.65,
      "to": 415.53,
      "sid": 203,
      "location": 2,
      "content": "你进的那个学校能如何呢",
      "music": 0.0
    },
    {
      "from": 415.53,
      "to": 416.73,
      "sid": 204,
      "location": 2,
      "content": "这就是我之前说的",
      "music": 0.0
    },
    {
      "from": 416.73,
      "to": 418.21,
      "sid": 205,
      "location": 2,
      "content": "很多人都只想着成功",
      "music": 0.0
    },
    {
      "from": 418.21,
      "to": 419.29,
      "sid": 206,
      "location": 2,
      "content": "没想着成长",
      "music": 0.0
    },
    {
      "from": 419.29,
      "to": 422.38,
      "sid": 207,
      "location": 2,
      "content": "很多人为了成功挤破了脑袋往上钻",
      "music": 0.0
    },
    {
      "from": 422.38,
      "to": 424.7,
      "sid": 208,
      "location": 2,
      "content": "但是当谈到真正的成长",
      "music": 0.0
    },
    {
      "from": 424.7,
      "to": 426.16,
      "sid": 209,
      "location": 2,
      "content": "就一点脑子都不转了",
      "music": 0.0
    },
    {
      "from": 426.16,
      "to": 428.28,
      "sid": 210,
      "location": 2,
      "content": "当然就算被美院录取了",
      "music": 0.0
    },
    {
      "from": 428.28,
      "to": 430.33,
      "sid": 211,
      "location": 2,
      "content": "也不代表你就是真的有才华",
      "music": 0.0
    },
    {
      "from": 430.33,
      "to": 432.25,
      "sid": 212,
      "location": 2,
      "content": "没有被美颜录取",
      "music": 0.0
    },
    {
      "from": 432.25,
      "to": 433.81,
      "sid": 213,
      "location": 2,
      "content": "就代表你什么都不是吗",
      "music": 0.0
    },
    {
      "from": 433.81,
      "to": 434.59,
      "sid": 214,
      "location": 2,
      "content": "不是这样的",
      "music": 0.0
    },
    {
      "from": 434.59,
      "to": 436.63,
      "sid": 215,
      "location": 2,
      "content": "只是正常情况下来说是这样的",
      "music": 0.0
    },
    {
      "from": 436.63,
      "to": 439.48,
      "sid": 216,
      "location": 2,
      "content": "但是天才总在正常之外是例外",
      "music": 0.0
    },
    {
      "from": 439.48,
      "to": 440.68,
      "sid": 217,
      "location": 2,
      "content": "我没有上帝视角",
      "music": 0.0
    },
    {
      "from": 440.68,
      "to": 442.56,
      "sid": 218,
      "location": 2,
      "content": "每个个体也没有上帝视角",
      "music": 0.0
    },
    {
      "from": 442.56,
      "to": 444.52,
      "sid": 219,
      "location": 2,
      "content": "所以我们都在摸黑前行着",
      "music": 0.0
    },
    {
      "from": 444.52,
      "to": 446.84,
      "sid": 220,
      "location": 2,
      "content": "都需要自己去认识自己",
      "music": 0.0
    },
    {
