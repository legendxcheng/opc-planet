{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.8,
      "sid": 1,
      "location": 2,
      "content": "真正阻碍我们拿到更大结果",
      "music": 0.0
    },
    {
      "from": 1.8,
      "to": 2.6,
      "sid": 2,
      "location": 2,
      "content": "让我们的业务更高",
      "music": 0.0
    },
    {
      "from": 2.6,
      "to": 4.8,
      "sid": 3,
      "location": 2,
      "content": "下滑板的一定不是我们的问题找不到答案",
      "music": 0.0
    },
    {
      "from": 4.8,
      "to": 6.5,
      "sid": 4,
      "location": 2,
      "content": "而是我们背后缺少一套思维框",
      "music": 0.0
    },
    {
      "from": 6.5,
      "to": 9.22,
      "sid": 5,
      "location": 2,
      "content": "一整套体系结构能让我们问出正确的问题",
      "music": 0.0
    },
    {
      "from": 9.22,
      "to": 9.66,
      "sid": 6,
      "location": 2,
      "content": "你去看",
      "music": 0.0
    },
    {
      "from": 9.66,
      "to": 11.18,
      "sid": 7,
      "location": 2,
      "content": "无论是我们自己业务里面的问题",
      "music": 0.0
    },
    {
      "from": 11.18,
      "to": 12.86,
      "sid": 8,
      "location": 2,
      "content": "还是我们看平时其他人问一个问题",
      "music": 0.0
    },
    {
      "from": 12.86,
      "to": 15.3,
      "sid": 9,
      "location": 2,
      "content": "如果我的这个问题问了身边好几个厉害的人",
      "music": 0.0
    },
    {
      "from": 15.3,
      "to": 16.8,
      "sid": 10,
      "location": 2,
      "content": "你会发现他们都没有办法",
      "music": 0.0
    },
    {
      "from": 16.8,
      "to": 18.1,
      "sid": 11,
      "location": 2,
      "content": "特别正面的回答这个问题",
      "music": 0.0
    },
    {
      "from": 18.1,
      "to": 19.6,
      "sid": 12,
      "location": 2,
      "content": "反而从另外一个角度去回答的话",
      "music": 0.0
    },
    {
      "from": 19.6,
      "to": 21.9,
      "sid": 13,
      "location": 2,
      "content": "一定是这个事情本身的表述有问题",
      "music": 0.0
    },
    {
      "from": 21.9,
      "to": 23.7,
      "sid": 14,
      "location": 2,
      "content": "而这个事情其实是语言的问题",
      "music": 0.0
    },
    {
      "from": 23.7,
      "to": 25.58,
      "sid": 15,
      "location": 2,
      "content": "那但语言的边界其实思维的边界嘛",
      "music": 0.0
    },
    {
      "from": 25.58,
      "to": 27.62,
      "sid": 16,
      "location": 2,
      "content": "所以并不是我这个话本身说不清楚",
      "music": 0.0
    },
    {
      "from": 27.62,
      "to": 29.26,
      "sid": 17,
      "location": 2,
      "content": "而是我背后没有一套思维框架",
      "music": 0.0
    },
    {
      "from": 29.26,
      "to": 30.82,
      "sid": 18,
      "location": 2,
      "content": "能让我把这个问题给想讲清楚",
      "music": 0.0
    },
    {
      "from": 30.82,
      "to": 33.14,
      "sid": 19,
      "location": 2,
      "content": "我下个月线下课要花四五个小时来讲这个事情",
      "music": 0.0
    },
    {
      "from": 33.14,
      "to": 34.78,
      "sid": 20,
      "location": 2,
      "content": "今天就拿一个案例先当个预告吧",
      "music": 0.0
    },
    {
      "from": 34.78,
      "to": 35.74,
      "sid": 21,
      "location": 2,
      "content": "比如说我直播的时候",
      "music": 0.0
    },
    {
      "from": 35.74,
      "to": 37.14,
      "sid": 22,
      "location": 2,
      "content": "经常会有人说一下自己的情况",
      "music": 0.0
    },
    {
      "from": 37.14,
      "to": 38.1,
      "sid": 23,
      "location": 2,
      "content": "然后最后问我一个问题",
      "music": 0.0
    },
    {
      "from": 38.1,
      "to": 39.44,
      "sid": 24,
      "location": 2,
      "content": "叫我适合干什么赛道",
      "music": 0.0
    },
    {
      "from": 39.44,
      "to": 40.84,
      "sid": 25,
      "location": 2,
      "content": "就我适合干什么赛道",
      "music": 0.0
    },
    {
      "from": 40.84,
      "to": 42.68,
      "sid": 26,
      "location": 2,
      "content": "这八个字他一定是一个错误的表述",
      "music": 0.0
    },
    {
      "from": 42.68,
      "to": 44.28,
      "sid": 27,
      "location": 2,
      "content": "这个我在之前短视频里面说过很多",
      "music": 0.0
    },
    {
      "from": 44.28,
      "to": 46.32,
      "sid": 28,
      "location": 2,
      "content": "但是我们今天要讲的是这八个字",
      "music": 0.0
    },
    {
      "from": 46.32,
      "to": 47.84,
      "sid": 29,
      "location": 2,
      "content": "之所以是一个错误的表述",
      "music": 0.0
    },
    {
      "from": 47.84,
      "to": 50.04,
      "sid": 30,
      "location": 2,
      "content": "是因为它背后映射出一个什么样的",
      "music": 0.0
    },
    {
      "from": 50.04,
      "to": 51.24,
      "sid": 31,
      "location": 2,
      "content": "有问题的思维结构",
      "music": 0.0
    },
    {
      "from": 51.24,
      "to": 53.44,
      "sid": 32,
      "location": 2,
      "content": "就如果我问你说我适合干什么赛道",
      "music": 0.0
    },
    {
      "from": 53.44,
      "to": 55.14,
      "sid": 33,
      "location": 2,
      "content": "这个问题其实背后对应的一个假设",
      "music": 0.0
    },
    {
      "from": 55.14,
      "to": 58.26,
      "sid": 34,
      "location": 2,
      "content": "就说肯定是存在某一个赛道或者多个赛道",
      "music": 0.0
    },
    {
      "from": 58.26,
      "to": 59.34,
      "sid": 35,
      "location": 2,
      "content": "是适合我去干的",
      "music": 0.0
    },
    {
      "from": 59.34,
      "to": 60.64,
      "sid": 36,
      "location": 2,
      "content": "那我才能问这个问题对吧",
      "music": 0.0
    },
    {
      "from": 60.64,
      "to": 61.94,
      "sid": 37,
      "location": 2,
      "content": "那这个假设背后对应",
      "music": 0.0
    },
    {
      "from": 61.94,
      "to": 63.46,
      "sid": 38,
      "location": 2,
      "content": "后面又对应了另外一个假设",
      "music": 0.0
    },
    {
      "from": 63.46,
      "to": 65.98,
      "sid": 39,
      "location": 2,
      "content": "叫做这个赛道下面的所有的事情",
      "music": 0.0
    },
    {
      "from": 65.98,
      "to": 66.94,
      "sid": 40,
      "location": 2,
      "content": "或者大部分的事情",
      "music": 0.0
    },
    {
      "from": 66.94,
      "to": 69.42,
      "sid": 41,
      "location": 2,
      "content": "它对应了同一个干法或者同一个打法",
      "music": 0.0
    },
    {
      "from": 69.42,
      "to": 71.46,
      "sid": 42,
      "location": 2,
      "content": "才能让我去适合干这个赛道对吧",
      "music": 0.0
    },
    {
      "from": 71.46,
      "to": 73.24,
      "sid": 43,
      "location": 2,
      "content": "因为下面所有的风扇我都能尝试",
      "music": 0.0
    },
    {
      "from": 73.24,
      "to": 74.68,
      "sid": 44,
      "location": 2,
      "content": "但我们举一个具体的例子来看",
      "music": 0.0
    },
    {
      "from": 74.68,
      "to": 75.68,
      "sid": 45,
      "location": 2,
      "content": "到底是不是真的是这样",
      "music": 0.0
    },
    {
      "from": 75.68,
      "to": 76.6,
      "sid": 46,
      "location": 2,
      "content": "比如我以前卖过水晶",
      "music": 0.0
    },
    {
      "from": 76.6,
      "to": 78.04,
      "sid": 47,
      "location": 2,
      "content": "我有一个通常意义上的同行",
      "music": 0.0
    },
    {
      "from": 78.04,
      "to": 79.46,
      "sid": 48,
      "location": 2,
      "content": "但其实我认为不是同行啊",
      "music": 0.0
    },
    {
      "from": 79.46,
      "to": 80.7,
      "sid": 49,
      "location": 2,
      "content": "是一个长得很漂亮的一个女生",
      "music": 0.0
    },
    {
      "from": 80.7,
      "to": 81.46,
      "sid": 50,
      "location": 2,
      "content": "你去看她的账号",
      "music": 0.0
    },
    {
      "from": 81.46,
      "to": 83.48,
      "sid": 51,
      "location": 2,
      "content": "你会觉得她可能就是一个颜值博主",
      "music": 0.0
    },
    {
      "from": 83.48,
      "to": 85.5,
      "sid": 52,
      "location": 2,
      "content": "但她其实只有二三十%的内容",
      "music": 0.0
    },
    {
      "from": 85.5,
      "to": 87.34,
      "sid": 53,
      "location": 2,
      "content": "是纯展示个人自己的个人生活",
      "music": 0.0
    },
    {
      "from": 87.34,
      "to": 88.94,
      "sid": 54,
      "location": 2,
      "content": "另外七八十%的内容呢",
      "music": 0.0
    },
    {
      "from": 88.94,
      "to": 91.1,
      "sid": 55,
      "location": 2,
      "content": "其实都是他和他的那个定制的水晶手串",
      "music": 0.0
    },
    {
      "from": 91.1,
      "to": 91.8,
      "sid": 56,
      "location": 2,
      "content": "一起出镜的",
      "music": 0.0
    },
    {
      "from": 91.8,
      "to": 93.3,
      "sid": 57,
      "location": 2,
      "content": "然后因为他这个内容做的特别好",
      "music": 0.0
    },
    {
      "from": 93.3,
      "to": 94.86,
      "sid": 58,
      "location": 2,
      "content": "就是哪怕你不买他的东西",
      "music": 0.0
    },
    {
      "from": 94.86,
      "to": 96.92,
      "sid": 59,
      "location": 2,
      "content": "你都觉得他的这个短视频本身",
      "music": 0.0
    },
    {
      "from": 96.92,
      "to": 98.14,
      "sid": 60,
      "location": 2,
      "content": "都是有一个消费价值的",
      "music": 0.0
    },
    {
      "from": 98.14,
      "to": 100.98,
      "sid": 61,
      "location": 2,
      "content": "所以他可以在同行都花钱买流量的情况下",
      "music": 0.0
    },
    {
      "from": 100.98,
      "to": 102.26,
      "sid": 62,
      "location": 2,
      "content": "可以不花一分钱",
      "music": 0.0
    },
    {
      "from": 102.26,
      "to": 103.14,
      "sid": 63,
      "location": 2,
      "content": "只用自然流量",
      "music": 0.0
    },
    {
      "from": 103.14,
      "to": 104.78,
      "sid": 64,
      "location": 2,
      "content": "然后每个月轻轻松松赚个五到10万",
      "music": 0.0
    },
    {
      "from": 104.78,
      "to": 106.74,
      "sid": 65,
      "location": 2,
      "content": "但我的日常工作和他完全不一样",
      "music": 0.0
    },
    {
      "from": 106.74,
      "to": 107.82,
      "sid": 66,
      "location": 2,
      "content": "我没有任何的自然流量",
      "music": 0.0
    },
    {
      "from": 107.82,
      "to": 109.6,
      "sid": 67,
      "location": 2,
      "content": "我的每一份流量都是我花钱买来的",
      "music": 0.0
    },
    {
      "from": 109.6,
      "to": 110.42,
      "sid": 68,
      "location": 2,
      "content": "我也不拍视频",
      "music": 0.0
    },
    {
      "from": 110.42,
      "to": 111.16,
      "sid": 69,
      "location": 2,
      "content": "我也不直播",
      "music": 0.0
    },
    {
      "from": 111.16,
      "to": 111.88,
      "sid": 70,
      "location": 2,
      "content": "我也不碰货",
      "music": 0.0
    },
    {
      "from": 111.88,
      "to": 113.2,
      "sid": 71,
      "location": 2,
      "content": "我也不需要去做那些手串",
      "music": 0.0
    },
    {
      "from": 113.2,
      "to": 114.08,
      "sid": 72,
      "location": 2,
      "content": "我每天早上醒来",
      "music": 0.0
    },
    {
      "from": 114.08,
      "to": 114.8,
      "sid": 73,
      "location": 2,
      "content": "我就负责一个事",
      "music": 0.0
    },
    {
      "from": 114.8,
      "to": 116.62,
      "sid": 74,
      "location": 2,
      "content": "就是保证我们这边产出的图文素材",
      "music": 0.0
    },
    {
      "from": 116.62,
      "to": 119.1,
      "sid": 75,
      "location": 2,
      "content": "可以碰到投放的那个广告系统的后台就投出去",
      "music": 0.0
    },
    {
      "from": 119.1,
      "to": 120.98,
      "sid": 76,
      "location": 2,
      "content": "我的开口成本不能高过25块钱",
      "music": 0.0
    },
    {
      "from": 120.98,
      "to": 123.14,
      "sid": 77,
      "location": 2,
      "content": "然后我每天至少要花掉四五千去投放",
      "music": 0.0
    },
    {
      "from": 123.14,
      "to": 124.02,
      "sid": 78,
      "location": 2,
      "content": "然后还有一些同行",
      "music": 0.0
    },
    {
      "from": 124.02,
      "to": 125.14,
      "sid": 79,
      "location": 2,
      "content": "他们的打法又完全不同",
      "music": 0.0
    },
    {
      "from": 125.14,
      "to": 126.74,
      "sid": 80,
      "location": 2,
      "content": "比如联名了什么五台山",
      "music": 0.0
    },
    {
      "from": 126.74,
      "to": 127.34,
      "sid": 81,
      "location": 2,
      "content": "灵隐寺",
      "music": 0.0
    },
    {
      "from": 127.34,
      "to": 129.7,
      "sid": 82,
      "location": 2,
      "content": "布达拉宫这些大的IP去做电商的直播流量",
      "music": 0.0
    },
    {
      "from": 129.7,
      "to": 131.26,
      "sid": 83,
      "location": 2,
      "content": "然后甚至还有人有些线下的店",
      "music": 0.0
    },
    {
      "from": 131.26,
      "to": 132.7,
      "sid": 84,
      "location": 2,
      "content": "做这个黄金的手工定制服务",
      "music": 0.0
    },
    {
      "from": 132.7,
      "to": 133.4,
      "sid": 85,
      "location": 2,
      "content": "客单价特特别高",
      "music": 0.0
    },
    {
      "from": 133.4,
      "to": 134.24,
      "sid": 86,
      "location": 2,
      "content": "可能几十上百万",
      "music": 0.0
    },
    {
      "from": 134.24,
      "to": 137.08,
      "sid": 87,
      "location": 2,
      "content": "那这个时候你问我说我是不适合干水晶赛道",
      "music": 0.0
    },
    {
      "from": 137.08,
      "to": 139.96,
      "sid": 88,
      "location": 2,
      "content": "这个这句话背后体现体现了什么样的思维缺陷",
      "music": 0.0
    },
    {
      "from": 139.96,
      "to": 141.4,
      "sid": 89,
      "location": 2,
      "content": "他看见了赛道这个词",
      "music": 0.0
    },
    {
      "from": 141.4,
      "to": 142.64,
      "sid": 90,
      "location": 2,
      "content": "可能是他刷抖音突然刷到的",
      "music": 0.0
    },
    {
      "from": 142.64,
      "to": 144.0,
      "sid": 91,
      "location": 2,
      "content": "说啊年轻人要定一个赛道",
      "music": 0.0
    },
    {
      "from": 144.0,
      "to": 145.56,
      "sid": 92,
      "location": 2,
      "content": "你要搞清楚自己往哪个方向去走",
      "music": 0.0
    },
    {
      "from": 145.56,
      "to": 147.1,
      "sid": 93,
      "location": 2,
      "content": "但他没有看见另外两个词",
      "music": 0.0
    },
    {
      "from": 147.1,
      "to": 148.64,
      "sid": 94,
      "location": 2,
      "content": "一个词叫品类水晶",
      "music": 0.0
    },
    {
      "from": 148.64,
      "to": 149.76,
      "sid": 95,
      "location": 2,
      "content": "它不一定是一个赛道词",
      "music": 0.0
    },
    {
      "from": 149.76,
      "to": 150.78,
      "sid": 96,
      "location": 2,
      "content": "它是一个品类词",
      "music": 0.0
    },
    {
      "from": 150.78,
      "to": 152.2,
      "sid": 97,
      "location": 2,
      "content": "另外一个词叫能力模型",
      "music": 0.0
    },
    {
      "from": 152.2,
      "to": 153.72,
      "sid": 98,
      "location": 2,
      "content": "而能力模型后面还有一个词",
      "music": 0.0
    },
    {
      "from": 153.72,
      "to": 155.56,
      "sid": 99,
      "location": 2,
      "content": "叫能力模型的可迁移性",
      "music": 0.0
    },
    {
      "from": 155.56,
      "to": 157.86,
      "sid": 100,
      "location": 2,
      "content": "你表面上看三个生意都是在卖水晶",
      "music": 0.0
    },
    {
      "from": 157.86,
      "to": 159.94,
      "sid": 101,
      "location": 2,
      "content": "那只不过是我们有不同的路径",
      "music": 0.0
    },
    {
      "from": 159.94,
      "to": 162.54,
      "sid": 102,
      "location": 2,
      "content": "最终都落到了水晶这一个品类上面而已",
      "music": 0.0
    },
    {
      "from": 162.54,
      "to": 165.3,
      "sid": 103,
      "location": 2,
      "content": "但是我们背后运用的是完全不同的能力模型",
      "music": 0.0
    },
    {
      "from": 165.3,
      "to": 167.42,
      "sid": 104,
      "location": 2,
      "content": "那么如果围绕能力模型去讲的话",
      "music": 0.0
    },
    {
      "from": 167.42,
      "to": 169.56,
      "sid": 105,
      "location": 2,
      "content": "你可以说我突然可以从水晶的赛道",
      "music": 0.0
    },
    {
      "from": 169.56,
      "to": 170.7,
      "sid": 106,
      "location": 2,
      "content": "切换到茶叶的赛道",
      "music": 0.0
    },
    {
      "from": 170.7,
      "to": 172.6,
