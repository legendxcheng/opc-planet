  "body": [
    {
      "from": 0.04,
      "to": 2.84,
      "sid": 1,
      "location": 2,
      "content": "如何在不抄别人的情况下做出自媒体的爆款",
      "music": 0.0
    },
    {
      "from": 2.84,
      "to": 4.96,
      "sid": 2,
      "location": 2,
      "content": "今天我公开一下我的整个内容生产流程",
      "music": 0.0
    },
    {
      "from": 4.96,
      "to": 5.88,
      "sid": 3,
      "location": 2,
      "content": "虽然是免费公开啊",
      "music": 0.0
    },
    {
      "from": 5.88,
      "to": 6.88,
      "sid": 4,
      "location": 2,
      "content": "不过我也有我的私信",
      "music": 0.0
    },
    {
      "from": 6.88,
      "to": 8.0,
      "sid": 5,
      "location": 2,
      "content": "这个私信放到后面再讲",
      "music": 0.0
    },
    {
      "from": 8.0,
      "to": 10.26,
      "sid": 6,
      "location": 2,
      "content": "首先一切的开端都来源于一个爆款选题",
      "music": 0.0
    },
    {
      "from": 10.26,
      "to": 11.34,
      "sid": 7,
      "location": 2,
      "content": "这个叫选题定生死",
      "music": 0.0
    },
    {
      "from": 11.34,
      "to": 11.9,
      "sid": 8,
      "location": 2,
      "content": "什么是选题",
      "music": 0.0
    },
    {
      "from": 14.5,
      "to": 15.56,
      "sid": 9,
      "location": 2,
      "content": "这个是我的选题",
      "music": 0.0
    },
    {
      "from": 15.56,
      "to": 16.88,
      "sid": 10,
      "location": 2,
      "content": "就是我要讲一个什么样的事",
      "music": 0.0
    },
    {
      "from": 18.48,
      "to": 19.12,
      "sid": 11,
      "location": 2,
      "content": "能赚不到钱呢",
      "music": 0.0
    },
    {
      "from": 19.12,
      "to": 19.8,
      "sid": 12,
      "location": 2,
      "content": "我会我的观点",
      "music": 0.0
    },
    {
      "from": 19.8,
      "to": 21.08,
      "sid": 13,
      "location": 2,
      "content": "这观点可能1234567",
      "music": 0.0
    },
    {
      "from": 21.08,
      "to": 21.8,
      "sid": 14,
      "location": 2,
      "content": "我说了一堆",
      "music": 0.0
    },
    {
      "from": 21.8,
      "to": 23.52,
      "sid": 15,
      "location": 2,
      "content": "最后再加上一个呈现的手法",
      "music": 0.0
    },
    {
      "from": 23.52,
      "to": 25.58,
      "sid": 16,
      "location": 2,
      "content": "比如我现在在用一三比四的横屏",
      "music": 0.0
    },
    {
      "from": 25.58,
      "to": 27.32,
      "sid": 17,
      "location": 2,
      "content": "加上一个玻璃板来展示我的观点",
      "music": 0.0
    },
    {
      "from": 27.32,
      "to": 28.08,
      "sid": 18,
      "location": 2,
      "content": "这个叫手法",
      "music": 0.0
    },
    {
      "from": 28.08,
      "to": 29.64,
      "sid": 19,
      "location": 2,
      "content": "选题加观点加手法",
      "music": 0.0
    },
    {
      "from": 29.64,
      "to": 30.94,
      "sid": 20,
      "location": 2,
      "content": "这三个东西放到一起",
      "music": 0.0
    },
    {
      "from": 30.94,
      "to": 33.64,
      "sid": 21,
      "location": 2,
      "content": "共同组成了你的一个自媒体内容手法的问题",
      "music": 0.0
    },
    {
      "from": 33.64,
      "to": 34.32,
      "sid": 22,
      "location": 2,
      "content": "我们今天先不谈",
      "music": 0.0
    },
    {
      "from": 34.32,
      "to": 35.64,
      "sid": 23,
      "location": 2,
      "content": "我们先说一个老大难的问题",
      "music": 0.0
    },
    {
      "from": 35.64,
      "to": 38.32,
      "sid": 24,
      "location": 2,
      "content": "就是这个选题我到底是原创还是抄原创",
      "music": 0.0
    },
    {
      "from": 38.32,
      "to": 40.56,
      "sid": 25,
      "location": 2,
      "content": "选题的问题是什么话题火什么话题不火",
      "music": 0.0
    },
    {
      "from": 40.56,
      "to": 41.66,
      "sid": 26,
      "location": 2,
      "content": "这个事情我没法预判",
      "music": 0.0
    },
    {
      "from": 41.66,
      "to": 42.56,
      "sid": 27,
      "location": 2,
      "content": "比如我今天讲一下",
      "music": 0.0
    },
    {
      "from": 42.56,
      "to": 44.5,
      "sid": 28,
      "location": 2,
      "content": "我开始换这个玻璃板来讲视频了",
      "music": 0.0
    },
    {
      "from": 44.5,
      "to": 45.78,
      "sid": 29,
      "location": 2,
      "content": "这个玻璃板怎么打光的",
      "music": 0.0
    },
    {
      "from": 45.78,
      "to": 47.42,
      "sid": 30,
      "location": 2,
      "content": "这个话题在抖音上有人看吗",
      "music": 0.0
    },
    {
      "from": 47.42,
      "to": 48.34,
      "sid": 31,
      "location": 2,
      "content": "在小红书上有人看吗",
      "music": 0.0
    },
    {
      "from": 48.34,
      "to": 48.78,
      "sid": 32,
      "location": 2,
      "content": "我不知道",
      "music": 0.0
    },
    {
      "from": 48.78,
      "to": 49.36,
      "sid": 33,
      "location": 2,
      "content": "我得靠猜",
      "music": 0.0
    },
    {
      "from": 49.36,
      "to": 50.62,
      "sid": 34,
      "location": 2,
      "content": "所以通常的解决方案是",
      "music": 0.0
    },
    {
      "from": 50.62,
      "to": 51.78,
      "sid": 35,
      "location": 2,
      "content": "如果有一个选题火了",
      "music": 0.0
    },
    {
      "from": 51.78,
      "to": 54.84,
      "sid": 36,
      "location": 2,
      "content": "我更倾向于用别人拍火过的选题或者是标题",
      "music": 0.0
    },
    {
      "from": 54.84,
      "to": 56.08,
      "sid": 37,
      "location": 2,
      "content": "来讲一下我自己的观点",
      "music": 0.0
    },
    {
      "from": 56.08,
      "to": 57.16,
      "sid": 38,
      "location": 2,
      "content": "但这个事情听起来简单",
      "music": 0.0
    },
    {
      "from": 57.16,
      "to": 58.1,
      "sid": 39,
      "location": 2,
      "content": "做起来其实很难",
      "music": 0.0
    },
    {
      "from": 58.1,
      "to": 60.18,
      "sid": 40,
      "location": 2,
      "content": "就是当我看到别人把一个选题拍混了之后",
      "music": 0.0
    },
    {
      "from": 60.18,
      "to": 61.46,
      "sid": 41,
      "location": 2,
      "content": "我总要看一下它的内容是什么",
      "music": 0.0
    },
    {
      "from": 61.46,
      "to": 61.78,
      "sid": 42,
      "location": 2,
      "content": "对吧",
      "music": 0.0
    },
    {
      "from": 61.78,
      "to": 63.08,
      "sid": 43,
      "location": 2,
      "content": "我看了那个内容之后",
      "music": 0.0
    },
    {
      "from": 63.08,
      "to": 64.2,
      "sid": 44,
      "location": 2,
      "content": "他所说的这个观点",
      "music": 0.0
    },
    {
      "from": 64.2,
      "to": 66.2,
      "sid": 45,
      "location": 2,
      "content": "就会先入为主的进入到我脑子里",
      "music": 0.0
    },
    {
      "from": 66.2,
      "to": 67.08,
      "sid": 46,
      "location": 2,
      "content": "然后我就会发现",
      "music": 0.0
    },
    {
      "from": 67.08,
      "to": 68.48,
      "sid": 47,
      "location": 2,
      "content": "无论我自己怎么去输出",
      "music": 0.0
    },
    {
      "from": 68.48,
      "to": 70.04,
      "sid": 48,
      "location": 2,
      "content": "都在围着他的这个东西去打转",
      "music": 0.0
    },
    {
      "from": 70.04,
      "to": 71.49,
      "sid": 49,
      "location": 2,
      "content": "这个在心理学上叫做锚定效应",
      "music": 0.0
    },
    {
      "from": 71.49,
      "to": 74.57,
      "sid": 50,
      "location": 2,
      "content": "一旦他的这个观点锚定在我脑子里之后了",
      "music": 0.0
    },
    {
      "from": 74.57,
      "to": 75.97,
      "sid": 51,
      "location": 2,
      "content": "我自己无论再怎么输出",
      "music": 0.0
    },
    {
      "from": 75.97,
      "to": 76.97,
      "sid": 52,
      "location": 2,
      "content": "都会跟他大差不差",
      "music": 0.0
    },
    {
      "from": 76.97,
      "to": 78.61,
      "sid": 53,
      "location": 2,
      "content": "我又要讲你讲过的选题",
      "music": 0.0
    },
    {
      "from": 78.61,
      "to": 80.46,
      "sid": 54,
      "location": 2,
      "content": "我还要讲你没有讲过的观点",
      "music": 0.0
    },
    {
      "from": 80.46,
      "to": 82.1,
      "sid": 55,
      "location": 2,
      "content": "我的这个观点还得自圆其说",
      "music": 0.0
    },
    {
      "from": 82.1,
      "to": 83.02,
      "sid": 56,
      "location": 2,
      "content": "让别人给我点赞",
      "music": 0.0
    },
    {
      "from": 83.02,
      "to": 83.54,
      "sid": 57,
      "location": 2,
      "content": "给我关注",
      "music": 0.0
    },
    {
      "from": 83.54,
      "to": 83.94,
      "sid": 58,
      "location": 2,
      "content": "给我付费",
      "music": 0.0
    },
    {
      "from": 83.94,
      "to": 85.26,
      "sid": 59,
      "location": 2,
      "content": "我觉得这个事情实在是太难",
      "music": 0.0
    },
    {
      "from": 85.26,
      "to": 87.42,
      "sid": 60,
      "location": 2,
      "content": "我来讲一下我是怎么解决这个问题的",
      "music": 0.0
    },
    {
      "from": 87.42,
      "to": 88.94,
      "sid": 61,
      "location": 2,
      "content": "三个方法要用到两个工具",
      "music": 0.0
    },
    {
      "from": 88.94,
      "to": 90.96,
      "sid": 62,
      "location": 2,
      "content": "一个是你日常要有储备知识",
      "music": 0.0
    },
    {
      "from": 90.96,
      "to": 92.2,
      "sid": 63,
      "location": 2,
      "content": "输出观点的一个习惯",
      "music": 0.0
    },
    {
      "from": 92.2,
      "to": 93.14,
      "sid": 64,
      "location": 2,
      "content": "另外一个就是AI",
      "music": 0.0
    },
    {
      "from": 93.14,
      "to": 94.8,
      "sid": 65,
      "location": 2,
      "content": "我会选一个文字型的社交媒体",
      "music": 0.0
    },
    {
      "from": 94.8,
      "to": 95.8,
      "sid": 66,
      "location": 2,
      "content": "来记录我平时的思考",
      "music": 0.0
    },
    {
      "from": 95.8,
      "to": 98.68,
      "sid": 67,
      "location": 2,
      "content": "或者说我在工作中遇到的解决方案以及问题",
      "music": 0.0
    },
    {
      "from": 98.68,
      "to": 100.36,
      "sid": 68,
      "location": 2,
      "content": "然后从去年的9月30号写到",
      "music": 0.0
    },
    {
      "from": 100.36,
      "to": 102.52,
      "sid": 69,
      "location": 2,
      "content": "现在是8729条",
      "music": 0.0
    },
    {
      "from": 102.52,
      "to": 104.16,
      "sid": 70,
      "location": 2,
      "content": "这但是这里面有一些回复和转发啊",
      "music": 0.0
    },
    {
      "from": 104.16,
      "to": 105.8,
      "sid": 71,
      "location": 2,
      "content": "我全是原创的帖子呃",
      "music": 0.0
    },
    {
      "from": 105.8,
      "to": 107.48,
      "sid": 72,
      "location": 2,
      "content": "统计了一下是1228条",
      "music": 0.0
    },
    {
      "from": 107.48,
      "to": 108.88,
      "sid": 73,
      "location": 2,
      "content": "但是你不用被这个数字吓退啊",
      "music": 0.0
    },
    {
      "from": 108.88,
      "to": 110.08,
      "sid": 74,
      "location": 2,
      "content": "我觉得一天写五条的话",
      "music": 0.0
    },
    {
      "from": 110.08,
      "to": 110.78,
      "sid": 75,
      "location": 2,
      "content": "写个两三个月",
      "music": 0.0
    },
    {
      "from": 110.78,
      "to": 112.54,
      "sid": 76,
      "location": 2,
      "content": "你的知识储备量按照我这个方法来讲",
      "music": 0.0
    },
    {
      "from": 112.54,
      "to": 113.46,
      "sid": 77,
      "location": 2,
      "content": "就是完全够用的",
      "music": 0.0
    },
    {
      "from": 113.46,
      "to": 115.18,
      "sid": 78,
      "location": 2,
      "content": "而这件事情的核心是在于",
      "music": 0.0
    },
    {
      "from": 115.18,
      "to": 117.8,
      "sid": 79,
      "location": 2,
      "content": "你一定要在爆款选题出现之前",
      "music": 0.0
    },
    {
      "from": 117.8,
      "to": 118.8,
      "sid": 80,
      "location": 2,
      "content": "就有你自己的观点",
      "music": 0.0
    },
    {
      "from": 118.8,
      "to": 121.24,
      "sid": 81,
      "location": 2,
      "content": "而不是围绕着爆款选题再去产出",
      "music": 0.0
    },
    {
      "from": 121.24,
      "to": 123.8,
      "sid": 82,
      "location": 2,
      "content": "如果你的观点永远出现在别人的爆款选题之后",
      "music": 0.0
    },
    {
      "from": 123.8,
      "to": 124.92,
      "sid": 83,
      "location": 2,
      "content": "就会就像我们刚才讲的一样",
      "music": 0.0
    },
    {
      "from": 124.92,
      "to": 126.84,
      "sid": 84,
      "location": 2,
      "content": "你的所有的产出都是别人的内容的",
      "music": 0.0
    },
    {
      "from": 126.84,
      "to": 128.3,
      "sid": 85,
      "location": 2,
      "content": "二次炒饭都是反刍",
      "music": 0.0
    },
    {
      "from": 128.3,
      "to": 129.32,
      "sid": 86,
      "location": 2,
      "content": "你没有自己的东西",
      "music": 0.0
    },
    {
      "from": 129.32,
      "to": 131.76,
      "sid": 87,
      "location": 2,
      "content": "而我认为自媒体IP这件事情的本质是",
      "music": 0.0
    },
    {
      "from": 131.76,
      "to": 134.82,
      "sid": 88,
      "location": 2,
      "content": "你本来就有一些值得被别人跟关注的观点",
      "music": 0.0
    },
    {
      "from": 134.82,
      "to": 136.58,
      "sid": 89,
      "location": 2,
      "content": "你本来就是一个值得被关注的人",
      "music": 0.0
    },
    {
      "from": 136.58,
      "to": 138.46,
      "sid": 90,
      "location": 2,
      "content": "只不过互联网是它是一个桥梁",
      "music": 0.0
    },
    {
      "from": 138.46,
      "to": 139.92,
      "sid": 91,
      "location": 2,
      "content": "把你和你的观众连接起来了",
      "music": 0.0
    },
    {
      "from": 139.92,
      "to": 143.36,
      "sid": 92,
      "location": 2,
      "content": "基于一个火热的爆款选题去临时去输出观点",
      "music": 0.0
    },
    {
      "from": 143.36,
      "to": 145.24,
      "sid": 93,
      "location": 2,
      "content": "这件事情他本来就是本末倒置",
      "music": 0.0
    },
    {
      "from": 145.24,
      "to": 147.36,
      "sid": 94,
      "location": 2,
      "content": "他是我们发现自媒体IP这个事情",
      "music": 0.0
    },
    {
      "from": 147.36,
      "to": 149.02,
      "sid": 95,
      "location": 2,
      "content": "好像是能搞流量能赚钱",
      "music": 0.0
    },
    {
      "from": 149.02,
      "to": 151.02,
      "sid": 96,
      "location": 2,
      "content": "所以而产生的一个畸形的一个产物",
      "music": 0.0
    },
    {
      "from": 151.02,
      "to": 152.02,
      "sid": 97,
      "location": 2,
      "content": "所以我的第一个方法是",
      "music": 0.0
    },
    {
      "from": 152.02,
      "to": 154.02,
      "sid": 98,
      "location": 2,
      "content": "在我建立了我的观点内容库之后",
      "music": 0.0
    },
    {
      "from": 154.02,
      "to": 156.5,
      "sid": 99,
      "location": 2,
      "content": "我每次在网上看到某一个选题火了",
      "music": 0.0
    },
    {
      "from": 156.5,
      "to": 158.1,
      "sid": 100,
      "location": 2,
      "content": "我就会去拿那个关键词去",
      "music": 0.0
    },
    {
      "from": 158.1,
      "to": 159.52,
      "sid": 101,
      "location": 2,
      "content": "在我的内容里面就搜一下",
      "music": 0.0
    },
    {
      "from": 159.52,
      "to": 161.36,
      "sid": 102,
      "location": 2,
      "content": "看我以前有没有产出过相关的东西",
      "music": 0.0
    },
    {
      "from": 161.36,
      "to": 163.56,
      "sid": 103,
      "location": 2,
      "content": "然后一搜我会发现你的这个爆款选题",
      "music": 0.0
    },
    {
      "from": 163.56,
      "to": 164.76,
      "sid": 104,
      "location": 2,
      "content": "原来我早就讲过",
      "music": 0.0
    },
    {
      "from": 164.76,
      "to": 166.08,
      "sid": 105,
      "location": 2,
      "content": "而且我讲的比你还早",
      "music": 0.0
    },
    {
      "from": 166.08,
      "to": 167.28,
      "sid": 106,
      "location": 2,
      "content": "我甚至讲过四次",
      "music": 0.0
    },
    {
      "from": 167.28,
      "to": 169.88,
      "sid": 107,
      "location": 2,
      "content": "只不过当初我不知道这样的话题",
      "music": 0.0
    },
    {
      "from": 169.88,
      "to": 171.68,
