  "body": [
    {
      "from": 0.28,
      "to": 1.9,
      "sid": 1,
      "location": 2,
      "content": "小瓶粉皮莱卡",
      "music": 0.0
    },
    {
      "from": 1.9,
      "to": 3.78,
      "sid": 2,
      "location": 2,
      "content": "一年前她还是我的小甜甜",
      "music": 0.0
    },
    {
      "from": 3.78,
      "to": 5.62,
      "sid": 3,
      "location": 2,
      "content": "但经过一年的柴米园以后",
      "music": 0.0
    },
    {
      "from": 5.62,
      "to": 7.22,
      "sid": 4,
      "location": 2,
      "content": "她已经成了牛夫人了",
      "music": 0.0
    },
    {
      "from": 7.22,
      "to": 9.7,
      "sid": 5,
      "location": 2,
      "content": "看着蓄势待发的众多小屏旗舰",
      "music": 0.0
    },
    {
      "from": 9.7,
      "to": 11.66,
      "sid": 6,
      "location": 2,
      "content": "我觉得是时候换个新老婆了",
      "music": 0.0
    },
    {
      "from": 11.66,
      "to": 13.62,
      "sid": 7,
      "location": 2,
      "content": "先从IPHONE16pro开始",
      "music": 0.0
    },
    {
      "from": 13.62,
      "to": 14.44,
      "sid": 8,
      "location": 2,
      "content": "众所周知",
      "music": 0.0
    },
    {
      "from": 14.44,
      "to": 15.7,
      "sid": 9,
      "location": 2,
      "content": "钱不是大风刮来的",
      "music": 0.0
    },
    {
      "from": 15.7,
      "to": 17.34,
      "sid": 10,
      "location": 2,
      "content": "换新手机是需要理由的",
      "music": 0.0
    },
    {
      "from": 17.34,
      "to": 20.02,
      "sid": 11,
      "location": 2,
      "content": "我搜肠刮肚给小米14准备了三条罪状",
      "music": 0.0
    },
    {
      "from": 20.02,
      "to": 20.62,
      "sid": 12,
      "location": 2,
      "content": "续航弱",
      "music": 0.0
    },
    {
      "from": 20.62,
      "to": 21.18,
      "sid": 13,
      "location": 2,
      "content": "系统卡",
      "music": 0.0
    },
    {
      "from": 21.18,
      "to": 22.17,
      "sid": 14,
      "location": 2,
      "content": "性能释放差",
      "music": 0.0
    },
    {
      "from": 22.17,
      "to": 22.85,
      "sid": 15,
      "location": 2,
      "content": "续航弱",
      "music": 0.0
    },
    {
      "from": 22.85,
      "to": 23.41,
      "sid": 16,
      "location": 2,
      "content": "好理解啊",
      "music": 0.0
    },
    {
      "from": 23.41,
      "to": 24.41,
      "sid": 17,
      "location": 2,
      "content": "小机身小电池",
      "music": 0.0
    },
    {
      "from": 24.41,
      "to": 26.08,
      "sid": 18,
      "location": 2,
      "content": "再加上漏电的澎湃S",
      "music": 0.0
    },
    {
      "from": 26.08,
      "to": 27.82,
      "sid": 19,
      "location": 2,
      "content": "在我用过的手机里面排倒数",
      "music": 0.0
    },
    {
      "from": 27.82,
      "to": 29.04,
      "sid": 20,
      "location": 2,
      "content": "系统卡不好理解",
      "music": 0.0
    },
    {
      "from": 29.04,
      "to": 31.06,
      "sid": 21,
      "location": 2,
      "content": "因为我一直用小米手机当主力机",
      "music": 0.0
    },
    {
      "from": 31.06,
      "to": 32.52,
      "sid": 22,
      "location": 2,
      "content": "一路都是这么坎坷过来的",
      "music": 0.0
    },
    {
      "from": 32.52,
      "to": 34.97,
      "sid": 23,
      "location": 2,
      "content": "直到我接触了橘子和后来的鸿蒙",
      "music": 0.0
    },
    {
      "from": 34.97,
      "to": 35.89,
      "sid": 24,
      "location": 2,
      "content": "性能释放差",
      "music": 0.0
    },
    {
      "from": 35.89,
      "to": 38.55,
      "sid": 25,
      "location": 2,
      "content": "主要出现在游戏和一些负载较高的场景里",
      "music": 0.0
    },
    {
      "from": 38.55,
      "to": 40.59,
      "sid": 26,
      "location": 2,
      "content": "夏天打两把王者都可能锁帧",
      "music": 0.0
    },
    {
      "from": 40.59,
      "to": 43.15,
      "sid": 27,
      "location": 2,
      "content": "退出游戏之后发现桌面已锁60帧了",
      "music": 0.0
    },
    {
      "from": 43.15,
      "to": 45.91,
      "sid": 28,
      "location": 2,
      "content": "手机将会有一段时间进入又卡又烫的黏腻状态",
      "music": 0.0
    },
    {
      "from": 45.91,
      "to": 46.6,
      "sid": 29,
      "location": 2,
      "content": "非常恶心",
      "music": 0.0
    },
    {
      "from": 46.6,
      "to": 47.6,
      "sid": 30,
      "location": 2,
      "content": "哪怕不玩游戏",
      "music": 0.0
    },
    {
      "from": 47.6,
      "to": 50.6,
      "sid": 31,
      "location": 2,
      "content": "在一些频繁切换app或者拍照录像的场景里",
      "music": 0.0
    },
    {
      "from": 50.6,
      "to": 52.33,
      "sid": 32,
      "location": 2,
      "content": "它也可能会变得又卡又烫",
      "music": 0.0
    },
    {
      "from": 52.33,
      "to": 54.39,
      "sid": 33,
      "location": 2,
      "content": "那IPHONE16pro用起来怎么样呢",
      "music": 0.0
    },
    {
      "from": 54.39,
      "to": 56.41,
      "sid": 34,
      "location": 2,
      "content": "外观相比上一代边框收窄了",
      "music": 0.0
    },
    {
      "from": 56.41,
      "to": 57.33,
      "sid": 35,
      "location": 2,
      "content": "机身变长了",
      "music": 0.0
    },
    {
      "from": 57.33,
      "to": 59.6,
      "sid": 36,
      "location": 2,
      "content": "但是跟小米14比还是矮了一截",
      "music": 0.0
    },
    {
      "from": 59.6,
      "to": 61.38,
      "sid": 37,
      "location": 2,
      "content": "再加上边角的弧度比较大",
      "music": 0.0
    },
    {
      "from": 61.38,
      "to": 62.78,
      "sid": 38,
      "location": 2,
      "content": "实际握持起来要润一些",
      "music": 0.0
    },
    {
      "from": 62.78,
      "to": 65.34,
      "sid": 39,
      "location": 2,
      "content": "所以你会发现原来小米14的所谓小屏",
      "music": 0.0
    },
    {
      "from": 65.34,
      "to": 68.12,
      "sid": 40,
      "location": 2,
      "content": "其实一直比IPHONE的标准版和pro都要更大",
      "music": 0.0
    },
    {
      "from": 68.12,
      "to": 70.24,
      "sid": 41,
      "location": 2,
      "content": "IPHONE16pro的电池容量有升级",
      "music": 0.0
    },
    {
      "from": 70.24,
      "to": 72.2,
      "sid": 42,
      "location": 2,
      "content": "但也只有3582ma时",
      "music": 0.0
    },
    {
      "from": 72.2,
      "to": 74.52,
      "sid": 43,
      "location": 2,
      "content": "这个容量只够给我米挥霍三个小时的",
      "music": 0.0
    },
    {
      "from": 74.52,
      "to": 74.96,
      "sid": 44,
      "location": 2,
      "content": "那还好",
      "music": 0.0
    },
    {
      "from": 74.96,
      "to": 76.4,
      "sid": 45,
      "location": 2,
      "content": "它是有着自然之母青睐的",
      "music": 0.0
    },
    {
      "from": 76.4,
      "to": 77.6,
      "sid": 46,
      "location": 2,
      "content": "苹果使用IPHONE的时候",
      "music": 0.0
    },
    {
      "from": 77.6,
      "to": 78.94,
      "sid": 47,
      "location": 2,
      "content": "可以汲取大自然中的灵气",
      "music": 0.0
    },
    {
      "from": 78.94,
      "to": 80.92,
      "sid": 48,
      "location": 2,
      "content": "让3582ma时的电池",
      "music": 0.0
    },
    {
      "from": 80.92,
      "to": 82.9,
      "sid": 49,
      "location": 2,
      "content": "发挥出小米5000ma时以上的水平",
      "music": 0.0
    },
    {
      "from": 82.9,
      "to": 84.66,
      "sid": 50,
      "location": 2,
      "content": "按照我个人的日常使用习惯",
      "music": 0.0
    },
    {
      "from": 84.66,
      "to": 85.42,
      "sid": 51,
      "location": 2,
      "content": "保守估计",
      "music": 0.0
    },
    {
      "from": 85.42,
      "to": 88.16,
      "sid": 52,
      "location": 2,
      "content": "IPHONE16pro可以比小米14续航多出一个小时",
      "music": 0.0
    },
    {
      "from": 88.16,
      "to": 90.59,
      "sid": 53,
      "location": 2,
      "content": "这还是在开启全天候显示的情况下",
      "music": 0.0
    },
    {
      "from": 90.59,
      "to": 93.33,
      "sid": 54,
      "location": 2,
      "content": "对比上一代需要经常插着尿管的IPHONE15pro",
      "music": 0.0
    },
    {
      "from": 93.33,
      "to": 95.77,
      "sid": 55,
      "location": 2,
      "content": "那16pro的续航已经不能算是一个槽点了",
      "music": 0.0
    },
    {
      "from": 95.77,
      "to": 97.03,
      "sid": 56,
      "location": 2,
      "content": "充电还是一如既往的慢",
      "music": 0.0
    },
    {
      "from": 97.03,
      "to": 98.48,
      "sid": 57,
      "location": 2,
      "content": "没有短时间回血的能力",
      "music": 0.0
    },
    {
      "from": 98.48,
      "to": 100.32,
      "sid": 58,
      "location": 2,
      "content": "甚至IPHONE的充电都不配叫充电",
      "music": 0.0
    },
    {
      "from": 100.32,
      "to": 101.26,
      "sid": 59,
      "location": 2,
      "content": "只能叫做续命",
      "music": 0.0
    },
    {
      "from": 101.26,
      "to": 103.82,
      "sid": 60,
      "location": 2,
      "content": "尤其是那最后80%感觉命都续不上了",
      "music": 0.0
    },
    {
      "from": 103.82,
      "to": 105.24,
      "sid": 61,
      "location": 2,
      "content": "这辈子就只有这么长了",
      "music": 0.0
    },
    {
      "from": 105.24,
      "to": 107.42,
      "sid": 62,
      "location": 2,
      "content": "当我给安卓旗舰电插上充电器的时候",
      "music": 0.0
    },
    {
      "from": 107.42,
      "to": 109.74,
      "sid": 63,
      "location": 2,
      "content": "常常有种能量融入的兴奋感和满足感",
      "music": 0.0
    },
    {
      "from": 109.74,
      "to": 112.14,
      "sid": 64,
      "location": 2,
      "content": "这使得我对下一步的打算都充满信心",
      "music": 0.0
    },
    {
      "from": 112.14,
      "to": 113.96,
      "sid": 65,
      "location": 2,
      "content": "但是给IPHONE插上充电器时",
      "music": 0.0
    },
    {
      "from": 113.96,
      "to": 115.4,
      "sid": 66,
      "location": 2,
      "content": "我要么是在苟延残喘",
      "music": 0.0
    },
    {
      "from": 115.4,
      "to": 118.44,
      "sid": 67,
      "location": 2,
      "content": "要么就是准备任命重开系统上IOS8",
      "music": 0.0
    },
    {
      "from": 118.44,
      "to": 119.2,
      "sid": 68,
      "location": 2,
      "content": "即便bug多",
      "music": 0.0
    },
    {
      "from": 119.2,
      "to": 119.92,
      "sid": 69,
      "location": 2,
      "content": "功能减安卓",
      "music": 0.0
    },
    {
      "from": 119.92,
      "to": 122.21,
      "sid": 70,
      "location": 2,
      "content": "剩下的刷信息流的时候只有80HZ",
      "music": 0.0
    },
    {
      "from": 122.21,
      "to": 124.85,
      "sid": 71,
      "location": 2,
      "content": "那使用起来也还是比小米14上的蓬莱OS",
      "music": 0.0
    },
    {
      "from": 124.85,
      "to": 125.71,
      "sid": 72,
      "location": 2,
      "content": "要流畅的多的",
      "music": 0.0
    },
    {
      "from": 125.71,
      "to": 127.09,
      "sid": 73,
      "location": 2,
      "content": "IPHONE的动画非常精致",
      "music": 0.0
    },
    {
      "from": 127.09,
      "to": 128.6,
      "sid": 74,
      "location": 2,
      "content": "而且是全方位的精致",
      "music": 0.0
    },
    {
      "from": 128.6,
      "to": 130.76,
      "sid": 75,
      "location": 2,
      "content": "几乎涵盖了系统99%的细节",
      "music": 0.0
    },
    {
      "from": 130.76,
      "to": 133.48,
      "sid": 76,
      "location": 2,
      "content": "别说灵动到了IPHONE16pro的极窄边框",
      "music": 0.0
    },
    {
      "from": 133.48,
      "to": 135.54,
      "sid": 77,
      "location": 2,
      "content": "加上我抽中的三星一等奖屏幕",
      "music": 0.0
    },
    {
      "from": 135.54,
      "to": 137.42,
      "sid": 78,
      "location": 2,
      "content": "让一个锁屏都看着赏心悦目",
      "music": 0.0
    },
    {
      "from": 137.42,
      "to": 140.02,
      "sid": 79,
      "location": 2,
      "content": "红牌S在小部分地方做的也挺有追求的",
      "music": 0.0
    },
    {
      "from": 140.02,
      "to": 142.76,
      "sid": 80,
      "location": 2,
      "content": "譬如这个开启高级材质后的毛玻璃效果",
      "music": 0.0
    },
    {
      "from": 142.76,
      "to": 144.98,
      "sid": 81,
      "location": 2,
      "content": "但是在某些地方又显得随意过头了",
      "music": 0.0
    },
    {
      "from": 144.98,
      "to": 146.42,
      "sid": 82,
      "location": 2,
      "content": "譬如这个灵动脑门",
      "music": 0.0
    },
    {
      "from": 146.42,
      "to": 148.52,
      "sid": 83,
      "location": 2,
      "content": "草率的像是关系户应纳的老鼠屎",
      "music": 0.0
    },
    {
      "from": 148.52,
      "to": 150.14,
      "sid": 84,
      "location": 2,
      "content": "譬如这个桌面的搜索动画",
      "music": 0.0
    },
    {
      "from": 150.14,
      "to": 151.8,
      "sid": 85,
      "location": 2,
      "content": "苹果来去都有迹可循",
      "music": 0.0
    },
    {
      "from": 151.8,
      "to": 154.19,
      "sid": 86,
      "location": 2,
      "content": "prop s则选择简单的闪两下",
      "music": 0.0
    },
    {
      "from": 154.19,
      "to": 157.23,
      "sid": 87,
      "location": 2,
      "content": "譬如这个应用启动和退出时的背景模糊",
      "music": 0.0
    },
    {
      "from": 157.23,
      "to": 157.87,
      "sid": 88,
      "location": 2,
      "content": "IPHONE有",
      "music": 0.0
    },
    {
      "from": 157.87,
      "to": 160.339,
      "sid": 89,
      "location": 2,
      "content": "所以它的动画显得立体而生动澎湃",
      "music": 0.0
    },
    {
      "from": 160.339,
      "to": 160.579,
      "sid": 90,
      "location": 2,
      "content": "没有",
      "music": 0.0
    },
    {
      "from": 160.579,
      "to": 161.579,
      "sid": 91,
      "location": 2,
      "content": "或者说阉割掉了",
      "music": 0.0
    },
    {
      "from": 161.579,
      "to": 162.679,
      "sid": 92,
      "location": 2,
      "content": "显得平庸而乏味",
      "music": 0.0
    },
    {
      "from": 162.679,
      "to": 164.34,
      "sid": 93,
      "location": 2,
      "content": "IOS是最近几个大的更新",
      "music": 0.0
    },
    {
      "from": 164.34,
      "to": 166.92,
      "sid": 94,
      "location": 2,
      "content": "最值得吹的就是加入了一些安卓的特色功能",
      "music": 0.0
    },
    {
      "from": 166.92,
      "to": 168.24,
      "sid": 95,
      "location": 2,
      "content": "可自定义的控制中心",
      "music": 0.0
    },
    {
      "from": 168.24,
      "to": 168.74,
      "sid": 96,
      "location": 2,
      "content": "应用锁",
      "music": 0.0
    },
    {
      "from": 168.74,
      "to": 170.53,
      "sid": 97,
      "location": 2,
      "content": "此地无银320的通话录音",
      "music": 0.0
    },
    {
      "from": 170.53,
      "to": 171.53,
      "sid": 98,
      "location": 2,
      "content": "虽然祖训崩塌",
      "music": 0.0
    },
    {
      "from": 171.53,
      "to": 173.05,
      "sid": 99,
      "location": 2,
      "content": "影响了部分嘴硬果粉的道心",
      "music": 0.0
    },
    {
      "from": 173.05,
      "to": 174.829,
      "sid": 100,
      "location": 2,
      "content": "但却实实在在的照护了用户",
      "music": 0.0
    },
    {
      "from": 174.829,
      "to": 176.309,
      "sid": 101,
      "location": 2,
      "content": "希望苹果能够放下身段",
      "music": 0.0
    },
    {
      "from": 176.309,
      "to": 177.429,
      "sid": 102,
      "location": 2,
      "content": "多听听用户的需求",
      "music": 0.0
    },
    {
      "from": 177.429,
      "to": 180.369,
      "sid": 103,
      "location": 2,
      "content": "把应用分身小窗这些实在的功能都安排一下",
      "music": 0.0
    },
    {
      "from": 180.369,
      "to": 182.82,
      "sid": 104,
      "location": 2,
      "content": "毕竟你确实已经没有什么13可以装了",
      "music": 0.0
    },
    {
      "from": 182.82,
      "to": 185.18,
      "sid": 105,
      "location": 2,
      "content": "这么些年挖空心思掏出来那些玩意儿",
      "music": 0.0
    },
    {
      "from": 185.18,
      "to": 186.74,
      "sid": 106,
      "location": 2,
      "content": "还不如皇帝的奏折展开",
      "music": 0.0
    },
