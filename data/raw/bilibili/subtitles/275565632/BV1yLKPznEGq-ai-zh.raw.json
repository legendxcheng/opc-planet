{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.92,
      "sid": 1,
      "location": 2,
      "content": "我在赚到第一个100万之后",
      "music": 0.0
    },
    {
      "from": 1.92,
      "to": 3.4,
      "sid": 2,
      "location": 2,
      "content": "明白的最重要的一个道理就是",
      "music": 0.0
    },
    {
      "from": 3.4,
      "to": 5.0,
      "sid": 3,
      "location": 2,
      "content": "赚钱其实是在耽误我赚钱",
      "music": 0.0
    },
    {
      "from": 5.0,
      "to": 6.28,
      "sid": 4,
      "location": 2,
      "content": "今天我在后台收到一个提问",
      "music": 0.0
    },
    {
      "from": 6.28,
      "to": 9.14,
      "sid": 5,
      "location": 2,
      "content": "是这位兄弟说他平均下来一天的工2000块钱",
      "music": 0.0
    },
    {
      "from": 9.14,
      "to": 11.66,
      "sid": 6,
      "location": 2,
      "content": "现在有一个兄弟找他去外面接一个小项目",
      "music": 0.0
    },
    {
      "from": 11.66,
      "to": 12.26,
      "sid": 7,
      "location": 2,
      "content": "支援几天",
      "music": 0.0
    },
    {
      "from": 12.26,
      "to": 13.94,
      "sid": 8,
      "location": 2,
      "content": "一天平均下来可以给他4000块钱",
      "music": 0.0
    },
    {
      "from": 13.94,
      "to": 15.14,
      "sid": 9,
      "location": 2,
      "content": "他问我这个单要不要接",
      "music": 0.0
    },
    {
      "from": 15.14,
      "to": 16.72,
      "sid": 10,
      "location": 2,
      "content": "我的建议肯定是坚决的反对",
      "music": 0.0
    },
    {
      "from": 16.72,
      "to": 18.04,
      "sid": 11,
      "location": 2,
      "content": "不要去赚这个4000块钱",
      "music": 0.0
    },
    {
      "from": 18.04,
      "to": 19.62,
      "sid": 12,
      "location": 2,
      "content": "接下来说一下我的决策逻辑",
      "music": 0.0
    },
    {
      "from": 19.62,
      "to": 21.12,
      "sid": 13,
      "location": 2,
      "content": "首先把时间拉长来看啊",
      "music": 0.0
    },
    {
      "from": 21.12,
      "to": 22.96,
      "sid": 14,
      "location": 2,
      "content": "我觉得互联网是没有长久的利润的",
      "music": 0.0
    },
    {
      "from": 22.96,
      "to": 24.76,
      "sid": 15,
      "location": 2,
      "content": "其实这句话放在其他的行业也都一样",
      "music": 0.0
    },
    {
      "from": 24.76,
      "to": 26.42,
      "sid": 16,
      "location": 2,
      "content": "我觉得80%情况下都成立吧",
      "music": 0.0
    },
    {
      "from": 26.42,
      "to": 28.46,
      "sid": 17,
      "location": 2,
      "content": "就是你的行业高薪也好",
      "music": 0.0
    },
    {
      "from": 28.46,
      "to": 29.54,
      "sid": 18,
      "location": 2,
      "content": "你的项目红利也好",
      "music": 0.0
    },
    {
      "from": 29.54,
      "to": 30.54,
      "sid": 19,
      "location": 2,
      "content": "平台给你的红利也好",
      "music": 0.0
    },
    {
      "from": 30.54,
      "to": 31.66,
      "sid": 20,
      "location": 2,
      "content": "这个事情都是短暂的",
      "music": 0.0
    },
    {
      "from": 31.66,
      "to": 32.62,
      "sid": 21,
      "location": 2,
      "content": "都是不可持续的",
      "music": 0.0
    },
    {
      "from": 32.62,
      "to": 34.1,
      "sid": 22,
      "location": 2,
      "content": "我不是一个提倡内卷的人",
      "music": 0.0
    },
    {
      "from": 34.1,
      "to": 35.5,
      "sid": 23,
      "location": 2,
      "content": "我也希望大家可以躺着赚钱",
      "music": 0.0
    },
    {
      "from": 35.5,
      "to": 37.36,
      "sid": 24,
      "location": 2,
      "content": "但是真正能像抖音啊",
      "music": 0.0
    },
    {
      "from": 37.36,
      "to": 37.98,
      "sid": 25,
      "location": 2,
      "content": "滴滴啊",
      "music": 0.0
    },
    {
      "from": 37.98,
      "to": 38.42,
      "sid": 26,
      "location": 2,
      "content": "微信啊",
      "music": 0.0
    },
    {
      "from": 38.42,
      "to": 38.9,
      "sid": 27,
      "location": 2,
      "content": "美团啊",
      "music": 0.0
    },
    {
      "from": 38.9,
      "to": 41.42,
      "sid": 28,
      "location": 2,
      "content": "这样能搭成一个平台的机会实在是太少了",
      "music": 0.0
    },
    {
      "from": 41.42,
      "to": 43.82,
      "sid": 29,
      "location": 2,
      "content": "绝大多数情况下都是时势造英雄",
      "music": 0.0
    },
    {
      "from": 43.82,
      "to": 45.3,
      "sid": 30,
      "location": 2,
      "content": "我对于我看过的那些项目的",
      "music": 0.0
    },
    {
      "from": 45.3,
      "to": 47.26,
      "sid": 31,
      "location": 2,
      "content": "利润的可持续性是比较悲观的",
      "music": 0.0
    },
    {
      "from": 47.26,
      "to": 48.02,
      "sid": 32,
      "location": 2,
      "content": "所以在这种情况下",
      "music": 0.0
    },
    {
      "from": 48.02,
      "to": 50.58,
      "sid": 33,
      "location": 2,
      "content": "我就要不断的去寻找势能更强",
      "music": 0.0
    },
    {
      "from": 50.58,
      "to": 51.7,
      "sid": 34,
      "location": 2,
      "content": "杠杆更高的业务去做",
      "music": 0.0
    },
    {
      "from": 51.7,
      "to": 53.5,
      "sid": 35,
      "location": 2,
      "content": "所以如果你对事业没有什么野心",
      "music": 0.0
    },
    {
      "from": 53.5,
      "to": 55.54,
      "sid": 36,
      "location": 2,
      "content": "或者对商业本身没有一些好奇心的话",
      "music": 0.0
    },
    {
      "from": 55.54,
      "to": 56.86,
      "sid": 37,
      "location": 2,
      "content": "我觉得这个过程就会比较痛苦",
      "music": 0.0
    },
    {
      "from": 56.86,
      "to": 58.1,
      "sid": 38,
      "location": 2,
      "content": "不过这是另外一个话题了",
      "music": 0.0
    },
    {
      "from": 58.1,
      "to": 60.42,
      "sid": 39,
      "location": 2,
      "content": "总之就是我觉得在我们退休之前",
      "music": 0.0
    },
    {
      "from": 60.42,
      "to": 62.34,
      "sid": 40,
      "location": 2,
      "content": "我需要不断的去找新的业务",
      "music": 0.0
    },
    {
      "from": 62.34,
      "to": 64.42,
      "sid": 41,
      "location": 2,
      "content": "不断的寻求我的业务的升级和转型",
      "music": 0.0
    },
    {
      "from": 64.42,
      "to": 66.48,
      "sid": 42,
      "location": 2,
      "content": "就这个事情是永远都不能停下来的",
      "music": 0.0
    },
    {
      "from": 66.48,
      "to": 68.08,
      "sid": 43,
      "location": 2,
      "content": "于是这就引出了第二个观点",
      "music": 0.0
    },
    {
      "from": 68.08,
      "to": 68.76,
      "sid": 44,
      "location": 2,
      "content": "很反常识啊",
      "music": 0.0
    },
    {
      "from": 68.76,
      "to": 70.7,
      "sid": 45,
      "location": 2,
      "content": "就是我认为赚钱是在当我赚钱",
      "music": 0.0
    },
    {
      "from": 70.7,
      "to": 73.36,
      "sid": 46,
      "location": 2,
      "content": "因为既然我要不断的去寻找结构性更好",
      "music": 0.0
    },
    {
      "from": 73.36,
      "to": 74.96,
      "sid": 47,
      "location": 2,
      "content": "势能更强更好更高的业务",
      "music": 0.0
    },
    {
      "from": 74.96,
      "to": 77.64,
      "sid": 48,
      "location": 2,
      "content": "就要给这件事情留出足够的时间和精力对吧",
      "music": 0.0
    },
    {
      "from": 77.64,
      "to": 78.8,
      "sid": 49,
      "location": 2,
      "content": "我要积累信息",
      "music": 0.0
    },
    {
      "from": 78.8,
      "to": 79.78,
      "sid": 50,
      "location": 2,
      "content": "我要积累认知",
      "music": 0.0
    },
    {
      "from": 79.78,
      "to": 82.12,
      "sid": 51,
      "location": 2,
      "content": "让我能更好的去探索新的业务形态",
      "music": 0.0
    },
    {
      "from": 82.12,
      "to": 83.76,
      "sid": 52,
      "location": 2,
      "content": "我已经很长时间没有上过班了",
      "music": 0.0
    },
    {
      "from": 83.76,
      "to": 84.92,
      "sid": 53,
      "location": 2,
      "content": "在我的业务里面",
      "music": 0.0
    },
    {
      "from": 84.92,
      "to": 86.04,
      "sid": 54,
      "location": 2,
      "content": "我并不是很简单",
      "music": 0.0
    },
    {
      "from": 86.04,
      "to": 87.56,
      "sid": 55,
      "location": 2,
      "content": "很疲惫的去拿时间换钱",
      "music": 0.0
    },
    {
      "from": 87.56,
      "to": 88.6,
      "sid": 56,
      "location": 2,
      "content": "但即便如此",
      "music": 0.0
    },
    {
      "from": 88.6,
      "to": 90.66,
      "sid": 57,
      "location": 2,
      "content": "我一天24小时时间是有限的",
      "music": 0.0
    },
    {
      "from": 90.66,
      "to": 93.62,
      "sid": 58,
      "location": 2,
      "content": "我多花一个小时去用我现有的业务去赚钱",
      "music": 0.0
    },
    {
      "from": 93.62,
      "to": 95.22,
      "sid": 59,
      "location": 2,
      "content": "我就少了一个小时去研究",
      "music": 0.0
    },
    {
      "from": 95.22,
      "to": 96.62,
      "sid": 60,
      "location": 2,
      "content": "我的业务转型和业务升级",
      "music": 0.0
    },
    {
      "from": 96.62,
      "to": 97.98,
      "sid": 61,
      "location": 2,
      "content": "所以这么多年磨合下来",
      "music": 0.0
    },
    {
      "from": 97.98,
      "to": 100.42,
      "sid": 62,
      "location": 2,
      "content": "就是如果有一个项目我不是很清楚",
      "music": 0.0
    },
    {
      "from": 100.42,
      "to": 101.1,
      "sid": 63,
      "location": 2,
      "content": "我不是很了解",
      "music": 0.0
    },
    {
      "from": 101.1,
      "to": 102.42,
      "sid": 64,
      "location": 2,
      "content": "对我来说是陌生的领域",
      "music": 0.0
    },
    {
      "from": 102.42,
      "to": 103.62,
      "sid": 65,
      "location": 2,
      "content": "我在做它的过程当中",
      "music": 0.0
    },
    {
      "from": 103.62,
      "to": 104.58,
      "sid": 66,
      "location": 2,
      "content": "就算但我不赚钱",
      "music": 0.0
    },
    {
      "from": 104.58,
      "to": 106.26,
      "sid": 67,
      "location": 2,
      "content": "我也可以收获到很多行业认知",
      "music": 0.0
    },
    {
      "from": 106.26,
      "to": 107.66,
      "sid": 68,
      "location": 2,
      "content": "我就特别愿意去做这个事情",
      "music": 0.0
    },
    {
      "from": 107.66,
      "to": 110.4,
      "sid": 69,
      "location": 2,
      "content": "我的整个人的状态是很积极很饱满的",
      "music": 0.0
    },
    {
      "from": 110.4,
      "to": 111.68,
      "sid": 70,
      "location": 2,
      "content": "但是如果有一个项目",
      "music": 0.0
    },
    {
      "from": 111.68,
      "to": 112.84,
      "sid": 71,
      "location": 2,
      "content": "我认为它已经定型了",
      "music": 0.0
    },
    {
      "from": 112.84,
      "to": 115.12,
      "sid": 72,
      "location": 2,
      "content": "就这么多年我都没有办法去改造它",
      "music": 0.0
    },
    {
      "from": 115.12,
      "to": 116.12,
      "sid": 73,
      "location": 2,
      "content": "虽然它很赚钱",
      "music": 0.0
    },
    {
      "from": 116.12,
      "to": 117.58,
      "sid": 74,
      "location": 2,
      "content": "但是我每次去做它",
      "music": 0.0
    },
    {
      "from": 117.58,
      "to": 119.5,
      "sid": 75,
      "location": 2,
      "content": "我就是机械地把我的时间换成钱",
      "music": 0.0
    },
    {
      "from": 119.5,
      "to": 120.18,
      "sid": 76,
      "location": 2,
      "content": "包的时间换成钱",
      "music": 0.0
    },
    {
      "from": 120.18,
      "to": 121.18,
      "sid": 77,
      "location": 2,
      "content": "不断重复这个过程",
      "music": 0.0
    },
    {
      "from": 121.18,
      "to": 123.76,
      "sid": 78,
      "location": 2,
      "content": "那我我的这个积极性就会被打击的很严重",
      "music": 0.0
    },
    {
      "from": 123.76,
      "to": 124.78,
      "sid": 79,
      "location": 2,
      "content": "然后最终复盘的时候",
      "music": 0.0
    },
    {
      "from": 124.78,
      "to": 127.22,
      "sid": 80,
      "location": 2,
      "content": "我发现我的这种性格特质或者是业务偏好",
      "music": 0.0
    },
    {
      "from": 127.22,
      "to": 128.34,
      "sid": 81,
      "location": 2,
      "content": "对我来说帮助很大",
      "music": 0.0
    },
    {
      "from": 128.34,
      "to": 130.22,
      "sid": 82,
      "location": 2,
      "content": "可以让我长久的把业务做下去",
      "music": 0.0
    },
    {
      "from": 130.22,
      "to": 131.74,
      "sid": 83,
      "location": 2,
      "content": "因为互联网没有长久的利润嘛",
      "music": 0.0
    },
    {
      "from": 131.74,
      "to": 133.44,
      "sid": 84,
      "location": 2,
      "content": "所以我做生意我就是逆水行舟",
      "music": 0.0
    },
    {
      "from": 133.44,
      "to": 134.9,
      "sid": 85,
      "location": 2,
      "content": "如果我的业务不转型",
      "music": 0.0
    },
    {
      "from": 134.9,
      "to": 135.94,
      "sid": 86,
      "location": 2,
      "content": "迟早有一天他就死掉",
      "music": 0.0
    },
    {
      "from": 135.94,
      "to": 139.16,
      "sid": 87,
      "location": 2,
      "content": "那么我的日常工作里面至少要有30%",
      "music": 0.0
    },
    {
      "from": 139.16,
      "to": 141.4,
      "sid": 88,
      "location": 2,
      "content": "甚至50%不断的去研究业务转型",
      "music": 0.0
    },
    {
      "from": 141.4,
      "to": 143.58,
      "sid": 89,
      "location": 2,
      "content": "我才还能让我的这个收入不断",
      "music": 0.0
    },
    {
      "from": 143.58,
      "to": 144.96,
      "sid": 90,
      "location": 2,
      "content": "所以之前大概在我",
      "music": 0.0
    },
    {
      "from": 144.96,
      "to": 146.56,
      "sid": 91,
      "location": 2,
      "content": "我一个小时能赚500块的时候",
      "music": 0.0
    },
    {
      "from": 146.56,
      "to": 148.28,
      "sid": 92,
      "location": 2,
      "content": "我就把我的一小时一对一",
      "music": 0.0
    },
    {
      "from": 148.28,
      "to": 149.86,
      "sid": 93,
      "location": 2,
      "content": "咨询的价格变成了3000",
      "music": 0.0
    },
    {
      "from": 149.86,
      "to": 153.04,
      "sid": 94,
      "location": 2,
      "content": "因为这件事情它本身没有业务转型升级",
      "music": 0.0
    },
    {
      "from": 153.04,
      "to": 155.16,
      "sid": 95,
      "location": 2,
      "content": "或者让你给你带来什么其他东西的机会",
      "music": 0.0
    },
    {
      "from": 155.16,
      "to": 157.12,
      "sid": 96,
      "location": 2,
      "content": "它就仅仅是在这个特殊的领域里",
      "music": 0.0
    },
    {
      "from": 157.12,
      "to": 157.76,
      "sid": 97,
      "location": 2,
      "content": "我懂你不懂",
      "music": 0.0
    },
    {
      "from": 157.76,
      "to": 158.94,
      "sid": 98,
      "location": 2,
      "content": "然后再来打一个小时电话",
      "music": 0.0
    },
    {
      "from": 158.94,
      "to": 159.82,
      "sid": 99,
      "location": 2,
      "content": "把这个事情讲明白",
      "music": 0.0
    },
    {
      "from": 159.82,
      "to": 160.62,
      "sid": 100,
      "location": 2,
      "content": "就仅此而已",
      "music": 0.0
    },
    {
      "from": 160.62,
      "to": 161.38,
      "sid": 101,
      "location": 2,
      "content": "但即便如此",
      "music": 0.0
    },
    {
      "from": 161.38,
      "to": 163.62,
      "sid": 102,
      "location": 2,
      "content": "我也只是赚钱比之前快了一点而已对吧",
      "music": 0.0
    },
    {
      "from": 163.62,
      "to": 166.92,
      "sid": 103,
      "location": 2,
      "content": "这件事情并没有给我的业务带来结构上的好处",
      "music": 0.0
    },
    {
      "from": 166.92,
      "to": 168.96,
      "sid": 104,
      "location": 2,
      "content": "所以我就不断的给这个一对一咨询涨价",
      "music": 0.0
    },
    {
      "from": 168.96,
      "to": 170.24,
      "sid": 105,
      "location": 2,
      "content": "我也不靠这个赚钱吧",
      "music": 0.0
    },
    {
      "from": 170.24,
      "to": 171.98,
      "sid": 106,
      "location": 2,
      "content": "涨到了一定的程度之后",
      "music": 0.0
    },
    {
      "from": 171.98,
      "to": 174.92,
      "sid": 107,
      "location": 2,
      "content": "我发现他筛选过来的人的质量非常高",
      "music": 0.0
    },
    {
      "from": 174.92,
      "to": 176.6,
      "sid": 108,
      "location": 2,
      "content": "都是一些在自己的领域里面",
      "music": 0.0
    },
    {
      "from": 176.6,
      "to": 178.38,
      "sid": 109,
      "location": 2,
      "content": "取得过非常好的成就的人",
      "music": 0.0
    },
    {
      "from": 178.38,
      "to": 180.58,
      "sid": 110,
      "location": 2,
      "content": "然后我就发现我跟他们沟通",
