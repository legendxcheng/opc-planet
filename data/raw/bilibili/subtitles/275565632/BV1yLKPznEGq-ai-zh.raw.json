    },
    {
      "from": 206.22,
      "to": 208.58,
      "sid": 127,
      "location": 2,
      "content": "但是未来九天我都可以留给自己",
      "music": 0.0
    },
    {
      "from": 208.58,
      "to": 210.4,
      "sid": 128,
      "location": 2,
      "content": "去探索我的新的业务形态",
      "music": 0.0
    },
    {
      "from": 210.4,
      "to": 212.3,
      "sid": 129,
      "location": 2,
      "content": "我的业务怎么转型升级之类的事情",
      "music": 0.0
    },
    {
      "from": 212.3,
      "to": 214.94,
      "sid": 130,
      "location": 2,
      "content": "所以按照最开始的那个后台兄弟给我提问",
