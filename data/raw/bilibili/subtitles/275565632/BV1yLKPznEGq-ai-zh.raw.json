    },
    {
      "from": 180.58,
      "to": 181.86,
      "sid": 111,
      "location": 2,
      "content": "就算我不收钱",
      "music": 0.0
    },
    {
      "from": 181.86,
      "to": 183.02,
      "sid": 112,
      "location": 2,
      "content": "我们免费打一个小时电话",
      "music": 0.0
    },
    {
      "from": 183.02,
      "to": 183.98,
      "sid": 113,
      "location": 2,
      "content": "对我的帮助也很大",
      "music": 0.0
    },
    {
      "from": 183.98,
      "to": 186.78,
      "sid": 114,
      "location": 2,
      "content": "这个时候我才觉得这个业务给我带来的投入",
      "music": 0.0
    },
    {
      "from": 186.78,
      "to": 187.72,
      "sid": 115,
      "location": 2,
      "content": "产出比是非常高",
      "music": 0.0
    },
    {
      "from": 187.72,
      "to": 189.32,
      "sid": 116,
      "location": 2,
      "content": "所以最后我就给自己定了个规矩",
      "music": 0.0
    },
    {
      "from": 189.32,
      "to": 191.02,
      "sid": 117,
      "location": 2,
      "content": "就是说如果有一个业务",
      "music": 0.0
    },
    {
      "from": 191.02,
      "to": 191.88,
      "sid": 118,
      "location": 2,
      "content": "他除了钱以外",
      "music": 0.0
    },
    {
      "from": 191.88,
      "to": 194.22,
      "sid": 119,
      "location": 2,
      "content": "不能给我带来其他任何形式的回报了",
      "music": 0.0
    },
    {
      "from": 194.22,
      "to": 196.34,
      "sid": 120,
      "location": 2,
      "content": "我就必须让他的产出的时薪",
      "music": 0.0
    },
    {
      "from": 196.34,
      "to": 198.22,
      "sid": 121,
      "location": 2,
      "content": "是我现在时薪的十倍以上",
      "music": 0.0
    },
    {
      "from": 198.22,
      "to": 198.94,
      "sid": 122,
      "location": 2,
      "content": "他的逻辑是",
      "music": 0.0
    },
    {
      "from": 198.94,
      "to": 200.54,
      "sid": 123,
      "location": 2,
      "content": "我现在虽然是在拿时间换钱",
      "music": 0.0
    },
    {
      "from": 200.54,
      "to": 202.46,
      "sid": 124,
      "location": 2,
      "content": "但是这笔钱可以给我换来更多的时间",
      "music": 0.0
    },
    {
      "from": 202.46,
      "to": 204.98,
      "sid": 125,
      "location": 2,
      "content": "比如说我花一天的时间赚到了十天的钱对吧",
      "music": 0.0
    },
    {
      "from": 204.98,
      "to": 206.22,
      "sid": 126,
      "location": 2,
      "content": "那么虽然这一天我浪费了",
