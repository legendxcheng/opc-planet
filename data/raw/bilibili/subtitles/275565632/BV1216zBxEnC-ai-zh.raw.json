{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 1.76,
      "sid": 1,
      "location": 2,
      "content": "今年是我不上班的第7年",
      "music": 0.0
    },
    {
      "from": 1.76,
      "to": 3.24,
      "sid": 2,
      "location": 2,
      "content": "我用去年一年的时间做起来了",
      "music": 0.0
    },
    {
      "from": 3.24,
      "to": 4.12,
      "sid": 3,
      "location": 2,
      "content": "这个自媒体的业务",
      "music": 0.0
    },
    {
      "from": 4.12,
      "to": 5.68,
      "sid": 4,
      "location": 2,
      "content": "那基本上就是我一个人在管理",
      "music": 0.0
    },
    {
      "from": 5.68,
      "to": 6.86,
      "sid": 5,
      "location": 2,
      "content": "七八个平台的账号",
      "music": 0.0
    },
    {
      "from": 6.86,
      "to": 7.7,
      "sid": 6,
      "location": 2,
      "content": "那变现方面呢",
      "music": 0.0
    },
    {
      "from": 7.7,
      "to": 9.66,
      "sid": 7,
      "location": 2,
      "content": "其实线上线下大家也大概预估的出来",
      "music": 0.0
    },
    {
      "from": 9.66,
      "to": 10.46,
      "sid": 8,
      "location": 2,
      "content": "这个收入量级",
      "music": 0.0
    },
    {
      "from": 10.46,
      "to": 11.74,
      "sid": 9,
      "location": 2,
      "content": "虽然到现在流行的说",
      "music": 0.0
    },
    {
      "from": 11.74,
      "to": 14.5,
      "sid": 10,
      "location": 2,
      "content": "那我就真的是那个字面意义上的艺人公司了",
      "music": 0.0
    },
    {
      "from": 14.5,
      "to": 15.9,
      "sid": 11,
      "location": 2,
      "content": "我知道这个也是大家想听的",
      "music": 0.0
    },
    {
      "from": 15.9,
      "to": 17.5,
      "sid": 12,
      "location": 2,
      "content": "就怎么能快速做一家艺人公司",
      "music": 0.0
    },
    {
      "from": 17.5,
      "to": 18.58,
      "sid": 13,
      "location": 2,
      "content": "我就不用上班了对吧",
      "music": 0.0
    },
    {
      "from": 18.58,
      "to": 19.62,
      "sid": 14,
      "location": 2,
      "content": "但实际情况呢",
      "music": 0.0
    },
    {
      "from": 19.62,
      "to": 21.42,
      "sid": 15,
      "location": 2,
      "content": "可能真的不是大家想象的那个样子",
      "music": 0.0
    },
    {
      "from": 21.42,
      "to": 23.14,
      "sid": 16,
      "location": 2,
      "content": "大家所以为的艺人公司是什么样子",
      "music": 0.0
    },
    {
      "from": 23.14,
      "to": 24.1,
      "sid": 17,
      "location": 2,
      "content": "就是我不用早起",
      "music": 0.0
    },
    {
      "from": 24.1,
      "to": 24.62,
      "sid": 18,
      "location": 2,
      "content": "没有老板",
      "music": 0.0
    },
    {
      "from": 24.62,
      "to": 25.56,
      "sid": 19,
      "location": 2,
      "content": "不用跟人打交道",
      "music": 0.0
    },
    {
      "from": 25.56,
      "to": 26.52,
      "sid": 20,
      "location": 2,
      "content": "完全自由可控",
      "music": 0.0
    },
    {
      "from": 26.52,
      "to": 27.6,
      "sid": 21,
      "location": 2,
      "content": "给我搞一些AI员工",
      "music": 0.0
    },
    {
      "from": 27.6,
      "to": 28.68,
      "sid": 22,
      "location": 2,
      "content": "我就直接原地起飞",
      "music": 0.0
    },
    {
      "from": 28.68,
      "to": 29.4,
      "sid": 23,
      "location": 2,
      "content": "年入百万了",
      "music": 0.0
    },
    {
      "from": 29.4,
      "to": 31.48,
      "sid": 24,
      "location": 2,
      "content": "这就是为什么我平时非常不喜欢用这个词",
      "music": 0.0
    },
    {
      "from": 31.48,
      "to": 32.56,
      "sid": 25,
      "location": 2,
      "content": "就是你只说好处",
      "music": 0.0
    },
    {
      "from": 32.56,
      "to": 33.32,
      "sid": 26,
      "location": 2,
      "content": "不说坏处",
      "music": 0.0
    },
    {
      "from": 33.32,
      "to": 35.88,
      "sid": 27,
      "location": 2,
      "content": "对于这种特定的形态所要面临的市场风险",
      "music": 0.0
    },
    {
      "from": 35.88,
      "to": 36.92,
      "sid": 28,
      "location": 2,
      "content": "完全避而不谈",
      "music": 0.0
    },
    {
      "from": 36.92,
      "to": 39.48,
      "sid": 29,
      "location": 2,
      "content": "不会真的有人以为说我搞一些扣子工作流",
      "music": 0.0
    },
    {
      "from": 39.48,
      "to": 41.0,
      "sid": 30,
      "location": 2,
      "content": "然后搞一个什么cloud code agent",
      "music": 0.0
    },
    {
      "from": 41.0,
      "to": 42.16,
      "sid": 31,
      "location": 2,
      "content": "我就完全万事大吉了",
      "music": 0.0
    },
    {
      "from": 42.16,
      "to": 43.16,
      "sid": 32,
      "location": 2,
      "content": "就一人公司了对吧",
      "music": 0.0
    },
    {
      "from": 43.16,
      "to": 43.88,
      "sid": 33,
      "location": 2,
      "content": "在过去的一年里",
      "music": 0.0
    },
    {
      "from": 43.88,
      "to": 46.12,
      "sid": 34,
      "location": 2,
      "content": "我接触了太多人是兴致冲冲的辞了职",
      "music": 0.0
    },
    {
      "from": 46.12,
      "to": 48.76,
      "sid": 35,
      "location": 2,
      "content": "然后狂干两个月就又一头雾水的就回去上班了",
      "music": 0.0
    },
    {
      "from": 48.76,
      "to": 50.26,
      "sid": 36,
      "location": 2,
      "content": "所以今天这我想来讲一下",
      "music": 0.0
    },
    {
      "from": 50.26,
      "to": 52.26,
      "sid": 37,
      "location": 2,
      "content": "如果你决定要用这种方式去解决",
      "music": 0.0
    },
    {
      "from": 52.26,
      "to": 52.9,
      "sid": 38,
      "location": 2,
      "content": "你想要辞职",
      "music": 0.0
    },
    {
      "from": 52.9,
      "to": 53.98,
      "sid": 39,
      "location": 2,
      "content": "不想上班的问题",
      "music": 0.0
    },
    {
      "from": 53.98,
      "to": 54.78,
      "sid": 40,
      "location": 2,
      "content": "在此之后",
      "music": 0.0
    },
    {
      "from": 54.78,
      "to": 56.86,
      "sid": 41,
      "location": 2,
      "content": "你所面临的真实的情况是什么",
      "music": 0.0
    },
    {
      "from": 56.86,
      "to": 57.86,
      "sid": 42,
      "location": 2,
      "content": "那么首先第一个问题",
      "music": 0.0
    },
    {
      "from": 57.86,
      "to": 59.74,
      "sid": 43,
      "location": 2,
      "content": "我认为所谓的艺人公司其实分为两种",
      "music": 0.0
    },
    {
      "from": 59.74,
      "to": 60.54,
      "sid": 44,
      "location": 2,
      "content": "一种叫效率型",
      "music": 0.0
    },
    {
      "from": 60.54,
      "to": 61.42,
      "sid": 45,
      "location": 2,
      "content": "一种叫逃避型",
      "music": 0.0
    },
    {
      "from": 61.42,
      "to": 63.54,
      "sid": 46,
      "location": 2,
      "content": "可惜大多数人都做成了逃避型",
      "music": 0.0
    },
    {
      "from": 63.54,
      "to": 66.86,
      "sid": 47,
      "location": 2,
      "content": "这也是为什么你其实很难在身边看到",
      "music": 0.0
    },
    {
      "from": 66.86,
      "to": 68.82,
      "sid": 48,
      "location": 2,
      "content": "真真正的所谓的艺人公司的成功案例",
      "music": 0.0
    },
    {
      "from": 68.82,
      "to": 71.34,
      "sid": 49,
      "location": 2,
      "content": "更多是在互联网上以故事的形式去传播而已",
      "music": 0.0
    },
    {
      "from": 71.34,
      "to": 73.06,
      "sid": 50,
      "location": 2,
      "content": "那么首先我认为有一个大的前提",
      "music": 0.0
    },
    {
      "from": 73.06,
      "to": 74.5,
      "sid": 51,
      "location": 2,
      "content": "这个前提还不是业务层面的",
      "music": 0.0
    },
    {
      "from": 74.5,
      "to": 75.4,
      "sid": 52,
      "location": 2,
      "content": "它是心理层面的",
      "music": 0.0
    },
    {
      "from": 75.4,
      "to": 77.04,
      "sid": 53,
      "location": 2,
      "content": "就是很多人之所以特别喜欢",
      "music": 0.0
    },
    {
      "from": 77.04,
      "to": 78.12,
      "sid": 54,
      "location": 2,
      "content": "一人制公司这个概念",
      "music": 0.0
    },
    {
      "from": 78.12,
      "to": 80.56,
      "sid": 55,
      "location": 2,
      "content": "是因为他的公司里面受到了不好的对待",
      "music": 0.0
    },
    {
      "from": 80.56,
      "to": 81.76,
      "sid": 56,
      "location": 2,
      "content": "他和同事的关系也不好",
      "music": 0.0
    },
    {
      "from": 81.76,
      "to": 83.08,
      "sid": 57,
      "location": 2,
      "content": "天天被老板PUA加班",
      "music": 0.0
    },
    {
      "from": 83.08,
      "to": 83.78,
      "sid": 58,
      "location": 2,
      "content": "也没有工资",
      "music": 0.0
    },
    {
      "from": 83.78,
      "to": 85.6,
      "sid": 59,
      "location": 2,
      "content": "所以我想要搞一个艺人公司",
      "music": 0.0
    },
    {
      "from": 85.6,
      "to": 87.28,
      "sid": 60,
      "location": 2,
      "content": "来解放我现在的这种痛苦",
      "music": 0.0
    },
    {
      "from": 87.28,
      "to": 88.4,
      "sid": 61,
      "location": 2,
      "content": "但是矛盾的一点在于",
      "music": 0.0
    },
    {
      "from": 88.4,
      "to": 89.72,
      "sid": 62,
      "location": 2,
      "content": "从你辞职的那一刻开始",
      "music": 0.0
    },
    {
      "from": 89.72,
      "to": 91.24,
      "sid": 63,
      "location": 2,
      "content": "你就要真正对自己的生活",
      "music": 0.0
    },
    {
      "from": 91.24,
      "to": 92.8,
      "sid": 64,
      "location": 2,
      "content": "对自己的收入开始负责了",
      "music": 0.0
    },
    {
      "from": 92.8,
      "to": 94.4,
      "sid": 65,
      "location": 2,
      "content": "哪怕那你手头有很多积蓄",
      "music": 0.0
    },
    {
      "from": 94.4,
      "to": 95.54,
      "sid": 66,
      "location": 2,
      "content": "或者你的家境很好",
      "music": 0.0
    },
    {
      "from": 95.54,
      "to": 98.12,
      "sid": 67,
      "location": 2,
      "content": "你依然会因为你的业务长期没有收入",
      "music": 0.0
    },
    {
      "from": 98.12,
      "to": 99.56,
      "sid": 68,
      "location": 2,
      "content": "长期没有正反馈而感到焦虑",
      "music": 0.0
    },
    {
      "from": 99.56,
      "to": 102.3,
      "sid": 69,
      "location": 2,
      "content": "那么当我一开始的做艺人公司的这个出发点",
      "music": 0.0
    },
    {
      "from": 102.3,
      "to": 103.98,
      "sid": 70,
      "location": 2,
      "content": "就是为了满足我自己的诉求",
      "music": 0.0
    },
    {
      "from": 103.98,
      "to": 105.66,
      "sid": 71,
      "location": 2,
      "content": "解决我自己想要不上班的问题",
      "music": 0.0
    },
    {
      "from": 105.66,
      "to": 107.74,
      "sid": 72,
      "location": 2,
      "content": "那凭什么确保这个东西可以赚到钱呢",
      "music": 0.0
    },
    {
      "from": 107.74,
      "to": 109.38,
      "sid": 73,
      "location": 2,
      "content": "这件事情德鲁克早就给过答案",
      "music": 0.0
    },
    {
      "from": 109.38,
      "to": 110.44,
      "sid": 74,
      "location": 2,
      "content": "叫做组组织规模",
      "music": 0.0
    },
    {
      "from": 110.44,
      "to": 111.74,
      "sid": 75,
      "location": 2,
      "content": "服务于客户价值创造",
      "music": 0.0
    },
    {
      "from": 111.74,
      "to": 114.14,
      "sid": 76,
      "location": 2,
      "content": "说白了就是你的业务需要几个人完成",
      "music": 0.0
    },
    {
      "from": 114.14,
      "to": 115.26,
      "sid": 77,
      "location": 2,
      "content": "你就用几个人去完成",
      "music": 0.0
    },
    {
      "from": 115.26,
      "to": 117.74,
      "sid": 78,
      "location": 2,
      "content": "而不是在我的客户在哪都不知道的情况下",
      "music": 0.0
    },
    {
      "from": 117.74,
      "to": 119.74,
      "sid": 79,
      "location": 2,
      "content": "我先定了我的公司就只有一个人",
      "music": 0.0
    },
    {
      "from": 119.74,
      "to": 120.7,
      "sid": 80,
      "location": 2,
      "content": "这是本末倒置",
      "music": 0.0
    },
    {
      "from": 120.7,
      "to": 122.22,
      "sid": 81,
      "location": 2,
      "content": "所以同样是所谓的艺人公司",
      "music": 0.0
    },
    {
      "from": 122.22,
      "to": 123.74,
      "sid": 82,
      "location": 2,
      "content": "我认为是存在两这种做法的",
      "music": 0.0
    },
    {
      "from": 123.74,
      "to": 125.02,
      "sid": 83,
      "location": 2,
      "content": "第一种做法就是我们刚刚说的",
      "music": 0.0
    },
    {
      "from": 125.02,
      "to": 125.98,
      "sid": 84,
      "location": 2,
      "content": "就我什么都不知道呢",
      "music": 0.0
    },
    {
      "from": 125.98,
      "to": 127.66,
      "sid": 85,
      "location": 2,
      "content": "我就先把公司的人数给定死了",
      "music": 0.0
    },
    {
      "from": 127.66,
      "to": 129.94,
      "sid": 86,
      "location": 2,
      "content": "这会给人造成非常大的思维局限",
      "music": 0.0
    },
    {
      "from": 129.94,
      "to": 132.3,
      "sid": 87,
      "location": 2,
      "content": "在你从0~1积累第一桶金的这个过程当中",
      "music": 0.0
    },
    {
      "from": 132.3,
      "to": 134.06,
      "sid": 88,
      "location": 2,
      "content": "你所能看到的更多的业务",
      "music": 0.0
    },
    {
      "from": 134.06,
      "to": 136.02,
      "sid": 89,
      "location": 2,
      "content": "其实都是需要你去和别人产生合作的",
      "music": 0.0
    },
    {
      "from": 136.02,
      "to": 138.52,
      "sid": 90,
      "location": 2,
      "content": "如果一开始你就把这些东西全部都干掉了",
      "music": 0.0
    },
    {
      "from": 138.52,
      "to": 140.76,
      "sid": 91,
      "location": 2,
      "content": "会让你的业务选择变得非常的困难",
      "music": 0.0
    },
    {
      "from": 140.76,
      "to": 143.12,
      "sid": 92,
      "location": 2,
      "content": "所以通常你会看到荣誉成功的是另外一种形态",
      "music": 0.0
    },
    {
      "from": 143.12,
      "to": 144.12,
      "sid": 93,
      "location": 2,
      "content": "我管这个叫效率型",
      "music": 0.0
    },
    {
      "from": 144.12,
      "to": 145.26,
      "sid": 94,
      "location": 2,
      "content": "就是有一些小老板",
      "music": 0.0
    },
    {
      "from": 145.26,
      "to": 147.1,
      "sid": 95,
      "location": 2,
      "content": "他吃过盲目扩张的苦头",
      "music": 0.0
    },
    {
      "from": 147.1,
      "to": 150.3,
      "sid": 96,
      "location": 2,
      "content": "他在搞清楚了一个小的团队如何能高效沟通",
      "music": 0.0
    },
    {
      "from": 150.3,
      "to": 151.38,
      "sid": 97,
      "location": 2,
      "content": "快速决策之后",
      "music": 0.0
    },
    {
      "from": 151.38,
      "to": 152.78,
      "sid": 98,
      "location": 2,
      "content": "把大多数的人都砍了",
      "music": 0.0
    },
    {
      "from": 152.78,
      "to": 154.78,
      "sid": 99,
      "location": 2,
      "content": "从而收缩到了一个小团队的一个形态",
      "music": 0.0
    },
    {
      "from": 154.78,
      "to": 156.14,
      "sid": 100,
      "location": 2,
      "content": "可能只有他和他的一个助理",
      "music": 0.0
    },
    {
      "from": 156.14,
      "to": 157.46,
      "sid": 101,
      "location": 2,
      "content": "只不过一般这样的人",
      "music": 0.0
    },
    {
      "from": 157.46,
      "to": 159.8,
      "sid": 102,
      "location": 2,
      "content": "不愿意给自己扣一顶叫艺人公司的帽子",
      "music": 0.0
    },
    {
      "from": 159.8,
      "to": 161.36,
      "sid": 103,
      "location": 2,
      "content": "包括我现在的业务也一样",
      "music": 0.0
    },
    {
      "from": 161.36,
      "to": 162.56,
      "sid": 104,
      "location": 2,
      "content": "核心人员包括我在内",
      "music": 0.0
    },
    {
      "from": 162.56,
      "to": 163.56,
      "sid": 105,
      "location": 2,
      "content": "总共就只有两个人",
      "music": 0.0
    },
    {
      "from": 163.56,
      "to": 165.24,
      "sid": 106,
      "location": 2,
      "content": "但是还有其他的大量的人",
      "music": 0.0
    },
    {
      "from": 165.24,
      "to": 166.64,
      "sid": 107,
      "location": 2,
      "content": "可能以外包签合同",
      "music": 0.0
    },
    {
      "from": 166.64,
      "to": 167.28,
