{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 2.8,
      "sid": 1,
      "location": 2,
      "content": "赚钱最大的弯路就想找一个自己擅长的事情啊",
      "music": 0.0
    },
    {
      "from": 2.8,
      "to": 4.0,
      "sid": 2,
      "location": 2,
      "content": "所谓的叫挖掘天赋",
      "music": 0.0
    },
    {
      "from": 4.0,
      "to": 5.76,
      "sid": 3,
      "location": 2,
      "content": "但如果你稍微仔细回忆一下",
      "music": 0.0
    },
    {
      "from": 5.76,
      "to": 8.56,
      "sid": 4,
      "location": 2,
      "content": "你会发现我们日常评价说谁谁谁有天赋的时候",
      "music": 0.0
    },
    {
      "from": 8.56,
      "to": 9.84,
      "sid": 5,
      "location": 2,
      "content": "全部都是事后评价",
      "music": 0.0
    },
    {
      "from": 9.84,
      "to": 10.86,
      "sid": 6,
      "location": 2,
      "content": "就除了算命的以外",
      "music": 0.0
    },
    {
      "from": 10.86,
      "to": 12.64,
      "sid": 7,
      "location": 2,
      "content": "没有谁是在事前去预判",
      "music": 0.0
    },
    {
      "from": 12.64,
      "to": 13.44,
      "sid": 8,
      "location": 2,
      "content": "说一个人有天赋的",
      "music": 0.0
    },
    {
      "from": 13.44,
      "to": 14.56,
      "sid": 9,
      "location": 2,
      "content": "你可以尝试去观察一下",
      "music": 0.0
    },
    {
      "from": 14.56,
      "to": 16.96,
      "sid": 10,
      "location": 2,
      "content": "我们日常生活对天赋这个词的用法",
      "music": 0.0
    },
    {
      "from": 16.96,
      "to": 20.22,
      "sid": 11,
      "location": 2,
      "content": "你会发现它本来就是对一已经拿到结果的人",
      "music": 0.0
    },
    {
      "from": 20.22,
      "to": 21.28,
      "sid": 12,
      "location": 2,
      "content": "的一种概括总结",
      "music": 0.0
    },
    {
      "from": 21.28,
      "to": 22.74,
      "sid": 13,
      "location": 2,
      "content": "比如说两个孩子一起学钢琴",
      "music": 0.0
    },
    {
      "from": 22.74,
      "to": 24.18,
      "sid": 14,
      "location": 2,
      "content": "一个三个月了就很熟练了",
      "music": 0.0
    },
    {
      "from": 24.18,
      "to": 25.38,
      "sid": 15,
      "location": 2,
      "content": "一个学了一年磕磕绊绊",
      "music": 0.0
    },
    {
      "from": 25.38,
      "to": 27.08,
      "sid": 16,
      "location": 2,
      "content": "那对于这个比优秀的这个孩子来说",
      "music": 0.0
    },
    {
      "from": 27.08,
      "to": 28.58,
      "sid": 17,
      "location": 2,
      "content": "你就说他学的快就可以了嘛",
      "music": 0.0
    },
    {
      "from": 28.58,
      "to": 29.52,
      "sid": 18,
      "location": 2,
      "content": "在这种场景下",
      "music": 0.0
    },
    {
      "from": 29.52,
      "to": 32.12,
      "sid": 19,
      "location": 2,
      "content": "学得快的三个字作为一种描述完全够用了",
      "music": 0.0
    },
    {
      "from": 32.12,
      "to": 34.2,
      "sid": 20,
      "location": 2,
      "content": "那你看为什么我们日常还非要添油加醋",
      "music": 0.0
    },
    {
      "from": 34.2,
      "to": 35.0,
      "sid": 21,
      "location": 2,
      "content": "说这个孩子有天赋",
      "music": 0.0
    },
    {
      "from": 35.0,
      "to": 35.94,
      "sid": 22,
      "location": 2,
      "content": "因为学得快",
      "music": 0.0
    },
    {
      "from": 35.94,
      "to": 38.16,
      "sid": 23,
      "location": 2,
      "content": "它只是表面的现象的描述",
      "music": 0.0
    },
    {
      "from": 38.16,
      "to": 40.68,
      "sid": 24,
      "location": 2,
      "content": "这个有天赋看起来才像是背后的原因",
      "music": 0.0
    },
    {
      "from": 40.68,
      "to": 41.72,
      "sid": 25,
      "location": 2,
      "content": "可是它真的是原因吗",
      "music": 0.0
    },
    {
      "from": 41.72,
      "to": 42.84,
      "sid": 26,
      "location": 2,
      "content": "我问你为啥这孩子学得快",
      "music": 0.0
    },
    {
      "from": 42.84,
      "to": 43.6,
      "sid": 27,
      "location": 2,
      "content": "你说他有天赋",
      "music": 0.0
    },
    {
      "from": 43.6,
      "to": 44.96,
      "sid": 28,
      "location": 2,
      "content": "那你咋知道他有天赋的啊",
      "music": 0.0
    },
    {
      "from": 44.96,
      "to": 45.64,
      "sid": 29,
      "location": 2,
      "content": "因为他学的快",
      "music": 0.0
    },
    {
      "from": 45.64,
      "to": 48.6,
      "sid": 30,
      "location": 2,
      "content": "所以你看表表面上你解释了他学得快的原因",
      "music": 0.0
    },
    {
      "from": 48.6,
      "to": 50.16,
      "sid": 31,
      "location": 2,
      "content": "实际上只是换了个说法而已",
      "music": 0.0
    },
    {
      "from": 50.16,
      "to": 52.0,
      "sid": 32,
      "location": 2,
      "content": "咱们并不知道他为什么真的学得快",
      "music": 0.0
    },
    {
      "from": 52.0,
      "to": 54.2,
      "sid": 33,
      "location": 2,
      "content": "而这就是为什么谈天去套公式",
      "music": 0.0
    },
    {
      "from": 54.2,
      "to": 55.22,
      "sid": 34,
      "location": 2,
      "content": "很多时候是有害的",
      "music": 0.0
    },
    {
      "from": 55.22,
      "to": 56.96,
      "sid": 35,
      "location": 2,
      "content": "因为当你把天赋这个词拿掉之后",
      "music": 0.0
    },
    {
      "from": 56.96,
      "to": 58.42,
      "sid": 36,
      "location": 2,
      "content": "你尝试去深挖一层的话",
      "music": 0.0
    },
    {
      "from": 58.42,
      "to": 60.66,
      "sid": 37,
      "location": 2,
      "content": "你可能会发现那个弹得好的孩子",
      "music": 0.0
    },
    {
      "from": 60.66,
      "to": 62.5,
      "sid": 38,
      "location": 2,
      "content": "可能是因为他是主动想谈的啊",
      "music": 0.0
    },
    {
      "from": 62.5,
      "to": 63.74,
      "sid": 39,
      "location": 2,
      "content": "另外一个是家长逼的啊",
      "music": 0.0
    },
    {
      "from": 63.74,
      "to": 65.86,
      "sid": 40,
      "location": 2,
      "content": "弹得好的那个可能是因为每次弹得好",
      "music": 0.0
    },
    {
      "from": 65.86,
      "to": 66.9,
      "sid": 41,
      "location": 2,
      "content": "都有老师和家长鼓励",
      "music": 0.0
    },
    {
      "from": 66.9,
      "to": 67.86,
      "sid": 42,
      "location": 2,
      "content": "而另外一个就算弹的好",
      "music": 0.0
    },
    {
      "from": 67.86,
      "to": 68.7,
      "sid": 43,
      "location": 2,
      "content": "也没有人搭理他",
      "music": 0.0
    },
    {
      "from": 68.7,
      "to": 70.46,
      "sid": 44,
      "location": 2,
      "content": "所以说语言的边界就是思维的边界嘛",
      "music": 0.0
    },
    {
      "from": 70.46,
      "to": 71.54,
      "sid": 45,
      "location": 2,
      "content": "你用什么样的措辞",
      "music": 0.0
    },
    {
      "from": 71.54,
      "to": 73.22,
      "sid": 46,
      "location": 2,
      "content": "就代表了你有什么样的思考方式",
      "music": 0.0
    },
    {
      "from": 73.22,
      "to": 74.98,
      "sid": 47,
      "location": 2,
      "content": "当我把天赋这个词拿掉的时候",
      "music": 0.0
    },
    {
      "from": 74.98,
      "to": 76.34,
      "sid": 48,
      "location": 2,
      "content": "你会发现你可以往下深",
      "music": 0.0
    },
    {
      "from": 76.34,
      "to": 78.34,
      "sid": 49,
      "location": 2,
      "content": "挖出事情背后的真正原因",
      "music": 0.0
    },
    {
      "from": 78.34,
      "to": 79.42,
      "sid": 50,
      "location": 2,
      "content": "你把这个词放回来",
      "music": 0.0
    },
    {
      "from": 79.42,
      "to": 80.82,
      "sid": 51,
      "location": 2,
      "content": "你就发现你停止追问了",
      "music": 0.0
    },
    {
      "from": 80.82,
      "to": 82.1,
      "sid": 52,
      "location": 2,
      "content": "因为你生下来就比别人强吗",
      "music": 0.0
    },
    {
      "from": 82.1,
      "to": 82.64,
      "sid": 53,
      "location": 2,
      "content": "那还问个啥",
      "music": 0.0
    },
    {
      "from": 82.64,
      "to": 83.94,
      "sid": 54,
      "location": 2,
      "content": "所以天赋这个词其实是人",
      "music": 0.0
    },
    {
      "from": 83.94,
      "to": 85.5,
      "sid": 55,
      "location": 2,
      "content": "人类为了节约自己的认知资源",
      "music": 0.0
    },
    {
      "from": 85.5,
      "to": 87.18,
      "sid": 56,
      "location": 2,
      "content": "打造的一套叙事工具啊",
      "music": 0.0
    },
    {
      "from": 87.18,
      "to": 89.1,
      "sid": 57,
      "location": 2,
      "content": "就明明这个拿到结果是先天的",
      "music": 0.0
    },
    {
      "from": 89.1,
      "to": 89.54,
      "sid": 58,
      "location": 2,
      "content": "后天的",
      "music": 0.0
    },
    {
      "from": 89.54,
      "to": 89.9,
      "sid": 59,
      "location": 2,
      "content": "运气的",
      "music": 0.0
    },
    {
      "from": 89.9,
      "to": 91.74,
      "sid": 60,
      "location": 2,
      "content": "随机的各种因素杂糅到一起的结果",
      "music": 0.0
    },
    {
      "from": 91.74,
      "to": 94.1,
      "sid": 61,
      "location": 2,
      "content": "但人类不喜欢这么复杂的因果链路吗",
      "music": 0.0
    },
    {
      "from": 94.1,
      "to": 95.1,
      "sid": 62,
      "location": 2,
      "content": "因为我认识不清嘛",
      "music": 0.0
    },
    {
      "from": 95.1,
      "to": 97.56,
      "sid": 63,
      "location": 2,
      "content": "我就想用极的这个认知资源搞清他",
      "music": 0.0
    },
    {
      "from": 97.56,
      "to": 98.6,
      "sid": 64,
      "location": 2,
      "content": "哎那我就编一个故事",
      "music": 0.0
    },
    {
      "from": 98.6,
      "to": 99.44,
      "sid": 65,
      "location": 2,
      "content": "叫这个人有天赋",
      "music": 0.0
    },
    {
      "from": 99.44,
      "to": 100.88,
      "sid": 66,
      "location": 2,
      "content": "这个简单的结论往这一放",
      "music": 0.0
    },
    {
      "from": 100.88,
      "to": 101.68,
      "sid": 67,
      "location": 2,
      "content": "我心里就踏实了",
      "music": 0.0
    },
    {
      "from": 101.68,
      "to": 103.82,
      "sid": 68,
      "location": 2,
      "content": "那为什么说天天赋论这个说法有一定的毒性呢",
      "music": 0.0
    },
    {
      "from": 103.82,
      "to": 104.58,
      "sid": 69,
      "location": 2,
      "content": "就我们开头说的",
      "music": 0.0
    },
    {
      "from": 104.58,
      "to": 106.06,
      "sid": 70,
      "location": 2,
      "content": "你想挖掘自己的天赋去赚钱",
      "music": 0.0
    },
    {
      "from": 106.06,
      "to": 107.14,
      "sid": 71,
      "location": 2,
      "content": "这个事为什么不靠谱呢",
      "music": 0.0
    },
    {
      "from": 107.14,
      "to": 108.46,
      "sid": 72,
      "location": 2,
      "content": "因为他的尝试去告诉你",
      "music": 0.0
    },
    {
      "from": 108.46,
      "to": 110.74,
      "sid": 73,
      "location": 2,
      "content": "事物背后仿佛是有一个标准答案的",
      "music": 0.0
    },
    {
      "from": 110.74,
      "to": 112.18,
      "sid": 74,
      "location": 2,
      "content": "只要你找到了这个标准答案",
      "music": 0.0
    },
    {
      "from": 112.18,
      "to": 113.22,
      "sid": 75,
      "location": 2,
      "content": "你挖掘了自己的天赋",
      "music": 0.0
    },
    {
      "from": 113.22,
      "to": 114.78,
      "sid": 76,
      "location": 2,
      "content": "你就可以线性的往前走了",
      "music": 0.0
    },
    {
      "from": 114.78,
      "to": 116.2,
      "sid": 77,
      "location": 2,
      "content": "我都可以预遇见你的成功了",
      "music": 0.0
    },
    {
      "from": 116.2,
      "to": 117.28,
      "sid": 78,
      "location": 2,
      "content": "他这个思路有个致命的问题",
      "music": 0.0
    },
    {
      "from": 117.28,
      "to": 117.64,
      "sid": 79,
      "location": 2,
      "content": "就在于",
      "music": 0.0
    },
    {
      "from": 117.64,
      "to": 120.58,
      "sid": 80,
      "location": 2,
      "content": "他在尝试让你把所有的赌注压在一个预判上",
      "music": 0.0
    },
    {
      "from": 120.58,
      "to": 121.72,
      "sid": 81,
      "location": 2,
      "content": "你错一次你就全输了",
      "music": 0.0
    },
    {
      "from": 121.72,
      "to": 123.88,
      "sid": 82,
      "location": 2,
      "content": "但我们说好的策略应该是纳西姆塔勒布说的",
      "music": 0.0
    },
    {
      "from": 123.88,
      "to": 125.3,
      "sid": 83,
      "location": 2,
      "content": "那个叫凸性策略啊",
      "music": 0.0
    },
    {
      "from": 125.3,
      "to": 126.32,
      "sid": 84,
      "location": 2,
      "content": "不是搞一把大的",
      "music": 0.0
    },
    {
      "from": 126.32,
      "to": 127.72,
      "sid": 85,
      "location": 2,
      "content": "是大量低成本试错",
      "music": 0.0
    },
    {
      "from": 127.72,
      "to": 128.96,
      "sid": 86,
      "location": 2,
      "content": "我失败了很多次也没关系",
      "music": 0.0
    },
    {
      "from": 128.96,
      "to": 129.72,
      "sid": 87,
      "location": 2,
      "content": "因为成本足够低",
      "music": 0.0
    },
    {
      "from": 129.72,
      "to": 130.58,
      "sid": 88,
      "location": 2,
      "content": "只要我赌对一次",
      "music": 0.0
    },
    {
      "from": 130.58,
      "to": 131.1,
      "sid": 89,
      "location": 2,
      "content": "我就起来了",
      "music": 0.0
    },
    {
      "from": 131.1,
      "to": 132.02,
      "sid": 90,
      "location": 2,
      "content": "这个叫凸性策略",
      "music": 0.0
    },
    {
      "from": 132.02,
      "to": 134.62,
      "sid": 91,
      "location": 2,
      "content": "那这个就要求你放下对天赋的执念",
      "music": 0.0
    },
    {
      "from": 134.62,
      "to": 135.94,
      "sid": 92,
      "location": 2,
      "content": "我什么都愿意去试一试",
      "music": 0.0
    },
    {
      "from": 135.94,
      "to": 137.06,
      "sid": 93,
      "location": 2,
      "content": "不是我一开始就笃定了",
      "music": 0.0
    },
    {
      "from": 137.06,
      "to": 138.54,
      "sid": 94,
      "location": 2,
      "content": "说我命里边有个什么东西啊",
      "music": 0.0
    },
    {
      "from": 138.54,
      "to": 139.34,
      "sid": 95,
      "location": 2,
      "content": "我非干他不可",
      "music": 0.0
    },
    {
      "from": 139.34,
      "to": 140.98,
      "sid": 96,
      "location": 2,
      "content": "你看乔丹六个总冠军戒指",
      "music": 0.0
    },
    {
      "from": 140.98,
      "to": 142.26,
      "sid": 97,
      "location": 2,
      "content": "没有人说乔丹没天赋吧",
      "music": 0.0
    },
    {
      "from": 142.26,
      "to": 144.06,
      "sid": 98,
      "location": 2,
      "content": "但是他打高中校队的时候都没进主力",
      "music": 0.0
    },
    {
      "from": 144.06,
      "to": 145.62,
      "sid": 99,
      "location": 2,
      "content": "那你能说那个时候乔丹没天赋吗",
      "music": 0.0
    },
    {
      "from": 145.62,
      "to": 147.58,
      "sid": 100,
      "location": 2,
      "content": "就在你取得那个很高的成就之前",
      "music": 0.0
    },
    {
      "from": 147.58,
      "to": 148.78,
      "sid": 101,
      "location": 2,
      "content": "你身体的硬件指标",
      "music": 0.0
    },
    {
      "from": 148.78,
      "to": 152.14,
      "sid": 102,
      "location": 2,
      "content": "什么身高臂展弹跳这些东西它是一些好的优势",
      "music": 0.0
    },
    {
      "from": 152.14,
      "to": 154.26,
      "sid": 103,
      "location": 2,
      "content": "但是我们没办法通过它去预判",
      "music": 0.0
    },
    {
      "from": 154.26,
      "to": 157.36,
      "sid": 104,
      "location": 2,
      "content": "说你竟然能取得前五古人的那么高的那个成就",
      "music": 0.0
    },
    {
      "from": 157.36,
      "to": 158.96,
      "sid": 105,
      "location": 2,
      "content": "这里面缺了一个预判信息",
      "music": 0.0
    },
    {
      "from": 158.96,
      "to": 159.84,
      "sid": 106,
      "location": 2,
      "content": "这个信息是啥呢",
      "music": 0.0
    },
    {
      "from": 159.84,
      "to": 160.76,
      "sid": 107,
      "location": 2,
      "content": "就乔丹本人说的",
      "music": 0.0
    },
    {
      "from": 160.76,
      "to": 162.76,
