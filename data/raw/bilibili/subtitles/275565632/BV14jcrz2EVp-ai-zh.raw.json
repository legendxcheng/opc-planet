  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 2.68,
      "sid": 1,
      "location": 2,
      "content": "上一条视频说我一个人运营了七个自媒体账号",
      "music": 0.0
    },
    {
      "from": 2.68,
      "to": 3.84,
      "sid": 2,
      "location": 2,
      "content": "一年发了1万多条帖子",
      "music": 0.0
    },
    {
      "from": 3.84,
      "to": 4.84,
      "sid": 3,
      "location": 2,
      "content": "然后这个评论区说啊",
      "music": 0.0
    },
    {
      "from": 4.84,
      "to": 6.48,
      "sid": 4,
      "location": 2,
      "content": "你这时间精力怎么可能顾得过来",
      "music": 0.0
    },
    {
      "from": 6.48,
      "to": 8.04,
      "sid": 5,
      "location": 2,
      "content": "那我今天这条视频给大家讲一下",
      "music": 0.0
    },
    {
      "from": 8.04,
      "to": 11.8,
      "sid": 6,
      "location": 2,
      "content": "我背后的这一整套多个AI角色和多个人类角色",
      "music": 0.0
    },
    {
      "from": 11.8,
      "to": 14.96,
      "sid": 7,
      "location": 2,
      "content": "一起去协作完成任务的框架和流程是什么样",
      "music": 0.0
    },
    {
      "from": 14.96,
      "to": 16.2,
      "sid": 8,
      "location": 2,
      "content": "我三到5分钟给大家捋清楚",
      "music": 0.0
    },
    {
      "from": 16.2,
      "to": 17.16,
      "sid": 9,
      "location": 2,
      "content": "很多人可能都知道",
      "music": 0.0
    },
    {
      "from": 17.16,
      "to": 19.6,
      "sid": 10,
      "location": 2,
      "content": "在我这个业务的绝大多数的时间里",
      "music": 0.0
    },
    {
      "from": 19.6,
      "to": 20.52,
      "sid": 11,
      "location": 2,
      "content": "全职的人类",
      "music": 0.0
    },
    {
      "from": 20.52,
      "to": 21.24,
      "sid": 12,
      "location": 2,
      "content": "包括我在内",
      "music": 0.0
    },
    {
      "from": 21.24,
      "to": 22.24,
      "sid": 13,
      "location": 2,
      "content": "总共就只有两个哦",
      "music": 0.0
    },
    {
      "from": 22.24,
      "to": 24.06,
      "sid": 14,
      "location": 2,
      "content": "偶尔帮忙的人可能是很多",
      "music": 0.0
    },
    {
      "from": 24.06,
      "to": 25.78,
      "sid": 15,
      "location": 2,
      "content": "这部分的话就不能算个数了对吧",
      "music": 0.0
    },
    {
      "from": 25.78,
      "to": 28.62,
      "sid": 16,
      "location": 2,
      "content": "因为agent是按绘画session一个一个去执行任务的",
      "music": 0.0
    },
    {
      "from": 28.62,
      "to": 30.62,
      "sid": 17,
      "location": 2,
      "content": "你把它当成人去统计个数没有意义",
      "music": 0.0
    },
    {
      "from": 30.62,
      "to": 33.98,
      "sid": 18,
      "location": 2,
      "content": "那么这个很小的组织可以释放出巨大生产力的",
      "music": 0.0
    },
    {
      "from": 33.98,
      "to": 35.76,
      "sid": 19,
      "location": 2,
      "content": "我觉得这个思维方式上的核心是",
      "music": 0.0
    },
    {
      "from": 35.76,
      "to": 40.24,
      "sid": 20,
      "location": 2,
      "content": "把人和AI当成是平等的独立角色个体去对待",
      "music": 0.0
    },
    {
      "from": 40.24,
      "to": 43.46,
      "sid": 21,
      "location": 2,
      "content": "而不仅仅是认为说AI就是人类的工具啊",
      "music": 0.0
    },
    {
      "from": 43.46,
      "to": 44.42,
      "sid": 22,
      "location": 2,
      "content": "虽然说AI在这里",
      "music": 0.0
    },
    {
      "from": 44.42,
      "to": 45.7,
      "sid": 23,
      "location": 2,
      "content": "它的确就是我干活的工具",
      "music": 0.0
    },
    {
      "from": 45.7,
      "to": 46.82,
      "sid": 24,
      "location": 2,
      "content": "但是在思维方式上",
      "music": 0.0
    },
    {
      "from": 46.82,
      "to": 48.94,
      "sid": 25,
      "location": 2,
      "content": "你仅仅是把它当成是人类的",
      "music": 0.0
    },
    {
      "from": 48.94,
      "to": 51.12,
      "sid": 26,
      "location": 2,
      "content": "这个锤子和扳手一样的工具",
      "music": 0.0
    },
    {
      "from": 51.12,
      "to": 54.12,
      "sid": 27,
      "location": 2,
      "content": "以及对比说你把它们当成是平等的个体",
      "music": 0.0
    },
    {
      "from": 54.12,
      "to": 57.76,
      "sid": 28,
      "location": 2,
      "content": "这对应着不同的组织架构和协作流程方法",
      "music": 0.0
    },
    {
      "from": 57.76,
      "to": 59.68,
      "sid": 29,
      "location": 2,
      "content": "那也就对应着不同的生产力层级",
      "music": 0.0
    },
    {
      "from": 59.68,
      "to": 60.82,
      "sid": 30,
      "location": 2,
      "content": "那具体怎么实现",
      "music": 0.0
    },
    {
      "from": 60.82,
      "to": 62.9,
      "sid": 31,
      "location": 2,
      "content": "比如说如果你用过agent的话",
      "music": 0.0
    },
    {
      "from": 62.9,
      "to": 65.02,
      "sid": 32,
      "location": 2,
      "content": "哪怕就只是最近最火的这个小龙虾",
      "music": 0.0
    },
    {
      "from": 65.02,
      "to": 65.58,
      "sid": 33,
      "location": 2,
      "content": "Open cloud",
      "music": 0.0
    },
    {
      "from": 65.58,
      "to": 67.58,
      "sid": 34,
      "location": 2,
      "content": "你会知道它有一个核心功能叫skill",
      "music": 0.0
    },
    {
      "from": 67.58,
      "to": 69.06,
      "sid": 35,
      "location": 2,
      "content": "翻译成中文叫技能对吧",
      "music": 0.0
    },
    {
      "from": 69.06,
      "to": 71.62,
      "sid": 36,
      "location": 2,
      "content": "比如说我给他发一个指令叫斜杠PPT",
      "music": 0.0
    },
    {
      "from": 71.62,
      "to": 73.58,
      "sid": 37,
      "location": 2,
      "content": "哎他可能就调用它做PPT的技能",
      "music": 0.0
    },
    {
      "from": 73.58,
      "to": 74.74,
      "sid": 38,
      "location": 2,
      "content": "把这个PPT给做完了",
      "music": 0.0
    },
    {
      "from": 74.74,
      "to": 75.9,
      "sid": 39,
      "location": 2,
      "content": "在最前单的场景下",
      "music": 0.0
    },
    {
      "from": 75.9,
      "to": 76.74,
      "sid": 40,
      "location": 2,
      "content": "这样的确是可以的",
      "music": 0.0
    },
    {
      "from": 76.74,
      "to": 79.38,
      "sid": 41,
      "location": 2,
      "content": "但是如果你想实现大规模的真正的协作的话",
      "music": 0.0
    },
    {
      "from": 79.38,
      "to": 81.86,
      "sid": 42,
      "location": 2,
      "content": "你会发现这件事情越来越像是你给AI打",
      "music": 0.0
    },
    {
      "from": 81.86,
      "to": 83.22,
      "sid": 43,
      "location": 2,
      "content": "比如说我调用一个技能",
      "music": 0.0
    },
    {
      "from": 83.22,
      "to": 83.78,
      "sid": 44,
      "location": 2,
      "content": "一个词skill",
      "music": 0.0
    },
    {
      "from": 83.78,
      "to": 85.62,
      "sid": 45,
      "location": 2,
      "content": "让AI足够做PPT做到一半",
      "music": 0.0
    },
    {
      "from": 85.62,
      "to": 86.82,
      "sid": 46,
      "location": 2,
      "content": "跟我说他缺资料了好",
      "music": 0.0
    },
    {
      "from": 86.82,
      "to": 89.56,
      "sid": 47,
      "location": 2,
      "content": "我让某一个人类的同事帮我搞到一堆资料",
      "music": 0.0
    },
    {
      "from": 89.56,
      "to": 90.3,
      "sid": 48,
      "location": 2,
      "content": "我再发给你",
      "music": 0.0
    },
    {
      "from": 90.3,
      "to": 90.96,
      "sid": 49,
      "location": 2,
      "content": "就做到一半",
      "music": 0.0
    },
    {
      "from": 90.96,
      "to": 91.2,
      "sid": 50,
      "location": 2,
      "content": "跟我说",
      "music": 0.0
    },
    {
      "from": 91.2,
      "to": 91.8,
      "sid": 51,
      "location": 2,
      "content": "你缺张图",
      "music": 0.0
    },
    {
      "from": 91.8,
      "to": 94.04,
      "sid": 52,
      "location": 2,
      "content": "这个图呢你你原有的这个sq搞不定",
      "music": 0.0
    },
    {
      "from": 94.04,
      "to": 96.36,
      "sid": 53,
      "location": 2,
      "content": "我又找另外一个AI产品去搞一张图",
      "music": 0.0
    },
    {
      "from": 96.36,
      "to": 97.24,
      "sid": 54,
      "location": 2,
      "content": "我又把这个图发给你",
      "music": 0.0
    },
    {
      "from": 97.24,
      "to": 97.76,
      "sid": 55,
      "location": 2,
      "content": "所以你就会发现",
      "music": 0.0
    },
    {
      "from": 97.76,
      "to": 99.48,
      "sid": 56,
      "location": 2,
      "content": "这个人是不断在给这个AI打杂的",
      "music": 0.0
    },
    {
      "from": 99.48,
      "to": 102.52,
      "sid": 57,
      "location": 2,
      "content": "而问题是出现在用于完成这个任务的",
      "music": 0.0
    },
    {
      "from": 102.52,
      "to": 104.86,
      "sid": 58,
      "location": 2,
      "content": "两个人类角色和两个agent的角色",
      "music": 0.0
    },
    {
      "from": 104.86,
      "to": 106.84,
      "sid": 59,
      "location": 2,
      "content": "他们没有被汇集到一个系统里",
      "music": 0.0
    },
    {
      "from": 106.84,
      "to": 109.56,
      "sid": 60,
      "location": 2,
      "content": "而要解决这个问题其实非常简单",
      "music": 0.0
    },
    {
      "from": 109.56,
      "to": 110.8,
      "sid": 61,
      "location": 2,
      "content": "你就记住一个效率原则",
      "music": 0.0
    },
    {
      "from": 110.8,
      "to": 111.12,
      "sid": 62,
      "location": 2,
      "content": "叫做",
      "music": 0.0
    },
    {
      "from": 111.12,
      "to": 114.36,
      "sid": 63,
      "location": 2,
      "content": "我们永远坚持让合适的角色去干合适的事情",
      "music": 0.0
    },
    {
      "from": 114.36,
      "to": 115.26,
      "sid": 64,
      "location": 2,
      "content": "而这就意味着",
      "music": 0.0
    },
    {
      "from": 115.26,
      "to": 117.24,
      "sid": 65,
      "location": 2,
      "content": "不仅仅是人可以调用AIAI",
      "music": 0.0
    },
    {
      "from": 117.24,
      "to": 118.36,
      "sid": 66,
      "location": 2,
      "content": "也可以反过来调用人",
      "music": 0.0
    },
    {
      "from": 118.36,
      "to": 121.08,
      "sid": 67,
      "location": 2,
      "content": "以及不仅仅是上级才能调用下级",
      "music": 0.0
    },
    {
      "from": 121.08,
      "to": 123.42,
      "sid": 68,
      "location": 2,
      "content": "如果这件事情适合上级去做的话",
      "music": 0.0
    },
    {
      "from": 123.42,
      "to": 124.92,
      "sid": 69,
      "location": 2,
      "content": "下级也可以反过来调用上级",
      "music": 0.0
    },
    {
      "from": 124.92,
      "to": 126.96,
      "sid": 70,
      "location": 2,
      "content": "那么一个比较好的协作流程",
      "music": 0.0
    },
    {
      "from": 126.96,
      "to": 128.48,
      "sid": 71,
      "location": 2,
      "content": "可能是这不是虚构出来的案例啊",
      "music": 0.0
    },
    {
      "from": 128.48,
      "to": 130.16,
      "sid": 72,
      "location": 2,
      "content": "这是一个真实的cloud code工程",
      "music": 0.0
    },
    {
      "from": 130.16,
      "to": 131.16,
      "sid": 73,
      "location": 2,
      "content": "它是真实可以用的",
      "music": 0.0
    },
    {
      "from": 131.16,
      "to": 132.32,
      "sid": 74,
      "location": 2,
      "content": "比较好的协作流程是",
      "music": 0.0
    },
    {
      "from": 132.32,
      "to": 134.6,
      "sid": 75,
      "location": 2,
      "content": "可能是我委派AI去做一个PPT",
      "music": 0.0
    },
    {
      "from": 134.6,
      "to": 137.22,
      "sid": 76,
      "location": 2,
      "content": "他发现自己缺文档或者缺图片了",
      "music": 0.0
    },
    {
      "from": 137.22,
      "to": 140.34,
      "sid": 77,
      "location": 2,
      "content": "他调用其他人类或者AI的这个技能",
      "music": 0.0
    },
    {
      "from": 140.34,
      "to": 141.46,
      "sid": 78,
      "location": 2,
      "content": "他去这个角色名单里",
      "music": 0.0
    },
    {
      "from": 141.46,
      "to": 144.42,
      "sid": 79,
      "location": 2,
      "content": "找到适合干这件事情的角色去完成这件事情",
      "music": 0.0
    },
    {
      "from": 144.42,
      "to": 145.02,
      "sid": 80,
      "location": 2,
      "content": "完成了之后",
      "music": 0.0
    },
    {
      "from": 145.02,
      "to": 146.28,
      "sid": 81,
      "location": 2,
      "content": "他接着去做这个PPT",
      "music": 0.0
    },
    {
      "from": 146.28,
      "to": 148.22,
      "sid": 82,
      "location": 2,
      "content": "所以在整个调用链路当中",
      "music": 0.0
    },
    {
      "from": 148.22,
      "to": 149.74,
      "sid": 83,
      "location": 2,
      "content": "有可能是人调用AI",
      "music": 0.0
    },
    {
      "from": 149.74,
      "to": 151.14,
      "sid": 84,
      "location": 2,
      "content": "也有可能是AI调用人",
      "music": 0.0
    },
    {
      "from": 151.14,
      "to": 152.72,
      "sid": 85,
      "location": 2,
      "content": "也有可能是A调用AI",
      "music": 0.0
    },
    {
      "from": 152.72,
      "to": 153.92,
      "sid": 86,
      "location": 2,
      "content": "那具体怎么实现这个事情",
      "music": 0.0
    },
    {
      "from": 153.92,
      "to": 156.08,
      "sid": 87,
      "location": 2,
      "content": "首先无论你是用cloud code还是open cloud",
      "music": 0.0
    },
    {
      "from": 156.08,
      "to": 157.04,
      "sid": 88,
      "location": 2,
      "content": "还是其他的agent的",
      "music": 0.0
    },
    {
      "from": 157.04,
      "to": 158.82,
      "sid": 89,
      "location": 2,
      "content": "你的工作目录里面文件吧",
      "music": 0.0
    },
    {
      "from": 158.82,
      "to": 161.1,
      "sid": 90,
      "location": 2,
      "content": "我们先维护一个叫做进行中的任务的",
      "music": 0.0
    },
    {
      "from": 161.1,
      "to": 161.74,
      "sid": 91,
      "location": 2,
      "content": "这样一个文档",
      "music": 0.0
    },
    {
      "from": 161.74,
      "to": 163.58,
      "sid": 92,
      "location": 2,
      "content": "我们先假设这个小规模团队协作",
      "music": 0.0
    },
    {
      "from": 163.58,
      "to": 165.24,
      "sid": 93,
      "location": 2,
      "content": "不考虑这个隐私保密的事情啊",
      "music": 0.0
    },
    {
      "from": 165.24,
      "to": 167.0,
      "sid": 94,
      "location": 2,
      "content": "这个文档对于团队内的",
      "music": 0.0
    },
    {
      "from": 167.0,
      "to": 169.32,
      "sid": 95,
      "location": 2,
      "content": "所有的人类和AI角色全部可见",
      "music": 0.0
    },
    {
      "from": 169.32,
      "to": 170.42,
      "sid": 96,
      "location": 2,
      "content": "那么在这个文档里面",
      "music": 0.0
    },
    {
      "from": 170.42,
      "to": 172.18,
      "sid": 97,
      "location": 2,
      "content": "每个任务对应了一个任务卡片",
      "music": 0.0
    },
    {
      "from": 172.18,
      "to": 173.26,
      "sid": 98,
      "location": 2,
      "content": "在最少的情况下",
      "music": 0.0
    },
    {
      "from": 173.26,
      "to": 175.62,
      "sid": 99,
      "location": 2,
      "content": "这个任务卡片里面只需要有两个信息就可以了",
      "music": 0.0
    },
    {
      "from": 175.62,
      "to": 176.54,
      "sid": 100,
      "location": 2,
      "content": "第一个是任务的描述",
      "music": 0.0
    },
    {
      "from": 176.54,
      "to": 177.9,
      "sid": 101,
      "location": 2,
      "content": "就是我们到底要干一个什么事情",
      "music": 0.0
    },
    {
      "from": 177.9,
      "to": 180.54,
      "sid": 102,
      "location": 2,
      "content": "第二个是衡量这个任务可以被标记为",
      "music": 0.0
    },
    {
      "from": 180.54,
      "to": 181.64,
      "sid": 103,
      "location": 2,
      "content": "完成的标准是什么",
      "music": 0.0
    },
    {
      "from": 181.64,
      "to": 183.04,
      "sid": 104,
      "location": 2,
      "content": "实际上在最简单的情况下",
      "music": 0.0
    },
    {
      "from": 183.04,
      "to": 184.52,
      "sid": 105,
      "location": 2,
      "content": "你只需要这么一个文件",
      "music": 0.0
    },
    {
      "from": 184.52,
      "to": 185.6,
      "sid": 106,
      "location": 2,
      "content": "就已经实现了",
      "music": 0.0
    },
    {
      "from": 185.6,
      "to": 187.2,
      "sid": 107,
      "location": 2,
      "content": "多个人类和多个AIA",
      "music": 0.0
    },
    {
      "from": 187.2,
      "to": 188.8,
