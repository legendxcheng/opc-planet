{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 1.18,
      "to": 2.4,
      "sid": 1,
      "location": 2,
      "content": "最近一周的行情",
      "music": 0.0
    },
    {
      "from": 2.4,
      "to": 5.12,
      "sid": 2,
      "location": 2,
      "content": "我相信不需要牛牛去做过多的赘述了",
      "music": 0.0
    },
    {
      "from": 5.12,
      "to": 7.06,
      "sid": 3,
      "location": 2,
      "content": "用一个字概括就是涨",
      "music": 0.0
    },
    {
      "from": 7.06,
      "to": 9.54,
      "sid": 4,
      "location": 2,
      "content": "用两个字概括就是暴涨",
      "music": 0.0
    },
    {
      "from": 9.54,
      "to": 11.52,
      "sid": 5,
      "location": 2,
      "content": "对于普通投资者而言",
      "music": 0.0
    },
    {
      "from": 11.52,
      "to": 12.8,
      "sid": 6,
      "location": 2,
      "content": "简直赢麻了",
      "music": 0.0
    },
    {
      "from": 12.8,
      "to": 14.44,
      "sid": 7,
      "location": 2,
      "content": "节前最后一个交易日",
      "music": 0.0
    },
    {
      "from": 14.44,
      "to": 16.619,
      "sid": 8,
      "location": 2,
      "content": "更是将热度推向了高潮",
      "music": 0.0
    },
    {
      "from": 16.619,
      "to": 18.739,
      "sid": 9,
      "location": 2,
      "content": "上证指数大涨8%",
      "music": 0.0
    },
    {
      "from": 18.739,
      "to": 21.239,
      "sid": 10,
      "location": 2,
      "content": "全天成交量创历史新高",
      "music": 0.0
    },
    {
      "from": 21.239,
      "to": 24.56,
      "sid": 11,
      "location": 2,
      "content": "后台收到了无数粉丝的私信和报喜反馈",
      "music": 0.0
    },
    {
      "from": 24.56,
      "to": 26.8,
      "sid": 12,
      "location": 2,
      "content": "虽然隔着屏幕看不到他们的表情",
      "music": 0.0
    },
    {
      "from": 26.8,
      "to": 28.32,
      "sid": 13,
      "location": 2,
      "content": "但是在字里行间里",
      "music": 0.0
    },
    {
      "from": 28.32,
      "to": 32.299,
      "sid": 14,
      "location": 2,
      "content": "还是能非常容易地感受到他们的惊喜和满足",
      "music": 0.0
    },
    {
      "from": 32.299,
      "to": 34.44,
      "sid": 15,
      "location": 2,
      "content": "我们现场也做一个小调研",
      "music": 0.0
    },
    {
      "from": 34.44,
      "to": 36.72,
      "sid": 16,
      "location": 2,
      "content": "靠着这波反弹已经回本的",
      "music": 0.0
    },
    {
      "from": 36.72,
      "to": 37.42,
      "sid": 17,
      "location": 2,
      "content": "请扣一",
      "music": 0.0
    },
    {
      "from": 37.42,
      "to": 39.06,
      "sid": 18,
      "location": 2,
      "content": "目前仍旧在亏损的",
      "music": 0.0
    },
    {
      "from": 39.06,
      "to": 39.82,
      "sid": 19,
      "location": 2,
      "content": "请扣二",
      "music": 0.0
    },
    {
      "from": 39.82,
      "to": 43.099,
      "sid": 20,
      "location": 2,
      "content": "看看投资收益的差别到底有多大",
      "music": 0.0
    },
    {
      "from": 43.099,
      "to": 44.399,
      "sid": 21,
      "location": 2,
      "content": "如果稍加留意",
      "music": 0.0
    },
    {
      "from": 44.399,
      "to": 45.179,
      "sid": 22,
      "location": 2,
      "content": "不难发现",
      "music": 0.0
    },
    {
      "from": 45.179,
      "to": 46.699,
      "sid": 23,
      "location": 2,
      "content": "在这满屏的红色之中",
      "music": 0.0
    },
    {
      "from": 46.699,
      "to": 49.319,
      "sid": 24,
      "location": 2,
      "content": "有一个板块非常的突出和耀眼",
      "music": 0.0
    },
    {
      "from": 49.319,
      "to": 50.59,
      "sid": 25,
      "location": 2,
      "content": "那就是白酒",
      "music": 0.0
    },
    {
      "from": 50.59,
      "to": 53.03,
      "sid": 26,
      "location": 2,
      "content": "连续几天整个行业涨停",
      "music": 0.0
    },
    {
      "from": 53.03,
      "to": 54.01,
      "sid": 27,
      "location": 2,
      "content": "你没听错",
      "music": 0.0
    },
    {
      "from": 54.01,
      "to": 57.57,
      "sid": 28,
      "location": 2,
      "content": "是整个行业连市值上万亿的茅台",
      "music": 0.0
    },
    {
      "from": 57.57,
      "to": 60.21,
      "sid": 29,
      "location": 2,
      "content": "五天时间也涨了近40%",
      "music": 0.0
    },
    {
      "from": 60.21,
      "to": 63.15,
      "sid": 30,
      "location": 2,
      "content": "这一下子给白酒投资者们乐坏了",
      "music": 0.0
    },
    {
      "from": 63.15,
      "to": 65.27,
      "sid": 31,
      "location": 2,
      "content": "我一个非常要好的朋友跟我说",
      "music": 0.0
    },
    {
      "from": 65.27,
      "to": 68.43,
      "sid": 32,
      "location": 2,
      "content": "这是他炒股以来最开心的一段时间了",
      "music": 0.0
    },
    {
      "from": 68.43,
      "to": 71.17,
      "sid": 33,
      "location": 2,
      "content": "虽然我没有细问到底他赚了多少",
      "music": 0.0
    },
    {
      "from": 71.17,
      "to": 73.99,
      "sid": 34,
      "location": 2,
      "content": "但是我知道他的白酒仓位很重",
      "music": 0.0
    },
    {
      "from": 73.99,
      "to": 76.61,
      "sid": 35,
      "location": 2,
      "content": "在前段时间白酒持续大跌的时候",
      "music": 0.0
    },
    {
      "from": 76.61,
      "to": 78.17,
      "sid": 36,
      "location": 2,
      "content": "他仍旧在加仓",
      "music": 0.0
    },
    {
      "from": 78.17,
      "to": 80.21,
      "sid": 37,
      "location": 2,
      "content": "中途虽有想过放弃",
      "music": 0.0
    },
    {
      "from": 80.21,
      "to": 82.59,
      "sid": 38,
      "location": 2,
      "content": "但最终还是咬牙坚持下来了",
      "music": 0.0
    },
    {
      "from": 82.59,
      "to": 83.89,
      "sid": 39,
      "location": 2,
      "content": "牛牛在大跌时",
      "music": 0.0
    },
    {
      "from": 83.89,
      "to": 86.77,
      "sid": 40,
      "location": 2,
      "content": "专门出了一期视频给大家加油打气",
      "music": 0.0
    },
    {
      "from": 86.77,
      "to": 90.37,
      "sid": 41,
      "location": 2,
      "content": "希望大家不要浪费这次千载难逢的危机",
      "music": 0.0
    },
    {
      "from": 90.37,
      "to": 93.36,
      "sid": 42,
      "location": 2,
      "content": "坚持4%定投法勇敢买入",
      "music": 0.0
    },
    {
      "from": 93.36,
      "to": 96.08,
      "sid": 43,
      "location": 2,
      "content": "当时的背景是美股不断创出新高",
      "music": 0.0
    },
    {
      "from": 96.08,
      "to": 98.1,
      "sid": 44,
      "location": 2,
      "content": "但A股跌破3000点之后",
      "music": 0.0
    },
    {
      "from": 98.1,
      "to": 99.64,
      "sid": 45,
      "location": 2,
      "content": "一路向下狂奔",
      "music": 0.0
    },
    {
      "from": 99.64,
      "to": 101.1,
      "sid": 46,
      "location": 2,
      "content": "很多人开玩笑说",
      "music": 0.0
    },
    {
      "from": 101.1,
      "to": 102.26,
      "sid": 47,
      "location": 2,
      "content": "投资很简单",
      "music": 0.0
    },
    {
      "from": 102.26,
      "to": 104.36,
      "sid": 48,
      "location": 2,
      "content": "相信国运定投纳指",
      "music": 0.0
    },
    {
      "from": 104.36,
      "to": 108.199,
      "sid": 49,
      "location": 2,
      "content": "不过牛友当时直截了当地表达了自己的观点",
      "music": 0.0
    },
    {
      "from": 108.199,
      "to": 111.35,
      "sid": 50,
      "location": 2,
      "content": "对于当下估值的美股完全没有兴趣",
      "music": 0.0
    },
    {
      "from": 111.35,
      "to": 114.21,
      "sid": 51,
      "location": 2,
      "content": "从潜在收入和潜在风险综合考量",
      "music": 0.0
    },
    {
      "from": 114.21,
      "to": 116.29,
      "sid": 52,
      "location": 2,
      "content": "A股明显是更好的选择",
      "music": 0.0
    },
    {
      "from": 116.29,
      "to": 117.83,
      "sid": 53,
      "location": 2,
      "content": "没有只涨不跌的市场",
      "music": 0.0
    },
    {
      "from": 117.83,
      "to": 119.54,
      "sid": 54,
      "location": 2,
      "content": "也没有只跌不涨的市场",
      "music": 0.0
    },
    {
      "from": 119.54,
      "to": 120.84,
      "sid": 55,
      "location": 2,
      "content": "尤其是A股的白酒",
      "music": 0.0
    },
    {
      "from": 120.84,
      "to": 123.1,
      "sid": 56,
      "location": 2,
      "content": "真的便宜的有点太过分了",
      "music": 0.0
    },
    {
      "from": 123.1,
      "to": 126.87,
      "sid": 57,
      "location": 2,
      "content": "只用一点点常识就可以判断出白酒的投资价值",
      "music": 0.0
    },
    {
      "from": 126.87,
      "to": 129.45,
      "sid": 58,
      "location": 2,
      "content": "当时白酒的股息率已经超过了",
      "music": 0.0
    },
    {
      "from": 129.45,
      "to": 131.23,
      "sid": 59,
      "location": 2,
      "content": "传统高股息的股票",
      "music": 0.0
    },
    {
      "from": 131.23,
      "to": 134.84,
      "sid": 60,
      "location": 2,
      "content": "部分白酒标的的股息率甚至接近7%",
      "music": 0.0
    },
    {
      "from": 134.84,
      "to": 137.32,
      "sid": 61,
      "location": 2,
      "content": "哪怕白酒以后完全不增长了",
      "music": 0.0
    },
    {
      "from": 137.32,
      "to": 140.63,
      "sid": 62,
      "location": 2,
      "content": "只拿股息也是一笔非常好的投资",
      "music": 0.0
    },
    {
      "from": 140.63,
      "to": 143.39,
      "sid": 63,
      "location": 2,
      "content": "但这个观点却遭到了无情的嘲笑",
      "music": 0.0
    },
    {
      "from": 143.39,
      "to": 146.69,
      "sid": 64,
      "location": 2,
      "content": "我相信后台很多在市场一众质疑声中",
      "music": 0.0
    },
    {
      "from": 146.69,
      "to": 149.19,
      "sid": 65,
      "location": 2,
      "content": "依然坚定投资白酒的小伙伴们",
      "music": 0.0
    },
    {
      "from": 149.19,
      "to": 151.41,
      "sid": 66,
      "location": 2,
      "content": "应该能产生强烈的共鸣",
      "music": 0.0
    },
    {
      "from": 151.41,
      "to": 153.97,
      "sid": 67,
      "location": 2,
      "content": "最近这段时间终于迎来了丰收",
      "music": 0.0
    },
    {
      "from": 153.97,
      "to": 157.42,
      "sid": 68,
      "location": 2,
      "content": "这大概就是价值投资的魅力所在吧",
      "music": 0.0
    },
    {
      "from": 157.42,
      "to": 160.02,
      "sid": 69,
      "location": 2,
      "content": "自己坚持的投资逻辑被市场验证",
      "music": 0.0
    },
    {
      "from": 160.02,
      "to": 162.86,
      "sid": 70,
      "location": 2,
      "content": "会让你有一种无与伦比的满足感",
      "music": 0.0
    },
    {
      "from": 162.86,
      "to": 164.7,
      "sid": 71,
      "location": 2,
      "content": "这感觉与钱相关",
      "music": 0.0
    },
    {
      "from": 164.7,
      "to": 167.14,
      "sid": 72,
      "location": 2,
      "content": "也不仅仅与钱相关",
      "music": 0.0
    },
    {
      "from": 167.14,
      "to": 168.82,
      "sid": 73,
      "location": 2,
      "content": "对于部分小伙伴来说",
      "music": 0.0
    },
    {
      "from": 168.82,
      "to": 170.74,
      "sid": 74,
      "location": 2,
      "content": "喜悦还没有完全品尝完",
      "music": 0.0
    },
    {
      "from": 170.74,
      "to": 172.62,
      "sid": 75,
      "location": 2,
      "content": "焦虑已经接踵而至",
      "music": 0.0
    },
    {
      "from": 172.62,
      "to": 173.56,
      "sid": 76,
      "location": 2,
      "content": "最近的大涨",
      "music": 0.0
    },
    {
      "from": 173.56,
      "to": 175.12,
      "sid": 77,
      "location": 2,
      "content": "让部分已经回本",
      "music": 0.0
    },
    {
      "from": 175.12,
      "to": 178.2,
      "sid": 78,
      "location": 2,
      "content": "或者在回本边缘的小伙伴非常的不安",
      "music": 0.0
    },
    {
      "from": 178.2,
      "to": 182.12,
      "sid": 79,
      "location": 2,
      "content": "后台基本问的都是对未来行情走势的相关问题",
      "music": 0.0
    },
    {
      "from": 182.12,
      "to": 183.74,
      "sid": 80,
      "location": 2,
      "content": "我觉得挺有代表性的",
      "music": 0.0
    },
    {
      "from": 183.74,
      "to": 185.06,
      "sid": 81,
      "location": 2,
      "content": "跟大家分享一下",
      "music": 0.0
    },
    {
      "from": 185.06,
      "to": 188.52,
      "sid": 82,
      "location": 2,
      "content": "有人问牛牛已经连着拉升很多天了",
      "music": 0.0
    },
    {
      "from": 188.52,
      "to": 189.92,
      "sid": 83,
      "location": 2,
      "content": "节后应该跌了吧",
      "music": 0.0
    },
    {
      "from": 189.92,
      "to": 190.64,
      "sid": 84,
      "location": 2,
      "content": "牛牛答",
      "music": 0.0
    },
    {
      "from": 190.64,
      "to": 192.61,
      "sid": 85,
      "location": 2,
      "content": "有可能又有人问",
      "music": 0.0
    },
    {
      "from": 192.61,
      "to": 194.19,
      "sid": 86,
      "location": 2,
      "content": "这几天涨得挺好的",
      "music": 0.0
    },
    {
      "from": 194.19,
      "to": 195.37,
      "sid": 87,
      "location": 2,
      "content": "气氛也很不错",
      "music": 0.0
    },
    {
      "from": 195.37,
      "to": 197.51,
      "sid": 88,
      "location": 2,
      "content": "节后应该会继续大涨吧",
      "music": 0.0
    },
    {
      "from": 197.51,
      "to": 198.3,
      "sid": 89,
      "location": 2,
      "content": "牛牛答",
      "music": 0.0
    },
    {
      "from": 198.3,
      "to": 201.88,
      "sid": 90,
      "location": 2,
      "content": "有可能还有人问你对节后的走势怎么看",
      "music": 0.0
    },
    {
      "from": 201.88,
      "to": 203.68,
      "sid": 91,
      "location": 2,
      "content": "是会涨还是会跌",
      "music": 0.0
    },
    {
      "from": 203.68,
      "to": 204.58,
      "sid": 92,
      "location": 2,
      "content": "牛牛答",
      "music": 0.0
    },
    {
      "from": 204.58,
      "to": 206.46,
      "sid": 93,
      "location": 2,
      "content": "一切皆有可能",
      "music": 0.0
    },
    {
      "from": 206.46,
      "to": 209.18,
      "sid": 94,
      "location": 2,
      "content": "看到这或许有一些小伙伴要骂街了",
      "music": 0.0
    },
    {
      "from": 209.18,
      "to": 211.14,
      "sid": 95,
      "location": 2,
      "content": "你这好像什么都说了",
      "music": 0.0
    },
    {
      "from": 211.14,
      "to": 212.98,
      "sid": 96,
      "location": 2,
      "content": "又好像什么都没有说",
      "music": 0.0
    },
    {
      "from": 212.98,
      "to": 216.02,
      "sid": 97,
      "location": 2,
      "content": "确实我不止一次地跟大家坦诚过",
      "music": 0.0
    },
    {
      "from": 216.02,
      "to": 218.38,
      "sid": 98,
      "location": 2,
      "content": "我无法预测未来一段时间的走势",
      "music": 0.0
    },
    {
      "from": 218.38,
      "to": 220.26,
      "sid": 99,
      "location": 2,
      "content": "也基本不去做那个事儿",
      "music": 0.0
    },
    {
      "from": 220.26,
      "to": 222.68,
      "sid": 100,
      "location": 2,
      "content": "哪怕最近每天盘中暴涨",
      "music": 0.0
    },
    {
      "from": 222.68,
      "to": 224.44,
      "sid": 101,
      "location": 2,
      "content": "大家都认为牛市来了",
      "music": 0.0
    },
    {
      "from": 224.44,
      "to": 226.3,
      "sid": 102,
      "location": 2,
      "content": "盘面一片繁荣的景象",
      "music": 0.0
    },
    {
      "from": 226.3,
      "to": 229.88,
      "sid": 103,
      "location": 2,
      "content": "但我依然无法预测盘尾会不会跳水",
      "music": 0.0
    },
    {
      "from": 229.88,
      "to": 232.96,
      "sid": 104,
      "location": 2,
      "content": "我相信也没有人有预测股市的水平",
      "music": 0.0
    },
    {
      "from": 232.96,
      "to": 235.52,
      "sid": 105,
      "location": 2,
      "content": "至少巴菲特活了快一个世纪了",
      "music": 0.0
    },
    {
      "from": 235.52,
      "to": 237.72,
      "sid": 106,
      "location": 2,
      "content": "也没有见过谁有这种能力",
      "music": 0.0
    },
    {
      "from": 237.72,
      "to": 241.24,
      "sid": 107,
      "location": 2,
