  "version": "v1.7.0.4",
  "body": [
    {
      "from": 4.079,
      "to": 5.759,
      "sid": 1,
      "location": 2,
      "content": "江南水乡种水稻呀",
      "music": 0.0
    },
    {
      "from": 5.759,
      "to": 6.499,
      "sid": 2,
      "location": 2,
      "content": "不稀奇",
      "music": 0.0
    },
    {
      "from": 6.499,
      "to": 8.82,
      "sid": 3,
      "location": 2,
      "content": "那沙漠里能不能种水稻呢",
      "music": 0.0
    },
    {
      "from": 8.82,
      "to": 9.8,
      "sid": 4,
      "location": 2,
      "content": "新疆和田",
      "music": 0.0
    },
    {
      "from": 9.8,
      "to": 13.04,
      "sid": 5,
      "location": 2,
      "content": "万亩沙漠设施农业产业园的植物工厂内",
      "music": 0.0
    },
    {
      "from": 13.04,
      "to": 15.64,
      "sid": 6,
      "location": 2,
      "content": "采用垂直立体栽培技术的水稻",
      "music": 0.0
    },
    {
      "from": 15.64,
      "to": 17.67,
      "sid": 7,
      "location": 2,
      "content": "正处于不同生长周期",
      "music": 0.0
    },
    {
      "from": 17.67,
      "to": 19.55,
      "sid": 8,
      "location": 2,
      "content": "有即将成熟收获的",
      "music": 0.0
    },
    {
      "from": 19.55,
      "to": 21.11,
      "sid": 9,
      "location": 2,
      "content": "也有正在抽穗的",
      "music": 0.0
    },
    {
      "from": 21.11,
      "to": 23.98,
      "sid": 10,
      "location": 2,
      "content": "还有一批正在循环育秧机上育苗",
      "music": 0.0
    },
    {
      "from": 23.98,
      "to": 25.7,
      "sid": 11,
      "location": 2,
      "content": "我国目前栽种的水稻",
      "music": 0.0
    },
    {
      "from": 25.7,
      "to": 29.28,
      "sid": 12,
      "location": 2,
      "content": "生长周期平均在120~150天左右",
      "music": 0.0
    },
    {
      "from": 29.28,
      "to": 33.33,
      "sid": 13,
      "location": 2,
      "content": "而这里的水稻从定植到收获只需60天",
      "music": 0.0
    },
    {
      "from": 33.33,
      "to": 37.23,
      "sid": 14,
      "location": 2,
      "content": "今年4月首次试种的快速繁育水稻收获",
      "music": 0.0
    },
    {
      "from": 37.23,
      "to": 41.23,
      "sid": 15,
      "location": 2,
      "content": "经测产亩产达到1051.5kg",
      "music": 0.0
    },
    {
      "from": 41.23,
      "to": 43.27,
      "sid": 16,
      "location": 2,
      "content": "这些都是如何做到的呢",
      "music": 0.0
    },
    {
      "from": 43.27,
      "to": 46.27,
      "sid": 17,
      "location": 2,
      "content": "中国农业科学院都市农业研究所",
      "music": 0.0
    },
    {
      "from": 46.27,
      "to": 49.349,
      "sid": 18,
      "location": 2,
      "content": "首席科学家杨其长率领的科研团队",
      "music": 0.0
    },
    {
      "from": 49.349,
      "to": 51.529,
      "sid": 19,
      "location": 2,
      "content": "利用快速繁育技术手段",
      "music": 0.0
    },
    {
      "from": 51.529,
      "to": 53.75,
      "sid": 20,
      "location": 2,
      "content": "实现了水稻生育期减半",
      "music": 0.0
    },
    {
      "from": 53.75,
      "to": 56.15,
      "sid": 21,
      "location": 2,
      "content": "原来我们在这个植物工厂的条件下",
      "music": 0.0
    },
    {
      "from": 56.15,
      "to": 59.81,
      "sid": 22,
      "location": 2,
      "content": "我们完全可以控制它的温度湿度",
      "music": 0.0
    },
    {
      "from": 59.81,
      "to": 60.37,
      "sid": 23,
      "location": 2,
      "content": "光照",
      "music": 0.0
    },
    {
      "from": 60.37,
      "to": 62.17,
      "sid": 24,
      "location": 2,
      "content": "二氧化碳和根茎营养",
      "music": 0.0
    },
    {
      "from": 62.17,
      "to": 64.99,
      "sid": 25,
      "location": 2,
      "content": "就是完全可以控制它的环境呃",
      "music": 0.0
    },
    {
      "from": 64.99,
      "to": 67.83,
      "sid": 26,
      "location": 2,
      "content": "通过我们这个led灯光的一个设置",
      "music": 0.0
    },
    {
      "from": 67.83,
      "to": 69.8,
      "sid": 27,
      "location": 2,
      "content": "进行一个光配方的不断调控",
      "music": 0.0
    },
    {
      "from": 69.8,
      "to": 71.38,
      "sid": 28,
      "location": 2,
      "content": "结合精准呃",
      "music": 0.0
    },
    {
      "from": 71.38,
      "to": 72.24,
      "sid": 29,
      "location": 2,
      "content": "补光一个措施",
      "music": 0.0
    },
    {
      "from": 72.24,
      "to": 75.63,
      "sid": 30,
      "location": 2,
      "content": "可以快速缩短水稻本身的一个繁育周期",
      "music": 0.0
    },
    {
      "from": 75.63,
      "to": 78.64,
      "sid": 31,
      "location": 2,
      "content": "为什么选择把植物工厂建在和田呢",
      "music": 0.0
    },
    {
      "from": 78.64,
      "to": 82.6,
      "sid": 32,
      "location": 2,
      "content": "首先是这项技术本身的目的就在于拓展耕地",
      "music": 0.0
    },
    {
      "from": 82.6,
      "to": 84.54,
      "sid": 33,
      "location": 2,
      "content": "加大对非耕地的利用",
      "music": 0.0
    },
    {
      "from": 84.54,
      "to": 88.4,
      "sid": 34,
      "location": 2,
      "content": "所以新疆和田的沙漠是非常理想的试验场地",
      "music": 0.0
    },
    {
      "from": 88.4,
      "to": 91.96,
      "sid": 35,
      "location": 2,
      "content": "其次和田的温室大棚大多建在沙漠上",
      "music": 0.0
    },
    {
      "from": 91.96,
      "to": 93.61,
      "sid": 36,
      "location": 2,
      "content": "建设用地成本低",
      "music": 0.0
    },
    {
      "from": 93.61,
      "to": 95.35,
      "sid": 37,
      "location": 2,
      "content": "同时日照时间长",
      "music": 0.0
    },
    {
      "from": 95.35,
      "to": 97.55,
      "sid": 38,
      "location": 2,
      "content": "可以最大限度利用自然光",
      "music": 0.0
    },
    {
      "from": 97.55,
      "to": 99.93,
      "sid": 39,
      "location": 2,
      "content": "综合运行成本低",
      "music": 0.0
    },
    {
      "from": 100.41,
      "to": 104.03,
      "sid": 40,
      "location": 2,
      "content": "我们这一次在和田探索的这种高效节能",
      "music": 0.0
    },
    {
      "from": 104.03,
      "to": 105.21,
      "sid": 41,
      "location": 2,
      "content": "沙漠联动温室",
      "music": 0.0
    },
    {
      "from": 105.21,
      "to": 109.09,
      "sid": 42,
      "location": 2,
      "content": "它的成本仅为一平方米350元左右",
      "music": 0.0
    },
    {
      "from": 109.09,
      "to": 112.47,
      "sid": 43,
      "location": 2,
      "content": "也就是说它是荷兰的玻璃温室的1/3",
      "music": 0.0
    },
    {
      "from": 112.47,
      "to": 113.29,
      "sid": 44,
      "location": 2,
      "content": "同时呢",
      "music": 0.0
    },
    {
      "from": 113.29,
      "to": 116.57,
      "sid": 45,
      "location": 2,
      "content": "我们的能耗成本也仅为荷兰玻璃温室的",
      "music": 0.0
    },
    {
      "from": 116.57,
      "to": 117.8,
      "sid": 46,
      "location": 2,
      "content": "25%左右",
      "music": 0.0
    },
    {
      "from": 117.8,
      "to": 119.0,
      "sid": 47,
      "location": 2,
      "content": "为了这种温室啊",
      "music": 0.0
    },
    {
      "from": 119.0,
      "to": 121.14,
      "sid": 48,
      "location": 2,
      "content": "可以跟新能源的结合",
      "music": 0.0
    },
    {
      "from": 121.14,
      "to": 122.3,
      "sid": 49,
      "location": 2,
      "content": "以及跟机械化",
      "music": 0.0
    },
    {
      "from": 122.3,
      "to": 124.58,
      "sid": 50,
      "location": 2,
      "content": "装备化和智能化技术的结合以后啊",
      "music": 0.0
    },
    {
      "from": 124.58,
      "to": 128.22,
      "sid": 51,
      "location": 2,
      "content": "它的建设成本和运营成本会大幅度的降低",
      "music": 0.0
    },
    {
      "from": 128.22,
      "to": 131.88,
      "sid": 52,
      "location": 2,
      "content": "未来这种温室在国际上影响有很强的竞争力",
      "music": 0.0
    }
  ]
}