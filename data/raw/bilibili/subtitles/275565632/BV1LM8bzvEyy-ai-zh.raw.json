{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.32,
      "sid": 1,
      "location": 2,
      "content": "说个很扎心的真相啊",
      "music": 0.0
    },
    {
      "from": 1.32,
      "to": 3.0,
      "sid": 2,
      "location": 2,
      "content": "就我们这个市场上最赚钱的人",
      "music": 0.0
    },
    {
      "from": 3.0,
      "to": 4.76,
      "sid": 3,
      "location": 2,
      "content": "一定是最会找卖点的人",
      "music": 0.0
    },
    {
      "from": 4.76,
      "to": 7.28,
      "sid": 4,
      "location": 2,
      "content": "而不是那些最能能帮客户解决问题的人",
      "music": 0.0
    },
    {
      "from": 7.28,
      "to": 9.44,
      "sid": 5,
      "location": 2,
      "content": "最能解决问题的人叫老实人商家",
      "music": 0.0
    },
    {
      "from": 9.44,
      "to": 11.6,
      "sid": 6,
      "location": 2,
      "content": "但是我们这个社会对老实人是很残酷的",
      "music": 0.0
    },
    {
      "from": 11.6,
      "to": 12.92,
      "sid": 7,
      "location": 2,
      "content": "他们并不是完全赚不到钱啊",
      "music": 0.0
    },
    {
      "from": 12.92,
      "to": 13.48,
      "sid": 8,
      "location": 2,
      "content": "能赚到",
      "music": 0.0
    },
    {
      "from": 13.48,
      "to": 15.26,
      "sid": 9,
      "location": 2,
      "content": "但是揣到腰包里的钱",
      "music": 0.0
    },
    {
      "from": 15.26,
      "to": 18.38,
      "sid": 10,
      "location": 2,
      "content": "和他们所展现出来的专业能力是完全不匹配的",
      "music": 0.0
    },
    {
      "from": 18.38,
      "to": 19.46,
      "sid": 11,
      "location": 2,
      "content": "最近有人来找我咨询",
      "music": 0.0
    },
    {
      "from": 19.46,
      "to": 20.22,
      "sid": 12,
      "location": 2,
      "content": "说了个什么事呢",
      "music": 0.0
    },
    {
      "from": 20.22,
      "to": 21.34,
      "sid": 13,
      "location": 2,
      "content": "他说他是帮人减肥的",
      "music": 0.0
    },
    {
      "from": 21.34,
      "to": 23.06,
      "sid": 14,
      "location": 2,
      "content": "这个事不仅在他自己身上成功了",
      "music": 0.0
    },
    {
      "from": 23.06,
      "to": 25.62,
      "sid": 15,
      "location": 2,
      "content": "在他身边很多人身上都帮别人减肥成功了",
      "music": 0.0
    },
    {
      "from": 25.62,
      "to": 28.64,
      "sid": 16,
      "location": 2,
      "content": "结果他发现那些不能真正帮别人减肥的",
      "music": 0.0
    },
    {
      "from": 28.64,
      "to": 30.16,
      "sid": 17,
      "location": 2,
      "content": "就是有点忽悠性质的一些生意",
      "music": 0.0
    },
    {
      "from": 30.16,
      "to": 31.32,
      "sid": 18,
      "location": 2,
      "content": "赚钱比他多得多",
      "music": 0.0
    },
    {
      "from": 31.32,
      "to": 32.16,
      "sid": 19,
      "location": 2,
      "content": "然后我们分析下来",
      "music": 0.0
    },
    {
      "from": 32.16,
      "to": 33.48,
      "sid": 20,
      "location": 2,
      "content": "发现这个原因其实也很简单",
      "music": 0.0
    },
    {
      "from": 33.48,
      "to": 34.72,
      "sid": 21,
      "location": 2,
      "content": "就是你要帮别人减肥",
      "music": 0.0
    },
    {
      "from": 34.72,
      "to": 35.72,
      "sid": 22,
      "location": 2,
      "content": "有两个硬性指标",
      "music": 0.0
    },
    {
      "from": 35.72,
      "to": 36.2,
      "sid": 23,
      "location": 2,
      "content": "逃不过的",
      "music": 0.0
    },
    {
      "from": 36.2,
      "to": 37.48,
      "sid": 24,
      "location": 2,
      "content": "就一个是要控制住嘴",
      "music": 0.0
    },
    {
      "from": 37.48,
      "to": 38.72,
      "sid": 25,
      "location": 2,
      "content": "一个是要基础的运动量",
      "music": 0.0
    },
    {
      "from": 38.72,
      "to": 40.56,
      "sid": 26,
      "location": 2,
      "content": "你不可能逃开这两个环节",
      "music": 0.0
    },
    {
      "from": 40.56,
      "to": 41.76,
      "sid": 27,
      "location": 2,
      "content": "说我们达到最终的成果",
      "music": 0.0
    },
    {
      "from": 41.76,
      "to": 44.8,
      "sid": 28,
      "location": 2,
      "content": "但是当你带着这样的产品去市场上去服务",
      "music": 0.0
    },
    {
      "from": 44.8,
      "to": 45.58,
      "sid": 29,
      "location": 2,
      "content": "去营销的时候",
      "music": 0.0
    },
    {
      "from": 45.58,
      "to": 47.46,
      "sid": 30,
      "location": 2,
      "content": "你会发现总会有人承诺说",
      "music": 0.0
    },
    {
      "from": 47.46,
      "to": 48.54,
      "sid": 31,
      "location": 2,
      "content": "我们不用管住嘴",
      "music": 0.0
    },
    {
      "from": 48.54,
      "to": 49.54,
      "sid": 32,
      "location": 2,
      "content": "我们也不用迈开腿",
      "music": 0.0
    },
    {
      "from": 49.54,
      "to": 50.92,
      "sid": 33,
      "location": 2,
      "content": "我们就可以实现这样的效果",
      "music": 0.0
    },
    {
      "from": 50.92,
      "to": 53.88,
      "sid": 34,
      "location": 2,
      "content": "所以当你尝试真正给客户去解决问题的时候",
      "music": 0.0
    },
    {
      "from": 53.88,
      "to": 55.98,
      "sid": 35,
      "location": 2,
      "content": "你在竞争中有的时候就会处于下风",
      "music": 0.0
    },
    {
      "from": 55.98,
      "to": 56.92,
      "sid": 36,
      "location": 2,
      "content": "你想帮他减肥",
      "music": 0.0
    },
    {
      "from": 56.92,
      "to": 57.88,
      "sid": 37,
      "location": 2,
      "content": "你就让他控制饮食",
      "music": 0.0
    },
    {
      "from": 57.88,
      "to": 59.36,
      "sid": 38,
      "location": 2,
      "content": "而他必然不想控制饮食",
      "music": 0.0
    },
    {
      "from": 59.36,
      "to": 60.8,
      "sid": 39,
      "location": 2,
      "content": "所以他就会去找其他解决方案",
      "music": 0.0
    },
    {
      "from": 60.8,
      "to": 62.08,
      "sid": 40,
      "location": 2,
      "content": "所以最终结果就很扎心",
      "music": 0.0
    },
    {
      "from": 62.08,
      "to": 64.8,
      "sid": 41,
      "location": 2,
      "content": "就是你帮他想要解决问题的这颗心",
      "music": 0.0
    },
    {
      "from": 64.8,
      "to": 65.92,
      "sid": 42,
      "location": 2,
      "content": "最终妨碍了你赚钱",
      "music": 0.0
    },
    {
      "from": 65.92,
      "to": 66.84,
      "sid": 43,
      "location": 2,
      "content": "这就跟开锁似的",
      "music": 0.0
    },
    {
      "from": 66.84,
      "to": 68.4,
      "sid": 44,
      "location": 2,
      "content": "顾客花500块钱请我去开锁",
      "music": 0.0
    },
    {
      "from": 68.4,
      "to": 69.56,
      "sid": 45,
      "location": 2,
      "content": "是因为他很着急进家门",
      "music": 0.0
    },
    {
      "from": 69.56,
      "to": 70.36,
      "sid": 46,
      "location": 2,
      "content": "等我真去了",
      "music": 0.0
    },
    {
      "from": 70.36,
      "to": 71.72,
      "sid": 47,
      "location": 2,
      "content": "一秒钟就把那所有给你捅开了",
      "music": 0.0
    },
    {
      "from": 71.72,
      "to": 72.56,
      "sid": 48,
      "location": 2,
      "content": "这时候他又不愿意了",
      "music": 0.0
    },
    {
      "from": 72.56,
      "to": 73.88,
      "sid": 49,
      "location": 2,
      "content": "说你一秒钟就赚500块钱",
      "music": 0.0
    },
    {
      "from": 73.88,
      "to": 74.56,
      "sid": 50,
      "location": 2,
      "content": "是不是太黑心了",
      "music": 0.0
    },
    {
      "from": 74.56,
      "to": 76.54,
      "sid": 51,
      "location": 2,
      "content": "所以最终结果就是我磨磨蹭蹭",
      "music": 0.0
    },
    {
      "from": 76.54,
      "to": 77.62,
      "sid": 52,
      "location": 2,
      "content": "在那表演半个小时",
      "music": 0.0
    },
    {
      "from": 77.62,
      "to": 78.18,
      "sid": 53,
      "location": 2,
      "content": "满头大汗",
      "music": 0.0
    },
    {
      "from": 78.18,
      "to": 80.18,
      "sid": 54,
      "location": 2,
      "content": "最终再花一秒钟把那索亚给他捅开",
      "music": 0.0
    },
    {
      "from": 80.18,
      "to": 80.84,
      "sid": 55,
      "location": 2,
      "content": "他就开心了",
      "music": 0.0
    },
    {
      "from": 80.84,
      "to": 82.24,
      "sid": 56,
      "location": 2,
      "content": "所以你就发现这个事很矛盾",
      "music": 0.0
    },
    {
      "from": 82.24,
      "to": 83.32,
      "sid": 57,
      "location": 2,
      "content": "一方面是我们的客户",
      "music": 0.0
    },
    {
      "from": 83.32,
      "to": 84.84,
      "sid": 58,
      "location": 2,
      "content": "不断要求我们提供解决方案",
      "music": 0.0
    },
    {
      "from": 84.84,
      "to": 85.76,
      "sid": 59,
      "location": 2,
      "content": "如果我们解决不了问题",
      "music": 0.0
    },
    {
      "from": 85.76,
      "to": 86.48,
      "sid": 60,
      "location": 2,
      "content": "就挣不了这个钱",
      "music": 0.0
    },
    {
      "from": 86.48,
      "to": 89.48,
      "sid": 61,
      "location": 2,
      "content": "但另外一方面我没有发现那些不不能解决问题",
      "music": 0.0
    },
    {
      "from": 89.48,
      "to": 91.04,
      "sid": 62,
      "location": 2,
      "content": "但是看起来能解决问题的人",
      "music": 0.0
    },
    {
      "from": 91.04,
      "to": 91.98,
      "sid": 63,
      "location": 2,
      "content": "赚的比我们多得多",
      "music": 0.0
    },
    {
      "from": 91.98,
      "to": 93.2,
      "sid": 64,
      "location": 2,
      "content": "那今天我们讲底层逻辑",
      "music": 0.0
    },
    {
      "from": 93.2,
      "to": 94.2,
      "sid": 65,
      "location": 2,
      "content": "就抠一下字眼啊",
      "music": 0.0
    },
    {
      "from": 94.2,
      "to": 95.06,
      "sid": 66,
      "location": 2,
      "content": "我们提两个词",
      "music": 0.0
    },
    {
      "from": 95.06,
      "to": 96.42,
      "sid": 67,
      "location": 2,
      "content": "需求和诉求的区别",
      "music": 0.0
    },
    {
      "from": 96.42,
      "to": 97.26,
      "sid": 68,
      "location": 2,
      "content": "比如说我要减肥",
      "music": 0.0
    },
    {
      "from": 97.26,
      "to": 98.1,
      "sid": 69,
      "location": 2,
      "content": "这个属于需求",
      "music": 0.0
    },
    {
      "from": 98.1,
      "to": 99.3,
      "sid": 70,
      "location": 2,
      "content": "无论是出于健康的考虑",
      "music": 0.0
    },
    {
      "from": 99.3,
      "to": 100.3,
      "sid": 71,
      "location": 2,
      "content": "还是出于变美的考虑",
      "music": 0.0
    },
    {
      "from": 100.3,
      "to": 101.14,
      "sid": 72,
      "location": 2,
      "content": "我们都想减肥",
      "music": 0.0
    },
    {
      "from": 101.14,
      "to": 101.88,
      "sid": 73,
      "location": 2,
      "content": "这个叫需求",
      "music": 0.0
    },
    {
      "from": 101.88,
      "to": 103.88,
      "sid": 74,
      "location": 2,
      "content": "但是有人能帮我减肥",
      "music": 0.0
    },
    {
      "from": 103.88,
      "to": 104.96,
      "sid": 75,
      "location": 2,
      "content": "就是满足了我的需求",
      "music": 0.0
    },
    {
      "from": 104.96,
      "to": 107.04,
      "sid": 76,
      "location": 2,
      "content": "不代表我会为这个事情下单",
      "music": 0.0
    },
    {
      "from": 107.04,
      "to": 109.32,
      "sid": 77,
      "location": 2,
      "content": "而真正能让我为了一个东西下单的这个东西",
      "music": 0.0
    },
    {
      "from": 109.32,
      "to": 110.06,
      "sid": 78,
      "location": 2,
      "content": "不叫需求",
      "music": 0.0
    },
    {
      "from": 110.06,
      "to": 110.7,
      "sid": 79,
      "location": 2,
      "content": "叫诉求",
      "music": 0.0
    },
    {
      "from": 110.7,
      "to": 113.08,
      "sid": 80,
      "location": 2,
      "content": "在我想要减肥这个需求背后隐藏着一个诉求",
      "music": 0.0
    },
    {
      "from": 113.08,
      "to": 115.44,
      "sid": 81,
      "location": 2,
      "content": "就是我希望我看起来像是在减肥",
      "music": 0.0
    },
    {
      "from": 115.44,
      "to": 116.12,
      "sid": 82,
      "location": 2,
      "content": "我努力了",
      "music": 0.0
    },
    {
      "from": 116.12,
      "to": 116.88,
      "sid": 83,
      "location": 2,
      "content": "我投入了",
      "music": 0.0
    },
    {
      "from": 116.88,
      "to": 117.88,
      "sid": 84,
      "location": 2,
      "content": "我找了一个解决方案",
      "music": 0.0
    },
    {
      "from": 117.88,
      "to": 119.04,
      "sid": 85,
      "location": 2,
      "content": "还花了我半个月的工资",
      "music": 0.0
    },
    {
      "from": 119.04,
      "to": 121.08,
      "sid": 86,
      "location": 2,
      "content": "哪怕最后我顺理成章的减肥失败了",
      "music": 0.0
    },
    {
      "from": 121.08,
      "to": 121.88,
      "sid": 87,
      "location": 2,
      "content": "至少我尝试过了",
      "music": 0.0
    },
    {
      "from": 121.88,
      "to": 122.94,
      "sid": 88,
      "location": 2,
      "content": "我对得起我自己",
      "music": 0.0
    },
    {
      "from": 122.94,
      "to": 124.14,
      "sid": 89,
      "location": 2,
      "content": "这个是顾客的诉求",
      "music": 0.0
    },
    {
      "from": 124.14,
      "to": 124.9,
      "sid": 90,
      "location": 2,
      "content": "这个话说出来",
      "music": 0.0
    },
    {
      "from": 124.9,
      "to": 126.14,
      "sid": 91,
      "location": 2,
      "content": "我觉得我可能是会被骂的",
      "music": 0.0
    },
    {
      "from": 126.14,
      "to": 128.06,
      "sid": 92,
      "location": 2,
      "content": "就很多人觉得我只是减肥失败了而已",
      "music": 0.0
    },
    {
      "from": 128.06,
      "to": 129.66,
      "sid": 93,
      "location": 2,
      "content": "你怎么能这么恶意的揣测我",
      "music": 0.0
    },
    {
      "from": 129.66,
      "to": 131.54,
      "sid": 94,
      "location": 2,
      "content": "但是我们拉市场数据来看",
      "music": 0.0
    },
    {
      "from": 131.54,
      "to": 134.06,
      "sid": 95,
      "location": 2,
      "content": "实际结果就是满足了用户需求的",
      "music": 0.0
    },
    {
      "from": 134.06,
      "to": 135.3,
      "sid": 96,
      "location": 2,
      "content": "商家不一定能赚到钱",
      "music": 0.0
    },
    {
      "from": 135.3,
      "to": 136.98,
      "sid": 97,
      "location": 2,
      "content": "但是我满足了你这个诉求的",
      "music": 0.0
    },
    {
      "from": 136.98,
      "to": 138.36,
      "sid": 98,
      "location": 2,
      "content": "商家往往就是能赚到钱",
      "music": 0.0
    },
    {
      "from": 138.36,
      "to": 141.24,
      "sid": 99,
      "location": 2,
      "content": "这是最终呈现出来的真金白银投票出来的结果",
      "music": 0.0
    },
    {
      "from": 141.24,
      "to": 142.5,
      "sid": 100,
      "location": 2,
      "content": "所以你看开锁的问题也一样",
      "music": 0.0
    },
    {
      "from": 142.5,
      "to": 144.02,
      "sid": 101,
      "location": 2,
      "content": "我们看需求这个事很简单",
      "music": 0.0
    },
    {
      "from": 144.02,
      "to": 144.78,
      "sid": 102,
      "location": 2,
      "content": "就是把门打开",
      "music": 0.0
    },
    {
      "from": 144.78,
      "to": 145.54,
      "sid": 103,
      "location": 2,
      "content": "让我进去就可以了",
      "music": 0.0
    },
    {
      "from": 145.54,
      "to": 147.3,
      "sid": 104,
      "location": 2,
      "content": "但是我们看诉求就远远不止这样了",
      "music": 0.0
    },
    {
      "from": 147.3,
      "to": 148.68,
      "sid": 105,
      "location": 2,
      "content": "不仅仅要把这个门打开",
      "music": 0.0
    },
    {
      "from": 148.68,
      "to": 150.04,
      "sid": 106,
      "location": 2,
      "content": "还得表明物有所值",
      "music": 0.0
    },
    {
      "from": 150.04,
      "to": 150.6,
      "sid": 107,
      "location": 2,
      "content": "你不能坑我",
      "music": 0.0
    },
    {
      "from": 150.6,
      "to": 151.2,
      "sid": 108,
      "location": 2,
      "content": "你不能误",
      "music": 0.0
    },
    {
      "from": 151.2,
      "to": 152.2,
      "sid": 109,
      "location": 2,
      "content": "一秒钟就赚500块钱",
      "music": 0.0
    },
    {
      "from": 152.2,
      "to": 152.96,
