  "body": [
    {
      "from": 0.04,
      "to": 2.48,
      "sid": 1,
      "location": 2,
      "content": "如何在24小时以内找到自己的生意",
      "music": 0.0
    },
    {
      "from": 2.48,
      "to": 3.12,
      "sid": 2,
      "location": 2,
      "content": "并开始盈利",
      "music": 0.0
    },
    {
      "from": 3.12,
      "to": 5.16,
      "sid": 3,
      "location": 2,
      "content": "这是我在两个多月以前发的一篇帖子",
      "music": 0.0
    },
    {
      "from": 5.16,
      "to": 6.6,
      "sid": 4,
      "location": 2,
      "content": "现在有30多万的阅读量",
      "music": 0.0
    },
    {
      "from": 6.6,
      "to": 7.6,
      "sid": 5,
      "location": 2,
      "content": "还有2万多个点赞",
      "music": 0.0
    },
    {
      "from": 7.6,
      "to": 8.96,
      "sid": 6,
      "location": 2,
      "content": "那这个帖子火了之后呢",
      "music": 0.0
    },
    {
      "from": 8.96,
      "to": 10.62,
      "sid": 7,
      "location": 2,
      "content": "就在我的私域群里面",
      "music": 0.0
    },
    {
      "from": 10.62,
      "to": 12.82,
      "sid": 8,
      "location": 2,
      "content": "朋友圈里面还有我各大账号的后台",
      "music": 0.0
    },
    {
      "from": 12.82,
      "to": 13.34,
      "sid": 9,
      "location": 2,
      "content": "私信里面",
      "music": 0.0
    },
    {
      "from": 13.34,
      "to": 14.379,
      "sid": 10,
      "location": 2,
      "content": "有很多的人问我",
      "music": 0.0
    },
    {
      "from": 14.379,
      "to": 16.299,
      "sid": 11,
      "location": 2,
      "content": "你这么擅长找到一个从0~1的生意",
      "music": 0.0
    },
    {
      "from": 16.299,
      "to": 18.499,
      "sid": 12,
      "location": 2,
      "content": "你能不能教教我们水晶行业怎么做",
      "music": 0.0
    },
    {
      "from": 18.499,
      "to": 19.619,
      "sid": 13,
      "location": 2,
      "content": "大健康行业怎么做",
      "music": 0.0
    },
    {
      "from": 19.619,
      "to": 20.91,
      "sid": 14,
      "location": 2,
      "content": "虚拟资料行业怎么做",
      "music": 0.0
    },
    {
      "from": 20.91,
      "to": 22.95,
      "sid": 15,
      "location": 2,
      "content": "可是我说的是要找到一个赚钱的生意",
      "music": 0.0
    },
    {
      "from": 22.95,
      "to": 24.15,
      "sid": 16,
      "location": 2,
      "content": "而不是一个赚钱的行业",
      "music": 0.0
    },
    {
      "from": 24.15,
      "to": 25.77,
      "sid": 17,
      "location": 2,
      "content": "因为任何行业都可以赚钱",
      "music": 0.0
    },
    {
      "from": 25.77,
      "to": 27.93,
      "sid": 18,
      "location": 2,
      "content": "区别在于你能不能找到这个行业里面",
      "music": 0.0
    },
    {
      "from": 27.93,
      "to": 29.25,
      "sid": 19,
      "location": 2,
      "content": "正确的赚钱的方法",
      "music": 0.0
    },
    {
      "from": 29.25,
      "to": 30.61,
      "sid": 20,
      "location": 2,
      "content": "所以很反直觉的一点是",
      "music": 0.0
    },
    {
      "from": 30.61,
      "to": 32.97,
      "sid": 21,
      "location": 2,
      "content": "我觉得你必须把赛道和行业这样的词",
      "music": 0.0
    },
    {
      "from": 32.97,
      "to": 34.459,
      "sid": 22,
      "location": 2,
      "content": "从你的脑子里面拿掉",
      "music": 0.0
    },
    {
      "from": 34.459,
      "to": 36.819,
      "sid": 23,
      "location": 2,
      "content": "你去专注地看一个又一个具体的生意",
      "music": 0.0
    },
    {
      "from": 36.819,
      "to": 39.26,
      "sid": 24,
      "location": 2,
      "content": "你才能更快地找到一个能赚钱的事情",
