{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.32,
      "to": 1.8,
      "sid": 1,
      "location": 2,
      "content": "之前做山姆视频的时候",
      "music": 0.0
    },
    {
      "from": 1.8,
      "to": 3.1,
      "sid": 2,
      "location": 2,
      "content": "就有很多朋友说一说",
      "music": 0.0
    },
    {
      "from": 3.1,
      "to": 5.82,
      "sid": 3,
      "location": 2,
      "content": "能不能看一下沃尔玛的甜点是什么水平",
      "music": 0.0
    },
    {
      "from": 5.82,
      "to": 7.02,
      "sid": 4,
      "location": 2,
      "content": "因为距离比较远",
      "music": 0.0
    },
    {
      "from": 7.02,
      "to": 10.38,
      "sid": 5,
      "location": 2,
      "content": "就趁国庆假期的期间帮大家来看一看",
      "music": 0.0
    },
    {
      "from": 10.38,
      "to": 12.9,
      "sid": 6,
      "location": 2,
      "content": "平时的日用百货区也就那么大同小异",
      "music": 0.0
    },
    {
      "from": 12.9,
      "to": 16.45,
      "sid": 7,
      "location": 2,
      "content": "还是去看看我比较关心的零食区和烘焙区吧",
      "music": 0.0
    },
    {
      "from": 16.45,
      "to": 20.13,
      "sid": 8,
      "location": 2,
      "content": "巧克力可颂主打是巧克力味西点酱",
      "music": 0.0
    },
    {
      "from": 20.13,
      "to": 23.17,
      "sid": 9,
      "location": 2,
      "content": "同类产品在山姆一般宣传的是比利时巧克力",
      "music": 0.0
    },
    {
      "from": 23.17,
      "to": 24.46,
      "sid": 10,
      "location": 2,
      "content": "和欧洲进口黄油",
      "music": 0.0
    },
    {
      "from": 24.46,
      "to": 26.28,
      "sid": 11,
      "location": 2,
      "content": "定位区分还是很明显的",
      "music": 0.0
    },
    {
      "from": 26.28,
      "to": 27.36,
      "sid": 12,
      "location": 2,
      "content": "主打的巧克力酱",
      "music": 0.0
    },
    {
      "from": 27.36,
      "to": 29.88,
      "sid": 13,
      "location": 2,
      "content": "主要用的是精炼植物油和可可粉",
      "music": 0.0
    },
    {
      "from": 29.88,
      "to": 32.28,
      "sid": 14,
      "location": 2,
      "content": "面包起酥也是用的人造黄油",
      "music": 0.0
    },
    {
      "from": 32.28,
      "to": 35.269,
      "sid": 15,
      "location": 2,
      "content": "山姆和沃尔玛经常会推出同类产品",
      "music": 0.0
    },
    {
      "from": 35.269,
      "to": 37.909,
      "sid": 16,
      "location": 2,
      "content": "但食材和工艺完全是两个水平",
      "music": 0.0
    },
    {
      "from": 37.909,
      "to": 40.649,
      "sid": 17,
      "location": 2,
      "content": "饼干和巧克力类总体来说还比较丰富",
      "music": 0.0
    },
    {
      "from": 40.649,
      "to": 42.0,
      "sid": 18,
      "location": 2,
      "content": "价钱也不算贵",
      "music": 0.0
    },
    {
      "from": 42.0,
      "to": 45.14,
      "sid": 19,
      "location": 2,
      "content": "这个焦糖饼干也很少在线下看到了正品",
      "music": 0.0
    },
    {
      "from": 45.14,
      "to": 46.59,
      "sid": 20,
      "location": 2,
      "content": "别以为我在开玩笑",
      "music": 0.0
    },
    {
      "from": 46.59,
      "to": 50.59,
      "sid": 21,
      "location": 2,
      "content": "我身边的四家大型超市卖的都是焦糖风味的",
      "music": 0.0
    },
    {
      "from": 50.59,
      "to": 51.89,
      "sid": 22,
      "location": 2,
      "content": "不知道什么玩意",
      "music": 0.0
    },
    {
      "from": 51.89,
      "to": 54.81,
      "sid": 23,
      "location": 2,
      "content": "后面看到一个叫盛田一冰的品牌",
      "music": 0.0
    },
    {
      "from": 54.81,
      "to": 56.33,
      "sid": 24,
      "location": 2,
      "content": "据说是来自澳门",
      "music": 0.0
    },
    {
      "from": 56.33,
      "to": 57.91,
      "sid": 25,
      "location": 2,
      "content": "也引起了我的注意",
      "music": 0.0
    },
    {
      "from": 57.91,
      "to": 59.84,
      "sid": 26,
      "location": 2,
      "content": "人造奶油做的蝴蝶酥",
      "music": 0.0
    },
    {
      "from": 59.84,
      "to": 61.54,
      "sid": 27,
      "location": 2,
      "content": "日语名字还写错了",
      "music": 0.0
    },
    {
      "from": 61.54,
      "to": 64.54,
      "sid": 28,
      "location": 2,
      "content": "但在接下来的柜台里还是同样的品牌",
      "music": 0.0
    },
    {
      "from": 64.54,
      "to": 66.17,
      "sid": 29,
      "location": 2,
      "content": "蝴蝶酥就是黄油做的",
      "music": 0.0
    },
    {
      "from": 66.17,
      "to": 67.73,
      "sid": 30,
      "location": 2,
      "content": "黄油大于30%",
      "music": 0.0
    },
    {
      "from": 67.73,
      "to": 69.75,
      "sid": 31,
      "location": 2,
      "content": "也没有一些奇怪的原材料",
      "music": 0.0
    },
    {
      "from": 69.75,
      "to": 71.93,
      "sid": 32,
      "location": 2,
      "content": "我买了一盒给大家探探险",
      "music": 0.0
    },
    {
      "from": 71.93,
      "to": 73.75,
      "sid": 33,
      "location": 2,
      "content": "确实有黄油的香味",
      "music": 0.0
    },
    {
      "from": 73.75,
      "to": 75.15,
      "sid": 34,
      "location": 2,
      "content": "做工也比较好",
      "music": 0.0
    },
    {
      "from": 75.15,
      "to": 76.21,
      "sid": 35,
      "location": 2,
      "content": "但是味道属实",
      "music": 0.0
    },
    {
      "from": 76.21,
      "to": 78.73,
      "sid": 36,
      "location": 2,
      "content": "一般考虑到19块九一盒的单价",
      "music": 0.0
    },
    {
      "from": 78.73,
      "to": 81.03,
      "sid": 37,
      "location": 2,
      "content": "吃着玩一下也不是不可以上楼",
      "music": 0.0
    },
    {
      "from": 81.03,
      "to": 83.48,
      "sid": 38,
      "location": 2,
      "content": "首先看到的是陈皮红豆沙精选",
      "music": 0.0
    },
    {
      "from": 83.48,
      "to": 83.88,
      "sid": 39,
      "location": 2,
      "content": "5年",
      "music": 0.0
    },
    {
      "from": 83.88,
      "to": 86.24,
      "sid": 40,
      "location": 2,
      "content": "陈皮每晚0.46克",
      "music": 0.0
    },
    {
      "from": 86.24,
      "to": 89.75,
      "sid": 41,
      "location": 2,
      "content": "和山姆在卖的陈皮红豆沙指标近似",
      "music": 0.0
    },
    {
      "from": 89.75,
      "to": 93.78,
      "sid": 42,
      "location": 2,
      "content": "难道这款产品沃尔玛是山姆的平替吉吉国王",
      "music": 0.0
    },
    {
      "from": 93.78,
      "to": 94.68,
      "sid": 43,
      "location": 2,
      "content": "你们别急",
      "music": 0.0
    },
    {
      "from": 94.68,
      "to": 96.02,
      "sid": 44,
      "location": 2,
      "content": "打开你们的计算器",
      "music": 0.0
    },
    {
      "from": 96.02,
      "to": 98.7,
      "sid": 45,
      "location": 2,
      "content": "就会发现山姆的那款更便宜",
      "music": 0.0
    },
    {
      "from": 98.7,
      "to": 100.56,
      "sid": 46,
      "location": 2,
      "content": "每一杯还多20克",
      "music": 0.0
    },
    {
      "from": 100.56,
      "to": 102.639,
      "sid": 47,
      "location": 2,
      "content": "然后就来到了烘焙区",
      "music": 0.0
    },
    {
      "from": 102.639,
      "to": 105.559,
      "sid": 48,
      "location": 2,
      "content": "第一个看到的鲜牛奶软蛋糕就让我绷不住",
      "music": 0.0
    },
    {
      "from": 105.559,
      "to": 107.379,
      "sid": 49,
      "location": 2,
      "content": "就这么一个简单的蛋糕",
      "music": 0.0
    },
    {
      "from": 107.379,
      "to": 108.579,
      "sid": 50,
      "location": 2,
      "content": "还要保湿剂",
      "music": 0.0
    },
    {
      "from": 108.579,
      "to": 109.579,
      "sid": 51,
      "location": 2,
      "content": "增稠剂",
      "music": 0.0
    },
    {
      "from": 109.579,
      "to": 111.99,
      "sid": 52,
      "location": 2,
      "content": "防腐剂都加防腐剂了",
      "music": 0.0
    },
    {
      "from": 111.99,
      "to": 113.729,
      "sid": 53,
      "location": 2,
      "content": "保质期还只有一天",
      "music": 0.0
    },
    {
      "from": 113.729,
      "to": 116.389,
      "sid": 54,
      "location": 2,
      "content": "而且蛋糕嘛鸡蛋味就可以了",
      "music": 0.0
    },
    {
      "from": 116.389,
      "to": 118.349,
      "sid": 55,
      "location": 2,
      "content": "还要往里面加固体饮料",
      "music": 0.0
    },
    {
      "from": 118.349,
      "to": 119.45,
      "sid": 56,
      "location": 2,
      "content": "加沙拉酱",
      "music": 0.0
    },
    {
      "from": 119.45,
      "to": 120.65,
      "sid": 57,
      "location": 2,
      "content": "旁边有试吃",
      "music": 0.0
    },
    {
      "from": 120.65,
      "to": 121.97,
      "sid": 58,
      "location": 2,
      "content": "我手都不敢伸",
      "music": 0.0
    },
    {
      "from": 121.97,
      "to": 125.61,
      "sid": 59,
      "location": 2,
      "content": "培根土豆芝士面包添加氨加黄油",
      "music": 0.0
    },
    {
      "from": 125.61,
      "to": 127.43,
      "sid": 60,
      "location": 2,
      "content": "分量比黑胡椒还少",
      "music": 0.0
    },
    {
      "from": 127.43,
      "to": 130.95,
      "sid": 61,
      "location": 2,
      "content": "九块九三个的面包就不要指望占什么大便宜了",
      "music": 0.0
    },
    {
      "from": 130.95,
      "to": 133.73,
      "sid": 62,
      "location": 2,
      "content": "隔壁柜台看吐司也都是差不多的问题",
      "music": 0.0
    },
    {
      "from": 133.73,
      "to": 136.42,
      "sid": 63,
      "location": 2,
      "content": "价钱便宜的面包越给油越可怕",
      "music": 0.0
    },
    {
      "from": 136.42,
      "to": 140.43,
      "sid": 64,
      "location": 2,
      "content": "软欧包和无油的全麦面包配料表就漂亮了很多",
      "music": 0.0
    },
    {
      "from": 140.43,
      "to": 144.15,
      "sid": 65,
      "location": 2,
      "content": "这就像19块九包邮的佛跳墙不一定做得好",
      "music": 0.0
    },
    {
      "from": 144.15,
      "to": 147.41,
      "sid": 66,
      "location": 2,
      "content": "但15块一碗的抄手就有可能很好吃",
      "music": 0.0
    },
    {
      "from": 147.41,
      "to": 150.53,
      "sid": 67,
      "location": 2,
      "content": "低温蛋糕百分之百使用天然动物奶油",
      "music": 0.0
    },
    {
      "from": 150.53,
      "to": 151.95,
      "sid": 68,
      "location": 2,
      "content": "非常值得表扬",
      "music": 0.0
    },
    {
      "from": 151.95,
      "to": 154.42,
      "sid": 69,
      "location": 2,
      "content": "但用的什么奶油值得我们深思",
      "music": 0.0
    },
    {
      "from": 154.42,
      "to": 157.34,
      "sid": 70,
      "location": 2,
      "content": "要知道沃尔玛的宣传语是非常准确的",
      "music": 0.0
    },
    {
      "from": 157.34,
      "to": 158.62,
      "sid": 71,
      "location": 2,
      "content": "一排产品看过去",
      "music": 0.0
    },
    {
      "from": 158.62,
      "to": 161.329,
      "sid": 72,
      "location": 2,
      "content": "我就觉得这个轻芝士蛋糕值得一试",
      "music": 0.0
    },
    {
      "from": 161.329,
      "to": 163.629,
      "sid": 73,
      "location": 2,
      "content": "不选泡芙是因为我不喜欢可思达",
      "music": 0.0
    },
    {
      "from": 163.629,
      "to": 164.889,
      "sid": 74,
      "location": 2,
      "content": "不选虎皮卷",
      "music": 0.0
    },
    {
      "from": 164.889,
      "to": 166.02,
      "sid": 75,
      "location": 2,
      "content": "是因为奶油少",
      "music": 0.0
    },
    {
      "from": 166.02,
      "to": 167.12,
      "sid": 76,
      "location": 2,
      "content": "更重要的是",
      "music": 0.0
    },
    {
      "from": 167.12,
      "to": 170.68,
      "sid": 77,
      "location": 2,
      "content": "20块钱真的可以做得出好吃的青芝士蛋糕",
      "music": 0.0
    },
    {
      "from": 170.68,
      "to": 173.72,
      "sid": 78,
      "location": 2,
      "content": "很多人在后台提到的沃尔玛提拉米苏",
      "music": 0.0
    },
    {
      "from": 173.72,
      "to": 176.8,
      "sid": 79,
      "location": 2,
      "content": "我也专门为大家看了一下小包装",
      "music": 0.0
    },
    {
      "from": 176.8,
      "to": 178.31,
      "sid": 80,
      "location": 2,
      "content": "价钱不到30",
      "music": 0.0
    },
    {
      "from": 178.31,
      "to": 180.37,
      "sid": 81,
      "location": 2,
      "content": "动物奶油进口芝士",
      "music": 0.0
    },
    {
      "from": 180.37,
      "to": 181.15,
      "sid": 82,
      "location": 2,
      "content": "翻过来看",
      "music": 0.0
    },
    {
      "from": 181.15,
      "to": 183.69,
      "sid": 83,
      "location": 2,
      "content": "配料表和山姆是同一家代工厂",
      "music": 0.0
    },
    {
      "from": 183.69,
      "to": 185.77,
      "sid": 84,
      "location": 2,
      "content": "但是奶油和芝士的量",
      "music": 0.0
    },
    {
      "from": 185.77,
      "to": 188.45,
      "sid": 85,
      "location": 2,
      "content": "包括对应的品质都有很大的差别",
      "music": 0.0
    },
    {
      "from": 188.45,
      "to": 190.709,
      "sid": 86,
      "location": 2,
      "content": "在我看来性价比是更低的",
      "music": 0.0
    },
    {
      "from": 190.709,
      "to": 193.569,
      "sid": 87,
      "location": 2,
      "content": "但是分量小本身就是它最大的优势",
      "music": 0.0
    },
    {
      "from": 193.569,
      "to": 196.02,
      "sid": 88,
      "location": 2,
      "content": "仍然属于市面上比较优秀的水平",
      "music": 0.0
    },
    {
      "from": 196.02,
      "to": 198.16,
      "sid": 89,
      "location": 2,
      "content": "这两款产品的对比说明一个问题",
      "music": 0.0
    },
    {
      "from": 198.16,
      "to": 200.56,
      "sid": 90,
      "location": 2,
      "content": "同一家公司不同档次的门店",
      "music": 0.0
    },
    {
      "from": 200.56,
      "to": 202.959,
      "sid": 91,
      "location": 2,
      "content": "卖的同一款产品品质不一样",
      "music": 0.0
    },
    {
      "from": 202.959,
      "to": 204.559,
      "sid": 92,
      "location": 2,
      "content": "再就是同一个代工厂",
      "music": 0.0
    },
    {
      "from": 204.559,
      "to": 207.87,
      "sid": 93,
      "location": 2,
      "content": "根据顾客的要求也会生产出不同的产品",
      "music": 0.0
    },
    {
      "from": 207.87,
      "to": 210.99,
      "sid": 94,
      "location": 2,
      "content": "所以以后再看到网上所谓揭秘供应链",
      "music": 0.0
    },
    {
      "from": 210.99,
      "to": 212.09,
      "sid": 95,
      "location": 2,
      "content": "揭秘代工厂",
      "music": 0.0
    },
    {
      "from": 212.09,
      "to": 213.69,
      "sid": 96,
      "location": 2,
      "content": "教你买平替的",
      "music": 0.0
    },
    {
      "from": 213.69,
      "to": 216.54,
      "sid": 97,
      "location": 2,
      "content": "欢迎直接把打在评论区",
      "music": 0.0
    },
    {
      "from": 216.54,
      "to": 217.66,
      "sid": 98,
      "location": 2,
      "content": "双层芝士蛋糕",
      "music": 0.0
    },
    {
      "from": 217.66,
      "to": 219.6,
      "sid": 99,
      "location": 2,
      "content": "我之前讲过北京华堂的出品",
      "music": 0.0
    },
    {
      "from": 219.6,
      "to": 221.12,
      "sid": 100,
      "location": 2,
      "content": "以及好利来的出品",
      "music": 0.0
    },
    {
      "from": 221.12,
      "to": 223.64,
      "sid": 101,
      "location": 2,
      "content": "沃尔玛的这款稍微不如北京华堂",
      "music": 0.0
    },
    {
      "from": 223.64,
      "to": 224.95,
      "sid": 102,
      "location": 2,
      "content": "但差距也不大",
      "music": 0.0
    },
    {
      "from": 224.95,
      "to": 226.19,
      "sid": 103,
      "location": 2,
      "content": "考虑到烘焙区",
      "music": 0.0
    },
    {
      "from": 226.19,
      "to": 230.07,
      "sid": 104,
      "location": 2,
      "content": "晚上八点钟以后经常会打七折到五折的活动",
      "music": 0.0
    },
    {
      "from": 230.07,
      "to": 232.06,
      "sid": 105,
      "location": 2,
      "content": "这时候他就是无敌的",
