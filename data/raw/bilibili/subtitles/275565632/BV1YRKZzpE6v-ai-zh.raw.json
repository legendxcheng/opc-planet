  "body": [
    {
      "from": 0.08,
      "to": 1.8,
      "sid": 1,
      "location": 2,
      "content": "如果你想在这个平台上赚到钱",
      "music": 0.0
    },
    {
      "from": 1.8,
      "to": 4.56,
      "sid": 2,
      "location": 2,
      "content": "就一定要学会站在平台的角度去思考问题",
      "music": 0.0
    },
    {
      "from": 4.56,
      "to": 5.32,
      "sid": 3,
      "location": 2,
      "content": "一定要意识到",
      "music": 0.0
    },
    {
      "from": 5.32,
      "to": 7.68,
      "sid": 4,
      "location": 2,
      "content": "我们所有人都是这个平台赚钱的工具",
      "music": 0.0
    },
    {
      "from": 7.68,
      "to": 9.08,
      "sid": 5,
      "location": 2,
      "content": "我作为平台赚钱的工具",
      "music": 0.0
    },
    {
      "from": 9.08,
      "to": 10.94,
      "sid": 6,
      "location": 2,
      "content": "我就要知道平台是怎么赚钱的",
      "music": 0.0
    },
    {
      "from": 10.94,
      "to": 13.04,
      "sid": 7,
      "location": 2,
      "content": "平台希望我成为哪个角色",
      "music": 0.0
    },
    {
      "from": 13.04,
      "to": 14.08,
      "sid": 8,
      "location": 2,
      "content": "填充哪个环节",
      "music": 0.0
    },
    {
      "from": 14.08,
      "to": 17.2,
      "sid": 9,
      "location": 2,
      "content": "我做什么才能帮助平台完成这个资本局",
      "music": 0.0
    },
    {
      "from": 17.2,
      "to": 18.56,
      "sid": 10,
      "location": 2,
      "content": "我们还是拿小红书来举例子啊",
      "music": 0.0
    },
    {
      "from": 18.56,
      "to": 20.24,
      "sid": 11,
      "location": 2,
      "content": "我们要搞清楚小红书这家平台",
      "music": 0.0
    },
    {
      "from": 20.24,
      "to": 22.04,
      "sid": 12,
      "location": 2,
      "content": "他最希望看到的景象是什么",
      "music": 0.0
    },
    {
      "from": 22.04,
      "to": 23.28,
      "sid": 13,
      "location": 2,
      "content": "当我们来到小红书的时候",
      "music": 0.0
    },
    {
      "from": 23.28,
      "to": 25.759,
      "sid": 14,
      "location": 2,
      "content": "我觉得你这是一个流量非常大的一个内容平台",
      "music": 0.0
    },
    {
      "from": 25.759,
      "to": 26.919,
      "sid": 15,
      "location": 2,
      "content": "我来到你这发笔记的时候",
      "music": 0.0
    },
    {
      "from": 26.919,
      "to": 28.279,
      "sid": 16,
      "location": 2,
      "content": "我需要平台给我分配流量",
      "music": 0.0
    },
    {
      "from": 28.279,
      "to": 30.919,
      "sid": 17,
      "location": 2,
      "content": "但是你要知道小红书他自己他也是一个产品",
      "music": 0.0
    },
    {
      "from": 30.919,
      "to": 32.8,
      "sid": 18,
      "location": 2,
      "content": "它的用户量比抖音少很多",
      "music": 0.0
    },
    {
      "from": 32.8,
      "to": 34.04,
      "sid": 19,
      "location": 2,
      "content": "它也需要增长",
      "music": 0.0
    },
    {
      "from": 34.04,
      "to": 34.88,
      "sid": 20,
      "location": 2,
      "content": "它也需要流量",
      "music": 0.0
    },
    {
      "from": 34.88,
      "to": 36.4,
      "sid": 21,
      "location": 2,
      "content": "那流量怎么去考核呢",
