    },
    {
      "from": 37.04,
      "to": 37.96,
      "sid": 23,
      "location": 2,
      "content": "第一个是用户数",
      "music": 0.0
    },
    {
      "from": 37.96,
      "to": 40.3,
      "sid": 24,
      "location": 2,
      "content": "小红书每天的活跃用户数量大概是一个亿",
      "music": 0.0
    },
    {
      "from": 40.3,
      "to": 42.22,
      "sid": 25,
      "location": 2,
      "content": "但是抖音如果算上极速版的话",
      "music": 0.0
    },
    {
      "from": 42.22,
      "to": 43.1,
      "sid": 26,
      "location": 2,
      "content": "可以超过八个亿",
      "music": 0.0
    },
    {
      "from": 43.1,
      "to": 44.8,
      "sid": 27,
      "location": 2,
      "content": "所以他还是有流量焦虑的",
      "music": 0.0
    },
    {
      "from": 44.8,
      "to": 46.84,
      "sid": 28,
      "location": 2,
      "content": "它并不是一个国民级的内容平台",
