{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 2.36,
      "sid": 1,
      "location": 2,
      "content": "核能一种很硬核的能源",
      "music": 0.0
    },
    {
      "from": 2.36,
      "to": 3.98,
      "sid": 2,
      "location": 2,
      "content": "比如说一克浓缩铀",
      "music": 0.0
    },
    {
      "from": 3.98,
      "to": 6.66,
      "sid": 3,
      "location": 2,
      "content": "就包含将近200亿卡路里的能量",
      "music": 0.0
    },
    {
      "from": 6.66,
      "to": 8.5,
      "sid": 4,
      "location": 2,
      "content": "喂爱吃饭的兄弟们有福了",
      "music": 0.0
    },
    {
      "from": 8.5,
      "to": 9.5,
      "sid": 5,
      "location": 2,
      "content": "只要吃上一克",
      "music": 0.0
    },
    {
      "from": 9.5,
      "to": 10.94,
      "sid": 6,
      "location": 2,
      "content": "无论从哪个方面说",
      "music": 0.0
    },
    {
      "from": 10.94,
      "to": 12.92,
      "sid": 7,
      "location": 2,
      "content": "你这辈子都不用再吃任何东西了",
      "music": 0.0
    },
    {
      "from": 12.92,
      "to": 14.72,
      "sid": 8,
      "location": 2,
      "content": "不过这玩意属于重金属超标",
      "music": 0.0
    },
    {
      "from": 14.72,
      "to": 15.74,
      "sid": 9,
      "location": 2,
      "content": "大家还是少吃",
      "music": 0.0
    },
    {
      "from": 15.74,
      "to": 17.24,
      "sid": 10,
      "location": 2,
      "content": "作为猛的一批的能量",
      "music": 0.0
    },
    {
      "from": 17.24,
      "to": 18.52,
      "sid": 11,
      "location": 2,
      "content": "核能是怎么没的",
      "music": 0.0
    },
    {
      "from": 18.52,
      "to": 19.14,
      "sid": 12,
      "location": 2,
      "content": "大家知道",
      "music": 0.0
    },
    {
      "from": 19.14,
      "to": 20.46,
      "sid": 13,
      "location": 2,
      "content": "但它是怎么来的呢",
      "music": 0.0
    },
    {
      "from": 20.46,
      "to": 21.2,
      "sid": 14,
      "location": 2,
      "content": "说也简单",
      "music": 0.0
    },
    {
      "from": 21.2,
      "to": 22.68,
      "sid": 15,
      "location": 2,
      "content": "核反应损失极小",
      "music": 0.0
    },
    {
      "from": 22.68,
      "to": 25.42,
      "sid": 16,
      "location": 2,
      "content": "一部分质量按照老I的智能方程与转化",
      "music": 0.0
    },
    {
      "from": 25.42,
      "to": 26.64,
      "sid": 17,
      "location": 2,
      "content": "能量就大得吓人",
      "music": 0.0
    },
    {
      "from": 26.64,
      "to": 27.68,
      "sid": 18,
      "location": 2,
      "content": "核能好就好",
      "music": 0.0
    },
    {
      "from": 27.68,
      "to": 29.02,
      "sid": 19,
      "location": 2,
      "content": "在产出比巨高",
      "music": 0.0
    },
    {
      "from": 29.02,
      "to": 30.54,
      "sid": 20,
      "location": 2,
      "content": "一顿吃饱三辈子不饿",
      "music": 0.0
    },
    {
      "from": 30.54,
      "to": 33.74,
      "sid": 21,
      "location": 2,
      "content": "所以像是哥斯拉这样的猛吃核辐射就合情合理",
      "music": 0.0
    },
    {
      "from": 33.74,
      "to": 35.1,
      "sid": 22,
      "location": 2,
      "content": "到了令人信服的地步",
      "music": 0.0
    },
    {
      "from": 35.1,
      "to": 36.22,
      "sid": 23,
      "location": 2,
      "content": "几百米高的身体",
      "music": 0.0
    },
    {
      "from": 36.22,
      "to": 38.94,
      "sid": 24,
      "location": 2,
      "content": "要是吃肉的动物们生冒烟了也不够",
      "music": 0.0
    },
    {
      "from": 38.94,
      "to": 39.78,
      "sid": 25,
      "location": 2,
      "content": "它炫的大",
      "music": 0.0
    },
    {
      "from": 39.78,
      "to": 40.76,
      "sid": 26,
      "location": 2,
      "content": "就得用核动力",
      "music": 0.0
    },
    {
      "from": 40.76,
      "to": 41.92,
      "sid": 27,
      "location": 2,
      "content": "比如说航空母舰",
      "music": 0.0
    },
    {
      "from": 41.92,
      "to": 42.68,
      "sid": 28,
      "location": 2,
      "content": "宇宙飞船",
      "music": 0.0
    },
    {
      "from": 42.68,
      "to": 44.78,
      "sid": 29,
      "location": 2,
      "content": "三体里打手枪的高手张飞海",
      "music": 0.0
    },
    {
      "from": 44.78,
      "to": 46.36,
      "sid": 30,
      "location": 2,
      "content": "用陨石子弹triple kill",
      "music": 0.0
    },
    {
      "from": 46.36,
      "to": 48.7,
      "sid": 31,
      "location": 2,
      "content": "也是为了让核动力飞船成为主流",
      "music": 0.0
    },
    {
      "from": 48.7,
      "to": 50.08,
      "sid": 32,
      "location": 2,
      "content": "才能跨星际航行",
      "music": 0.0
    },
    {
      "from": 50.08,
      "to": 53.41,
      "sid": 33,
      "location": 2,
      "content": "你看人家水滴也就核能才能续航四光年",
      "music": 0.0
    },
    {
      "from": 53.41,
      "to": 54.71,
      "sid": 34,
      "location": 2,
      "content": "10吨左右的水滴",
      "music": 0.0
    },
    {
      "from": 54.71,
      "to": 56.61,
      "sid": 35,
      "location": 2,
      "content": "即便只有一半是核物质",
      "music": 0.0
    },
    {
      "from": 56.61,
      "to": 59.07,
      "sid": 36,
      "location": 2,
      "content": "也足足能发出120万亿度的电",
      "music": 0.0
    },
    {
      "from": 59.07,
      "to": 61.02,
      "sid": 37,
      "location": 2,
      "content": "够全地球疯狂造45年的",
      "music": 0.0
    },
    {
      "from": 61.02,
      "to": 62.98,
      "sid": 38,
      "location": 2,
      "content": "要是给这十个水滴抓活的",
      "music": 0.0
    },
    {
      "from": 62.98,
      "to": 64.68,
      "sid": 39,
      "location": 2,
      "content": "拴地球上当超级充电宝",
      "music": 0.0
    },
    {
      "from": 64.68,
      "to": 66.64,
      "sid": 40,
      "location": 2,
      "content": "至少半个世纪没有能源危机了",
      "music": 0.0
    },
    {
      "from": 66.64,
      "to": 68.46,
      "sid": 41,
      "location": 2,
      "content": "那咱们要是能吃核原料",
      "music": 0.0
    },
    {
      "from": 68.46,
      "to": 70.26,
      "sid": 42,
      "location": 2,
      "content": "骑个水滴就能星辰大海了",
      "music": 0.0
    },
    {
      "from": 70.26,
      "to": 71.42,
      "sid": 43,
      "location": 2,
      "content": "饿了就吸他两口人",
      "music": 0.0
    },
    {
      "from": 71.42,
      "to": 72.42,
      "sid": 44,
      "location": 2,
      "content": "出去还得吃饭",
      "music": 0.0
    },
    {
      "from": 72.42,
      "to": 73.72,
      "sid": 45,
      "location": 2,
      "content": "吃不惯还得窜稀",
      "music": 0.0
    },
    {
      "from": 73.72,
      "to": 74.54,
      "sid": 46,
      "location": 2,
      "content": "那电能",
      "music": 0.0
    },
    {
      "from": 74.54,
      "to": 76.52,
      "sid": 47,
      "location": 2,
      "content": "一般人也分不清是葛洲坝的水电",
      "music": 0.0
    },
    {
      "from": 76.52,
      "to": 77.6,
      "sid": 48,
      "location": 2,
      "content": "还是敦煌的光电",
      "music": 0.0
    },
    {
      "from": 77.6,
      "to": 79.14,
      "sid": 49,
      "location": 2,
      "content": "毕竟即便是吃核原料",
      "music": 0.0
    },
    {
      "from": 79.14,
      "to": 80.98,
      "sid": 50,
      "location": 2,
      "content": "最后也得转化成电来供能",
      "music": 0.0
    },
    {
      "from": 80.98,
      "to": 83.8,
      "sid": 51,
      "location": 2,
      "content": "三体人要是有这技能还怕什么三体问题",
      "music": 0.0
    },
    {
      "from": 83.8,
      "to": 85.36,
      "sid": 52,
      "location": 2,
      "content": "三体星系那种环境下",
      "music": 0.0
    },
    {
      "from": 85.36,
      "to": 87.38,
      "sid": 53,
      "location": 2,
      "content": "智慧生物尚活不过几个时代",
      "music": 0.0
    },
    {
      "from": 87.38,
      "to": 88.82,
      "sid": 54,
      "location": 2,
      "content": "动植物们也就更惨了",
      "music": 0.0
    },
    {
      "from": 88.82,
      "to": 90.7,
      "sid": 55,
      "location": 2,
      "content": "而要是它们吃核原料为生",
      "music": 0.0
    },
    {
      "from": 90.7,
      "to": 92.42,
      "sid": 56,
      "location": 2,
      "content": "吃一克管三袋休眠",
      "music": 0.0
    },
    {
      "from": 92.42,
      "to": 93.22,
      "sid": 57,
      "location": 2,
      "content": "还能加续航",
      "music": 0.0
    },
    {
      "from": 93.22,
      "to": 94.18,
      "sid": 58,
      "location": 2,
      "content": "能扛核辐射",
      "music": 0.0
    },
    {
      "from": 94.18,
      "to": 95.46,
      "sid": 59,
      "location": 2,
      "content": "就能抗严寒酷暑",
      "music": 0.0
    },
    {
      "from": 96.94,
      "to": 98.44,
      "sid": 60,
      "location": 2,
      "content": "也不过微微一笑",
      "music": 0.0
    },
    {
      "from": 98.44,
      "to": 100.36,
      "sid": 61,
      "location": 2,
      "content": "更何况飞船是核能人",
      "music": 0.0
    },
    {
      "from": 100.36,
      "to": 102.56,
      "sid": 62,
      "location": 2,
      "content": "要是还吃粮食就有点不礼貌了",
      "music": 0.0
    },
    {
      "from": 102.56,
      "to": 103.64,
      "sid": 63,
      "location": 2,
      "content": "你想吃喝玩乐",
      "music": 0.0
    },
    {
      "from": 103.64,
      "to": 106.98,
      "sid": 64,
      "location": 2,
      "content": "还得在干净又卫生的高科技飞船里养猪喂牛",
      "music": 0.0
    },
    {
      "from": 106.98,
      "to": 108.26,
      "sid": 65,
      "location": 2,
      "content": "种红薯卫生",
      "music": 0.0
    },
    {
      "from": 108.26,
      "to": 109.5,
      "sid": 66,
      "location": 2,
      "content": "那就没办法卫生",
      "music": 0.0
    },
    {
      "from": 109.5,
      "to": 111.48,
      "sid": 67,
      "location": 2,
      "content": "所以人要是以核原料为食",
      "music": 0.0
    },
    {
      "from": 111.48,
      "to": 112.56,
      "sid": 68,
      "location": 2,
      "content": "岂不美哉",
      "music": 0.0
    },
    {
      "from": 112.56,
      "to": 114.4,
      "sid": 69,
      "location": 2,
      "content": "现如今咱们只能蹲在地球",
      "music": 0.0
    },
    {
      "from": 114.4,
      "to": 116.66,
      "sid": 70,
      "location": 2,
      "content": "就是因为人造生态系统搞不出来",
      "music": 0.0
    },
    {
      "from": 116.66,
      "to": 118.62,
      "sid": 71,
      "location": 2,
      "content": "要是你我个个生吃浓缩铀",
      "music": 0.0
    },
    {
      "from": 118.62,
      "to": 120.1,
      "sid": 72,
      "location": 2,
      "content": "干吃黄饼配不还",
      "music": 0.0
    },
    {
      "from": 120.1,
      "to": 122.06,
      "sid": 73,
      "location": 2,
      "content": "现在就能远征半人马座呀",
      "music": 0.0
    },
    {
      "from": 122.06,
      "to": 125.4,
      "sid": 74,
      "location": 2,
      "content": "核反应堆的最大问题就是人有点不太能承受",
      "music": 0.0
    },
    {
      "from": 125.4,
      "to": 127.68,
      "sid": 75,
      "location": 2,
      "content": "咱们之前说过一位猛男钢铁侠",
      "music": 0.0
    },
    {
      "from": 127.68,
      "to": 130.26,
      "sid": 76,
      "location": 2,
      "content": "他的核反应堆既不高温也不高压",
      "music": 0.0
    },
    {
      "from": 130.26,
      "to": 131.14,
      "sid": 77,
      "location": 2,
      "content": "还没有辐射",
      "music": 0.0
    },
    {
      "from": 131.14,
      "to": 132.72,
      "sid": 78,
      "location": 2,
      "content": "这要是能植入人体",
      "music": 0.0
    },
    {
      "from": 132.72,
      "to": 134.56,
      "sid": 79,
      "location": 2,
      "content": "岂不是就能实现咱们的想法",
      "music": 0.0
    },
    {
      "from": 134.56,
      "to": 135.72,
      "sid": 80,
      "location": 2,
      "content": "把什么大嘴子",
      "music": 0.0
    },
    {
      "from": 135.72,
      "to": 136.44,
      "sid": 81,
      "location": 2,
      "content": "食管子",
      "music": 0.0
    },
    {
      "from": 136.44,
      "to": 137.2,
      "sid": 82,
      "location": 2,
      "content": "肠子肚子皮",
      "music": 0.0
    },
    {
      "from": 137.2,
      "to": 138.82,
      "sid": 83,
      "location": 2,
      "content": "燕子一整套全切了",
      "music": 0.0
    },
    {
      "from": 138.82,
      "to": 140.46,
      "sid": 84,
      "location": 2,
      "content": "上面换成钢铁侠的反应堆",
      "music": 0.0
    },
    {
      "from": 140.46,
      "to": 141.28,
      "sid": 85,
      "location": 2,
      "content": "下面发电",
      "music": 0.0
    },
    {
      "from": 141.28,
      "to": 143.0,
      "sid": 86,
      "location": 2,
      "content": "一方面当做攻击性武器",
      "music": 0.0
    },
    {
      "from": 143.0,
      "to": 144.02,
      "sid": 87,
      "location": 2,
      "content": "还能给手机充电",
      "music": 0.0
    },
    {
      "from": 144.02,
      "to": 145.82,
      "sid": 88,
      "location": 2,
      "content": "另一方面用电合成ATP",
      "music": 0.0
    },
    {
      "from": 145.82,
      "to": 147.28,
      "sid": 89,
      "location": 2,
      "content": "直接给全身细胞供能",
      "music": 0.0
    },
    {
      "from": 147.28,
      "to": 149.56,
      "sid": 90,
      "location": 2,
      "content": "钢铁侠这一套叫做冷核反应堆",
      "music": 0.0
    },
    {
      "from": 149.56,
      "to": 150.54,
      "sid": 91,
      "location": 2,
      "content": "加点重元素",
      "music": 0.0
    },
    {
      "from": 150.54,
      "to": 151.76,
      "sid": 92,
      "location": 2,
      "content": "常温常压就能反应",
      "music": 0.0
    },
    {
      "from": 151.76,
      "to": 153.84,
      "sid": 93,
      "location": 2,
      "content": "装修口上不疼不痒不烧心",
      "music": 0.0
    },
    {
      "from": 153.84,
      "to": 154.68,
      "sid": 94,
      "location": 2,
      "content": "如果实现了",
      "music": 0.0
    },
    {
      "from": 154.68,
      "to": 156.38,
      "sid": 95,
      "location": 2,
      "content": "咱们个个都是核动力超人了",
      "music": 0.0
    },
    {
      "from": 156.38,
      "to": 158.74,
      "sid": 96,
      "location": 2,
      "content": "想象一下以后还接什么电网呀",
      "music": 0.0
    },
    {
      "from": 158.74,
      "to": 160.22,
      "sid": 97,
      "location": 2,
      "content": "手机拿手里就能充电",
      "music": 0.0
    },
    {
      "from": 160.22,
      "to": 161.82,
      "sid": 98,
      "location": 2,
      "content": "家里电脑冰箱洗衣机",
      "music": 0.0
    },
    {
      "from": 161.82,
      "to": 162.5,
      "sid": 99,
      "location": 2,
      "content": "空调风扇",
      "music": 0.0
    },
    {
      "from": 162.5,
      "to": 164.22,
      "sid": 100,
      "location": 2,
      "content": "吸尘器就全连你身上了",
      "music": 0.0
    },
    {
      "from": 164.22,
      "to": 166.06,
      "sid": 101,
      "location": 2,
      "content": "以前出门是车给你充电",
      "music": 0.0
    },
    {
      "from": 166.06,
      "to": 167.34,
      "sid": 102,
      "location": 2,
      "content": "现在是你给车充电",
      "music": 0.0
    },
    {
      "from": 167.34,
      "to": 168.4,
      "sid": 103,
      "location": 2,
      "content": "还考虑什么续航",
      "music": 0.0
    },
    {
      "from": 168.4,
      "to": 169.14,
      "sid": 104,
      "location": 2,
      "content": "你吃饱了",
      "music": 0.0
    },
    {
      "from": 169.14,
      "to": 169.94,
      "sid": 105,
      "location": 2,
      "content": "车就是满电",
      "music": 0.0
    },
    {
      "from": 169.94,
      "to": 170.88,
      "sid": 106,
      "location": 2,
      "content": "你使劲越大",
      "music": 0.0
    },
    {
      "from": 170.88,
      "to": 172.34,
      "sid": 107,
      "location": 2,
      "content": "车百公里加速就越强",
      "music": 0.0
    },
    {
      "from": 172.34,
      "to": 174.08,
      "sid": 108,
      "location": 2,
      "content": "最重要的是这辈子不用吃",
      "music": 0.0
    },
    {
      "from": 174.08,
      "to": 174.98,
      "sid": 109,
      "location": 2,
      "content": "也就不用拉",
