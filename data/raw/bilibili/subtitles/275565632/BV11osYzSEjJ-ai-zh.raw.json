  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.96,
      "sid": 1,
      "location": 2,
      "content": "直到今天还在谈精准人群",
      "music": 0.0
    },
    {
      "from": 1.96,
      "to": 2.92,
      "sid": 2,
      "location": 2,
      "content": "精准流量这个概念呢",
      "music": 0.0
    },
    {
      "from": 2.92,
      "to": 4.6,
      "sid": 3,
      "location": 2,
      "content": "我觉得咱互联网这碗饭可以不用吃了",
      "music": 0.0
    },
    {
      "from": 4.6,
      "to": 6.04,
      "sid": 4,
      "location": 2,
      "content": "就是精准人群这四个大字",
      "music": 0.0
    },
    {
      "from": 6.04,
      "to": 7.96,
      "sid": 5,
      "location": 2,
      "content": "一说出口赚钱这个事就跟我没什么关系了",
      "music": 0.0
    },
    {
      "from": 7.96,
      "to": 10.52,
      "sid": 6,
      "location": 2,
      "content": "咱今天就用一个视频把这两个概念彻底盘清楚",
      "music": 0.0
    },
    {
      "from": 10.52,
      "to": 12.84,
      "sid": 7,
      "location": 2,
      "content": "就讲一讲互联网上的钱到底是怎么挣的",
      "music": 0.0
    },
    {
      "from": 12.84,
      "to": 14.58,
      "sid": 8,
      "location": 2,
      "content": "互联网上的商品到底是怎么卖出去的",
      "music": 0.0
    },
    {
      "from": 14.58,
      "to": 16.98,
      "sid": 9,
      "location": 2,
      "content": "首先所有让你觉得听起来很别扭",
      "music": 0.0
    },
    {
      "from": 16.98,
      "to": 19.18,
      "sid": 10,
      "location": 2,
      "content": "无法解释现实生活中这些情况的",
      "music": 0.0
    },
    {
      "from": 19.18,
      "to": 20.18,
      "sid": 11,
      "location": 2,
      "content": "这些错误的用词",
      "music": 0.0
    },
    {
      "from": 20.18,
      "to": 22.02,
      "sid": 12,
      "location": 2,
      "content": "它背后都隐藏着错误的假设",
      "music": 0.0
    },
    {
      "from": 22.02,
      "to": 23.24,
      "sid": 13,
      "location": 2,
      "content": "就比如说这个精准人群",
      "music": 0.0
    },
    {
      "from": 23.24,
      "to": 24.92,
      "sid": 14,
      "location": 2,
      "content": "它背后的隐藏的假设是",
      "music": 0.0
    },
    {
      "from": 24.92,
      "to": 28.14,
      "sid": 15,
      "location": 2,
      "content": "人分为精准的人和不精准的人这两种对吧",
      "music": 0.0
    },
    {
      "from": 28.14,
      "to": 29.22,
      "sid": 16,
      "location": 2,
      "content": "否则怎么会有这个词呢",
      "music": 0.0
    },
    {
      "from": 29.22,
      "to": 31.14,
      "sid": 17,
      "location": 2,
      "content": "那我们是不是还知道另外一个概念叫转化",
      "music": 0.0
    },
    {
      "from": 31.14,
      "to": 33.54,
      "sid": 18,
      "location": 2,
      "content": "就如果人分为精准和不精准的两种",
      "music": 0.0
    },
    {
      "from": 33.54,
      "to": 36.12,
      "sid": 19,
      "location": 2,
      "content": "那你从医院产房里面爆出来你的基因",
      "music": 0.0
    },
    {
      "from": 36.12,
      "to": 37.56,
      "sid": 20,
      "location": 2,
      "content": "你的DNA里边就写死了",
      "music": 0.0
    },
    {
      "from": 37.56,
      "to": 38.64,
      "sid": 21,
      "location": 2,
      "content": "你一定会买我的商品",
      "music": 0.0
    },
    {
      "from": 38.64,
      "to": 39.4,
      "sid": 22,
      "location": 2,
      "content": "这叫精准对吧",
      "music": 0.0
    },
    {
      "from": 39.4,
      "to": 40.28,
      "sid": 23,
      "location": 2,
      "content": "你是精准的人呢",
      "music": 0.0
    },
    {
      "from": 40.28,
      "to": 41.72,
      "sid": 24,
      "location": 2,
      "content": "那我为什么还要转化你",
      "music": 0.0
    },
    {
      "from": 41.72,
      "to": 43.8,
      "sid": 25,
      "location": 2,
      "content": "我为什么还要优化我的直播间话术",
      "music": 0.0
    },
    {
      "from": 43.8,
      "to": 44.96,
      "sid": 26,
      "location": 2,
      "content": "优化我的商品详情页",
      "music": 0.0
    },
    {
      "from": 44.96,
      "to": 46.44,
      "sid": 27,
      "location": 2,
      "content": "优化我的门店招牌对吧",
      "music": 0.0
    },
    {
      "from": 46.44,
      "to": 47.28,
      "sid": 28,
      "location": 2,
      "content": "你本来就很精准",
      "music": 0.0
    },
    {
      "from": 47.28,
      "to": 48.0,
      "sid": 29,
      "location": 2,
      "content": "我转化你干嘛",
      "music": 0.0
    },
    {
      "from": 48.0,
      "to": 48.82,
      "sid": 30,
      "location": 2,
      "content": "那我们就要说了",
      "music": 0.0
    },
    {
      "from": 48.82,
      "to": 50.9,
      "sid": 31,
      "location": 2,
      "content": "所有的概念和词汇的出现",
      "music": 0.0
    },
    {
      "from": 50.9,
      "to": 51.8,
      "sid": 32,
      "location": 2,
      "content": "它都不是空穴来风",
      "music": 0.0
    },
    {
      "from": 51.8,
      "to": 53.66,
      "sid": 33,
      "location": 2,
      "content": "我们通过如此简单的分析",
      "music": 0.0
    },
    {
      "from": 53.66,
      "to": 55.62,
      "sid": 34,
      "location": 2,
      "content": "就会发现这个概念错的如此的离谱",
      "music": 0.0
    },
    {
      "from": 55.62,
      "to": 57.5,
      "sid": 35,
      "location": 2,
      "content": "那为什么这个概念还能传播开对吧",
      "music": 0.0
    },
    {
      "from": 57.5,
      "to": 58.62,
      "sid": 36,
      "location": 2,
      "content": "你在抖音上一搜一大堆",
      "music": 0.0
    },
    {
      "from": 58.62,
      "to": 61.02,
      "sid": 37,
      "location": 2,
      "content": "原因是这个概念还是切实的帮助到了一些人",
      "music": 0.0
    },
    {
      "from": 61.02,
      "to": 62.3,
      "sid": 38,
      "location": 2,
      "content": "但是也产生了很深的误导",
      "music": 0.0
    },
    {
      "from": 62.3,
      "to": 64.66,
      "sid": 39,
      "location": 2,
      "content": "比如说有一些想干自媒体的外行对吧",
      "music": 0.0
    },
    {
      "from": 64.66,
      "to": 66.98,
      "sid": 40,
      "location": 2,
      "content": "小白我发现有流量就有金钱",
      "music": 0.0
    },
    {
      "from": 66.98,
      "to": 68.7,
      "sid": 41,
      "location": 2,
      "content": "或者说掌握了钱的人",
      "music": 0.0
    },
    {
      "from": 68.7,
      "to": 69.86,
      "sid": 42,
      "location": 2,
      "content": "通常他有巨大的流量",
      "music": 0.0
    },
    {
      "from": 69.86,
      "to": 71.18,
      "sid": 43,
      "location": 2,
      "content": "那我搞流量我又很痛苦",
      "music": 0.0
    },
    {
      "from": 71.18,
      "to": 71.64,
      "sid": 44,
      "location": 2,
      "content": "怎么办呢",
      "music": 0.0
    },
    {
      "from": 71.64,
      "to": 73.98,
      "sid": 45,
      "location": 2,
      "content": "我看见哪个明星这个出轨离婚了对吧",
      "music": 0.0
    },
    {
      "from": 73.98,
      "to": 75.28,
      "sid": 46,
      "location": 2,
      "content": "我看见西贝有个什么什么新闻",
      "music": 0.0
    },
    {
      "from": 75.28,
      "to": 76.08,
      "sid": 47,
      "location": 2,
      "content": "我就跟这个流量",
      "music": 0.0
    },
    {
      "from": 76.08,
      "to": 78.54,
      "sid": 48,
      "location": 2,
      "content": "然后呢发现这个东西不转化不赚钱呢",
      "music": 0.0
    },
    {
      "from": 78.54,
      "to": 79.84,
      "sid": 49,
      "location": 2,
      "content": "所以管这个东西叫泛流量",
      "music": 0.0
    },
    {
      "from": 79.84,
      "to": 80.52,
      "sid": 50,
      "location": 2,
      "content": "什么叫泛流量",
      "music": 0.0
    },
    {
      "from": 80.52,
      "to": 81.98,
      "sid": 51,
      "location": 2,
      "content": "就是我凭什么",
      "music": 0.0
    },
    {
      "from": 81.98,
      "to": 85.08,
      "sid": 52,
      "location": 2,
      "content": "因为你发了一些这个西贝贾老板的事情",
      "music": 0.0
    },
    {
      "from": 85.08,
      "to": 86.36,
      "sid": 53,
      "location": 2,
      "content": "就你买你们家的袜子",
      "music": 0.0
    },
    {
      "from": 86.36,
      "to": 87.12,
      "sid": 54,
      "location": 2,
      "content": "买你们家的水杯",
      "music": 0.0
    },
    {
      "from": 87.12,
      "to": 88.08,
      "sid": 55,
      "location": 2,
      "content": "买你买巧克力呢对吧",
      "music": 0.0
    },
    {
      "from": 88.08,
      "to": 88.6,
      "sid": 56,
      "location": 2,
      "content": "不转化",
      "music": 0.0
    },
    {
      "from": 88.6,
      "to": 90.66,
      "sid": 57,
      "location": 2,
      "content": "于是就有一些自媒体导师冒出来说",
      "music": 0.0
    },
    {
      "from": 90.66,
      "to": 91.96,
      "sid": 58,
      "location": 2,
      "content": "你别发这些泛流量",
      "music": 0.0
    },
    {
      "from": 91.96,
      "to": 93.72,
      "sid": 59,
      "location": 2,
      "content": "你发一些所谓的精准流量",
      "music": 0.0
    },
    {
      "from": 93.72,
      "to": 94.56,
      "sid": 60,
      "location": 2,
      "content": "你是卖袜子的",
      "music": 0.0
    },
    {
      "from": 94.56,
      "to": 95.76,
      "sid": 61,
      "location": 2,
      "content": "你就天天宣传你的袜子",
      "music": 0.0
    },
    {
      "from": 95.76,
      "to": 97.36,
      "sid": 62,
      "location": 2,
      "content": "虽然没有人愿意看你的内容",
      "music": 0.0
    },
    {
      "from": 97.36,
      "to": 99.16,
      "sid": 63,
      "location": 2,
      "content": "但是流量来的精准呀",
      "music": 0.0
    },
    {
      "from": 99.16,
      "to": 100.24,
      "sid": 64,
      "location": 2,
      "content": "你多多少少能转化呀",
      "music": 0.0
    },
    {
      "from": 100.24,
      "to": 101.74,
      "sid": 65,
      "location": 2,
      "content": "这个叫低粉高变现对吧",
      "music": 0.0
    },
    {
      "from": 101.74,
      "to": 104.26,
      "sid": 66,
      "location": 2,
      "content": "我们用精准的内容去获取精准的流量",
      "music": 0.0
    },
    {
      "from": 104.26,
      "to": 106.36,
      "sid": 67,
      "location": 2,
      "content": "把精准的人群灌过来做精准转换",
      "music": 0.0
    },
    {
      "from": 106.36,
      "to": 107.94,
      "sid": 68,
      "location": 2,
      "content": "那么想想这背后到底发生了什么",
      "music": 0.0
    },
    {
      "from": 107.94,
      "to": 108.8,
      "sid": 69,
      "location": 2,
      "content": "什么叫泛流量",
      "music": 0.0
    },
    {
      "from": 108.8,
      "to": 110.48,
      "sid": 70,
      "location": 2,
      "content": "泛流量背后难道是泛人群吗",
      "music": 0.0
    },
    {
      "from": 110.48,
      "to": 113.12,
      "sid": 71,
      "location": 2,
      "content": "就是我从医院产房里出生的时候啊",
      "music": 0.0
    },
    {
      "from": 113.12,
      "to": 114.96,
      "sid": 72,
      "location": 2,
      "content": "我就是有着泛的DNA",
      "music": 0.0
    },
    {
      "from": 114.96,
      "to": 116.08,
      "sid": 73,
      "location": 2,
      "content": "然后你们家发了袜子",
      "music": 0.0
    },
    {
      "from": 116.08,
      "to": 117.22,
      "sid": 74,
      "location": 2,
      "content": "我就不可能买对吧",
      "music": 0.0
    },
    {
      "from": 117.22,
      "to": 119.22,
      "sid": 75,
      "location": 2,
      "content": "最后等你把袜子拍成精美的视频之后",
      "music": 0.0
    },
    {
      "from": 119.22,
      "to": 120.54,
      "sid": 76,
      "location": 2,
      "content": "我又基因突变了对吧",
      "music": 0.0
    },
    {
      "from": 120.54,
      "to": 122.9,
      "sid": 77,
      "location": 2,
      "content": "我从泛基因突变成了精准基因",
      "music": 0.0
    },
    {
      "from": 122.9,
      "to": 123.74,
      "sid": 78,
      "location": 2,
      "content": "我就买你们家袜子了",
      "music": 0.0
    },
    {
      "from": 123.74,
      "to": 124.34,
      "sid": 79,
      "location": 2,
      "content": "是这样吗",
      "music": 0.0
    },
    {
      "from": 124.34,
      "to": 125.98,
      "sid": 80,
      "location": 2,
      "content": "所以你就会发现人群这个概念",
      "music": 0.0
    },
    {
      "from": 125.98,
      "to": 127.42,
      "sid": 81,
      "location": 2,
      "content": "他是尝试带给人做分类",
      "music": 0.0
    },
    {
      "from": 127.42,
      "to": 130.18,
      "sid": 82,
      "location": 2,
      "content": "但是你们会发现给人做分类这套理论",
      "music": 0.0
    },
    {
      "from": 130.18,
      "to": 131.14,
      "sid": 83,
      "location": 2,
      "content": "这套思维模型",
      "music": 0.0
    },
    {
      "from": 131.14,
      "to": 134.06,
      "sid": 84,
      "location": 2,
      "content": "他无法解释我们在日常生活中所观察的",
      "music": 0.0
    },
    {
      "from": 134.06,
      "to": 134.88,
      "sid": 85,
      "location": 2,
      "content": "那些商业现象",
      "music": 0.0
    },
    {
      "from": 134.88,
      "to": 137.74,
      "sid": 86,
      "location": 2,
      "content": "所以我们尝试提出一个更好的模型来解释",
      "music": 0.0
    },
    {
      "from": 137.74,
      "to": 138.46,
      "sid": 87,
      "location": 2,
      "content": "商业现象",
      "music": 0.0
    },
    {
      "from": 138.46,
      "to": 140.76,
      "sid": 88,
      "location": 2,
      "content": "叫做人看见了内容之后",
      "music": 0.0
    },
    {
      "from": 140.76,
      "to": 142.06,
      "sid": 89,
      "location": 2,
      "content": "然后被转化了",
      "music": 0.0
    },
    {
      "from": 142.06,
      "to": 143.48,
      "sid": 90,
      "location": 2,
      "content": "再去购买你的产品",
      "music": 0.0
    },
    {
      "from": 143.48,
      "to": 145.86,
      "sid": 91,
      "location": 2,
      "content": "当你脑子里面把精准人群四个大字给干掉",
      "music": 0.0
    },
    {
      "from": 145.86,
      "to": 147.1,
      "sid": 92,
      "location": 2,
      "content": "换成这套公式之后",
      "music": 0.0
    },
    {
      "from": 147.1,
      "to": 148.54,
      "sid": 93,
      "location": 2,
      "content": "很多现象解释的通了对吧",
      "music": 0.0
    },
    {
      "from": 148.54,
      "to": 150.5,
      "sid": 94,
      "location": 2,
      "content": "为什么直播间有POA的话术",
      "music": 0.0
    },
    {
      "from": 150.5,
      "to": 151.42,
      "sid": 95,
      "location": 2,
      "content": "有编段的话术",
      "music": 0.0
    },
    {
      "from": 151.42,
      "to": 152.98,
      "sid": 96,
      "location": 2,
      "content": "为什么我点进商品详情页",
      "music": 0.0
    },
    {
      "from": 152.98,
      "to": 154.66,
      "sid": 97,
      "location": 2,
      "content": "有买家秀有好评",
      "music": 0.0
    },
    {
      "from": 154.66,
      "to": 156.04,
      "sid": 98,
      "location": 2,
      "content": "为什么要给我搞价格歧视",
      "music": 0.0
    },
    {
      "from": 156.04,
      "to": 157.86,
      "sid": 99,
      "location": 2,
      "content": "是因为他们在做内容呀",
      "music": 0.0
    },
    {
      "from": 157.86,
      "to": 158.84,
      "sid": 100,
      "location": 2,
      "content": "为什么他做内容",
      "music": 0.0
    },
    {
      "from": 158.84,
      "to": 159.52,
      "sid": 101,
      "location": 2,
      "content": "做内容",
      "music": 0.0
    },
    {
      "from": 159.52,
      "to": 162.12,
      "sid": 102,
      "location": 2,
      "content": "是为了把我从一个不愿意买这个产品的人",
      "music": 0.0
    },
    {
      "from": 162.12,
      "to": 164.44,
      "sid": 103,
      "location": 2,
      "content": "或者不太愿意买这个愿意买这个产品的人",
      "music": 0.0
    },
    {
      "from": 164.44,
      "to": 167.04,
      "sid": 104,
      "location": 2,
      "content": "变成一个最终愿意为死而付款的人",
      "music": 0.0
    },
    {
      "from": 167.04,
      "to": 168.48,
      "sid": 105,
      "location": 2,
      "content": "那么这个过程叫做什么",
      "music": 0.0
    },
    {
      "from": 168.48,
      "to": 169.22,
      "sid": 106,
      "location": 2,
      "content": "叫做转化",
      "music": 0.0
    },
    {
