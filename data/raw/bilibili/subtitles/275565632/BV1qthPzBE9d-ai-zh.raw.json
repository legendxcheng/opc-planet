{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 2.16,
      "sid": 1,
      "location": 2,
      "content": "我们这个社会是一边鼓吹暴富",
      "music": 0.0
    },
    {
      "from": 2.16,
      "to": 3.72,
      "sid": 2,
      "location": 2,
      "content": "一边又对风险极度恐惧的",
      "music": 0.0
    },
    {
      "from": 3.72,
      "to": 4.52,
      "sid": 3,
      "location": 2,
      "content": "所以说句实在话",
      "music": 0.0
    },
    {
      "from": 4.52,
      "to": 6.28,
      "sid": 4,
      "location": 2,
      "content": "我觉得很多人其实是不敢挣钱的",
      "music": 0.0
    },
    {
      "from": 6.28,
      "to": 7.04,
      "sid": 5,
      "location": 2,
      "content": "我一开始说这个事",
      "music": 0.0
    },
    {
      "from": 7.04,
      "to": 7.92,
      "sid": 6,
      "location": 2,
      "content": "好多人不信啊",
      "music": 0.0
    },
    {
      "from": 7.92,
      "to": 9.24,
      "sid": 7,
      "location": 2,
      "content": "说我们这个经济都这样了",
      "music": 0.0
    },
    {
      "from": 9.24,
      "to": 10.12,
      "sid": 8,
      "location": 2,
      "content": "你还不敢挣钱",
      "music": 0.0
    },
    {
      "from": 10.12,
      "to": 11.08,
      "sid": 9,
      "location": 2,
      "content": "你不是心理变态吗",
      "music": 0.0
    },
    {
      "from": 11.08,
      "to": 13.36,
      "sid": 10,
      "location": 2,
      "content": "后来发现真不是因为我工作的特性啊",
      "music": 0.0
    },
    {
      "from": 13.36,
      "to": 14.88,
      "sid": 11,
      "location": 2,
      "content": "我就是看从0~1起步的",
      "music": 0.0
    },
    {
      "from": 14.88,
      "to": 15.96,
      "sid": 12,
      "location": 2,
      "content": "各种各样的生意特别多",
      "music": 0.0
    },
    {
      "from": 15.96,
      "to": 17.36,
      "sid": 13,
      "location": 2,
      "content": "然后和这些人聊的过程当中",
      "music": 0.0
    },
    {
      "from": 17.36,
      "to": 19.3,
      "sid": 14,
      "location": 2,
      "content": "我就发现有一些人他他非常诡异",
      "music": 0.0
    },
    {
      "from": 19.3,
      "to": 20.78,
      "sid": 15,
      "location": 2,
      "content": "甚至我都觉得有点可怕了",
      "music": 0.0
    },
    {
      "from": 20.78,
      "to": 22.06,
      "sid": 16,
      "location": 2,
      "content": "就他在跟我聊的过程中",
      "music": 0.0
    },
    {
      "from": 22.06,
      "to": 23.74,
      "sid": 17,
      "location": 2,
      "content": "表面上是找我咨询一下",
      "music": 0.0
    },
    {
      "from": 23.74,
      "to": 24.9,
      "sid": 18,
      "location": 2,
      "content": "请教一下这个事怎么干",
      "music": 0.0
    },
    {
      "from": 24.9,
      "to": 27.1,
      "sid": 19,
      "location": 2,
      "content": "但实际上他的潜台词总是想让我给他",
      "music": 0.0
    },
    {
      "from": 27.1,
      "to": 28.9,
      "sid": 20,
      "location": 2,
      "content": "一个百分之百成功的一个解决方案",
      "music": 0.0
    },
    {
      "from": 28.9,
      "to": 30.9,
      "sid": 21,
      "location": 2,
      "content": "我细想了一下这个事背后的心理动机",
      "music": 0.0
    },
    {
      "from": 30.9,
      "to": 31.78,
      "sid": 22,
      "location": 2,
      "content": "我觉得非常可怕",
      "music": 0.0
    },
    {
      "from": 31.78,
      "to": 33.54,
      "sid": 23,
      "location": 2,
      "content": "就是你想任何一个智力正常的人",
      "music": 0.0
    },
    {
      "from": 33.54,
      "to": 35.58,
      "sid": 24,
      "location": 2,
      "content": "都不可能觉得创业或者说做生意吧",
      "music": 0.0
    },
    {
      "from": 35.58,
      "to": 36.6,
      "sid": 25,
      "location": 2,
      "content": "这事成功率百分之百",
      "music": 0.0
    },
    {
      "from": 36.6,
      "to": 39.16,
      "sid": 26,
      "location": 2,
      "content": "那为什么他明知道这个事成功率不是百分之百",
      "music": 0.0
    },
    {
      "from": 39.16,
      "to": 40.08,
      "sid": 27,
      "location": 2,
      "content": "他还要问我呢",
      "music": 0.0
    },
    {
      "from": 40.08,
      "to": 41.24,
      "sid": 28,
      "location": 2,
      "content": "实际上就是因为他不想赚",
      "music": 0.0
    },
    {
      "from": 41.24,
      "to": 42.72,
      "sid": 29,
      "location": 2,
      "content": "或者准确的讲就是他不敢正",
      "music": 0.0
    },
    {
      "from": 42.72,
      "to": 44.26,
      "sid": 30,
      "location": 2,
      "content": "他觉得这个事我比他懂",
      "music": 0.0
    },
    {
      "from": 44.26,
      "to": 45.94,
      "sid": 31,
      "location": 2,
      "content": "那我都说不可能百分之百成功了",
      "music": 0.0
    },
    {
      "from": 45.94,
      "to": 47.3,
      "sid": 32,
      "location": 2,
      "content": "那他就更不可能成功了对吧",
      "music": 0.0
    },
    {
      "from": 47.3,
      "to": 49.34,
      "sid": 33,
      "location": 2,
      "content": "他就可以心安理得的把这个事情给放下来",
      "music": 0.0
    },
    {
      "from": 49.34,
      "to": 50.16,
      "sid": 34,
      "location": 2,
      "content": "他就可以不用干了",
      "music": 0.0
    },
    {
      "from": 50.16,
      "to": 51.92,
      "sid": 35,
      "location": 2,
      "content": "表面上是来咨询请教一下",
      "music": 0.0
    },
    {
      "from": 51.92,
      "to": 52.6,
      "sid": 36,
      "location": 2,
      "content": "找我问问题",
      "music": 0.0
    },
    {
      "from": 52.6,
      "to": 53.52,
      "sid": 37,
      "location": 2,
      "content": "实际上就是套话",
      "music": 0.0
    },
    {
      "from": 53.52,
      "to": 55.0,
      "sid": 38,
      "location": 2,
      "content": "他想听我亲口说出来",
      "music": 0.0
    },
    {
      "from": 55.0,
      "to": 56.4,
      "sid": 39,
      "location": 2,
      "content": "这个事的成功率不是百分之百",
      "music": 0.0
    },
    {
      "from": 56.4,
      "to": 58.52,
      "sid": 40,
      "location": 2,
      "content": "然后他就觉得哎呀创业果然有风险对吧",
      "music": 0.0
    },
    {
      "from": 58.52,
      "to": 59.48,
      "sid": 41,
      "location": 2,
      "content": "不是一般人能干的",
      "music": 0.0
    },
    {
      "from": 59.48,
      "to": 61.34,
      "sid": 42,
      "location": 2,
      "content": "他就可以心安理得的躲避起来",
      "music": 0.0
    },
    {
      "from": 61.34,
      "to": 62.12,
      "sid": 43,
      "location": 2,
      "content": "不干这个事情了",
      "music": 0.0
    },
    {
      "from": 64.84,
      "to": 65.62,
      "sid": 44,
      "location": 2,
      "content": "这个是怎么来的",
      "music": 0.0
    },
    {
      "from": 65.62,
      "to": 66.7,
      "sid": 45,
      "location": 2,
      "content": "就是我们这个社会文化里面",
      "music": 0.0
    },
    {
      "from": 66.7,
      "to": 68.06,
      "sid": 46,
      "location": 2,
      "content": "有一些非常矛盾的地方",
      "music": 0.0
    },
    {
      "from": 68.06,
      "to": 69.62,
      "sid": 47,
      "location": 2,
      "content": "第一打小就给你灌输一个观念",
      "music": 0.0
    },
    {
      "from": 69.62,
      "to": 70.58,
      "sid": 48,
      "location": 2,
      "content": "就是有钱就是牛逼",
      "music": 0.0
    },
    {
      "from": 70.58,
      "to": 71.5,
      "sid": 49,
      "location": 2,
      "content": "有钱就是人上人",
      "music": 0.0
    },
    {
      "from": 71.5,
      "to": 72.54,
      "sid": 50,
      "location": 2,
      "content": "甚至有个词叫老婆本",
      "music": 0.0
    },
    {
      "from": 72.54,
      "to": 73.58,
      "sid": 51,
      "location": 2,
      "content": "老婆本这词啥意思啊",
      "music": 0.0
    },
    {
      "from": 73.58,
      "to": 74.98,
      "sid": 52,
      "location": 2,
      "content": "就假如说你是一个雄性",
      "music": 0.0
    },
    {
      "from": 74.98,
      "to": 75.86,
      "sid": 53,
      "location": 2,
      "content": "完了你还没钱",
      "music": 0.0
    },
    {
      "from": 75.86,
      "to": 77.12,
      "sid": 54,
      "location": 2,
      "content": "挣不够这个老婆本儿的话",
      "music": 0.0
    },
    {
      "from": 77.12,
      "to": 79.48,
      "sid": 55,
      "location": 2,
      "content": "这地球上30多亿个雌性都看不上",
      "music": 0.0
    },
    {
      "from": 79.48,
      "to": 79.64,
      "sid": 56,
      "location": 2,
      "content": "你",
      "music": 0.0
    },
    {
      "from": 79.64,
      "to": 80.64,
      "sid": 57,
      "location": 2,
      "content": "说白了就是这个意思吗",
      "music": 0.0
    },
    {
      "from": 80.64,
      "to": 83.16,
      "sid": 58,
      "location": 2,
      "content": "第二从六岁开始上小学到22岁",
      "music": 0.0
    },
    {
      "from": 83.16,
      "to": 84.28,
      "sid": 59,
      "location": 2,
      "content": "一个大学本科生毕业",
      "music": 0.0
    },
    {
      "from": 84.28,
      "to": 85.36,
      "sid": 60,
      "location": 2,
      "content": "中间是16年的教育",
      "music": 0.0
    },
    {
      "from": 85.36,
      "to": 88.62,
      "sid": 61,
      "location": 2,
      "content": "这16年教育的核心就是考找一个好工作",
      "music": 0.0
    },
    {
      "from": 88.62,
      "to": 90.32,
      "sid": 62,
      "location": 2,
      "content": "然后去稳定的一个事业单位",
      "music": 0.0
    },
    {
      "from": 90.32,
      "to": 91.62,
      "sid": 63,
      "location": 2,
      "content": "大家都做着一个发财梦",
      "music": 0.0
    },
    {
      "from": 91.62,
      "to": 93.18,
      "sid": 64,
      "location": 2,
      "content": "但是你真要问起来怎么创业",
      "music": 0.0
    },
    {
      "from": 93.18,
      "to": 94.26,
      "sid": 65,
      "location": 2,
      "content": "不知道怎么注册公司",
      "music": 0.0
    },
    {
      "from": 94.26,
      "to": 95.02,
      "sid": 66,
      "location": 2,
      "content": "不知道怎么招人",
      "music": 0.0
    },
    {
      "from": 95.02,
      "to": 96.12,
      "sid": 67,
      "location": 2,
      "content": "不知道怎么投资",
      "music": 0.0
    },
    {
      "from": 96.12,
      "to": 97.88,
      "sid": 68,
      "location": 2,
      "content": "不知道美股和A股有什么区别",
      "music": 0.0
    },
    {
      "from": 97.88,
      "to": 100.2,
      "sid": 69,
      "location": 2,
      "content": "不知道那这两点带来的直接的结果就是",
      "music": 0.0
    },
    {
      "from": 100.2,
      "to": 102.48,
      "sid": 70,
      "location": 2,
      "content": "绝大多数人是没有靠自己的双手",
      "music": 0.0
    },
    {
      "from": 102.48,
      "to": 103.72,
      "sid": 71,
      "location": 2,
      "content": "在市场上赚过一分钱的",
      "music": 0.0
    },
    {
      "from": 103.72,
      "to": 105.36,
      "sid": 72,
      "location": 2,
      "content": "就哪怕是摆个摊这么简单的事情",
      "music": 0.0
    },
    {
      "from": 105.36,
      "to": 108.68,
      "sid": 73,
      "location": 2,
      "content": "对于绝大多数的大学生来说都是抽象的遥远的",
      "music": 0.0
    },
    {
      "from": 108.68,
      "to": 111.28,
      "sid": 74,
      "location": 2,
      "content": "甚至带着一些所谓的神秘感甚至恐惧感",
      "music": 0.0
    },
    {
      "from": 111.28,
      "to": 114.06,
      "sid": 75,
      "location": 2,
      "content": "那少数的在性格上可能对风险偏好比较高的人",
      "music": 0.0
    },
    {
      "from": 114.06,
      "to": 115.14,
      "sid": 76,
      "location": 2,
      "content": "可能大学尝试一下对吧",
      "music": 0.0
    },
    {
      "from": 115.14,
      "to": 116.22,
      "sid": 77,
      "location": 2,
      "content": "我开个淘宝店什么的",
      "music": 0.0
    },
    {
      "from": 116.22,
      "to": 117.86,
      "sid": 78,
      "location": 2,
      "content": "那一旦他遇到点挫折",
      "music": 0.0
    },
    {
      "from": 117.86,
      "to": 120.34,
      "sid": 79,
      "location": 2,
      "content": "他所接受的比如说来自父母长辈的安慰",
      "music": 0.0
    },
    {
      "from": 120.34,
      "to": 122.9,
      "sid": 80,
      "location": 2,
      "content": "绝对不是帮他解决店铺的流量问题",
      "music": 0.0
    },
    {
      "from": 122.9,
      "to": 124.76,
      "sid": 81,
      "location": 2,
      "content": "而是说哦你现在好好上学嘛",
      "music": 0.0
    },
    {
      "from": 124.76,
      "to": 125.88,
      "sid": 82,
      "location": 2,
      "content": "你不指着你赚钱",
      "music": 0.0
    },
    {
      "from": 125.88,
      "to": 127.52,
      "sid": 83,
      "location": 2,
      "content": "你就积累点社会经验就可以了",
      "music": 0.0
    },
    {
      "from": 127.52,
      "to": 128.58,
      "sid": 84,
      "location": 2,
      "content": "最后你该上班上班",
      "music": 0.0
    },
    {
      "from": 128.58,
      "to": 130.4,
      "sid": 85,
      "location": 2,
      "content": "潜台词就还是上班是你最终归宿嘛",
      "music": 0.0
    },
    {
      "from": 130.4,
      "to": 133.06,
      "sid": 86,
      "location": 2,
      "content": "所以从这条应试教育的这个路径走下来的人",
      "music": 0.0
    },
    {
      "from": 133.06,
      "to": 135.18,
      "sid": 87,
      "location": 2,
      "content": "就都是风险偏好极低",
      "music": 0.0
    },
    {
      "from": 135.18,
      "to": 137.18,
      "sid": 88,
      "location": 2,
      "content": "对创业做生意极其恐惧的一帮人",
      "music": 0.0
    },
    {
      "from": 137.18,
      "to": 138.94,
      "sid": 89,
      "location": 2,
      "content": "我们在文化上是鼓吹暴富的",
      "music": 0.0
    },
    {
      "from": 138.94,
      "to": 139.94,
      "sid": 90,
      "location": 2,
      "content": "鼓励你当个有钱人",
      "music": 0.0
    },
    {
      "from": 139.94,
      "to": 141.02,
      "sid": 91,
      "location": 2,
      "content": "但是教育又只教你打工",
      "music": 0.0
    },
    {
      "from": 141.02,
      "to": 142.26,
      "sid": 92,
      "location": 2,
      "content": "从来都没有市场实操",
      "music": 0.0
    },
    {
      "from": 142.26,
      "to": 143.54,
      "sid": 93,
      "location": 2,
      "content": "那少数尝试过的人",
      "music": 0.0
    },
    {
      "from": 143.54,
      "to": 145.3,
      "sid": 94,
      "location": 2,
      "content": "大概率接收到的也是负反馈",
      "music": 0.0
    },
    {
      "from": 145.3,
      "to": 146.82,
      "sid": 95,
      "location": 2,
      "content": "就是就归因为自己能力不行",
      "music": 0.0
    },
    {
      "from": 146.82,
      "to": 148.08,
      "sid": 96,
      "location": 2,
      "content": "对风险是极度恐惧的",
      "music": 0.0
    },
    {
      "from": 148.08,
      "to": 149.12,
      "sid": 97,
      "location": 2,
      "content": "只想要百分之百的成功",
      "music": 0.0
    },
    {
      "from": 149.12,
      "to": 151.4,
      "sid": 98,
      "location": 2,
      "content": "最终的结局就是完全放弃主动行动",
      "music": 0.0
    },
    {
      "from": 151.4,
      "to": 152.26,
      "sid": 99,
      "location": 2,
      "content": "彻底不会赚钱",
      "music": 0.0
    },
    {
      "from": 152.26,
      "to": 153.7,
      "sid": 100,
      "location": 2,
      "content": "然后你就理解开头我说的那帮人",
      "music": 0.0
    },
    {
      "from": 153.7,
      "to": 154.9,
      "sid": 101,
      "location": 2,
      "content": "他为什么搞一个假咨询",
      "music": 0.0
    },
    {
      "from": 154.9,
      "to": 155.46,
      "sid": 102,
      "location": 2,
      "content": "真套话了",
      "music": 0.0
    },
    {
      "from": 155.46,
      "to": 156.88,
      "sid": 103,
      "location": 2,
      "content": "就是经过这么多年的规训",
      "music": 0.0
    },
    {
      "from": 156.88,
      "to": 159.82,
      "sid": 104,
      "location": 2,
      "content": "他已经彻底认定自己是不适合赚钱的",
      "music": 0.0
    },
    {
      "from": 159.82,
      "to": 161.0,
      "sid": 105,
      "location": 2,
      "content": "就自己不是这块料了",
      "music": 0.0
    },
    {
      "from": 161.0,
      "to": 162.92,
      "sid": 106,
      "location": 2,
      "content": "然后我只是他说服自己",
      "music": 0.0
    },
    {
      "from": 162.92,
      "to": 164.9,
      "sid": 107,
      "location": 2,
      "content": "不要去创业的这个play当中的一环",
      "music": 0.0
    },
    {
