{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.32,
      "sid": 1,
      "location": 2,
      "content": "如果真的说有什么原因",
      "music": 0.0
    },
    {
      "from": 1.32,
      "to": 2.96,
      "sid": 2,
      "location": 2,
      "content": "使得我赚到了一点点的小钱",
      "music": 0.0
    },
    {
      "from": 2.96,
      "to": 5.14,
      "sid": 3,
      "location": 2,
      "content": "那就是我这个没有能力处理情绪问题",
      "music": 0.0
    },
    {
      "from": 5.14,
      "to": 6.76,
      "sid": 4,
      "location": 2,
      "content": "有的时候无能也是一种解脱",
      "music": 0.0
    },
    {
      "from": 6.76,
      "to": 7.94,
      "sid": 5,
      "location": 2,
      "content": "因为我没有这个能力",
      "music": 0.0
    },
    {
      "from": 7.94,
      "to": 10.18,
      "sid": 6,
      "location": 2,
      "content": "所以我也就没有机会再处理情绪问题上",
      "music": 0.0
    },
    {
      "from": 10.18,
      "to": 11.14,
      "sid": 7,
      "location": 2,
      "content": "花什么时间",
      "music": 0.0
    },
    {
      "from": 11.14,
      "to": 11.62,
      "sid": 8,
      "location": 2,
      "content": "我想花",
      "music": 0.0
    },
    {
      "from": 11.62,
      "to": 12.42,
      "sid": 9,
      "location": 2,
      "content": "我也花不了",
      "music": 0.0
    },
    {
      "from": 12.42,
      "to": 14.46,
      "sid": 10,
      "location": 2,
      "content": "这带来的直接结果就是我的认知",
      "music": 0.0
    },
    {
      "from": 14.46,
      "to": 16.26,
      "sid": 11,
      "location": 2,
      "content": "带宽的利用率被极大地提升了",
      "music": 0.0
    },
    {
      "from": 16.26,
      "to": 17.56,
      "sid": 12,
      "location": 2,
      "content": "因为几乎所有的情绪",
      "music": 0.0
    },
    {
      "from": 17.56,
      "to": 18.32,
      "sid": 13,
      "location": 2,
      "content": "比如焦虑等等",
      "music": 0.0
    },
    {
      "from": 18.32,
      "to": 19.6,
      "sid": 14,
      "location": 2,
      "content": "都会占用你的工作记忆",
      "music": 0.0
    },
    {
      "from": 19.6,
      "to": 20.72,
      "sid": 15,
      "location": 2,
      "content": "会窄化你的注意力",
      "music": 0.0
    },
    {
      "from": 20.72,
      "to": 23.0,
      "sid": 16,
      "location": 2,
      "content": "而创业的本质其实是信息处理",
      "music": 0.0
    },
    {
      "from": 23.0,
      "to": 25.42,
      "sid": 17,
      "location": 2,
      "content": "叫做人根据市场信号去做出决策",
      "music": 0.0
    },
    {
      "from": 25.42,
      "to": 26.76,
      "sid": 18,
      "location": 2,
      "content": "再根据决策去行动",
      "music": 0.0
    },
    {
      "from": 26.76,
      "to": 27.84,
      "sid": 19,
      "location": 2,
      "content": "而在这两个环节里面",
      "music": 0.0
    },
    {
      "from": 27.84,
      "to": 29.0,
      "sid": 20,
      "location": 2,
      "content": "情绪都会知道问题",
      "music": 0.0
    },
    {
      "from": 29.0,
      "to": 31.04,
      "sid": 21,
      "location": 2,
      "content": "第一个他会扭曲你得到的市场信号哈",
      "music": 0.0
    },
    {
      "from": 31.04,
      "to": 32.96,
      "sid": 22,
      "location": 2,
      "content": "比如我明明把一个产品介绍写的清清楚楚",
      "music": 0.0
    },
    {
      "from": 32.96,
      "to": 33.94,
      "sid": 23,
      "location": 2,
      "content": "结果老有人来问我",
      "music": 0.0
    },
    {
      "from": 33.94,
      "to": 35.46,
      "sid": 24,
      "location": 2,
      "content": "那我觉得我总共赚不要几块钱",
      "music": 0.0
    },
    {
      "from": 35.46,
      "to": 36.3,
      "sid": 25,
      "location": 2,
      "content": "你们屁事这么多",
      "music": 0.0
    },
    {
      "from": 36.3,
      "to": 38.86,
      "sid": 26,
      "location": 2,
      "content": "然后得出一个结论叫穷人的生意绝对不能做",
      "music": 0.0
    },
    {
      "from": 38.86,
      "to": 41.54,
      "sid": 27,
      "location": 2,
      "content": "这就是明一个被情绪扭曲过的市场信号",
      "music": 0.0
    },
    {
      "from": 41.54,
      "to": 42.94,
      "sid": 28,
      "location": 2,
      "content": "那真实的信号可能仅仅是",
      "music": 0.0
    },
    {
      "from": 42.94,
      "to": 44.1,
      "sid": 29,
      "location": 2,
      "content": "你把那个字写的大一点",
      "music": 0.0
    },
    {
      "from": 44.1,
      "to": 44.66,
      "sid": 30,
      "location": 2,
      "content": "显眼一点",
      "music": 0.0
    },
    {
      "from": 44.66,
      "to": 45.82,
      "sid": 31,
      "location": 2,
      "content": "问你的人就变少了",
      "music": 0.0
    },
    {
      "from": 45.82,
      "to": 48.5,
      "sid": 32,
      "location": 2,
      "content": "你的行为是可以改变这件事情出现的概率的",
      "music": 0.0
    },
    {
      "from": 48.5,
      "to": 49.46,
      "sid": 33,
      "location": 2,
      "content": "另外一个问题是",
      "music": 0.0
    },
    {
      "from": 49.46,
      "to": 51.78,
      "sid": 34,
      "location": 2,
      "content": "总有人非得把情绪问题处理完了",
      "music": 0.0
    },
    {
      "from": 51.78,
      "to": 52.66,
      "sid": 35,
      "location": 2,
      "content": "才能开始行动啊",
      "music": 0.0
    },
    {
      "from": 52.66,
      "to": 53.52,
      "sid": 36,
      "location": 2,
      "content": "比如说我发个视频",
      "music": 0.0
    },
    {
      "from": 53.52,
      "to": 54.62,
      "sid": 37,
      "location": 2,
      "content": "我非得流量好了",
      "music": 0.0
    },
    {
      "from": 54.62,
      "to": 56.86,
      "sid": 38,
      "location": 2,
      "content": "我才能发这个流量不好就得内耗个一两天",
      "music": 0.0
    },
    {
      "from": 56.86,
      "to": 57.44,
      "sid": 39,
      "location": 2,
      "content": "老有人问我",
      "music": 0.0
    },
    {
      "from": 57.44,
      "to": 58.6,
      "sid": 40,
      "location": 2,
      "content": "我说怎么你执行力这么强",
      "music": 0.0
    },
    {
      "from": 58.6,
      "to": 59.12,
      "sid": 41,
      "location": 2,
      "content": "这怎么练的",
      "music": 0.0
    },
    {
      "from": 59.12,
      "to": 61.32,
      "sid": 42,
      "location": 2,
      "content": "我说我们背后的这个因果关系刚好相反",
      "music": 0.0
    },
    {
      "from": 61.32,
      "to": 62.36,
      "sid": 43,
      "location": 2,
      "content": "我没有负面情绪",
      "music": 0.0
    },
    {
      "from": 62.36,
      "to": 63.44,
      "sid": 44,
      "location": 2,
      "content": "但是我有负面感受",
      "music": 0.0
    },
    {
      "from": 63.44,
      "to": 66.72,
      "sid": 45,
      "location": 2,
      "content": "而我的负面感受就来源于系统运行的阻力太大",
      "music": 0.0
    },
    {
      "from": 66.72,
      "to": 68.1,
      "sid": 46,
      "location": 2,
      "content": "或者是信息密度太低",
      "music": 0.0
    },
    {
      "from": 68.1,
      "to": 69.4,
      "sid": 47,
      "location": 2,
      "content": "比如今天这条视频发出去之后",
      "music": 0.0
    },
    {
      "from": 69.4,
      "to": 70.68,
      "sid": 48,
      "location": 2,
      "content": "它的流量好或者不好好",
      "music": 0.0
    },
    {
      "from": 70.68,
      "to": 71.92,
      "sid": 49,
      "location": 2,
      "content": "对我来说是没有区别的",
      "music": 0.0
    },
    {
      "from": 71.92,
      "to": 73.1,
      "sid": 50,
      "location": 2,
      "content": "我不会有什么情绪波动",
      "music": 0.0
    },
    {
      "from": 73.1,
      "to": 74.3,
      "sid": 51,
      "location": 2,
      "content": "真正让我着急的是",
      "music": 0.0
    },
    {
      "from": 74.3,
      "to": 75.98,
      "sid": 52,
      "location": 2,
      "content": "这个视频一直拖着没发出去",
      "music": 0.0
    },
    {
      "from": 75.98,
      "to": 77.26,
      "sid": 53,
      "location": 2,
      "content": "导致我看不见反馈",
      "music": 0.0
    },
    {
      "from": 77.26,
      "to": 78.22,
      "sid": 54,
      "location": 2,
      "content": "我获取不到信息",
      "music": 0.0
    },
    {
      "from": 78.22,
      "to": 79.06,
      "sid": 55,
      "location": 2,
      "content": "我收集不到信息",
      "music": 0.0
    },
    {
      "from": 79.06,
      "to": 79.86,
      "sid": 56,
      "location": 2,
      "content": "我就无法决策",
      "music": 0.0
    },
    {
      "from": 79.86,
      "to": 81.4,
      "sid": 57,
      "location": 2,
      "content": "是这个事情让我感受很差",
      "music": 0.0
    },
    {
      "from": 81.4,
      "to": 83.28,
      "sid": 58,
      "location": 2,
      "content": "至于这个视频的流量好或者不好",
      "music": 0.0
    },
    {
      "from": 83.28,
      "to": 84.14,
      "sid": 59,
      "location": 2,
      "content": "它都是信息",
      "music": 0.0
    },
    {
      "from": 84.14,
      "to": 86.66,
      "sid": 60,
      "location": 2,
      "content": "信息与信息之间是没有高低好坏之分的",
      "music": 0.0
    },
    {
      "from": 86.66,
      "to": 88.58,
      "sid": 61,
      "location": 2,
      "content": "很多人说我发了一个视频火了就正反馈",
      "music": 0.0
    },
    {
      "from": 88.58,
      "to": 89.38,
      "sid": 62,
      "location": 2,
      "content": "不火就负反馈",
      "music": 0.0
    },
    {
      "from": 89.38,
      "to": 91.0,
      "sid": 63,
      "location": 2,
      "content": "我觉得这是一个很奇怪的说法",
      "music": 0.0
    },
    {
      "from": 91.0,
      "to": 92.9,
      "sid": 64,
      "location": 2,
      "content": "反馈它不应该分正负",
      "music": 0.0
    },
    {
      "from": 92.9,
      "to": 94.08,
      "sid": 65,
      "location": 2,
      "content": "它应该分左右",
      "music": 0.0
    },
    {
      "from": 94.08,
      "to": 95.68,
      "sid": 66,
      "location": 2,
      "content": "你的视频流量好或者不好",
      "music": 0.0
    },
    {
      "from": 95.68,
      "to": 96.6,
      "sid": 67,
      "location": 2,
      "content": "它都是反馈",
      "music": 0.0
    },
    {
      "from": 96.6,
      "to": 98.6,
      "sid": 68,
      "location": 2,
      "content": "对于你的创业来说是同等重要的",
      "music": 0.0
    },
    {
      "from": 98.6,
      "to": 99.4,
      "sid": 69,
      "location": 2,
      "content": "有价值的信息",
      "music": 0.0
    },
    {
      "from": 99.4,
      "to": 100.56,
      "sid": 70,
      "location": 2,
      "content": "它怎么能分正负呢",
      "music": 0.0
    },
    {
      "from": 100.56,
      "to": 101.16,
      "sid": 71,
      "location": 2,
      "content": "所以久而久之",
      "music": 0.0
    },
    {
      "from": 101.16,
      "to": 103.38,
      "sid": 72,
      "location": 2,
      "content": "我真的是发现我们面对情绪的这种无能",
      "music": 0.0
    },
    {
      "from": 103.38,
      "to": 104.42,
      "sid": 73,
      "location": 2,
      "content": "无力和无感",
      "music": 0.0
    },
    {
      "from": 104.42,
      "to": 105.74,
      "sid": 74,
      "location": 2,
      "content": "真的帮我节约了大量的时间",
      "music": 0.0
    },
    {
      "from": 105.74,
      "to": 108.34,
      "sid": 75,
      "location": 2,
      "content": "你说身边有什么同事或者合伙人有情绪问题了",
      "music": 0.0
    },
    {
      "from": 108.34,
      "to": 109.5,
      "sid": 76,
      "location": 2,
      "content": "会不会找我来解决一下",
      "music": 0.0
    },
    {
      "from": 109.5,
      "to": 110.08,
      "sid": 77,
      "location": 2,
      "content": "不存在",
      "music": 0.0
    },
    {
      "from": 110.08,
      "to": 111.98,
      "sid": 78,
      "location": 2,
      "content": "因为我根本就解决不了",
      "music": 0.0
    },
    {
      "from": 111.98,
      "to": 113.52,
      "sid": 79,
      "location": 2,
      "content": "就好比大家都知道你没钱",
      "music": 0.0
    },
    {
      "from": 113.52,
      "to": 114.96,
      "sid": 80,
      "location": 2,
      "content": "就不可能有人找你来借钱",
      "music": 0.0
    },
    {
      "from": 114.96,
      "to": 115.88,
      "sid": 81,
      "location": 2,
      "content": "每次有人找到我",
      "music": 0.0
    },
    {
      "from": 115.88,
      "to": 117.2,
      "sid": 82,
      "location": 2,
      "content": "我都说负反馈就正反馈",
      "music": 0.0
    },
    {
      "from": 117.2,
      "to": 118.2,
      "sid": 83,
      "location": 2,
      "content": "你应该兴奋才对啊",
      "music": 0.0
    },
    {
      "from": 118.2,
      "to": 120.48,
      "sid": 84,
      "location": 2,
      "content": "那这只会让他们有更严重的情绪问题",
      "music": 0.0
    },
    {
      "from": 120.48,
      "to": 122.04,
      "sid": 85,
      "location": 2,
      "content": "所以自然而然就没有人找我",
      "music": 0.0
    },
    {
      "from": 122.04,
      "to": 123.48,
      "sid": 86,
      "location": 2,
      "content": "而我又没有什么负面情绪",
      "music": 0.0
    },
    {
      "from": 123.48,
      "to": 124.68,
      "sid": 87,
      "location": 2,
      "content": "我根本就不需要去处理",
      "music": 0.0
    },
    {
      "from": 124.68,
      "to": 126.88,
      "sid": 88,
      "location": 2,
      "content": "这又进一步的导致了我没有处理他的能力",
      "music": 0.0
    },
    {
      "from": 126.88,
      "to": 128.12,
      "sid": 89,
      "location": 2,
      "content": "因为他毕竟是个技能嘛",
      "music": 0.0
    },
    {
      "from": 128.12,
      "to": 129.0,
      "sid": 90,
      "location": 2,
      "content": "技能讲究熟能",
      "music": 0.0
    },
    {
      "from": 129.0,
      "to": 129.8,
      "sid": 91,
      "location": 2,
      "content": "我不用它",
      "music": 0.0
    },
    {
      "from": 129.8,
      "to": 130.96,
      "sid": 92,
      "location": 2,
      "content": "当然就丧失了这个能力",
      "music": 0.0
    },
    {
      "from": 130.96,
      "to": 132.36,
      "sid": 93,
      "location": 2,
      "content": "然后这时候就会有人跳出来说说",
      "music": 0.0
    },
    {
      "from": 132.36,
      "to": 133.56,
      "sid": 94,
      "location": 2,
      "content": "你这个不叫情绪稳定",
      "music": 0.0
    },
    {
      "from": 133.56,
      "to": 134.8,
      "sid": 95,
      "location": 2,
      "content": "你这个叫心理疾病",
      "music": 0.0
    },
    {
      "from": 134.8,
      "to": 136.12,
      "sid": 96,
      "location": 2,
      "content": "这个就说到点子上了",
      "music": 0.0
    },
    {
      "from": 136.12,
      "to": 137.76,
      "sid": 97,
      "location": 2,
      "content": "相关方面的书我还真没少看",
      "music": 0.0
    },
    {
      "from": 137.76,
      "to": 139.92,
      "sid": 98,
      "location": 2,
      "content": "比如按弗洛伊德的精神分析流派呢",
      "music": 0.0
    },
    {
      "from": 139.92,
      "to": 140.76,
      "sid": 99,
      "location": 2,
      "content": "认为你没有情绪",
      "music": 0.0
    },
    {
      "from": 140.76,
      "to": 141.6,
      "sid": 100,
      "location": 2,
      "content": "那显然就是个症状",
      "music": 0.0
    },
    {
      "from": 141.6,
      "to": 143.52,
      "sid": 101,
      "location": 2,
      "content": "你得治更加广为流传的一个说法",
      "music": 0.0
    },
    {
      "from": 143.52,
      "to": 145.6,
      "sid": 102,
      "location": 2,
      "content": "那叫依恋理论的这个回避型人格",
      "music": 0.0
    },
    {
      "from": 145.6,
      "to": 147.14,
      "sid": 103,
      "location": 2,
      "content": "就说你这个人他不是没有情绪",
      "music": 0.0
    },
    {
      "from": 147.14,
      "to": 148.78,
      "sid": 104,
      "location": 2,
      "content": "而是习得性的情绪隔离了",
      "music": 0.0
    },
    {
      "from": 148.78,
      "to": 150.42,
      "sid": 105,
      "location": 2,
      "content": "但是如果你再多翻译一些书的话呢",
      "music": 0.0
    },
    {
      "from": 150.42,
      "to": 152.1,
      "sid": 106,
      "location": 2,
      "content": "你可能会发现按照神经科学的说法",
      "music": 0.0
    },
    {
      "from": 152.1,
      "to": 154.34,
      "sid": 107,
      "location": 2,
      "content": "他会认为是人的这个性仁和反应比较弱",
      "music": 0.0
    },
    {
      "from": 154.34,
      "to": 157.1,
      "sid": 108,
      "location": 2,
      "content": "它是比较让你能适合高压环境的一个特点",
      "music": 0.0
    },
    {
      "from": 157.1,
      "to": 158.24,
      "sid": 109,
      "location": 2,
      "content": "它算不上是什么缺点",
