{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 2.2,
      "sid": 1,
      "location": 2,
      "content": "很希望就是说能期待",
      "music": 0.0
    },
    {
      "from": 2.2,
      "to": 4.72,
      "sid": 2,
      "location": 2,
      "content": "早日能加入咱们京东这个大家庭",
      "music": 0.0
    },
    {
      "from": 4.72,
      "to": 5.68,
      "sid": 3,
      "location": 2,
      "content": "好兄弟好",
      "music": 0.0
    },
    {
      "from": 5.68,
      "to": 6.48,
      "sid": 4,
      "location": 2,
      "content": "来起手来",
      "music": 0.0
    },
    {
      "from": 6.48,
      "to": 6.96,
      "sid": 5,
      "location": 2,
      "content": "兄弟们",
      "music": 0.0
    },
    {
      "from": 6.96,
      "to": 9.18,
      "sid": 6,
      "location": 2,
      "content": "欢迎美团饿了么兄弟加入我们京东啊",
      "music": 0.0
    },
    {
      "from": 9.18,
      "to": 12.87,
      "sid": 7,
      "location": 2,
      "content": "好当所有公司都在抖音小红书买流量的时候",
      "music": 0.0
    },
    {
      "from": 12.87,
      "to": 13.87,
      "sid": 8,
      "location": 2,
      "content": "东哥告诉大家",
      "music": 0.0
    },
    {
      "from": 13.87,
      "to": 16.25,
      "sid": 9,
      "location": 2,
      "content": "其实你也可以选择把这笔钱交到社保",
      "music": 0.0
    },
    {
      "from": 16.25,
      "to": 19.36,
      "sid": 10,
      "location": 2,
      "content": "然后你会发现流量从未如此便宜过",
      "music": 0.0
    },
    {
      "from": 19.36,
      "to": 20.12,
      "sid": 11,
      "location": 2,
      "content": "对企业而言",
      "music": 0.0
    },
    {
      "from": 20.12,
      "to": 21.88,
      "sid": 12,
      "location": 2,
      "content": "这个世界上是没有免费的流量的",
      "music": 0.0
    },
    {
      "from": 21.88,
      "to": 22.96,
      "sid": 13,
      "location": 2,
      "content": "不同形式的流量",
      "music": 0.0
    },
    {
      "from": 22.96,
      "to": 24.84,
      "sid": 14,
      "location": 2,
      "content": "只不过是把钱花到不同的地方而已",
      "music": 0.0
    },
    {
      "from": 24.84,
      "to": 25.32,
      "sid": 15,
      "location": 2,
      "content": "打广告",
      "music": 0.0
    },
    {
      "from": 25.32,
      "to": 26.32,
      "sid": 16,
      "location": 2,
      "content": "这个是直接卖流量",
      "music": 0.0
    },
    {
      "from": 26.32,
      "to": 28.02,
      "sid": 17,
      "location": 2,
      "content": "我给我的产品做一波打折促销",
      "music": 0.0
    },
    {
      "from": 28.02,
      "to": 29.12,
      "sid": 18,
      "location": 2,
      "content": "这个是变相买流量",
      "music": 0.0
    },
    {
      "from": 29.12,
      "to": 30.68,
      "sid": 19,
      "location": 2,
      "content": "雷军给苏七的车主开车门",
      "music": 0.0
    },
    {
      "from": 30.68,
      "to": 31.84,
      "sid": 20,
      "location": 2,
      "content": "这个其实还是买流量",
      "music": 0.0
    },
    {
      "from": 31.84,
      "to": 33.42,
      "sid": 21,
      "location": 2,
      "content": "雷老板耽误半天的工作时间",
      "music": 0.0
    },
    {
      "from": 33.42,
      "to": 34.86,
      "sid": 22,
      "location": 2,
      "content": "去跟小米车主握手合影",
      "music": 0.0
    },
    {
      "from": 34.86,
      "to": 35.66,
      "sid": 23,
      "location": 2,
      "content": "这个是不是成本",
      "music": 0.0
    },
    {
      "from": 35.66,
      "to": 36.34,
      "sid": 24,
      "location": 2,
      "content": "当然是成本",
      "music": 0.0
    },
    {
      "from": 36.34,
      "to": 37.94,
      "sid": 25,
      "location": 2,
      "content": "那为什么有成本还要干这个事情",
      "music": 0.0
    },
    {
      "from": 37.94,
      "to": 39.42,
      "sid": 26,
      "location": 2,
      "content": "因为这个成本投出去之后",
      "music": 0.0
    },
    {
      "from": 39.42,
      "to": 42.24,
      "sid": 27,
      "location": 2,
      "content": "你所换来的流量是你花十倍的钱都买不过来的",
      "music": 0.0
    },
    {
      "from": 42.24,
      "to": 43.6,
      "sid": 28,
      "location": 2,
      "content": "所以你这么一想就都通了",
      "music": 0.0
    },
    {
      "from": 43.6,
      "to": 45.28,
      "sid": 29,
      "location": 2,
      "content": "京东开始决定做外卖业务的时候",
      "music": 0.0
    },
    {
      "from": 45.28,
      "to": 47.62,
      "sid": 30,
      "location": 2,
      "content": "公司里面是不是有一笔广告预算肯定有啊",
      "music": 0.0
    },
    {
      "from": 47.62,
      "to": 48.58,
      "sid": 31,
      "location": 2,
      "content": "那既然有预算",
      "music": 0.0
    },
    {
      "from": 48.58,
      "to": 51.3,
      "sid": 32,
      "location": 2,
      "content": "咱们就得想一想这笔钱怎么花性价比最高",
      "music": 0.0
    },
    {
      "from": 51.3,
      "to": 51.98,
      "sid": 33,
      "location": 2,
      "content": "思来想去",
      "music": 0.0
    },
    {
      "from": 51.98,
      "to": 53.14,
      "sid": 34,
      "location": 2,
      "content": "还是给兄弟们交社保",
      "music": 0.0
    },
    {
      "from": 53.14,
      "to": 54.02,
      "sid": 35,
      "location": 2,
      "content": "性价比最高",
      "music": 0.0
    },
    {
      "from": 54.02,
      "to": 56.0,
      "sid": 36,
      "location": 2,
      "content": "一个市值100亿美金的上市公司",
      "music": 0.0
    },
    {
      "from": 56.0,
      "to": 58.58,
      "sid": 37,
      "location": 2,
      "content": "花这么大一笔钱是不可能不给资本一个交代的",
      "music": 0.0
    },
    {
      "from": 58.58,
      "to": 59.52,
      "sid": 38,
      "location": 2,
      "content": "好你要一个交代",
      "music": 0.0
    },
    {
      "from": 59.52,
      "to": 60.52,
      "sid": 39,
      "location": 2,
      "content": "那我也给你一个交代",
      "music": 0.0
    },
    {
      "from": 60.52,
      "to": 62.82,
      "sid": 40,
      "location": 2,
      "content": "给兄弟们交社保不仅仅是仁义道德",
      "music": 0.0
    },
    {
      "from": 62.82,
      "to": 64.7,
      "sid": 41,
      "location": 2,
      "content": "这还是全中国最便宜的广告",
      "music": 0.0
    },
    {
      "from": 64.7,
      "to": 65.5,
      "sid": 42,
      "location": 2,
      "content": "对美团来讲",
      "music": 0.0
    },
    {
      "from": 65.5,
      "to": 66.36,
      "sid": 43,
      "location": 2,
      "content": "社保该不该交",
      "music": 0.0
    },
    {
      "from": 66.36,
      "to": 68.1,
      "sid": 44,
      "location": 2,
      "content": "从企业社会责任的角度来讲",
      "music": 0.0
    },
    {
      "from": 68.1,
      "to": 68.94,
      "sid": 45,
      "location": 2,
      "content": "你可以说他该交",
      "music": 0.0
    },
    {
      "from": 68.94,
      "to": 70.24,
      "sid": 46,
      "location": 2,
      "content": "但是从资本的角度来讲",
      "music": 0.0
    },
    {
      "from": 70.24,
      "to": 71.48,
      "sid": 47,
      "location": 2,
      "content": "他其实是不该交的",
      "music": 0.0
    },
    {
      "from": 71.48,
      "to": 72.1,
      "sid": 48,
      "location": 2,
      "content": "在商言商",
      "music": 0.0
    },
    {
      "from": 72.1,
      "to": 73.0,
      "sid": 49,
      "location": 2,
      "content": "资本是要逐利的",
      "music": 0.0
    },
    {
      "from": 73.0,
      "to": 74.2,
      "sid": 50,
      "location": 2,
      "content": "能花五毛钱干的事",
      "music": 0.0
    },
    {
      "from": 74.2,
      "to": 75.42,
      "sid": 51,
      "location": 2,
      "content": "他肯定不会花一块钱",
      "music": 0.0
    },
    {
      "from": 75.42,
      "to": 78.18,
      "sid": 52,
      "location": 2,
      "content": "但是在美团不交社保这个事情发生了之后",
      "music": 0.0
    },
    {
      "from": 78.18,
      "to": 79.28,
      "sid": 53,
      "location": 2,
      "content": "京东该不该交呢",
      "music": 0.0
    },
    {
      "from": 79.28,
      "to": 80.1,
      "sid": 54,
      "location": 2,
      "content": "一定得交",
      "music": 0.0
    },
    {
      "from": 80.1,
      "to": 81.42,
      "sid": 55,
      "location": 2,
      "content": "因为你对兄弟们好",
      "music": 0.0
    },
    {
      "from": 81.42,
      "to": 82.28,
      "sid": 56,
      "location": 2,
      "content": "舆论就对你好",
      "music": 0.0
    },
    {
      "from": 82.28,
      "to": 83.68,
      "sid": 57,
      "location": 2,
      "content": "用户就会从你这下单",
      "music": 0.0
    },
    {
      "from": 83.68,
      "to": 85.0,
      "sid": 58,
      "location": 2,
      "content": "这个叫做获客外卖平台",
      "music": 0.0
    },
    {
      "from": 85.0,
      "to": 85.52,
      "sid": 59,
      "location": 2,
      "content": "要做起来",
      "music": 0.0
    },
    {
      "from": 85.52,
      "to": 86.68,
      "sid": 60,
      "location": 2,
      "content": "需要获取几个角色",
      "music": 0.0
    },
    {
      "from": 86.68,
      "to": 87.52,
      "sid": 61,
      "location": 2,
      "content": "一起手",
      "music": 0.0
    },
    {
      "from": 87.52,
      "to": 89.7,
      "sid": 62,
      "location": 2,
      "content": "二用户三商家对骑手来讲",
      "music": 0.0
    },
    {
      "from": 89.7,
      "to": 90.82,
      "sid": 63,
      "location": 2,
      "content": "公司给你五险一金",
      "music": 0.0
    },
    {
      "from": 90.82,
      "to": 91.3,
      "sid": 64,
      "location": 2,
      "content": "给你交社保",
      "music": 0.0
    },
    {
      "from": 91.3,
      "to": 91.78,
      "sid": 65,
      "location": 2,
      "content": "你干不干",
      "music": 0.0
    },
    {
      "from": 91.78,
      "to": 92.38,
      "sid": 66,
      "location": 2,
      "content": "当然干",
      "music": 0.0
    },
    {
      "from": 92.38,
      "to": 93.26,
      "sid": 67,
      "location": 2,
      "content": "对用户来讲",
      "music": 0.0
    },
    {
      "from": 93.26,
      "to": 94.38,
      "sid": 68,
      "location": 2,
      "content": "用户选不选择京东",
      "music": 0.0
    },
    {
      "from": 94.38,
      "to": 95.5,
      "sid": 69,
      "location": 2,
      "content": "你刷一刷抖音就知道了",
      "music": 0.0
    },
    {
      "from": 95.5,
      "to": 96.4,
      "sid": 70,
      "location": 2,
      "content": "舆论已经给你答案",
      "music": 0.0
    },
    {
      "from": 96.4,
      "to": 97.4,
      "sid": 71,
      "location": 2,
      "content": "对商家来讲",
      "music": 0.0
    },
    {
      "from": 97.4,
      "to": 98.88,
      "sid": 72,
      "location": 2,
      "content": "如果用户都选择京东",
      "music": 0.0
    },
    {
      "from": 98.88,
      "to": 99.66,
      "sid": 73,
      "location": 2,
      "content": "你有得选吗",
      "music": 0.0
    },
    {
      "from": 99.66,
      "to": 101.72,
      "sid": 74,
      "location": 2,
      "content": "其实按照主流券商的观点",
      "music": 0.0
    },
    {
      "from": 101.72,
      "to": 102.94,
      "sid": 75,
      "location": 2,
      "content": "到2025年底",
      "music": 0.0
    },
    {
      "from": 102.94,
      "to": 105.34,
      "sid": 76,
      "location": 2,
      "content": "京东最多也就能吃掉10%的市场份额",
      "music": 0.0
    },
    {
      "from": 105.34,
      "to": 107.72,
      "sid": 77,
      "location": 2,
      "content": "到2026年还得再滑落到5%",
      "music": 0.0
    },
    {
      "from": 107.72,
      "to": 109.04,
      "sid": 78,
      "location": 2,
      "content": "所以从资本的角度来讲",
      "music": 0.0
    },
    {
      "from": 109.04,
      "to": 110.48,
      "sid": 79,
      "location": 2,
      "content": "这件事情不是小孩过家家",
      "music": 0.0
    },
    {
      "from": 110.48,
      "to": 113.04,
      "sid": 80,
      "location": 2,
      "content": "没有人真正觉得京东能干掉美团",
      "music": 0.0
    },
    {
      "from": 113.04,
      "to": 115.72,
      "sid": 81,
      "location": 2,
      "content": "但是今天这波操作依然是教科书级别的",
      "music": 0.0
    },
    {
      "from": 115.72,
      "to": 118.34,
      "sid": 82,
      "location": 2,
      "content": "所以你会发现顶级企业家都是搞流量的天才",
      "music": 0.0
    },
    {
      "from": 118.34,
      "to": 119.12,
      "sid": 83,
      "location": 2,
      "content": "京东交社保",
      "music": 0.0
    },
    {
      "from": 119.12,
      "to": 120.0,
      "sid": 84,
      "location": 2,
      "content": "雷军开车门",
      "music": 0.0
    },
    {
      "from": 120.0,
      "to": 120.94,
      "sid": 85,
      "location": 2,
      "content": "特斯拉不打广告",
      "music": 0.0
    },
    {
      "from": 120.94,
      "to": 121.82,
      "sid": 86,
      "location": 2,
      "content": "本质上都是一回事",
      "music": 0.0
    },
    {
      "from": 121.82,
      "to": 122.74,
      "sid": 87,
      "location": 2,
      "content": "特斯拉为啥不打广告",
      "music": 0.0
    },
    {
      "from": 122.74,
      "to": 123.58,
      "sid": 88,
      "location": 2,
      "content": "因为广告太贵了",
      "music": 0.0
    },
    {
      "from": 123.58,
      "to": 124.7,
      "sid": 89,
      "location": 2,
      "content": "我有钱请广告行星",
      "music": 0.0
    },
    {
      "from": 124.7,
      "to": 126.6,
      "sid": 90,
      "location": 2,
      "content": "不如拿这个钱让马斯克又发射两枚火箭",
      "music": 0.0
    },
    {
      "from": 126.6,
      "to": 127.3,
      "sid": 91,
      "location": 2,
      "content": "火箭一上天",
      "music": 0.0
    },
    {
      "from": 127.3,
      "to": 128.039,
      "sid": 92,
      "location": 2,
      "content": "全网又刷屏了",
      "music": 0.0
    },
    {
      "from": 128.039,
      "to": 129.719,
      "sid": 93,
      "location": 2,
      "content": "全世界没有比这更便宜的广告了",
      "music": 0.0
    },
    {
      "from": 129.719,
      "to": 131.159,
      "sid": 94,
      "location": 2,
      "content": "我把社交媒体账号做起来之后",
      "music": 0.0
    },
    {
      "from": 131.159,
      "to": 132.119,
      "sid": 95,
      "location": 2,
      "content": "好多人问我投没投留",
      "music": 0.0
    },
    {
      "from": 132.119,
      "to": 132.959,
      "sid": 96,
      "location": 2,
      "content": "我说我投了",
      "music": 0.0
    },
    {
      "from": 132.959,
      "to": 134.2,
      "sid": 97,
      "location": 2,
      "content": "但是其实也没投",
      "music": 0.0
    },
    {
      "from": 134.2,
      "to": 134.96,
      "sid": 98,
      "location": 2,
      "content": "我说我没投",
      "music": 0.0
    },
    {
      "from": 134.96,
      "to": 136.84,
      "sid": 99,
      "location": 2,
      "content": "是说你所想象的那种信息流广告",
      "music": 0.0
    },
    {
      "from": 136.84,
      "to": 137.38,
      "sid": 100,
      "location": 2,
      "content": "我没投",
      "music": 0.0
    },
    {
      "from": 137.38,
      "to": 140.26,
      "sid": 101,
      "location": 2,
      "content": "但是我投了的意思是说我作为一个知识博主",
      "music": 0.0
    },
    {
      "from": 140.26,
      "to": 142.1,
      "sid": 102,
      "location": 2,
      "content": "如果我能拿出一个观点",
      "music": 0.0
    },
    {
      "from": 142.1,
      "to": 143.22,
      "sid": 103,
      "location": 2,
      "content": "是你从来没听过的",
      "music": 0.0
    },
    {
      "from": 143.22,
      "to": 145.64,
      "sid": 104,
      "location": 2,
      "content": "我通过这个获取到的流量其实是投流的十倍",
      "music": 0.0
    },
    {
      "from": 145.64,
      "to": 146.94,
      "sid": 105,
      "location": 2,
      "content": "那么怎么能拿到这个观点呢",
      "music": 0.0
    },
    {
      "from": 146.94,
      "to": 147.78,
      "sid": 106,
      "location": 2,
      "content": "找到正确的人",
      "music": 0.0
    },
    {
      "from": 147.78,
      "to": 148.62,
      "sid": 107,
      "location": 2,
      "content": "请她吃顿饭",
      "music": 0.0
    },
    {
      "from": 148.62,
      "to": 149.54,
      "sid": 108,
      "location": 2,
      "content": "请她喝杯咖啡",
      "music": 0.0
    },
    {
      "from": 149.54,
      "to": 150.72,
      "sid": 109,
      "location": 2,
      "content": "这个就是我投入的方式",
      "music": 0.0
    },
    {
      "from": 150.72,
      "to": 151.74,
      "sid": 110,
      "location": 2,
