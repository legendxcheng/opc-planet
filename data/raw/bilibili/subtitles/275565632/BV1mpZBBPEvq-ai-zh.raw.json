  "body": [
    {
      "from": 0.0,
      "to": 0.68,
      "sid": 1,
      "location": 2,
      "content": "真摔了啊",
      "music": 0.0
    },
    {
      "from": 0.68,
      "to": 1.28,
      "sid": 2,
      "location": 2,
      "content": "真摔吧",
      "music": 0.0
    },
    {
      "from": 2.48,
      "to": 4.88,
      "sid": 3,
      "location": 2,
      "content": "我去我已经听到碎的声音了",
      "music": 0.0
    },
    {
      "from": 4.88,
      "to": 10.02,
      "sid": 4,
      "location": 2,
      "content": "是啊看一下碎了没哇喂我去没有",
      "music": 0.0
    },
    {
      "from": 10.02,
      "to": 10.66,
      "sid": 5,
      "location": 2,
      "content": "碎",
      "music": 0.0
    },
    {
      "from": 10.66,
      "to": 11.9,
      "sid": 6,
      "location": 2,
      "content": "够厉害的",
      "music": 0.0
    },
    {
      "from": 13.18,
      "to": 13.6,
      "sid": 7,
      "location": 2,
      "content": "完美",
      "music": 0.0
    },
    {
      "from": 13.6,
      "to": 14.6,
      "sid": 8,
      "location": 2,
      "content": "这是柏油路",
      "music": 0.0
    },
    {
      "from": 14.6,
      "to": 16.69,
      "sid": 9,
      "location": 2,
      "content": "我们测试一下",
      "music": 0.0
    },
    {
      "from": 19.96,
      "to": 21.88,
      "sid": 10,
      "location": 2,
      "content": "哇没事情",
      "music": 0.0
    },
    {
      "from": 21.88,
      "to": 23.0,
      "sid": 11,
      "location": 2,
      "content": "没有碎",
      "music": 0.0
    },
    {
      "from": 23.0,
      "to": 27.32,
      "sid": 12,
      "location": 2,
      "content": "模拟下走路撞到的嘶",
      "music": 0.0
    },
    {
      "from": 27.32,
      "to": 30.12,
      "sid": 13,
      "location": 2,
      "content": "我去我都感觉已经碎了",
      "music": 0.0
    },
    {
      "from": 31.88,
      "to": 32.629,
      "sid": 14,
      "location": 2,
      "content": "没事吧",
      "music": 0.0
    },
    {
      "from": 32.629,
      "to": 34.089,
      "sid": 15,
      "location": 2,
      "content": "哇没问题",
      "music": 0.0
    },
    {
      "from": 34.089,
      "to": 35.269,
      "sid": 16,
      "location": 2,
      "content": "这石榴真厉害啊",
      "music": 0.0
    },
    {
      "from": 35.269,
      "to": 36.44,
      "sid": 17,
      "location": 2,
      "content": "我去我去",
      "music": 0.0
    },
    {
      "from": 36.44,
      "to": 38.64,
      "sid": 18,
      "location": 2,
      "content": "虽然大家都说先行者先踩坑",
      "music": 0.0
    },
    {
      "from": 38.64,
      "to": 41.18,
      "sid": 19,
      "location": 2,
      "content": "但是嘴硬的老弟只相信先入手先爽",
      "music": 0.0
    },
    {
      "from": 41.18,
      "to": 43.86,
      "sid": 20,
      "location": 2,
      "content": "这次到手第一件事就是先试一下他的防爆",
      "music": 0.0
    },
    {
      "from": 43.86,
      "to": 46.42,
      "sid": 21,
      "location": 2,
      "content": "看会不会像IPHONE15一样那么弱不禁风",
      "music": 0.0
    },
    {
      "from": 46.42,
      "to": 48.66,
      "sid": 22,
      "location": 2,
      "content": "简单测试后发现手机是没有爆",
      "music": 0.0
    },
    {
      "from": 48.66,
      "to": 50.8,
      "sid": 23,
      "location": 2,
      "content": "但满屏的划痕触目惊心",
      "music": 0.0
    },
    {
      "from": 50.8,
      "to": 52.62,
      "sid": 24,
      "location": 2,
      "content": "虽然说超磁晶面板非常抗摔",
      "music": 0.0
    },
    {
      "from": 52.62,
      "to": 53.72,
      "sid": 25,
      "location": 2,
      "content": "但终究是玻璃",
      "music": 0.0
    },
    {
      "from": 53.72,
      "to": 56.32,
      "sid": 26,
      "location": 2,
      "content": "在末世硬度表中比玻璃硬度高的还有很多",
      "music": 0.0
    },
    {
      "from": 56.32,
      "to": 57.02,
      "sid": 27,
      "location": 2,
      "content": "比如石英",
      "music": 0.0
    },
    {
      "from": 57.02,
      "to": 58.68,
      "sid": 28,
      "location": 2,
      "content": "它就能很轻松的划伤屏幕",
      "music": 0.0
    },
    {
      "from": 58.68,
      "to": 60.46,
      "sid": 29,
      "location": 2,
      "content": "所以贴一张膜还是有必要的",
      "music": 0.0
    },
    {
      "from": 60.46,
      "to": 61.56,
      "sid": 30,
      "location": 2,
      "content": "由于手机刚刚发布",
      "music": 0.0
    },
    {
      "from": 61.56,
      "to": 63.86,
      "sid": 31,
      "location": 2,
      "content": "想找到一款满意的钢化膜并没有那么容易",
      "music": 0.0
    },
    {
      "from": 63.86,
      "to": 66.06,
      "sid": 32,
      "location": 2,
      "content": "当我打开手机搜索IPHONE16钢化膜时",
      "music": 0.0
    },
    {
      "from": 66.06,
      "to": 68.96,
      "sid": 33,
      "location": 2,
      "content": "发现不是这IPHONE16的钢化膜是高人一等啊",
      "music": 0.0
    },
    {
      "from": 68.96,
      "to": 70.98,
      "sid": 34,
      "location": 2,
      "content": "为什么价格比国产机贵了一倍之多",
      "music": 0.0
    },
    {
      "from": 70.98,
      "to": 72.1,
      "sid": 35,
      "location": 2,
      "content": "还是说里面含有纯金",
      "music": 0.0
    },
    {
      "from": 72.1,
      "to": 72.88,
      "sid": 36,
      "location": 2,
      "content": "999",
      "music": 0.0
    },
    {
      "from": 72.88,
      "to": 74.28,
      "sid": 37,
      "location": 2,
      "content": "No no no no no",
      "music": 0.1428571326530634
    },
    {
      "from": 74.28,
      "to": 75.14,
      "sid": 38,
      "location": 2,
      "content": "毫无头绪的我",
      "music": 0.0
    },
    {
      "from": 75.14,
      "to": 77.92,
      "sid": 39,
      "location": 2,
      "content": "索性直接将销量比较高的几款全部买了回来",
      "music": 0.0
    },
    {
      "from": 77.92,
      "to": 79.16,
      "sid": 40,
      "location": 2,
      "content": "打算一起测试一下",
      "music": 0.0
    },
    {
      "from": 79.16,
      "to": 80.58,
      "sid": 41,
      "location": 2,
      "content": "看看到底是真的好用",
      "music": 0.0
    },
    {
      "from": 80.58,
      "to": 81.92,
      "sid": 42,
      "location": 2,
      "content": "还是靠着噱头割韭菜",
      "music": 0.0
    },
    {
      "from": 81.92,
      "to": 82.96,
      "sid": 43,
      "location": 2,
      "content": "既然都跳坑里了",
      "music": 0.0
    },
    {
      "from": 82.96,
      "to": 83.96,
      "sid": 44,
      "location": 2,
      "content": "那就帮大家避个雷",
      "music": 0.0
    },
    {
      "from": 83.96,
      "to": 86.04,
      "sid": 45,
      "location": 2,
      "content": "也顺便给准备入手的兄弟们一个建议",
      "music": 0.0
    },
    {
      "from": 86.04,
      "to": 87.28,
      "sid": 46,
      "location": 2,
      "content": "首先来看贴膜方式",
      "music": 0.0
    },
    {
      "from": 87.28,
      "to": 89.58,
      "sid": 47,
      "location": 2,
      "content": "目前市面上主流的贴膜方式是分三种",
      "music": 0.0
    },
    {
      "from": 89.58,
      "to": 90.86,
      "sid": 48,
      "location": 2,
      "content": "首先是胶框定位器",
      "music": 0.0
    },
    {
      "from": 90.86,
      "to": 93.22,
      "sid": 49,
      "location": 2,
      "content": "这种类型的特点就是可以避免贴膜贴歪",
      "music": 0.0
    },
    {
      "from": 93.22,
      "to": 95.0,
      "sid": 50,
      "location": 2,
      "content": "但是这种交换定位器的生产",
      "music": 0.0
    },
    {
      "from": 95.0,
      "to": 96.26,
      "sid": 51,
      "location": 2,
      "content": "是通过开模注塑而成",
      "music": 0.0
    },
    {
      "from": 96.26,
      "to": 97.68,
      "sid": 52,
      "location": 2,
      "content": "有时候也会有误差",
      "music": 0.0
    },
    {
      "from": 97.68,
      "to": 99.74,
      "sid": 53,
      "location": 2,
      "content": "这种误差就会导致我们贴膜贴歪",
      "music": 0.0
    },
    {
      "from": 99.74,
      "to": 101.22,
      "sid": 54,
      "location": 2,
      "content": "第二种就是无人仓类型",
      "music": 0.0
    },
    {
      "from": 101.22,
      "to": 102.34,
      "sid": 55,
      "location": 2,
      "content": "这种类型相比较",
      "music": 0.0
    },
    {
      "from": 102.34,
      "to": 104.6,
      "sid": 56,
      "location": 2,
      "content": "框定位器可以大概率减少灰尘的进入",
      "music": 0.0
    },
    {
      "from": 104.6,
      "to": 105.74,
      "sid": 57,
      "location": 2,
      "content": "提高贴膜的成功率",
      "music": 0.0
    },
    {
      "from": 105.74,
      "to": 107.14,
      "sid": 58,
      "location": 2,
      "content": "最后就是秒贴盒类型",
      "music": 0.0
    },
    {
      "from": 107.14,
      "to": 108.94,
      "sid": 59,
      "location": 2,
      "content": "这种操作起来就比较简单了",
      "music": 0.0
    },
    {
      "from": 108.94,
      "to": 110.58,
      "sid": 60,
      "location": 2,
      "content": "一盖一拉就能把膜贴好",
      "music": 0.0
    },
    {
      "from": 110.58,
      "to": 111.56,
      "sid": 61,
      "location": 2,
      "content": "即使是新手小白",
      "music": 0.0
    },
    {
      "from": 111.56,
      "to": 112.88,
      "sid": 62,
      "location": 2,
      "content": "也能顺利的完成贴膜",
      "music": 0.0
    },
    {
      "from": 112.88,
      "to": 115.0,
      "sid": 63,
      "location": 2,
      "content": "总体来说是不推荐胶框定位器的",
      "music": 0.0
    },
    {
      "from": 115.0,
      "to": 116.94,
      "sid": 64,
      "location": 2,
      "content": "因为在贴膜过程中比较容易贴歪",
      "music": 0.0
    },
    {
      "from": 116.94,
      "to": 118.54,
      "sid": 65,
      "location": 2,
      "content": "而且很大概率都会进灰",
      "music": 0.0
    },
    {
      "from": 118.54,
      "to": 121.14,
      "sid": 66,
      "location": 2,
      "content": "表现突出的是秒天河定位器不容易贴歪",
      "music": 0.0
    },
    {
      "from": 121.14,
      "to": 122.78,
      "sid": 67,
      "location": 2,
      "content": "也不会出现有气泡的情况",
      "music": 0.0
    },
    {
      "from": 122.78,
      "to": 123.64,
      "sid": 68,
      "location": 2,
      "content": "操作难度很低",
      "music": 0.0
    },
    {
      "from": 123.64,
      "to": 125.14,
      "sid": 69,
      "location": 2,
      "content": "也会提高贴膜的成功率",
      "music": 0.0
    },
    {
      "from": 125.14,
      "to": 126.9,
      "sid": 70,
      "location": 2,
      "content": "有白边并不是说钢化膜不好",
      "music": 0.0
    },
    {
      "from": 129.62,
      "to": 130.7,
      "sid": 71,
      "location": 2,
      "content": "之所以有白边",
      "music": 0.0
    },
    {
      "from": 130.7,
      "to": 133.34,
      "sid": 72,
      "location": 2,
      "content": "是因为个别厂家没有考虑到手机屏幕弧度问题",
      "music": 0.0
    },
    {
      "from": 133.34,
      "to": 136.14,
      "sid": 73,
      "location": 2,
      "content": "还有一些是通过缩小覆盖面积来解决屏幕边",
      "music": 0.0
    },
    {
      "from": 136.14,
      "to": 138.14,
      "sid": 74,
      "location": 2,
      "content": "但边缘又很容易出现藏灰的情况",
      "music": 0.0
    },
    {
      "from": 138.14,
      "to": 140.64,
      "sid": 75,
      "location": 2,
      "content": "只有少数品牌是将钢化膜做成3D大弧边",
      "music": 0.0
    },
    {
      "from": 140.64,
      "to": 142.96,
      "sid": 76,
      "location": 2,
      "content": "在不影响全面覆盖的情况下解决屏幕糊边",
      "music": 0.0
    },
    {
      "from": 142.96,
      "to": 144.86,
      "sid": 77,
      "location": 2,
      "content": "这里我将贴膜体验做成了一个表格",
      "music": 0.0
    },
    {
      "from": 144.86,
      "to": 145.6,
      "sid": 78,
      "location": 2,
      "content": "供大家参考",
      "music": 0.0
    },
    {
      "from": 145.6,
      "to": 147.08,
      "sid": 79,
      "location": 2,
      "content": "为什么有的人贴了钢化膜",
      "music": 0.0
    },
    {
      "from": 147.08,
      "to": 149.44,
      "sid": 80,
      "location": 2,
      "content": "就像一块原生玻璃吸附在屏幕上",
      "music": 0.0
    },
    {
      "from": 149.44,
      "to": 150.94,
      "sid": 81,
      "location": 2,
      "content": "看起来非常的美观高级",
      "music": 0.0
    },
    {
      "from": 150.94,
      "to": 152.3,
      "sid": 82,
      "location": 2,
      "content": "而有的人贴了钢化膜",
      "music": 0.0
    },
    {
      "from": 152.3,
      "to": 154.5,
      "sid": 83,
      "location": 2,
      "content": "屏幕四周的缝隙都能停下航母了",
      "music": 0.0
    },
    {
      "from": 154.5,
      "to": 156.54,
      "sid": 84,
      "location": 2,
      "content": "这其实都和钢化膜的覆盖面积有关",
      "music": 0.0
    },
    {
      "from": 156.54,
      "to": 157.58,
      "sid": 85,
      "location": 2,
      "content": "如果覆盖面积太小",
      "music": 0.0
    },
    {
      "from": 157.58,
      "to": 158.74,
      "sid": 86,
      "location": 2,
      "content": "就会出现覆盖不全",
      "music": 0.0
    },
    {
      "from": 158.74,
      "to": 159.78,
      "sid": 87,
      "location": 2,
      "content": "边缘藏灰的情况",
      "music": 0.0
    },
    {
      "from": 159.78,
      "to": 161.42,
      "sid": 88,
      "location": 2,
      "content": "太大则会被手机壳顶起来",
      "music": 0.0
    },
    {
      "from": 161.42,
      "to": 163.38,
      "sid": 89,
      "location": 2,
      "content": "想知道钢化膜的覆盖率也非常简单",
      "music": 0.0
    },
    {
      "from": 163.38,
      "to": 164.84,
      "sid": 90,
      "location": 2,
      "content": "这里我运用了小学知识",
      "music": 0.0
    },
    {
      "from": 164.84,
      "to": 166.68,
      "sid": 91,
      "location": 2,
      "content": "先测出保护膜和屏幕的长和宽",
      "music": 0.0
    },
    {
      "from": 166.68,
      "to": 167.24,
      "sid": 92,
      "location": 2,
      "content": "算出面积",
      "music": 0.0
    },
    {
      "from": 167.24,
      "to": 168.96,
      "sid": 93,
      "location": 2,
      "content": "再用保护面积除以屏幕面积",
      "music": 0.0
    },
    {
      "from": 168.96,
      "to": 169.8,
      "sid": 94,
      "location": 2,
      "content": "得出覆盖百分比",
      "music": 0.0
    },
    {
      "from": 169.8,
      "to": 171.26,
      "sid": 95,
      "location": 2,
      "content": "再观察每款膜贴上去的情况",
      "music": 0.0
    },
    {
      "from": 171.26,
      "to": 172.26,
      "sid": 96,
      "location": 2,
      "content": "出现白边的都有",
      "music": 0.0
    },
    {
      "from": 172.26,
      "to": 172.76,
      "sid": 97,
      "location": 2,
      "content": "蓝星",
      "music": 0.0
    },
    {
      "from": 172.76,
      "to": 175.42,
      "sid": 98,
      "location": 2,
      "content": "普拉斯星空卫士都出现了顶壳的情况",
      "music": 0.0
    },
    {
      "from": 175.42,
      "to": 176.3,
      "sid": 99,
      "location": 2,
      "content": "测量之后发现",
      "music": 0.0
    },
    {
      "from": 176.3,
      "to": 178.68,
      "sid": 100,
      "location": 2,
      "content": "钢化膜的面积只要不大于97.8%",
      "music": 0.0
    },
    {
      "from": 178.68,
      "to": 180.12,
      "sid": 101,
      "location": 2,
      "content": "不小于97.3%",
      "music": 0.0
    },
    {
      "from": 180.12,
      "to": 182.14,
      "sid": 102,
      "location": 2,
      "content": "就不会出现底壳和白边的情况",
      "music": 0.0
    },
    {
      "from": 182.14,
      "to": 184.74,
      "sid": 103,
      "location": 2,
      "content": "虽然IPHONE16pro max超神性面板非常坚硬",
      "music": 0.0
    },
    {
      "from": 184.74,
      "to": 186.06,
      "sid": 104,
      "location": 2,
      "content": "但是掉落在地面上之后",
      "music": 0.0
    },
    {
      "from": 186.06,
      "to": 187.6,
      "sid": 105,
      "location": 2,
      "content": "也会造成不同程度的损伤",
      "music": 0.0
    },
    {
      "from": 187.6,
      "to": 189.92,
      "sid": 106,
      "location": 2,
      "content": "所以贴张膜最大的作用还是保护腹肌",
      "music": 0.0
    },
    {
      "from": 189.92,
      "to": 192.42,
