  "body": [
    {
      "from": 0.08,
      "to": 3.42,
      "sid": 1,
      "location": 2,
      "content": "没想到杨幂的回旋镖来得如此之快",
      "music": 0.0
    },
    {
      "from": 3.42,
      "to": 6.32,
      "sid": 2,
      "location": 2,
      "content": "事情发生在上海一脱口秀现场",
      "music": 0.0
    },
    {
      "from": 6.32,
      "to": 9.32,
      "sid": 3,
      "location": 2,
      "content": "一位极帅脱口秀演员在表演时",
      "music": 0.0
    },
    {
      "from": 9.32,
      "to": 12.78,
      "sid": 4,
      "location": 2,
      "content": "喊了一位29岁的集美一声大姐",
      "music": 0.0
    },
    {
      "from": 12.78,
      "to": 15.26,
      "sid": 5,
      "location": 2,
      "content": "此刻被喊的集美一脸质疑",
      "music": 0.0
    },
    {
      "from": 15.26,
      "to": 16.94,
      "sid": 6,
      "location": 2,
      "content": "吉帅立马明白了",
      "music": 0.0
    },
    {
      "from": 16.94,
      "to": 18.4,
      "sid": 7,
      "location": 2,
      "content": "随即便道歉了",
      "music": 0.0
    },
    {
      "from": 18.4,
      "to": 20.2,
      "sid": 8,
      "location": 2,
      "content": "但是吉美依旧不认可",
      "music": 0.0
    },
    {
      "from": 20.2,
      "to": 22.1,
      "sid": 9,
      "location": 2,
      "content": "并骂了一句滚",
      "music": 0.11290321670135409
    },
    {
      "from": 22.1,
      "to": 24.16,
      "sid": 10,
      "location": 2,
      "content": "原以为此事结束了",
      "music": 0.0
    },
    {
      "from": 24.16,
      "to": 28.3,
      "sid": 11,
      "location": 2,
      "content": "没想到集美回家后立马在小红薯上面表示",
      "music": 0.0
    },
    {
      "from": 28.3,
      "to": 30.16,
      "sid": 12,
      "location": 2,
      "content": "自己被深深的冒犯",
      "music": 0.0
    },
    {
      "from": 30.16,
      "to": 34.72,
      "sid": 13,
      "location": 2,
      "content": "此时该剧场的工作人员立马在帖子下面道歉了",
      "music": 0.0
    },
    {
      "from": 34.72,
      "to": 38.23,
      "sid": 14,
      "location": 2,
      "content": "并表示会补偿两张后续的门票",
      "music": 0.0
    },
    {
      "from": 38.23,
      "to": 42.27,
      "sid": 15,
      "location": 2,
      "content": "没想到该集美表示两张门票不能修复",
      "music": 0.0
    },
    {
      "from": 42.27,
      "to": 43.35,
      "sid": 16,
      "location": 2,
      "content": "对我的伤害",
      "music": 0.0
    },
    {
      "from": 43.35,
      "to": 46.41,
      "sid": 17,
      "location": 2,
      "content": "幽默不应以贬低他人为代价",
      "music": 0.0
    },
    {
      "from": 46.41,
      "to": 49.49,
      "sid": 18,
      "location": 2,
      "content": "所以之前说脱口秀是冒犯的艺术",
      "music": 0.0
    },
    {
      "from": 49.49,
      "to": 50.99,
      "sid": 19,
      "location": 2,
      "content": "是无稽之谈嘛",
      "music": 0.0
    },
    {
      "from": 50.99,
      "to": 53.8,
      "sid": 20,
      "location": 2,
      "content": "所以到底是哪个群体在双标",
      "music": 0.0
    }
  ]
}