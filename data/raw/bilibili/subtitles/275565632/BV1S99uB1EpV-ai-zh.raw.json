  "body": [
    {
      "from": 0.04,
      "to": 1.08,
      "sid": 1,
      "location": 2,
      "content": "我今天收到私信说",
      "music": 0.0
    },
    {
      "from": 1.08,
      "to": 2.84,
      "sid": 2,
      "location": 2,
      "content": "我被一个700多万粉丝的大V",
      "music": 0.0
    },
    {
      "from": 2.84,
      "to": 4.24,
      "sid": 3,
      "location": 2,
      "content": "逐字逐句的给写稿了",
      "music": 0.0
    },
    {
      "from": 4.24,
      "to": 5.12,
      "sid": 4,
      "location": 2,
      "content": "是不是写稿呢",
      "music": 0.0
    },
    {
      "from": 5.12,
      "to": 5.84,
      "sid": 5,
      "location": 2,
      "content": "我不做评判",
      "music": 0.0
    },
    {
      "from": 5.84,
      "to": 6.48,
      "sid": 6,
      "location": 2,
      "content": "视频发出来",
      "music": 0.0
    },
    {
      "from": 6.48,
      "to": 7.14,
      "sid": 7,
      "location": 2,
      "content": "大家自己看",
      "music": 0.0
    },
    {
      "from": 7.14,
      "to": 9.159,
      "sid": 8,
      "location": 2,
      "content": "一个人赚不到钱的核心原因就是你上班多了",
      "music": 0.0
    },
    {
      "from": 9.159,
      "to": 9.679,
      "sid": 9,
      "location": 2,
      "content": "你为什么赚不到钱",
      "music": 0.0
    },
    {
      "from": 9.679,
      "to": 11.079,
      "sid": 10,
      "location": 2,
      "content": "就是因为你上班上的太多了",
      "music": 0.0
    },
    {
      "from": 11.079,
      "to": 11.999,
      "sid": 11,
      "location": 2,
      "content": "有很多人来问我说啊",
      "music": 0.0
    },
    {
      "from": 11.999,
      "to": 12.639,
      "sid": 12,
      "location": 2,
      "content": "有人问我",
      "music": 0.0
    },
    {
      "from": 12.639,
      "to": 13.599,
      "sid": 13,
      "location": 2,
      "content": "是不是我把工作辞了",
      "music": 0.0
    },
    {
      "from": 13.599,
      "to": 15.079,
      "sid": 14,
      "location": 2,
      "content": "我就可以解除掉这个上班思维",
      "music": 0.0
    },
    {
      "from": 15.079,
      "to": 16.879,
      "sid": 15,
      "location": 2,
      "content": "是不是把工作辞了就能够破除上班思维",
      "music": 0.0
    },
    {
      "from": 16.879,
      "to": 18.04,
      "sid": 16,
      "location": 2,
      "content": "我说情况恰恰相反",
      "music": 0.0
    },
    {
      "from": 18.04,
      "to": 19.16,
      "sid": 17,
      "location": 2,
      "content": "是是是恰恰相反",
      "music": 0.0
    },
    {
      "from": 19.16,
      "to": 21.08,
      "sid": 18,
      "location": 2,
      "content": "如果你是在没有解除上班思维的情况下",
      "music": 0.0
    },
    {
      "from": 21.08,
      "to": 21.8,
      "sid": 19,
      "location": 2,
      "content": "就把工作给辞了",
      "music": 0.0
    },
    {
      "from": 21.8,
      "to": 22.8,
      "sid": 20,
      "location": 2,
      "content": "你的情况会更加糟糕",
      "music": 0.0
    },
    {
      "from": 22.8,
      "to": 24.0,
      "sid": 21,
      "location": 2,
      "content": "你会陷入无穷无尽的内耗",
      "music": 0.0
    },
    {
      "from": 24.0,
      "to": 25.16,
      "sid": 22,
      "location": 2,
      "content": "如果你没有转变思维就辞职",
      "music": 0.0
    },
    {
      "from": 25.16,
      "to": 25.8,
      "sid": 23,
      "location": 2,
      "content": "情况只会更糟",
      "music": 0.0
    },
    {
      "from": 25.8,
      "to": 27.12,
      "sid": 24,
      "location": 2,
      "content": "那它会让你陷入无穷无尽的内耗",
      "music": 0.0
    },
    {
      "from": 27.12,
      "to": 28.28,
      "sid": 25,
      "location": 2,
      "content": "所以今天我常数据画一张表",
      "music": 0.0
    },
    {
      "from": 28.28,
      "to": 29.68,
      "sid": 26,
      "location": 2,
      "content": "我想把破除上班思维这个事情",
      "music": 0.0
    },
    {
      "from": 29.68,
      "to": 30.64,
      "sid": 27,
      "location": 2,
      "content": "给系统性的讲清楚",
      "music": 0.0
    },
    {
      "from": 30.64,
      "to": 32.299,
      "sid": 28,
      "location": 2,
      "content": "今天我就把这个事彻底的一次性给你讲",
      "music": 0.0
    },
    {
      "from": 32.299,
      "to": 33.659,
      "sid": 29,
      "location": 2,
      "content": "上班的本质是生存",
