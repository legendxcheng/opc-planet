    },
    {
      "from": 34.659,
      "to": 35.499,
      "sid": 31,
      "location": 2,
      "content": "它是个生存方式",
      "music": 0.0
    },
    {
      "from": 35.499,
      "to": 36.539,
      "sid": 32,
      "location": 2,
      "content": "首先你要知道上班的本质是什么",
      "music": 0.0
    },
    {
      "from": 36.539,
