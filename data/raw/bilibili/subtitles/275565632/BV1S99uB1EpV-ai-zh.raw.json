    },
    {
      "from": 41.2,
      "to": 42.72,
      "sid": 37,
      "location": 2,
      "content": "换取安全上边给你塑造了三种读思维",
      "music": 0.0
    },
    {
      "from": 42.72,
      "to": 44.2,
      "sid": 38,
      "location": 2,
      "content": "第一种叫做用服从换取安全感",
      "music": 0.0
    },
    {
      "from": 44.2,
      "to": 45.64,
      "sid": 39,
      "location": 2,
      "content": "就我明知道老板让我干了一个任务",
