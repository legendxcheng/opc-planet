{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.02,
      "to": 1.38,
      "sid": 1,
      "location": 2,
      "content": "怎么能够在不内耗",
      "music": 0.0
    },
    {
      "from": 1.38,
      "to": 2.46,
      "sid": 2,
      "location": 2,
      "content": "不觉得累的情况下",
      "music": 0.0
    },
    {
      "from": 2.46,
      "to": 4.82,
      "sid": 3,
      "location": 2,
      "content": "完全靠自我驱动实现年入百万以上",
      "music": 0.0
    },
    {
      "from": 4.82,
      "to": 6.92,
      "sid": 4,
      "location": 2,
      "content": "我这个自媒体业务在做到第三个月的时候",
      "music": 0.0
    },
    {
      "from": 6.92,
      "to": 7.68,
      "sid": 5,
      "location": 2,
      "content": "实现了这一点",
      "music": 0.0
    },
    {
      "from": 7.68,
      "to": 8.72,
      "sid": 6,
      "location": 2,
      "content": "模式也非常简单",
      "music": 0.0
    },
    {
      "from": 8.72,
      "to": 9.48,
      "sid": 7,
      "location": 2,
      "content": "就是发视频",
      "music": 0.0
    },
    {
      "from": 9.48,
      "to": 10.76,
      "sid": 8,
      "location": 2,
      "content": "而且你往前翻的话会发现",
      "music": 0.0
    },
    {
      "from": 10.76,
      "to": 12.4,
      "sid": 9,
      "location": 2,
      "content": "我那个时候发的视频其实挺烂的",
      "music": 0.0
    },
    {
      "from": 12.4,
      "to": 13.5,
      "sid": 10,
      "location": 2,
      "content": "变现的产品也很简单",
      "music": 0.0
    },
    {
      "from": 13.5,
      "to": 14.94,
      "sid": 11,
      "location": 2,
      "content": "就是199块钱答疑",
      "music": 0.0
    },
    {
      "from": 14.94,
      "to": 16.18,
      "sid": 12,
      "location": 2,
      "content": "你一天能卖掉11个",
      "music": 0.0
    },
    {
      "from": 16.18,
      "to": 16.94,
      "sid": 13,
      "location": 2,
      "content": "一年就是80万",
      "music": 0.0
    },
    {
      "from": 16.94,
      "to": 18.78,
      "sid": 14,
      "location": 2,
      "content": "再加上其他的零零散散的咨询什么的",
      "music": 0.0
    },
    {
      "from": 18.78,
      "to": 19.78,
      "sid": 15,
      "location": 2,
      "content": "一年就错过100万了",
      "music": 0.0
    },
    {
      "from": 19.78,
      "to": 20.42,
      "sid": 16,
      "location": 2,
      "content": "那今天讲一下",
      "music": 0.0
    },
    {
      "from": 20.42,
      "to": 22.3,
      "sid": 17,
      "location": 2,
      "content": "如果我要从0~11直奔目标",
      "music": 0.0
    },
    {
      "from": 22.3,
      "to": 24.98,
      "sid": 18,
      "location": 2,
      "content": "我就是要直接拿到不内耗年入百万这个结果",
      "music": 0.0
    },
    {
      "from": 24.98,
      "to": 26.78,
      "sid": 19,
      "location": 2,
      "content": "这个过程当中的核心要素是什么",
      "music": 0.0
    },
    {
      "from": 26.78,
      "to": 27.42,
      "sid": 20,
      "location": 2,
      "content": "很多人跟我说",
      "music": 0.0
    },
    {
      "from": 27.42,
      "to": 28.22,
      "sid": 21,
      "location": 2,
      "content": "上班太累了",
      "music": 0.0
    },
    {
      "from": 28.22,
      "to": 29.22,
      "sid": 22,
      "location": 2,
      "content": "我这活根本就干不完",
      "music": 0.0
    },
    {
      "from": 29.22,
      "to": 31.02,
      "sid": 23,
      "location": 2,
      "content": "我怎么能跟你一样又轻松又赚到钱",
      "music": 0.0
    },
    {
      "from": 31.02,
      "to": 33.26,
      "sid": 24,
      "location": 2,
      "content": "我说这里面有个关键点一定要搞清楚啊",
      "music": 0.0
    },
    {
      "from": 33.26,
      "to": 34.84,
      "sid": 25,
      "location": 2,
      "content": "就是你干的活多不多",
      "music": 0.0
    },
    {
      "from": 34.84,
      "to": 36.82,
      "sid": 26,
      "location": 2,
      "content": "和你觉得这个工作轻松不轻松",
      "music": 0.0
    },
    {
      "from": 36.82,
      "to": 38.9,
      "sid": 27,
      "location": 2,
      "content": "这两件事情之间是没有必然联系的",
      "music": 0.0
    },
    {
      "from": 38.9,
      "to": 40.14,
      "sid": 28,
      "location": 2,
      "content": "我在公司上班的时候",
      "music": 0.0
    },
    {
      "from": 40.14,
      "to": 40.74,
      "sid": 29,
      "location": 2,
      "content": "坦白讲",
      "music": 0.0
    },
    {
      "from": 40.74,
      "to": 42.9,
      "sid": 30,
      "location": 2,
      "content": "我觉得我的有效工作产出并不多",
      "music": 0.0
    },
    {
      "from": 42.9,
      "to": 45.06,
      "sid": 31,
      "location": 2,
      "content": "我都担心老板给我发的工资能不能回本",
      "music": 0.0
    },
    {
      "from": 45.06,
      "to": 46.58,
      "sid": 32,
      "location": 2,
      "content": "但是我每天困得要死",
      "music": 0.0
    },
    {
      "from": 46.58,
      "to": 47.28,
      "sid": 33,
      "location": 2,
      "content": "我累的不行",
      "music": 0.0
    },
    {
      "from": 47.28,
      "to": 49.32,
      "sid": 34,
      "location": 2,
      "content": "原因是有一个概念叫自我决定理论",
      "music": 0.0
    },
    {
      "from": 49.32,
      "to": 49.82,
      "sid": 35,
      "location": 2,
      "content": "他说的是",
      "music": 0.0
    },
    {
      "from": 49.82,
      "to": 52.4,
      "sid": 36,
      "location": 2,
      "content": "即便是有一件你原本很喜欢做的事情",
      "music": 0.0
    },
    {
      "from": 52.4,
      "to": 54.52,
      "sid": 37,
      "location": 2,
      "content": "如果有人强迫你在特定的时间",
      "music": 0.0
    },
    {
      "from": 54.52,
      "to": 57.0,
      "sid": 38,
      "location": 2,
      "content": "特定的地点非要用特定的方式去做",
      "music": 0.0
    },
    {
      "from": 57.0,
      "to": 59.3,
      "sid": 39,
      "location": 2,
      "content": "他也会马上变成一件你很讨厌的事情",
      "music": 0.0
    },
    {
      "from": 59.3,
      "to": 61.16,
      "sid": 40,
      "location": 2,
      "content": "显然这件事情就叫做上班对吧",
      "music": 0.0
    },
    {
      "from": 61.16,
      "to": 63.18,
      "sid": 41,
      "location": 2,
      "content": "所以不想上班的核心是这件事情",
      "music": 0.0
    },
    {
      "from": 63.18,
      "to": 64.54,
      "sid": 42,
      "location": 2,
      "content": "破坏了我的自主性",
      "music": 0.0
    },
    {
      "from": 64.54,
      "to": 65.9,
      "sid": 43,
      "location": 2,
      "content": "而不是我干的活太多了",
      "music": 0.0
    },
    {
      "from": 65.9,
      "to": 66.9,
      "sid": 44,
      "location": 2,
      "content": "那么反过来也一样",
      "music": 0.0
    },
    {
      "from": 66.9,
      "to": 69.52,
      "sid": 45,
      "location": 2,
      "content": "当我决定我自由职业或者我自己创业的时候",
      "music": 0.0
    },
    {
      "from": 69.52,
      "to": 71.96,
      "sid": 46,
      "location": 2,
      "content": "我要干的第一件事情是恢复我的自主性",
      "music": 0.0
    },
    {
      "from": 71.96,
      "to": 73.62,
      "sid": 47,
      "location": 2,
      "content": "而不是减少我的工作量",
      "music": 0.0
    },
    {
      "from": 73.62,
      "to": 74.74,
      "sid": 48,
      "location": 2,
      "content": "减少我的工作量",
      "music": 0.0
    },
    {
      "from": 74.74,
      "to": 76.72,
      "sid": 49,
      "location": 2,
      "content": "这件事情本身并不会让我开心的",
      "music": 0.0
    },
    {
      "from": 76.72,
      "to": 78.5,
      "sid": 50,
      "location": 2,
      "content": "并且我们从现实的角度去想一下",
      "music": 0.0
    },
    {
      "from": 78.5,
      "to": 80.72,
      "sid": 51,
      "location": 2,
      "content": "如果你要在六个月以内从0~1",
      "music": 0.0
    },
    {
      "from": 80.72,
      "to": 82.36,
      "sid": 52,
      "location": 2,
      "content": "去实现一个年入百万的生意",
      "music": 0.0
    },
    {
      "from": 82.36,
      "to": 84.2,
      "sid": 53,
      "location": 2,
      "content": "这意味着你很快就要开始",
      "music": 0.0
    },
    {
      "from": 84.2,
      "to": 86.64,
      "sid": 54,
      "location": 2,
      "content": "每天至少创造2700块钱的利润",
      "music": 0.0
    },
    {
      "from": 86.64,
      "to": 89.28,
      "sid": 55,
      "location": 2,
      "content": "我们凭常识去想一下这件事情的工作量",
      "music": 0.0
    },
    {
      "from": 89.28,
      "to": 90.32,
      "sid": 56,
      "location": 2,
      "content": "他有可能很小吗",
      "music": 0.0
    },
    {
      "from": 90.32,
      "to": 91.46,
      "sid": 57,
      "location": 2,
      "content": "这个概率是极低的",
      "music": 0.0
    },
    {
      "from": 94.48,
      "to": 96.34,
      "sid": 58,
      "location": 2,
      "content": "这个时候可能有原或者AIA阵",
      "music": 0.0
    },
    {
      "from": 96.34,
      "to": 97.02,
      "sid": 59,
      "location": 2,
      "content": "他帮你干活",
      "music": 0.0
    },
    {
      "from": 97.02,
      "to": 99.18,
      "sid": 60,
      "location": 2,
      "content": "这个时候你有可能实现你啥都不用干",
      "music": 0.0
    },
    {
      "from": 99.18,
      "to": 100.02,
      "sid": 61,
      "location": 2,
      "content": "躺着就年入百万",
      "music": 0.0
    },
    {
      "from": 100.02,
      "to": 102.84,
      "sid": 62,
      "location": 2,
      "content": "否则在从0~1的这个第一个100万的阶段",
      "music": 0.0
    },
    {
      "from": 102.84,
      "to": 103.96,
      "sid": 63,
      "location": 2,
      "content": "你想要实现不累他",
      "music": 0.0
    },
    {
      "from": 103.96,
      "to": 105.24,
      "sid": 64,
      "location": 2,
      "content": "他一定是因为你有兴趣",
      "music": 0.0
    },
    {
      "from": 105.24,
      "to": 105.92,
      "sid": 65,
      "location": 2,
      "content": "你有正反馈",
      "music": 0.0
    },
    {
      "from": 105.92,
      "to": 107.16,
      "sid": 66,
      "location": 2,
      "content": "你在时间上是自由的",
      "music": 0.0
    },
    {
      "from": 107.16,
      "to": 109.02,
      "sid": 67,
      "location": 2,
      "content": "你实现了自我感感受上的轻松",
      "music": 0.0
    },
    {
      "from": 109.02,
      "to": 110.6,
      "sid": 68,
      "location": 2,
      "content": "我们管这个叫乐此不疲对吧",
      "music": 0.0
    },
    {
      "from": 110.6,
      "to": 112.5,
      "sid": 69,
      "location": 2,
      "content": "而不是因为你什么活都不用干了",
      "music": 0.0
    },
    {
      "from": 112.5,
      "to": 114.96,
      "sid": 70,
      "location": 2,
      "content": "所以我们研究的这个事情不是如何让我不工作",
      "music": 0.0
    },
    {
      "from": 114.96,
      "to": 117.04,
      "sid": 71,
      "location": 2,
      "content": "而是如何让工作这件事情更有动力",
      "music": 0.0
    },
    {
      "from": 117.04,
      "to": 118.16,
      "sid": 72,
      "location": 2,
      "content": "让我不会去排斥他",
      "music": 0.0
    },
    {
      "from": 118.16,
      "to": 119.56,
      "sid": 73,
      "location": 2,
      "content": "让他不会掏空我的精力",
      "music": 0.0
    },
    {
      "from": 119.56,
      "to": 121.04,
      "sid": 74,
      "location": 2,
      "content": "那么这件事情的核心就是",
      "music": 0.0
    },
    {
      "from": 123.12,
      "to": 124.48,
      "sid": 75,
      "location": 2,
      "content": "让别人给你付钱的同时",
      "music": 0.0
    },
    {
      "from": 124.48,
      "to": 127.84,
      "sid": 76,
      "location": 2,
      "content": "你对内还要设计一套类似游戏一样的一个机制",
      "music": 0.0
    },
    {
      "from": 127.84,
      "to": 129.02,
      "sid": 77,
      "location": 2,
      "content": "可以不断的激励你",
      "music": 0.0
    },
    {
      "from": 129.02,
      "to": 129.54,
      "sid": 78,
      "location": 2,
      "content": "有热情",
      "music": 0.0
    },
    {
      "from": 129.54,
      "to": 130.94,
      "sid": 79,
      "location": 2,
      "content": "有激情去完成你的工作",
      "music": 0.0
    },
    {
      "from": 130.94,
      "to": 132.86,
      "sid": 80,
      "location": 2,
      "content": "否则如果你只是靠什么自律",
      "music": 0.0
    },
    {
      "from": 132.86,
      "to": 135.82,
      "sid": 81,
      "location": 2,
      "content": "坚韧刻苦去完成这件事情来光宗耀祖",
      "music": 0.0
    },
    {
      "from": 135.82,
      "to": 137.34,
      "sid": 82,
      "location": 2,
      "content": "我觉得这个事情是没有意义的",
      "music": 0.0
    },
    {
      "from": 137.34,
      "to": 139.34,
      "sid": 83,
      "location": 2,
      "content": "因为你的生活状态并没有改变了对吧",
      "music": 0.0
    },
    {
      "from": 139.34,
      "to": 140.98,
      "sid": 84,
      "location": 2,
      "content": "你只是给自己重新找了一个班上",
      "music": 0.0
    },
    {
      "from": 140.98,
      "to": 143.48,
      "sid": 85,
      "location": 2,
      "content": "那怎么能实现这个游戏化的自我驱动的赚钱",
      "music": 0.0
    },
    {
      "from": 143.48,
      "to": 144.68,
      "sid": 86,
      "location": 2,
      "content": "我有一个非常简单的标准",
      "music": 0.0
    },
    {
      "from": 144.68,
      "to": 146.04,
      "sid": 87,
      "location": 2,
      "content": "就是我做一件事情",
      "music": 0.0
    },
    {
      "from": 146.04,
      "to": 147.32,
      "sid": 88,
      "location": 2,
      "content": "要求有三份回报",
      "music": 0.0
    },
    {
      "from": 147.32,
      "to": 149.96,
      "sid": 89,
      "location": 2,
      "content": "每当有一个节点是需要消耗我的能量",
      "music": 0.0
    },
    {
      "from": 149.96,
      "to": 151.48,
      "sid": 90,
      "location": 2,
      "content": "消耗我的心力去产出的时候",
      "music": 0.0
    },
    {
      "from": 151.48,
      "to": 153.98,
      "sid": 91,
      "location": 2,
      "content": "我都必须同时获得三层正反馈",
      "music": 0.0
    },
    {
      "from": 153.98,
      "to": 155.22,
      "sid": 92,
      "location": 2,
      "content": "在这三层正反馈里面",
      "music": 0.0
    },
    {
      "from": 155.22,
      "to": 156.58,
      "sid": 93,
      "location": 2,
      "content": "第一层可能最反常识",
      "music": 0.0
    },
    {
      "from": 156.58,
      "to": 157.82,
      "sid": 94,
      "location": 2,
      "content": "他其实是自我成就",
      "music": 0.0
    },
    {
      "from": 157.82,
      "to": 159.28,
      "sid": 95,
      "location": 2,
      "content": "就说这个事在抛开前",
      "music": 0.0
    },
    {
      "from": 159.28,
      "to": 161.12,
      "sid": 96,
      "location": 2,
      "content": "抛开各种利益都不谈的情况下",
      "music": 0.0
    },
    {
      "from": 161.12,
      "to": 163.54,
      "sid": 97,
      "location": 2,
      "content": "我这个事他在社会层面上就是有价值的",
      "music": 0.0
    },
    {
      "from": 163.54,
      "to": 164.94,
      "sid": 98,
      "location": 2,
      "content": "我能感说到自我实现",
      "music": 0.0
    },
    {
      "from": 164.94,
      "to": 167.62,
      "sid": 99,
      "location": 2,
      "content": "我能明显的感受到我是一个对社会有用的人",
      "music": 0.0
    },
    {
      "from": 167.62,
      "to": 168.14,
      "sid": 100,
      "location": 2,
      "content": "很多人跟我说",
      "music": 0.0
    },
    {
      "from": 168.14,
      "to": 169.12,
      "sid": 101,
      "location": 2,
      "content": "我年入百万的话",
      "music": 0.0
    },
    {
      "from": 169.12,
      "to": 170.52,
      "sid": 102,
      "location": 2,
      "content": "我都要被社会扒一层皮了",
      "music": 0.0
    },
    {
      "from": 170.52,
      "to": 171.52,
      "sid": 103,
      "location": 2,
      "content": "我哪有时间管你那么多",
      "music": 0.0
    },
    {
      "from": 171.52,
      "to": 172.16,
      "sid": 104,
      "location": 2,
      "content": "有的没的",
      "music": 0.0
    },
    {
      "from": 172.16,
      "to": 173.08,
      "sid": 105,
      "location": 2,
      "content": "但实际情况是",
      "music": 0.0
    },
    {
      "from": 173.08,
      "to": 174.12,
      "sid": 106,
      "location": 2,
      "content": "即便是功利的讲",
      "music": 0.0
    },
    {
      "from": 174.12,
      "to": 175.42,
      "sid": 107,
      "location": 2,
      "content": "即便是从商业角度讲",
      "music": 0.0
    },
    {
      "from": 175.42,
      "to": 178.3,
