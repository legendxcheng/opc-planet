      "sid": 216,
      "location": 2,
      "content": "我会觉得工作和生活的界限消失是一个坏事",
      "music": 0.0
    },
    {
      "from": 352.22,
      "to": 353.38,
      "sid": 217,
      "location": 2,
      "content": "因为我们有自己的时间了",
      "music": 0.0
    },
    {
      "from": 353.38,
      "to": 354.58,
      "sid": 218,
      "location": 2,
      "content": "但是在这里新的模式下",
      "music": 0.0
    },
    {
      "from": 354.58,
      "to": 356.62,
      "sid": 219,
      "location": 2,
      "content": "你本身就希望二者之间没有边界",
      "music": 0.0
    },
    {
      "from": 356.62,
      "to": 358.76,
      "sid": 220,
      "location": 2,
      "content": "因为当你的工作当中充满这个反馈的时候",
      "music": 0.0
    },
    {
      "from": 358.76,
      "to": 361.08,
      "sid": 221,
      "location": 2,
      "content": "你的工作本身就是你想要的生活方式",
      "music": 0.0
    },
    {
      "from": 361.08,
      "to": 362.4,
      "sid": 222,
      "location": 2,
      "content": "所以什么是好的商业模式",
      "music": 0.0
    },
    {
      "from": 362.4,
      "to": 363.56,
      "sid": 223,
      "location": 2,
      "content": "不是把别人兜里的钱",
      "music": 0.0
    },
    {
      "from": 363.56,
      "to": 365.44,
      "sid": 224,
      "location": 2,
      "content": "更快的更多的揣到我的腰包里",
      "music": 0.0
    },
    {
      "from": 365.44,
      "to": 367.9,
      "sid": 225,
      "location": 2,
      "content": "而是让所有参与到交易过程当中的人",
      "music": 0.0
    },
    {
      "from": 367.9,
      "to": 369.86,
      "sid": 226,
      "location": 2,
      "content": "都可以交换到自己想要的东西",
      "music": 0.0
    },
    {
      "from": 369.86,
      "to": 370.88,
      "sid": 227,
      "location": 2,
      "content": "而最终你会发现",
      "music": 0.0
    },
    {
      "from": 370.88,
      "to": 373.0,
      "sid": 228,
      "location": 2,
      "content": "在一个真正可持续的商业模式里面",
      "music": 0.0
    },
    {
      "from": 373.0,
      "to": 374.8,
      "sid": 229,
      "location": 2,
      "content": "你所想要交换到的那个东西",
      "music": 0.0
    },
    {
      "from": 374.8,
      "to": 376.68,
      "sid": 230,
      "location": 2,
      "content": "它绝对不仅仅是钱",
      "music": 0.0
    }
  ]
}