  "body": [
    {
      "from": 0,
      "to": 3.41,
      "location": 2,
      "content": "今天的内容会有些不一样。"
    },
    {
      "from": 3.41,
      "to": 7.41,
      "location": 2,
      "content": "珍妮·古道尔博士（Dr. Jane Goodall ） 会给你们讲个故事。"
    },
    {
      "from": 7.42,
      "to": 9.31,
      "location": 2,
      "content": "在动画结束之后请耐心等待，"
    },
    {
      "from": 9.31,
      "to": 12.38,
      "location": 2,
      "content": "了解如何把本视频下载为 免费的儿童读物。"
    },
    {
      "from": 13.31,
      "to": 15.04,
      "location": 2,
      "content": "准备好了吗?"
    },
    {
      "from": 15.04,
      "to": 16.26,
      "location": 2,
      "content": "让我们开始吧。"
    },
    {
      "from": 20.43,
      "to": 23,
      "location": 2,
      "content": "一切都源于一声"
    },
    {
      "from": 23.2,
      "to": 25.35,
      "location": 2,
      "content": "空中传来的低语。"
    },
    {
      "from": 25.35,
      "to": 29.18,
      "location": 2,
      "content": "虽无法听清， 但你知道它就在那里。"
    },
    {
      "from": 30.45,
      "to": 32.36,
      "location": 2,
      "content": "如阳光般温和，"
    },
    {
      "from": 32.56,
      "to": 34.36,
      "location": 2,
      "content": "似冰雹般坚韧，"
    },
    {
      "from": 34.36,
      "to": 38.1,
      "location": 2,
      "content": "它一往无前，直达心间。"
    },
    {
      "from": 39.29,
      "to": 42.29,
      "location": 2,
      "content": "人们从日复一日的任务，"
    },
    {
      "from": 42.29,
      "to": 44.36,
      "location": 2,
      "content": "周而复始的工作"
    },
    {
      "from": 44.56,
      "to": 47.06,
      "location": 2,
      "content": "以及循环往复的口罩中 抬头观望。"
    },
    {
      "from": 47.97,
      "to": 50.33,
      "location": 2,
      "content": "他们听到或是感受到了"
    },
    {
      "from": 50.33,
      "to": 51.97,
      "location": 2,
      "content": "那声低语会引领的方向，"
    },
    {
      "from": 51.97,
      "to": 54.15,
      "location": 2,
      "content": "他们瞪大双眼"
    },
    {
      "from": 54.35,
      "to": 56.29,
      "location": 2,
      "content": "试图明白它可能意味着什么。"
    },
    {
      "from": 57.58,
      "to": 61.62,
      "location": 2,
      "content": "一旦他们明白其含义， 便无法抗拒"
    },
    {
      "from": 61.62,
      "to": 64.25,
      "location": 2,
      "content": "它施展魔法"
    },
    {
      "from": 64.25,
      "to": 66.41,
      "location": 2,
      "content": "所唱出的甜美歌谣。"
    },
    {
      "from": 68.38,
      "to": 72.71,
      "location": 2,
      "content": "但当人们再次抬眼四望 自己曾经拥有的世界时，"
    },
    {
      "from": 72.71,
      "to": 75.07,
      "location": 2,
      "content": "这声低语带来的"
    },
    {
      "from": 75.07,
      "to": 77.45,
      "location": 2,
      "content": "却是痛苦。"
    },
    {
      "from": 77.45,
      "to": 79.53,
      "location": 2,
      "content": "当他们仿佛从梦中醒来，"
    },
    {
      "from": 79.53,
      "to": 82.62,
      "location": 2,
      "content": "却发现自己几乎已是孤独地"
    },
    {
      "from": 83.15,
      "to": 86.51,
      "location": 2,
      "content": "存在于这片大地与海洋之上。"
    },
    {
      "from": 89.6,
      "to": 91.86,
      "location": 2,
      "content": "树木已近乎砍伐殆尽，"
    },
    {
      "from": 91.86,
      "to": 94.21,
      "location": 2,
      "content": "蜜蜂已几乎悄然离去，"
    },
    {
      "from": 94.21,
      "to": 96.86,
      "location": 2,
      "content": "住在海边贝壳里的生物"
    },
    {
      "from": 96.86,
      "to": 98.43,
      "location": 2,
      "content": "已几乎销声匿迹。"
    },
    {
      "from": 98.43,
      "to": 101.95,
      "location": 2,
      "content": "当人们看到新世界时， 不免感到悲伤，"
    },
    {
      "from": 101.95,
      "to": 104.27,
      "location": 2,
      "content": "但他们知道，机会来了——"
    },
    {
      "from": 104.27,
      "to": 107.34,
      "location": 2,
      "content": "一次可以焕发新生、 拥有无限可能性的机会。"
    },
    {
      "from": 109.49,
      "to": 113,
      "location": 2,
      "content": "开垦土地，精心播种，"
    },
    {
      "from": 113,
      "to": 116.92,
      "location": 2,
      "content": "泥土的芬芳残留在额前与手中。"
    },
    {
      "from": 116.92,
      "to": 121.22,
      "location": 2,
      "content": "没有时间感伤颓废， 我们在为未来准备。"
    },
    {
      "from": 121.22,
      "to": 125.27,
      "location": 2,
      "content": "萌芽声正将我们包围。"
    },
    {
      "from": 127.47,
      "to": 131.47,
      "location": 2,
      "content": "当荒原重生， 森林长出新枝，"
    },
    {
      "from": 131.47,
      "to": 134.12,
      "location": 2,
      "content": "未来可期的想法"
    },
    {
      "from": 134.12,
      "to": 135.8,
      "location": 2,
      "content": "开始生根发芽。"
    },
    {
      "from": 135.8,
      "to": 138.11,
      "location": 2,
      "content": "没时间懈怠和休息，"
    },
    {
      "from": 138.11,
      "to": 140.62,
      "location": 2,
      "content": "我们必须竭尽全力。"
    },
    {
      "from": 140.62,
      "to": 143.22,
      "location": 2,
      "content": "这一刻可以带领我们 回到最初那天，"
    },
    {
      "from": 143.22,
      "to": 145,
      "location": 2,
      "content": "这是属于我们的试炼。"
    },
    {
      "from": 146.96,
      "to": 149.68,
      "location": 2,
      "content": "一切都源于一声"
    },
    {
      "from": 149.68,
      "to": 152.22,
      "location": 2,
      "content": "空中传来的低语。"
    },
    {
      "from": 152.42,
      "to": 156.28,
      "location": 2,
      "content": "虽无法听清， 但你知道它就在那里。"
    },
    {
      "from": 158.21,
      "to": 160.59,
      "location": 2,
      "content": "转瞬间它却如惊雷般炸响，"
    },
    {
      "from": 160.79,
      "to": 162.62,
      "location": 2,
      "content": "直到我们都行动起来。"
    },
    {
      "from": 162.62,
      "to": 163.72,
      "location": 2,
      "content": "我们可以做到。"
    },
    {
      "from": 163.92,
      "to": 165.23,
      "location": 2,
      "content": "我们已参与其中。"
    },
    {
      "from": 165.23,
      "to": 166.5,
      "location": 2,
      "content": "等一切大功告成，"
    },
    {
      "from": 167.52,
      "to": 169.26,
      "location": 2,
      "content": "世界已重获新生。"
    },
    {
      "from": 174.87,
      "to": 180.62,
      "location": 2,
      "content": "现在分享这首诗， 以助力将这声低语变为咆哮。"
    },
    {
