{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "sync-v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.76,
      "sid": 1,
      "location": 2,
      "content": "如果说在今天这个经济环境下",
      "music": 0.0
    },
    {
      "from": 1.76,
      "to": 3.56,
      "sid": 2,
      "location": 2,
      "content": "真正想赚钱的人依然很少",
      "music": 0.0
    },
    {
      "from": 3.56,
      "to": 4.68,
      "sid": 3,
      "location": 2,
      "content": "我不知道会不会有人来喷我啊",
      "music": 0.0
    },
    {
      "from": 4.68,
      "to": 5.72,
      "sid": 4,
      "location": 2,
      "content": "或者我换一个表述",
      "music": 0.0
    },
    {
      "from": 5.72,
      "to": 6.92,
      "sid": 5,
      "location": 2,
      "content": "就是想要钱",
      "music": 0.0
    },
    {
      "from": 6.92,
      "to": 8.52,
      "sid": 6,
      "location": 2,
      "content": "想要拥有金钱的人很多",
      "music": 0.0
    },
    {
      "from": 8.52,
      "to": 11.56,
      "sid": 7,
      "location": 2,
      "content": "但是真正愿意用自己的双手去市场上拿钱的人",
      "music": 0.0
    },
    {
      "from": 11.56,
      "to": 12.54,
      "sid": 8,
      "location": 2,
      "content": "我觉得非常少",
      "music": 0.0
    },
    {
      "from": 12.54,
      "to": 13.08,
      "sid": 9,
      "location": 2,
      "content": "我给你说一下",
      "music": 0.0
    },
    {
      "from": 13.08,
      "to": 14.12,
      "sid": 10,
      "location": 2,
      "content": "我怎么发现这个事的",
      "music": 0.0
    },
    {
      "from": 14.12,
      "to": 16.16,
      "sid": 11,
      "location": 2,
      "content": "就是我是从互联网行业退出来",
      "music": 0.0
    },
    {
      "from": 16.16,
      "to": 18.86,
      "sid": 12,
      "location": 2,
      "content": "我靠我自己从0~1做小生意赚到的第一桶金",
      "music": 0.0
    },
    {
      "from": 18.86,
      "to": 23.68,
      "sid": 13,
      "location": 2,
      "content": "然后我把我这个屡试不爽的方法提炼总结为一个很简短的方法论",
      "music": 0.0
    },
    {
      "from": 23.68,
      "to": 24.3,
      "sid": 14,
      "location": 2,
      "content": "去找对标",
      "music": 0.0
    },
    {
      "from": 24.3,
      "to": 26.28,
      "sid": 15,
      "location": 2,
      "content": "这个理论也不能算是我的原创",
      "music": 0.0
    },
    {
      "from": 26.28,
      "to": 27.84,
      "sid": 16,
      "location": 2,
      "content": "因为上世纪七八十年代",
      "music": 0.0
    },
    {
      "from": 27.84,
      "to": 31.26,
      "sid": 17,
      "location": 2,
      "content": "美国就有一套成熟的让大公司去模仿对标别人的理论",
      "music": 0.0
    },
    {
      "from": 31.26,
      "to": 32.02,
      "sid": 18,
      "location": 2,
      "content": "叫做BENCHMARKING",
      "music": 0.0
    },
    {
      "from": 32.02,
      "to": 33.78,
      "sid": 19,
      "location": 2,
      "content": "只不过把它放到国内的环境下",
      "music": 0.0
    },
    {
      "from": 33.78,
      "to": 35.46,
      "sid": 20,
      "location": 2,
      "content": "做了一套比较简洁的一个表述",
      "music": 0.0
    },
    {
      "from": 35.46,
      "to": 36.86,
      "sid": 21,
      "location": 2,
      "content": "说找对标有三个标准",
      "music": 0.0
    },
    {
      "from": 36.86,
      "to": 38.1,
      "sid": 22,
      "location": 2,
      "content": "第一他必须挣钱",
      "music": 0.0
    },
    {
      "from": 38.1,
      "to": 38.9,
      "sid": 23,
      "location": 2,
      "content": "必须是有利润啊",
      "music": 0.0
    },
    {
      "from": 38.9,
      "to": 39.78,
      "sid": 24,
      "location": 2,
      "content": "还不能是有收入",
      "music": 0.0
    },
    {
      "from": 39.78,
      "to": 41.34,
      "sid": 25,
      "location": 2,
      "content": "并且最好是你预期的十倍",
      "music": 0.0
    },
    {
      "from": 41.34,
      "to": 42.54,
      "sid": 26,
      "location": 2,
      "content": "因为你去模仿别人的时候",
      "music": 0.0
    },
    {
      "from": 42.54,
      "to": 44.38,
      "sid": 27,
      "location": 2,
      "content": "你能模仿个1/10的收入就不错了",
      "music": 0.0
    },
    {
      "from": 44.38,
      "to": 46.02,
      "sid": 28,
      "location": 2,
      "content": "第二点是你要能看懂这个生意",
      "music": 0.0
    },
    {
      "from": 46.02,
      "to": 49.22,
      "sid": 29,
      "location": 2,
      "content": "第三点是你敢于你愿意你有能力去模仿这个事情",
      "music": 0.0
    },
    {
      "from": 49.22,
      "to": 53.6,
      "sid": 30,
      "location": 2,
      "content": "那我本来还认为这套方法其实是一个非常简洁又行之有效的一个理论",
      "music": 0.0
    },
    {
      "from": 53.6,
      "to": 54.8,
      "sid": 31,
      "location": 2,
      "content": "比如以前看过视频的知道",
      "music": 0.0
    },
    {
      "from": 54.8,
      "to": 56.96,
      "sid": 32,
      "location": 2,
      "content": "其实我第一个生意就是靠这个方法赚到钱的",
      "music": 0.0
    },
    {
      "from": 56.96,
      "to": 61.28,
      "sid": 33,
      "location": 2,
      "content": "但是后来我发现其实这个方法对人有着并不低的要求",
      "music": 0.0
    },
    {
      "from": 61.28,
      "to": 63.24,
      "sid": 34,
      "location": 2,
      "content": "而这个要求就叫你真的想赚钱",
      "music": 0.0
    },
    {
      "from": 63.24,
      "to": 63.92,
      "sid": 35,
      "location": 2,
      "content": "这个事是这样的",
      "music": 0.0
    },
    {
      "from": 63.92,
      "to": 64.76,
      "sid": 36,
      "location": 2,
      "content": "就有个人跟我说",
      "music": 0.0
    },
    {
      "from": 64.76,
      "to": 66.48,
      "sid": 37,
      "location": 2,
      "content": "我想用你这套找对标的方法",
      "music": 0.0
    },
    {
      "from": 66.48,
      "to": 67.12,
      "sid": 38,
      "location": 2,
      "content": "我现在找一个",
      "music": 0.0
    },
    {
      "from": 67.12,
      "to": 67.6,
      "sid": 39,
      "location": 2,
      "content": "我开始模仿",
      "music": 0.0
    },
    {
      "from": 67.6,
      "to": 68.32,
      "sid": 40,
      "location": 2,
      "content": "我就开始赚钱",
      "music": 0.0
    },
    {
      "from": 68.32,
      "to": 68.96,
      "sid": 41,
      "location": 2,
      "content": "我说好啊",
      "music": 0.0
    },
    {
      "from": 68.96,
      "to": 69.94,
      "sid": 42,
      "location": 2,
      "content": "他说死活找不到",
      "music": 0.0
    },
    {
      "from": 69.94,
      "to": 70.76,
      "sid": 43,
      "location": 2,
      "content": "我说怎么可能呢",
      "music": 0.0
    },
    {
      "from": 70.76,
      "to": 71.52,
      "sid": 44,
      "location": 2,
      "content": "我给你找一个",
      "music": 0.0
    },
    {
      "from": 71.52,
      "to": 72.54,
      "sid": 45,
      "location": 2,
      "content": "你看能不能干好吧",
      "music": 0.0
    },
    {
      "from": 72.54,
      "to": 73.78,
      "sid": 46,
      "location": 2,
      "content": "丢过去一个说哎呦",
      "music": 0.0
    },
    {
      "from": 73.78,
      "to": 74.46,
      "sid": 47,
      "location": 2,
      "content": "这个不行",
      "music": 0.0
    },
    {
      "from": 74.46,
      "to": 75.58,
      "sid": 48,
      "location": 2,
      "content": "他露脸出镜了",
      "music": 0.0
    },
    {
      "from": 75.58,
      "to": 76.34,
      "sid": 49,
      "location": 2,
      "content": "这个拍视频了",
      "music": 0.0
    },
    {
      "from": 76.34,
      "to": 77.06,
      "sid": 50,
      "location": 2,
      "content": "我是体制内的",
      "music": 0.0
    },
    {
      "from": 77.06,
      "to": 77.54,
      "sid": 51,
      "location": 2,
      "content": "不方便",
      "music": 0.0
    },
    {
      "from": 77.54,
      "to": 78.1,
      "sid": 52,
      "location": 2,
      "content": "我说好",
      "music": 0.0
    },
    {
      "from": 78.1,
      "to": 79.42,
      "sid": 53,
      "location": 2,
      "content": "那我们调整一下你的目标啊",
      "music": 0.0
    },
    {
      "from": 79.42,
      "to": 81.16,
      "sid": 54,
      "location": 2,
      "content": "你原本的目标叫我想赚钱",
      "music": 0.0
    },
    {
      "from": 81.16,
      "to": 84.36,
      "sid": 55,
      "location": 2,
      "content": "现在的目标调整为我想在不露脸的情况下赚钱好",
      "music": 0.0
    },
    {
      "from": 84.36,
      "to": 84.96,
      "sid": 56,
      "location": 2,
      "content": "我又扔一个",
      "music": 0.0
    },
    {
      "from": 84.96,
      "to": 85.4,
      "sid": 57,
      "location": 2,
      "content": "他说哎呦",
      "music": 0.0
    },
    {
      "from": 85.4,
      "to": 86.04,
      "sid": 58,
      "location": 2,
      "content": "这个也不行",
      "music": 0.0
    },
    {
      "from": 86.04,
      "to": 87.0,
      "sid": 59,
      "location": 2,
      "content": "人家有七八个的团队",
      "music": 0.0
    },
    {
      "from": 87.0,
      "to": 87.52,
      "sid": 60,
      "location": 2,
      "content": "我就一个人",
      "music": 0.0
    },
    {
      "from": 87.52,
      "to": 88.08,
      "sid": 61,
      "location": 2,
      "content": "我说好",
      "music": 0.0
    },
    {
      "from": 88.08,
      "to": 89.4,
      "sid": 62,
      "location": 2,
      "content": "那你再调整一下你的目标",
      "music": 0.0
    },
    {
      "from": 89.4,
      "to": 93.44,
      "sid": 63,
      "location": 2,
      "content": "你现在的目标是我想在不露脸并且不顾人的情况下赚钱好",
      "music": 0.0
    },
    {
      "from": 93.44,
      "to": 94.08,
      "sid": 64,
      "location": 2,
      "content": "我再扔一个",
      "music": 0.0
    },
    {
      "from": 94.08,
      "to": 94.64,
      "sid": 65,
      "location": 2,
      "content": "又说哎呦",
      "music": 0.0
    },
    {
      "from": 94.64,
      "to": 95.8,
      "sid": 66,
      "location": 2,
      "content": "这个人家会剪辑",
      "music": 0.0
    },
    {
      "from": 95.8,
      "to": 96.92,
      "sid": 67,
      "location": 2,
      "content": "我之前学过剪辑",
      "music": 0.0
    },
    {
      "from": 96.92,
      "to": 97.76,
      "sid": 68,
      "location": 2,
      "content": "我这个天分不行",
      "music": 0.0
    },
    {
      "from": 97.76,
      "to": 98.8,
      "sid": 69,
      "location": 2,
      "content": "这剪辑我真学不会",
      "music": 0.0
    },
    {
      "from": 98.8,
      "to": 99.6,
      "sid": 70,
      "location": 2,
      "content": "别的我都行好",
      "music": 0.0
    },
    {
      "from": 99.6,
      "to": 101.42,
      "sid": 71,
      "location": 2,
      "content": "我说那再咱们再调整一下目标啊",
      "music": 0.0
    },
    {
      "from": 101.42,
      "to": 103.42,
      "sid": 72,
      "location": 2,
      "content": "你的目标叫做我想在不露脸",
      "music": 0.0
    },
    {
      "from": 103.42,
      "to": 105.66,
      "sid": 73,
      "location": 2,
      "content": "不顾人且不剪辑的情况下赚钱",
      "music": 0.0
    },
    {
      "from": 105.66,
      "to": 108.82,
      "sid": 74,
      "location": 2,
      "content": "那我说如果你的目标仅仅是这样的话呢",
      "music": 0.0
    },
    {
      "from": 108.82,
      "to": 110.24,
      "sid": 75,
      "location": 2,
      "content": "其实这个事依然能干",
      "music": 0.0
    },
    {
      "from": 110.24,
      "to": 112.52,
      "sid": 76,
      "location": 2,
      "content": "但是我才跟你聊了30秒",
      "music": 0.0
    },
    {
      "from": 112.52,
      "to": 114.62,
      "sid": 77,
      "location": 2,
      "content": "我就发现你有三个事是不能干的",
      "music": 0.0
    },
    {
      "from": 114.62,
      "to": 116.02,
      "sid": 78,
      "location": 2,
      "content": "我再跟你聊一个小时",
      "music": 0.0
    },
    {
      "from": 116.02,
      "to": 118.2,
      "sid": 79,
      "location": 2,
      "content": "我觉得可能地球上没有你能干的生意",
      "music": 0.0
    },
    {
      "from": 118.2,
      "to": 120.84,
      "sid": 80,
      "location": 2,
      "content": "所以我回顾当初就发现我好像还有一点天赋",
      "music": 0.0
    },
    {
      "from": 120.84,
      "to": 121.76,
      "sid": 81,
      "location": 2,
      "content": "这个天赋叫什么呢",
      "music": 0.0
    },
    {
      "from": 121.76,
      "to": 123.94,
      "sid": 82,
      "location": 2,
      "content": "就是只要这个事儿他不犯法",
      "music": 0.0
    },
    {
      "from": 123.94,
      "to": 125.44,
      "sid": 83,
      "location": 2,
      "content": "不要太触犯道德底线",
      "music": 0.0
    },
    {
      "from": 125.44,
      "to": 126.22,
      "sid": 84,
      "location": 2,
      "content": "只要能赚钱",
      "music": 0.0
    },
    {
      "from": 126.22,
      "to": 127.26,
      "sid": 85,
      "location": 2,
      "content": "我都愿意干",
      "music": 0.0
    },
    {
      "from": 127.26,
      "to": 129.86,
      "sid": 86,
      "location": 2,
      "content": "但是后来我发现他不是一个基准要求",
      "music": 0.0
    },
    {
      "from": 129.86,
      "to": 131.3,
      "sid": 87,
      "location": 2,
      "content": "他是一有很高的要求",
      "music": 0.0
    },
    {
      "from": 131.3,
      "to": 133.9,
      "sid": 88,
      "location": 2,
      "content": "就是不愿意做这个要求的人真的好多呀",
      "music": 0.0
    },
    {
      "from": 133.9,
      "to": 134.8,
      "sid": 89,
      "location": 2,
      "content": "然后这个人就跟我说",
      "music": 0.0
    },
    {
      "from": 134.8,
      "to": 136.36,
      "sid": 90,
      "location": 2,
      "content": "我觉得你这次要找对标的方法",
      "music": 0.0
    },
    {
      "from": 136.36,
      "to": 137.72,
      "sid": 91,
      "location": 2,
      "content": "可能不是很适合我",
      "music": 0.0
    },
    {
      "from": 137.72,
      "to": 139.44,
      "sid": 92,
      "location": 2,
      "content": "我自己去找一个原创的路径",
      "music": 0.0
    },
    {
      "from": 139.44,
      "to": 140.16,
      "sid": 93,
      "location": 2,
      "content": "我也比较舒服",
      "music": 0.0
    },
    {
      "from": 140.16,
      "to": 141.36,
      "sid": 94,
      "location": 2,
      "content": "这个事也有几率能成",
      "music": 0.0
    },
    {
      "from": 141.36,
      "to": 142.92,
      "sid": 95,
      "location": 2,
      "content": "那我对这个事的看法是什么呢",
      "music": 0.0
    },
    {
      "from": 142.92,
      "to": 144.0,
      "sid": 96,
      "location": 2,
      "content": "就是我们看到对标",
      "music": 0.0
    },
    {
      "from": 144.0,
      "to": 147.26,
      "sid": 97,
      "location": 2,
      "content": "看到别人经历过各种千辛万苦之后吧",
      "music": 0.0
    },
    {
      "from": 147.26,
      "to": 148.3,
      "sid": 98,
      "location": 2,
      "content": "最终决定说哦",
      "music": 0.0
    },
    {
      "from": 148.3,
      "to": 148.98,
      "sid": 99,
      "location": 2,
      "content": "这个事儿不露脸",
      "music": 0.0
    },
    {
      "from": 148.98,
      "to": 149.78,
      "sid": 100,
      "location": 2,
      "content": "是真的赚不了钱",
      "music": 0.0
    },
    {
      "from": 149.78,
      "to": 151.14,
      "sid": 101,
      "location": 2,
      "content": "所以人家天天露脸拍视频",
      "music": 0.0
    },
    {
      "from": 151.14,
      "to": 156.38,
      "sid": 102,
      "location": 2,
      "content": "那与其你自己磕磕绊绊一整年或者半年之后才发现这个事必须要露脸",
      "music": 0.0
    },
    {
      "from": 156.38,
      "to": 158.5,
      "sid": 103,
      "location": 2,
      "content": "我帮你第一天判断出这个点有什么不好呢",
      "music": 0.0
    },
    {
      "from": 158.5,
      "to": 159.32,
      "sid": 104,
      "location": 2,
      "content": "没什么不好对吧",
      "music": 0.0
    },
    {
      "from": 159.32,
      "to": 162.48,
      "sid": 105,
      "location": 2,
      "content": "你自己强去找了一个又不需要剪辑",
      "music": 0.0
    },
    {
      "from": 162.48,
      "to": 163.4,
      "sid": 106,
      "location": 2,
      "content": "又不需要雇人",
      "music": 0.0
    },
    {
      "from": 163.4,
      "to": 165.78,
      "sid": 107,
      "location": 2,
      "content": "又不需要这个露脸出镜的一个生意",
      "music": 0.0
    },
    {
      "from": 165.78,
      "to": 167.68,
      "sid": 108,
      "location": 2,
      "content": "然后去干了一个成功率为零的事情",
      "music": 0.0
    },
    {
      "from": 167.68,
      "to": 168.82,
      "sid": 109,
      "location": 2,
      "content": "我认为成功率是零啊",
