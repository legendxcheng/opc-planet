    },
    {
      "from": 132.76,
      "to": 134.68,
      "sid": 84,
      "location": 2,
      "content": "或者是给了别人邀请码之后",
      "music": 0.0
    },
    {
      "from": 134.68,
      "to": 135.36,
      "sid": 85,
      "location": 2,
      "content": "告诉别人",
      "music": 0.0
    },
    {
      "from": 135.36,
      "to": 137.04,
      "sid": 86,
      "location": 2,
      "content": "我把邀请码填到哪一个地方",
      "music": 0.0
    },
    {
      "from": 137.04,
      "to": 138.12,
      "sid": 87,
      "location": 2,
      "content": "我怎么用这个产品",
      "music": 0.0
    },
    {
      "from": 138.12,
      "to": 139.6,
      "sid": 88,
      "location": 2,
      "content": "以及提前想好",
      "music": 0.0
    },
    {
      "from": 139.6,
      "to": 141.36,
      "sid": 89,
      "location": 2,
      "content": "用户可能会问你的问题是什么",
