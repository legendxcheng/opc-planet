    },
    {
      "from": 153.24,
      "to": 156.18,
      "sid": 97,
      "location": 2,
      "content": "这样你就能吃掉咸鱼吃不掉的那一批用户",
      "music": 0.0
    },
    {
      "from": 156.18,
      "to": 156.92,
      "sid": 98,
      "location": 2,
      "content": "所以你会发现",
      "music": 0.0
    },
    {
      "from": 156.92,
      "to": 159.36,
      "sid": 99,
      "location": 2,
      "content": "用信息差赚钱是没有那么简单直白",
      "music": 0.0
    },
    {
      "from": 159.36,
      "to": 160.46,
      "sid": 100,
      "location": 2,
      "content": "没有那么想当然的",
      "music": 0.0
    },
    {
      "from": 160.46,
      "to": 161.6,
      "sid": 101,
      "location": 2,
      "content": "你开一家饭馆",
      "music": 0.0
    },
    {
      "from": 161.6,
      "to": 162.7,
      "sid": 102,
      "location": 2,
      "content": "让别人来吃饭",
      "music": 0.0
    },
    {
      "from": 162.7,
      "to": 164.7,
      "sid": 103,
      "location": 2,
      "content": "和你做一个美团外卖app",
      "music": 0.0
    },
    {
      "from": 164.7,
      "to": 166.34,
      "sid": 104,
      "location": 2,
      "content": "把饭送到别人家门口",
      "music": 0.0
    },
    {
      "from": 166.34,
      "to": 167.18,
      "sid": 105,
      "location": 2,
      "content": "再给别人敲门",
      "music": 0.0
    },
    {
      "from": 167.18,
      "to": 168.1,
      "sid": 106,
      "location": 2,
      "content": "要一个五星好评",
