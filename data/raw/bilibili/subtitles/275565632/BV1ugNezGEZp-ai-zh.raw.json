  "body": [
    {
      "from": 0.08,
      "to": 2.52,
      "sid": 1,
      "location": 2,
      "content": "闲鱼上99%的商家都不知道",
      "music": 0.0
    },
    {
      "from": 2.52,
      "to": 4.42,
      "sid": 2,
      "location": 2,
      "content": "如何正确利用信息差赚钱",
      "music": 0.0
    },
    {
      "from": 4.42,
      "to": 5.52,
      "sid": 3,
      "location": 2,
      "content": "首先在思维上",
      "music": 0.0
    },
    {
      "from": 5.52,
      "to": 7.96,
      "sid": 4,
      "location": 2,
      "content": "你要认同喂饭这件事情是有价值的",
      "music": 0.0
    },
    {
      "from": 7.96,
      "to": 10.04,
      "sid": 5,
      "location": 2,
      "content": "你要把饭喂到你的买家的嘴里",
      "music": 0.0
    },
    {
      "from": 10.04,
      "to": 10.6,
      "sid": 6,
      "location": 2,
      "content": "举个例子",
      "music": 0.0
    },
    {
      "from": 10.6,
      "to": 12.48,
      "sid": 7,
      "location": 2,
      "content": "前段时间国内有个工具特别火",
      "music": 0.0
    },
    {
      "from": 12.48,
      "to": 12.96,
      "sid": 8,
      "location": 2,
      "content": "叫minus",
      "music": 0.0
    },
    {
      "from": 12.96,
      "to": 14.24,
      "sid": 9,
      "location": 2,
      "content": "它和deep sk不是一个东西",
      "music": 0.0
    },
    {
      "from": 14.24,
      "to": 16.16,
      "sid": 10,
      "location": 2,
      "content": "可以演示一些比较神奇的AI效果吧",
      "music": 0.0
    },
    {
      "from": 16.16,
      "to": 17.16,
      "sid": 11,
      "location": 2,
      "content": "一直没有开放注册",
      "music": 0.0
    },
    {
      "from": 17.16,
      "to": 19.2,
      "sid": 12,
      "location": 2,
      "content": "这时候我身边我朋友给我分享了邀请码",
      "music": 0.0
    },
    {
      "from": 19.2,
      "to": 20.4,
      "sid": 13,
      "location": 2,
      "content": "我就试用了一下这个产品",
      "music": 0.0
    },
    {
      "from": 20.4,
      "to": 22.04,
      "sid": 14,
      "location": 2,
      "content": "发现对我的工作的确是很有帮助",
      "music": 0.0
    },
    {
      "from": 22.04,
      "to": 22.72,
      "sid": 15,
      "location": 2,
      "content": "效果非常好",
      "music": 0.0
    },
    {
      "from": 22.72,
      "to": 24.44,
      "sid": 16,
      "location": 2,
      "content": "我就把使用的截图发到了群里",
      "music": 0.0
    },
    {
      "from": 24.44,
      "to": 25.96,
      "sid": 17,
      "location": 2,
      "content": "这个时候群里就铺天盖地",
      "music": 0.0
    },
    {
      "from": 25.96,
      "to": 26.56,
      "sid": 18,
      "location": 2,
      "content": "乌泱乌泱的",
      "music": 0.0
    },
    {
      "from": 26.56,
      "to": 28.12,
      "sid": 19,
      "location": 2,
      "content": "好多人问我怎么能用上这个产品",
      "music": 0.0
    },
    {
      "from": 28.12,
      "to": 29.72,
      "sid": 20,
      "location": 2,
      "content": "然后我当场就去闲鱼上查了一下",
      "music": 0.0
    },
    {
      "from": 29.72,
      "to": 31.64,
      "sid": 21,
      "location": 2,
      "content": "之前被炒到几千几万块钱的邀请码",
      "music": 0.0
    },
    {
      "from": 31.64,
      "to": 32.759,
      "sid": 22,
      "location": 2,
      "content": "现在只要50块钱了",
      "music": 0.0
    },
    {
      "from": 32.759,
      "to": 35.439,
      "sid": 23,
      "location": 2,
      "content": "可是第二天我发现在我明确展示了这个产品",
      "music": 0.0
    },
    {
      "from": 35.439,
      "to": 36.079,
      "sid": 24,
      "location": 2,
      "content": "效果很好",
      "music": 0.0
    },
    {
      "from": 36.079,
      "to": 39.08,
      "sid": 25,
      "location": 2,
      "content": "并且大家对于这个产品的热度也很高的情况下",
      "music": 0.0
    },
    {
      "from": 39.08,
      "to": 41.52,
      "sid": 26,
      "location": 2,
      "content": "最后没有几个人真正用上了这个产品",
      "music": 0.0
    },
    {
      "from": 41.52,
      "to": 43.06,
      "sid": 27,
      "location": 2,
      "content": "对于闲鱼上的卖家来说",
      "music": 0.0
    },
    {
      "from": 43.06,
      "to": 44.96,
      "sid": 28,
      "location": 2,
      "content": "卖minus邀请码就只有一个步骤",
      "music": 0.0
    },
    {
      "from": 44.96,
      "to": 46.7,
      "sid": 29,
      "location": 2,
      "content": "我把码给你能用上就可以了",
      "music": 0.0
    },
    {
      "from": 46.7,
      "to": 47.86,
      "sid": 30,
      "location": 2,
      "content": "但是对于买家来说",
      "music": 0.0
    },
    {
      "from": 47.86,
      "to": 49.14,
      "sid": 31,
      "location": 2,
      "content": "这里面是好几个步骤",
      "music": 0.0
    },
    {
      "from": 49.14,
      "to": 50.8,
      "sid": 32,
      "location": 2,
      "content": "首先我要有一个闲鱼app",
      "music": 0.0
    },
    {
      "from": 50.8,
      "to": 53.7,
      "sid": 33,
      "location": 2,
      "content": "第二我还要在这上面找到一个靠谱的买家",
      "music": 0.0
    },
    {
      "from": 53.7,
      "to": 54.7,
      "sid": 34,
      "location": 2,
      "content": "买到了邀请码之后",
      "music": 0.0
    },
    {
      "from": 54.7,
      "to": 55.72,
      "sid": 35,
      "location": 2,
      "content": "我填写到哪里呢",
      "music": 0.0
    },
    {
      "from": 55.72,
      "to": 56.74,
      "sid": 36,
      "location": 2,
      "content": "你说minus很好用",
      "music": 0.0
    },
    {
      "from": 56.74,
      "to": 58.26,
      "sid": 37,
      "location": 2,
      "content": "它是一个网站还是一个app",
      "music": 0.0
    },
    {
      "from": 58.26,
      "to": 59.1,
      "sid": 38,
      "location": 2,
      "content": "再者说了",
      "music": 0.0
    },
    {
      "from": 59.1,
      "to": 59.94,
      "sid": 39,
      "location": 2,
      "content": "你觉得很好用",
      "music": 0.0
    },
    {
      "from": 59.94,
      "to": 61.3,
      "sid": 40,
      "location": 2,
      "content": "不代表我也觉得很好用啊",
      "music": 0.0
    },
    {
      "from": 61.3,
      "to": 62.54,
      "sid": 41,
      "location": 2,
      "content": "万一我买来没有用",
      "music": 0.0
    },
    {
      "from": 62.54,
      "to": 63.36,
      "sid": 42,
      "location": 2,
      "content": "或者我不会用",
      "music": 0.0
    },
    {
      "from": 63.36,
      "to": 64.44,
      "sid": 43,
      "location": 2,
      "content": "那我岂不是亏钱了",
      "music": 0.0
    },
    {
      "from": 64.44,
      "to": 66.8,
      "sid": 44,
      "location": 2,
      "content": "另外我现在手头还有一个AI工具叫deep sick",
      "music": 0.0
    },
    {
      "from": 66.8,
      "to": 68.88,
      "sid": 45,
      "location": 2,
      "content": "deep sick和你这个minus的区别是什么呢",
      "music": 0.0
    },
    {
      "from": 68.88,
      "to": 69.68,
      "sid": 46,
      "location": 2,
      "content": "我有了TIPSK",
      "music": 0.0
    },
    {
      "from": 69.68,
      "to": 71.36,
      "sid": 47,
      "location": 2,
      "content": "你这个minus是不是就可以不买了呢",
      "music": 0.0
    },
    {
      "from": 71.36,
      "to": 73.96,
      "sid": 48,
      "location": 2,
      "content": "你仔细盘算下来就会发现这里面不是一个问题",
      "music": 0.0
    },
    {
      "from": 73.96,
      "to": 75.0,
      "sid": 49,
      "location": 2,
      "content": "是十个问题",
      "music": 0.0
    },
    {
      "from": 75.0,
      "to": 75.96,
      "sid": 50,
      "location": 2,
      "content": "暂且不说",
      "music": 0.0
    },
    {
      "from": 75.96,
      "to": 77.92,
      "sid": 51,
      "location": 2,
      "content": "闲鱼上的卖家就赚你几十块钱",
      "music": 0.0
    },
    {
      "from": 77.92,
      "to": 79.64,
      "sid": 52,
      "location": 2,
      "content": "有没有耐心回答你这么多问题",
      "music": 0.0
    },
    {
      "from": 79.64,
      "to": 82.0,
      "sid": 53,
      "location": 2,
      "content": "很多买家觉得我除了给钱之外",
      "music": 0.0
    },
    {
      "from": 82.0,
      "to": 83.48,
      "sid": 54,
      "location": 2,
      "content": "还要搞清楚这么多的难题",
      "music": 0.0
    },
    {
      "from": 83.48,
      "to": 85.06,
      "sid": 55,
      "location": 2,
      "content": "我压根就不想用这个产品了",
      "music": 0.0
    },
    {
      "from": 85.06,
      "to": 85.76,
      "sid": 56,
      "location": 2,
      "content": "我该吃吃",
      "music": 0.0
    },
    {
      "from": 85.76,
      "to": 86.2,
      "sid": 57,
      "location": 2,
      "content": "该喝喝",
      "music": 0.0
    },
    {
      "from": 86.2,
      "to": 87.9,
      "sid": 58,
      "location": 2,
      "content": "没有这个东西也不影响我的生活",
      "music": 0.0
    },
    {
      "from": 87.9,
      "to": 91.62,
      "sid": 59,
      "location": 2,
      "content": "而这就是为什么闲鱼上卖邀请码的商家不挣钱",
      "music": 0.0
    },
    {
      "from": 91.62,
      "to": 93.98,
      "sid": 60,
      "location": 2,
      "content": "我当天上午看邀请码的价格是100",
      "music": 0.0
    },
    {
      "from": 93.98,
      "to": 95.14,
      "sid": 61,
      "location": 2,
      "content": "等下午我发到群里的时候",
      "music": 0.0
    },
    {
      "from": 95.14,
      "to": 96.0,
      "sid": 62,
      "location": 2,
      "content": "就只要50了",
      "music": 0.0
    },
    {
      "from": 96.0,
      "to": 97.26,
      "sid": 63,
      "location": 2,
      "content": "截止到我发视频之前",
      "music": 0.0
    },
    {
      "from": 97.26,
      "to": 99.46,
      "sid": 64,
      "location": 2,
      "content": "我去闲鱼上又看了一下价钱max的邀请码",
      "music": 0.0
    },
    {
      "from": 99.46,
      "to": 100.7,
      "sid": 65,
      "location": 2,
      "content": "现在只要20块钱一个了",
      "music": 0.0
    },
    {
      "from": 100.7,
      "to": 101.46,
      "sid": 66,
      "location": 2,
      "content": "所以你就会发现",
      "music": 0.0
    },
    {
      "from": 101.46,
      "to": 102.26,
      "sid": 67,
      "location": 2,
      "content": "闲鱼上的邀请码",
      "music": 0.0
    },
    {
      "from": 102.26,
      "to": 104.5,
      "sid": 68,
      "location": 2,
      "content": "对于信息差的弥合程度是远远不够的",
      "music": 0.0
    },
    {
      "from": 104.5,
      "to": 105.34,
      "sid": 69,
      "location": 2,
      "content": "它只能解决",
      "music": 0.0
    },
    {
      "from": 105.34,
      "to": 107.82,
      "sid": 70,
      "location": 2,
      "content": "那些明确知道自己要用这个产品的人",
      "music": 0.0
    },
    {
      "from": 107.82,
      "to": 108.98,
      "sid": 71,
      "location": 2,
      "content": "想要买一个邀请码",
      "music": 0.0
    },
    {
      "from": 108.98,
      "to": 110.32,
      "sid": 72,
      "location": 2,
      "content": "有地方可买的问题",
      "music": 0.0
    },
    {
      "from": 110.32,
      "to": 112.58,
      "sid": 73,
      "location": 2,
      "content": "可是对于80%的有一点意向",
      "music": 0.0
    },
    {
      "from": 112.58,
      "to": 114.1,
      "sid": 74,
      "location": 2,
      "content": "但又不知道这个东西是什么",
      "music": 0.0
    },
    {
      "from": 114.1,
      "to": 115.5,
      "sid": 75,
      "location": 2,
      "content": "不知道该怎么用的人来说",
      "music": 0.0
    },
    {
      "from": 115.5,
      "to": 117.18,
      "sid": 76,
      "location": 2,
      "content": "他们的问题其实没有被解决",
      "music": 0.0
    },
    {
      "from": 117.18,
      "to": 118.66,
      "sid": 77,
      "location": 2,
      "content": "他们的需求没有被满足",
      "music": 0.0
    },
    {
      "from": 118.66,
      "to": 121.14,
      "sid": 78,
      "location": 2,
      "content": "那么正确的利用信息差去赚钱的方法是什么",
      "music": 0.0
    },
    {
      "from": 121.14,
      "to": 123.7,
      "sid": 79,
      "location": 2,
      "content": "就是把饭喂到你的用户的嘴里",
      "music": 0.0
    },
    {
      "from": 123.7,
      "to": 126.66,
      "sid": 80,
      "location": 2,
      "content": "第一你可能不得不适当的夸大这个产品的价值",
      "music": 0.0
    },
    {
      "from": 126.66,
      "to": 129.1,
      "sid": 81,
      "location": 2,
      "content": "或者说只展示那些最完美的使用案例",
      "music": 0.0
    },
    {
      "from": 129.1,
      "to": 130.84,
      "sid": 82,
      "location": 2,
      "content": "把日用户的热情拉得高一点",
      "music": 0.0
    },
    {
      "from": 130.84,
      "to": 132.76,
      "sid": 83,
      "location": 2,
      "content": "第二你要提供一个现成的账号",
