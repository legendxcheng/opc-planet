{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 2.4,
      "sid": 1,
      "location": 2,
      "content": "流量变现是一门可以被拆解",
      "music": 0.0
    },
    {
      "from": 2.4,
      "to": 3.28,
      "sid": 2,
      "location": 2,
      "content": "可以被学习",
      "music": 0.0
    },
    {
      "from": 3.28,
      "to": 5.6,
      "sid": 3,
      "location": 2,
      "content": "可以被复制的非常具体的一门技术",
      "music": 0.0
    },
    {
      "from": 5.6,
      "to": 6.56,
      "sid": 4,
      "location": 2,
      "content": "这东西不是玄学",
      "music": 0.0
    },
    {
      "from": 6.56,
      "to": 8.9,
      "sid": 5,
      "location": 2,
      "content": "那么绝大多数空有流量不赚钱的账号",
      "music": 0.0
    },
    {
      "from": 8.9,
      "to": 9.54,
      "sid": 6,
      "location": 2,
      "content": "他们在干什么呢",
      "music": 0.0
    },
    {
      "from": 9.54,
      "to": 11.6,
      "sid": 7,
      "location": 2,
      "content": "在干一件事情叫做告知",
      "music": 0.0
    },
    {
      "from": 11.6,
      "to": 13.98,
      "sid": 8,
      "location": 2,
      "content": "当你做告知类的这个内容多到一定的程度",
      "music": 0.0
    },
    {
      "from": 13.98,
      "to": 14.94,
      "sid": 9,
      "location": 2,
      "content": "你就变成一个工具人",
      "music": 0.0
    },
    {
      "from": 14.94,
      "to": 16.66,
      "sid": 10,
      "location": 2,
      "content": "账号就不会有人再愿意给你付钱了",
      "music": 0.0
    },
    {
      "from": 16.66,
      "to": 18.22,
      "sid": 11,
      "location": 2,
      "content": "这类内容的一个典型特征是",
      "music": 0.0
    },
    {
      "from": 18.22,
      "to": 19.76,
      "sid": 12,
      "location": 2,
      "content": "收藏的数量会大于点赞",
      "music": 0.0
    },
    {
      "from": 19.76,
      "to": 21.34,
      "sid": 13,
      "location": 2,
      "content": "比如很多做小红书的会来问我说",
      "music": 0.0
    },
    {
      "from": 21.34,
      "to": 23.2,
      "sid": 14,
      "location": 2,
      "content": "那个小红书主页不是显示一个指标吗",
      "music": 0.0
    },
    {
      "from": 23.2,
      "to": 24.18,
      "sid": 15,
      "location": 2,
      "content": "叫做获赞与收藏",
      "music": 0.0
    },
    {
      "from": 24.18,
      "to": 25.82,
      "sid": 16,
      "location": 2,
      "content": "他说我这个赞藏量特别高",
      "music": 0.0
    },
    {
      "from": 25.82,
      "to": 27.18,
      "sid": 17,
      "location": 2,
      "content": "为什么就是不涨幅不变现",
      "music": 0.0
    },
    {
      "from": 27.18,
      "to": 29.02,
      "sid": 18,
      "location": 2,
      "content": "我说你先别跟我提什么赞藏赞藏",
      "music": 0.0
    },
    {
      "from": 29.02,
      "to": 30.2,
      "sid": 19,
      "location": 2,
      "content": "我就讨厌听这个词啊",
      "music": 0.0
    },
    {
      "from": 30.2,
      "to": 31.36,
      "sid": 20,
      "location": 2,
      "content": "暂时赞藏是藏",
      "music": 0.0
    },
    {
      "from": 31.36,
      "to": 32.4,
      "sid": 21,
      "location": 2,
      "content": "你把这两个东西分开",
      "music": 0.0
    },
    {
      "from": 32.4,
      "to": 32.92,
      "sid": 22,
      "location": 2,
      "content": "不要搞什么",
      "music": 0.0
    },
    {
      "from": 32.92,
      "to": 34.64,
      "sid": 23,
      "location": 2,
      "content": "我跟马云平均一人有1000个亿",
      "music": 0.0
    },
    {
      "from": 34.64,
      "to": 36.52,
      "sid": 24,
      "location": 2,
      "content": "当你的点赞量高于收藏量的时候",
      "music": 0.0
    },
    {
      "from": 36.52,
      "to": 38.64,
      "sid": 25,
      "location": 2,
      "content": "我并不认为收藏数是一个负面的指标",
      "music": 0.0
    },
    {
      "from": 38.64,
      "to": 40.58,
      "sid": 26,
      "location": 2,
      "content": "因为你各个指标当然是同步增长的",
      "music": 0.0
    },
    {
      "from": 40.58,
      "to": 42.7,
      "sid": 27,
      "location": 2,
      "content": "但是如果你的收藏量高于点赞量",
      "music": 0.0
    },
    {
      "from": 42.7,
      "to": 43.82,
      "sid": 28,
      "location": 2,
      "content": "你收藏量再往上涨",
      "music": 0.0
    },
    {
      "from": 43.82,
      "to": 44.82,
      "sid": 29,
      "location": 2,
      "content": "我觉得意义就不大",
      "music": 0.0
    },
    {
      "from": 44.82,
      "to": 47.06,
      "sid": 30,
      "location": 2,
      "content": "因为很可能你在不能变现的这条道路上",
      "music": 0.0
    },
    {
      "from": 47.06,
      "to": 47.96,
      "sid": 31,
      "location": 2,
      "content": "越走越远了",
      "music": 0.0
    },
    {
      "from": 47.96,
      "to": 49.44,
      "sid": 32,
      "location": 2,
      "content": "包括有很多说想对标",
      "music": 0.0
    },
    {
      "from": 49.44,
      "to": 50.52,
      "sid": 33,
      "location": 2,
      "content": "我做一个聊赚钱的账号",
      "music": 0.0
    },
    {
      "from": 50.52,
      "to": 51.46,
      "sid": 34,
      "location": 2,
      "content": "我打开那个账号一看",
      "music": 0.0
    },
    {
      "from": 51.46,
      "to": 53.34,
      "sid": 35,
      "location": 2,
      "content": "要不就是分享个某鱼的信息差",
      "music": 0.0
    },
    {
      "from": 53.34,
      "to": 55.34,
      "sid": 36,
      "location": 2,
      "content": "要不就说国外的这个某个油管大神",
      "music": 0.0
    },
    {
      "from": 55.34,
      "to": 56.34,
      "sid": 37,
      "location": 2,
      "content": "又分享了什么什么东西",
      "music": 0.0
    },
    {
      "from": 56.34,
      "to": 57.3,
      "sid": 38,
      "location": 2,
      "content": "就打开这个账号",
      "music": 0.0
    },
    {
      "from": 57.3,
      "to": 59.7,
      "sid": 39,
      "location": 2,
      "content": "一眼看过去就完全一副不可能赚钱的样子",
      "music": 0.0
    },
    {
      "from": 59.7,
      "to": 60.28,
      "sid": 40,
      "location": 2,
      "content": "因为什么呢",
      "music": 0.0
    },
    {
      "from": 60.28,
      "to": 61.28,
      "sid": 41,
      "location": 2,
      "content": "都在干一件事情",
      "music": 0.0
    },
    {
      "from": 61.28,
      "to": 62.56,
      "sid": 42,
      "location": 2,
      "content": "叫做信息传递",
      "music": 0.0
    },
    {
      "from": 62.56,
      "to": 64.28,
      "sid": 43,
      "location": 2,
      "content": "第一如果你做了一个账号",
      "music": 0.0
    },
    {
      "from": 64.28,
      "to": 65.28,
      "sid": 44,
      "location": 2,
      "content": "专门做信息传递",
      "music": 0.0
    },
    {
      "from": 65.28,
      "to": 66.84,
      "sid": 45,
      "location": 2,
      "content": "你绝对是一个彻头彻尾的工具人",
      "music": 0.0
    },
    {
      "from": 66.84,
      "to": 68.36,
      "sid": 46,
      "location": 2,
      "content": "账号不会有人愿意给你付钱",
      "music": 0.0
    },
    {
      "from": 68.36,
      "to": 70.52,
      "sid": 47,
      "location": 2,
      "content": "第二如果你这个账号本来就能变现",
      "music": 0.0
    },
    {
      "from": 70.52,
      "to": 71.98,
      "sid": 48,
      "location": 2,
      "content": "现在你往里面加了一些",
      "music": 0.0
    },
    {
      "from": 71.98,
      "to": 74.94,
      "sid": 49,
      "location": 2,
      "content": "只能基于别人的行为层去做信息传递的内容啊",
      "music": 0.0
    },
    {
      "from": 74.94,
      "to": 76.02,
      "sid": 50,
      "location": 2,
      "content": "叫做告知性的内容",
      "music": 0.0
    },
    {
      "from": 76.02,
      "to": 79.22,
      "sid": 51,
      "location": 2,
      "content": "这个内容会让别人对你的付费意愿大大降低",
      "music": 0.0
    },
    {
      "from": 79.22,
      "to": 81.3,
      "sid": 52,
      "location": 2,
      "content": "因为我认为你就是一个廉价的工具人",
      "music": 0.0
    },
    {
      "from": 81.3,
      "to": 82.96,
      "sid": 53,
      "location": 2,
      "content": "你不不值得让我给你付出那么多钱",
      "music": 0.0
    },
    {
      "from": 82.96,
      "to": 83.96,
      "sid": 54,
      "location": 2,
      "content": "那这个问题怎么解决",
      "music": 0.0
    },
    {
      "from": 83.96,
      "to": 85.56,
      "sid": 55,
      "location": 2,
      "content": "我拿我最近的一个案例来举个例子啊",
      "music": 0.0
    },
    {
      "from": 85.56,
      "to": 87.8,
      "sid": 56,
      "location": 2,
      "content": "是小红书的工作人员找我约了一个电话访谈",
      "music": 0.0
    },
    {
      "from": 87.8,
      "to": 88.6,
      "sid": 57,
      "location": 2,
      "content": "聊了一个多小时",
      "music": 0.0
    },
    {
      "from": 88.6,
      "to": 90.4,
      "sid": 58,
      "location": 2,
      "content": "然后我要把这个谈话的内容呢",
      "music": 0.0
    },
    {
      "from": 90.4,
      "to": 91.88,
      "sid": 59,
      "location": 2,
      "content": "整理成一个短视频发在小红书",
      "music": 0.0
    },
    {
      "from": 91.88,
      "to": 94.36,
      "sid": 60,
      "location": 2,
      "content": "结果发完之后有60多万的播放量",
      "music": 0.0
    },
    {
      "from": 94.36,
      "to": 95.04,
      "sid": 61,
      "location": 2,
      "content": "可能还不错啊",
      "music": 0.0
    },
    {
      "from": 95.04,
      "to": 96.24,
      "sid": 62,
      "location": 2,
      "content": "相当于抖音600多万了",
      "music": 0.0
    },
    {
      "from": 96.24,
      "to": 97.56,
      "sid": 63,
      "location": 2,
      "content": "那但是这种内容你要知道",
      "music": 0.0
    },
    {
      "from": 97.56,
      "to": 99.58,
      "sid": 64,
      "location": 2,
      "content": "他是最容易沦为信息传递的",
      "music": 0.0
    },
    {
      "from": 99.58,
      "to": 101.88,
      "sid": 65,
      "location": 2,
      "content": "因为我仅仅是把我们的这个通话记录",
      "music": 0.0
    },
    {
      "from": 101.88,
      "to": 103.5,
      "sid": 66,
      "location": 2,
      "content": "变成一个传话筒告诉你们而已",
      "music": 0.0
    },
    {
      "from": 103.5,
      "to": 104.6,
      "sid": 67,
      "location": 2,
      "content": "那我怎么解决这个问题",
      "music": 0.0
    },
    {
      "from": 104.6,
      "to": 105.82,
      "sid": 68,
      "location": 2,
      "content": "首先基础思路",
      "music": 0.0
    },
    {
      "from": 105.82,
      "to": 107.66,
      "sid": 69,
      "location": 2,
      "content": "所谓的信息传递对我的危害",
      "music": 0.0
    },
    {
      "from": 107.66,
      "to": 109.54,
      "sid": 70,
      "location": 2,
      "content": "指的是别人看过了我的内容之后",
      "music": 0.0
    },
    {
      "from": 109.54,
      "to": 110.26,
      "sid": 71,
      "location": 2,
      "content": "不愿意点赞",
      "music": 0.0
    },
    {
      "from": 110.26,
      "to": 110.86,
      "sid": 72,
      "location": 2,
      "content": "不愿意关注",
      "music": 0.0
    },
    {
      "from": 110.86,
      "to": 111.66,
      "sid": 73,
      "location": 2,
      "content": "不愿意付费",
      "music": 0.0
    },
    {
      "from": 111.66,
      "to": 114.94,
      "sid": 74,
      "location": 2,
      "content": "但是信息传递并不影响别人点开我的内容对吧",
      "music": 0.0
    },
    {
      "from": 114.94,
      "to": 117.22,
      "sid": 75,
      "location": 2,
      "content": "所以我在我的小红书的封面和标题",
      "music": 0.0
    },
    {
      "from": 117.22,
      "to": 118.48,
      "sid": 76,
      "location": 2,
      "content": "还有短视频的第一句话",
      "music": 0.0
    },
    {
      "from": 118.48,
      "to": 120.14,
      "sid": 77,
      "location": 2,
      "content": "连续三个地方强调",
      "music": 0.0
    },
    {
      "from": 120.14,
      "to": 122.56,
      "sid": 78,
      "location": 2,
      "content": "这是和官方沟通过后产生的内容",
      "music": 0.0
    },
    {
      "from": 122.56,
      "to": 123.6,
      "sid": 79,
      "location": 2,
      "content": "我不是路人甲",
      "music": 0.0
    },
    {
      "from": 123.6,
      "to": 125.28,
      "sid": 80,
      "location": 2,
      "content": "我的东西是有凭有据的",
      "music": 0.0
    },
    {
      "from": 125.28,
      "to": 127.24,
      "sid": 81,
      "location": 2,
      "content": "所以就算是做高数类内容",
      "music": 0.0
    },
    {
      "from": 127.24,
      "to": 129.24,
      "sid": 82,
      "location": 2,
      "content": "我也是平台上最稀缺的那一种",
      "music": 0.0
    },
    {
      "from": 129.24,
      "to": 130.96,
      "sid": 83,
      "location": 2,
      "content": "第二如果你看过我的原视频的话",
      "music": 0.0
    },
    {
      "from": 130.96,
      "to": 133.12,
      "sid": 84,
      "location": 2,
      "content": "你会发现每次我做信息传递之后",
      "music": 0.0
    },
    {
      "from": 133.12,
      "to": 134.08,
      "sid": 85,
      "location": 2,
      "content": "紧接着第二句话",
      "music": 0.0
    },
    {
      "from": 134.08,
      "to": 136.36,
      "sid": 86,
      "location": 2,
      "content": "就一定是我对这件事情的认知是什么",
      "music": 0.0
    },
    {
      "from": 136.36,
      "to": 137.76,
      "sid": 87,
      "location": 2,
      "content": "比如说平台做了某个动作之后",
      "music": 0.0
    },
    {
      "from": 137.76,
      "to": 139.02,
      "sid": 88,
      "location": 2,
      "content": "会对创作者有什么影响",
      "music": 0.0
    },
    {
      "from": 139.02,
      "to": 139.98,
      "sid": 89,
      "location": 2,
      "content": "对于商家有什么影响",
      "music": 0.0
    },
    {
      "from": 139.98,
      "to": 141.14,
      "sid": 90,
      "location": 2,
      "content": "对于平台有什么影响",
      "music": 0.0
    },
    {
      "from": 141.14,
      "to": 142.18,
      "sid": 91,
      "location": 2,
      "content": "平台的顾虑又是什么",
      "music": 0.0
    },
    {
      "from": 142.18,
      "to": 144.54,
      "sid": 92,
      "location": 2,
      "content": "而这三者之间又构成了一个什么样的三角关系",
      "music": 0.0
    },
    {
      "from": 144.54,
      "to": 145.82,
      "sid": 93,
      "location": 2,
      "content": "这个是我的认知",
      "music": 0.0
    },
    {
      "from": 145.82,
      "to": 148.32,
      "sid": 94,
      "location": 2,
      "content": "而基于信息传递这个渠道去做认知",
      "music": 0.0
    },
    {
      "from": 148.32,
      "to": 149.62,
      "sid": 95,
      "location": 2,
      "content": "这个内容叫启发",
      "music": 0.0
    },
    {
      "from": 149.62,
      "to": 151.86,
      "sid": 96,
      "location": 2,
      "content": "启发是一个非常明确的",
      "music": 0.0
    },
    {
      "from": 151.86,
      "to": 153.62,
      "sid": 97,
      "location": 2,
      "content": "可以复刻的一个做内容的技巧",
      "music": 0.0
    },
    {
      "from": 153.62,
      "to": 155.9,
      "sid": 98,
      "location": 2,
      "content": "而你从告知升级为启发之后",
      "music": 0.0
    },
    {
      "from": 155.9,
      "to": 158.22,
      "sid": 99,
      "location": 2,
      "content": "这就构成了一个明确的让别人关注我的",
      "music": 0.0
    },
    {
      "from": 158.22,
      "to": 159.66,
      "sid": 100,
      "location": 2,
      "content": "理由是别人为什么关注你",
      "music": 0.0
    },
    {
      "from": 159.66,
      "to": 160.74,
      "sid": 101,
      "location": 2,
      "content": "是因为我怕我不关注你",
      "music": 0.0
    },
    {
      "from": 160.74,
      "to": 161.88,
      "sid": 102,
      "location": 2,
      "content": "下次刷我刷不到你了对吧",
      "music": 0.0
    },
    {
      "from": 161.88,
      "to": 163.0,
      "sid": 103,
      "location": 2,
      "content": "为什么担心刷不到你呢",
      "music": 0.0
    },
    {
      "from": 163.0,
      "to": 164.12,
      "sid": 104,
      "location": 2,
      "content": "是因为你足够稀缺对吧",
      "music": 0.0
    },
    {
      "from": 164.12,
      "to": 165.34,
      "sid": 105,
      "location": 2,
      "content": "那什么人是稀缺的",
      "music": 0.0
    },
    {
      "from": 165.34,
      "to": 166.56,
      "sid": 106,
      "location": 2,
      "content": "是不愿意讲认知的人",
      "music": 0.0
    },
    {
      "from": 166.56,
      "to": 167.26,
      "sid": 107,
      "location": 2,
      "content": "就是稀缺的",
