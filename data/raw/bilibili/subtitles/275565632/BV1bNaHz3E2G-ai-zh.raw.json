{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.64,
      "sid": 1,
      "location": 2,
      "content": "在我赚到第一个100万之后",
      "music": 0.0
    },
    {
      "from": 1.64,
      "to": 3.4,
      "sid": 2,
      "location": 2,
      "content": "我心里有一个确凿无疑的结论",
      "music": 0.0
    },
    {
      "from": 3.4,
      "to": 5.279,
      "sid": 3,
      "location": 2,
      "content": "就是副业绝对是个伪命题",
      "music": 0.0
    },
    {
      "from": 5.279,
      "to": 6.679,
      "sid": 4,
      "location": 2,
      "content": "你又要一边上着班",
      "music": 0.0
    },
    {
      "from": 6.679,
      "to": 7.999,
      "sid": 5,
      "location": 2,
      "content": "不能投入太多时间精力",
      "music": 0.0
    },
    {
      "from": 7.999,
      "to": 9.779,
      "sid": 6,
      "location": 2,
      "content": "你还要让他的收入持平",
      "music": 0.0
    },
    {
      "from": 9.779,
      "to": 11.14,
      "sid": 7,
      "location": 2,
      "content": "甚至超过你的工资",
      "music": 0.0
    },
    {
      "from": 11.14,
      "to": 12.62,
      "sid": 8,
      "location": 2,
      "content": "还要让这个收入稳定",
      "music": 0.0
    },
    {
      "from": 12.62,
      "to": 13.42,
      "sid": 9,
      "location": 2,
      "content": "你才敢辞职",
      "music": 0.0
    },
    {
      "from": 13.42,
      "to": 15.34,
      "sid": 10,
      "location": 2,
      "content": "咱是不是把赚钱想的太简单了",
      "music": 0.0
    },
    {
      "from": 15.34,
      "to": 16.18,
      "sid": 11,
      "location": 2,
      "content": "最近好多人来问我",
      "music": 0.0
    },
    {
      "from": 16.18,
      "to": 17.58,
      "sid": 12,
      "location": 2,
      "content": "说自己副业有些收入了",
      "music": 0.0
    },
    {
      "from": 17.58,
      "to": 18.22,
      "sid": 13,
      "location": 2,
      "content": "好像还不错",
      "music": 0.0
    },
    {
      "from": 18.22,
      "to": 19.259,
      "sid": 14,
      "location": 2,
      "content": "但要不要辞职呢",
      "music": 0.0
    },
    {
      "from": 19.259,
      "to": 20.339,
      "sid": 15,
      "location": 2,
      "content": "我还没开始说话呢",
      "music": 0.0
    },
    {
      "from": 20.339,
      "to": 21.979,
      "sid": 16,
      "location": 2,
      "content": "这些人我发现心里都有答案对吧",
      "music": 0.0
    },
    {
      "from": 21.979,
      "to": 25.099,
      "sid": 17,
      "location": 2,
      "content": "就是说我要副业的收入连续稳定三个月",
      "music": 0.0
    },
    {
      "from": 25.099,
      "to": 25.659,
      "sid": 18,
      "location": 2,
      "content": "超过工资",
      "music": 0.0
    },
    {
      "from": 25.659,
      "to": 26.52,
      "sid": 19,
      "location": 2,
      "content": "我才能辞职",
      "music": 0.0
    },
    {
      "from": 26.52,
      "to": 28.52,
      "sid": 20,
      "location": 2,
      "content": "就从财务稳定性的角度来讲",
      "music": 0.0
    },
    {
      "from": 28.52,
      "to": 29.8,
      "sid": 21,
      "location": 2,
      "content": "这个事儿一点问题都没有",
      "music": 0.0
    },
    {
      "from": 29.8,
      "to": 31.72,
      "sid": 22,
      "location": 2,
      "content": "但问题是哪有这么好的事呢",
      "music": 0.0
    },
    {
      "from": 31.72,
      "to": 33.64,
      "sid": 23,
      "location": 2,
      "content": "工资是用来买确定性的",
      "music": 0.0
    },
    {
      "from": 33.64,
      "to": 36.64,
      "sid": 24,
      "location": 2,
      "content": "但是生意是要你从不确定性里面去赚溢价",
      "music": 0.0
    },
    {
      "from": 36.64,
      "to": 38.08,
      "sid": 25,
      "location": 2,
      "content": "它两个逻辑是反过来的",
      "music": 0.0
    },
    {
      "from": 38.08,
      "to": 38.98,
      "sid": 26,
      "location": 2,
      "content": "时间投入少",
      "music": 0.0
    },
    {
      "from": 38.98,
      "to": 39.5,
      "sid": 27,
      "location": 2,
      "content": "你是兼职",
      "music": 0.0
    },
    {
      "from": 39.5,
      "to": 40.38,
      "sid": 28,
      "location": 2,
      "content": "还要收入高",
      "music": 0.0
    },
    {
      "from": 40.38,
      "to": 41.18,
      "sid": 29,
      "location": 2,
      "content": "还要收入稳定",
      "music": 0.0
    },
    {
      "from": 41.18,
      "to": 42.3,
      "sid": 30,
      "location": 2,
      "content": "这是一个不可能三角",
      "music": 0.0
    },
    {
      "from": 42.3,
      "to": 44.22,
      "sid": 31,
      "location": 2,
      "content": "你不能站在员工的角度去要求老板",
      "music": 0.0
    },
    {
      "from": 44.22,
      "to": 45.48,
      "sid": 32,
      "location": 2,
      "content": "让老板的收入稳定",
      "music": 0.0
    },
    {
      "from": 45.48,
      "to": 46.8,
      "sid": 33,
      "location": 2,
      "content": "这是违背商业逻辑的",
      "music": 0.0
    },
    {
      "from": 46.8,
      "to": 48.2,
      "sid": 34,
      "location": 2,
      "content": "在我过往的经历当中",
      "music": 0.0
    },
    {
      "from": 48.2,
      "to": 49.36,
      "sid": 35,
      "location": 2,
      "content": "就我实现的那种",
      "music": 0.0
    },
    {
      "from": 49.36,
      "to": 51.76,
      "sid": 36,
      "location": 2,
      "content": "我自己干的生意的收入超过我以前的工资",
      "music": 0.0
    },
    {
      "from": 51.76,
      "to": 52.8,
      "sid": 37,
      "location": 2,
      "content": "你别说三角了",
      "music": 0.0
    },
    {
      "from": 52.8,
      "to": 53.84,
      "sid": 38,
      "location": 2,
      "content": "一个角都实现不了",
      "music": 0.0
    },
    {
      "from": 53.84,
      "to": 56.02,
      "sid": 39,
      "location": 2,
      "content": "首先我每次干我自己的生意",
      "music": 0.0
    },
    {
      "from": 56.02,
      "to": 57.38,
      "sid": 40,
      "location": 2,
      "content": "都是辞职之后all in的",
      "music": 0.0
    },
    {
      "from": 57.38,
      "to": 58.62,
      "sid": 41,
      "location": 2,
      "content": "就是all in的情况下",
      "music": 0.0
    },
    {
      "from": 58.62,
      "to": 61.58,
      "sid": 42,
      "location": 2,
      "content": "忙起来之后也是只有师范和上厕所的时间",
      "music": 0.0
    },
    {
      "from": 61.58,
      "to": 62.72,
      "sid": 43,
      "location": 2,
      "content": "别的什么事都干不了",
      "music": 0.0
    },
    {
      "from": 62.72,
      "to": 63.68,
      "sid": 44,
      "location": 2,
      "content": "就算是吃饭",
      "music": 0.0
    },
    {
      "from": 63.68,
      "to": 64.52,
      "sid": 45,
      "location": 2,
      "content": "外卖到门口了",
      "music": 0.0
    },
    {
      "from": 64.52,
      "to": 65.34,
      "sid": 46,
      "location": 2,
      "content": "都没有时间去拿",
      "music": 0.0
    },
    {
      "from": 65.34,
      "to": 66.92,
      "sid": 47,
      "location": 2,
      "content": "你要说稳定就更不可能了",
      "music": 0.0
    },
    {
      "from": 66.92,
      "to": 67.84,
      "sid": 48,
      "location": 2,
      "content": "一天十几20万的事",
      "music": 0.0
    },
    {
      "from": 67.84,
      "to": 70.44,
      "sid": 49,
      "location": 2,
      "content": "咱干过十几20天见不着一分钱收入的时候",
      "music": 0.0
    },
    {
      "from": 70.44,
      "to": 71.24,
      "sid": 50,
      "location": 2,
      "content": "咱也经历过",
      "music": 0.0
    },
    {
      "from": 71.24,
      "to": 72.36,
      "sid": 51,
      "location": 2,
      "content": "那这个心态怎么来的",
      "music": 0.0
    },
    {
      "from": 72.36,
      "to": 75.84,
      "sid": 52,
      "location": 2,
      "content": "就是因为他这个事赚钱这个事他是我一路走来",
      "music": 0.0
    },
    {
      "from": 75.84,
      "to": 76.84,
      "sid": 53,
      "location": 2,
      "content": "我不断的受挫",
      "music": 0.0
    },
    {
      "from": 76.84,
      "to": 77.8,
      "sid": 54,
      "location": 2,
      "content": "不断的被打压",
      "music": 0.0
    },
    {
      "from": 77.8,
      "to": 80.28,
      "sid": 55,
      "location": 2,
      "content": "然后最后终于通过自己的经验也好",
      "music": 0.0
    },
    {
      "from": 80.28,
      "to": 81.48,
      "sid": 56,
      "location": 2,
      "content": "然后这个认知也好",
      "music": 0.0
    },
    {
      "from": 81.48,
      "to": 82.96,
      "sid": 57,
      "location": 2,
      "content": "手动策划出来了",
      "music": 0.0
    },
    {
      "from": 82.96,
      "to": 85.4,
      "sid": 58,
      "location": 2,
      "content": "我自己从0~1策划出来的这么一个挣钱的事",
      "music": 0.0
    },
    {
      "from": 85.4,
      "to": 86.94,
      "sid": 59,
      "location": 2,
      "content": "所以我觉得十几20万1天",
      "music": 0.0
    },
    {
      "from": 86.94,
      "to": 88.4,
      "sid": 60,
      "location": 2,
      "content": "这个事下次我还能再干一次",
      "music": 0.0
    },
    {
      "from": 88.4,
      "to": 90.36,
      "sid": 61,
      "location": 2,
      "content": "他的安全感来源于这个安全感",
      "music": 0.0
    },
    {
      "from": 90.36,
      "to": 92.68,
      "sid": 62,
      "location": 2,
      "content": "来源于我有随时能赚钱的能力",
      "music": 0.0
    },
    {
      "from": 92.68,
      "to": 94.24,
      "sid": 63,
      "location": 2,
      "content": "而不是我的收入很稳定",
      "music": 0.0
    },
    {
      "from": 94.24,
      "to": 95.58,
      "sid": 64,
      "location": 2,
      "content": "你别说稳定三个月了",
      "music": 0.0
    },
    {
      "from": 95.58,
      "to": 97.24,
      "sid": 65,
      "location": 2,
      "content": "我就算让你有一个副业",
      "music": 0.0
    },
    {
      "from": 97.24,
      "to": 98.72,
      "sid": 66,
      "location": 2,
      "content": "连连续稳定12个月",
      "music": 0.0
    },
    {
      "from": 98.72,
      "to": 100.24,
      "sid": 67,
      "location": 2,
      "content": "每个月都能赚到差不多的钱",
      "music": 0.0
    },
    {
      "from": 100.24,
      "to": 101.16,
      "sid": 68,
      "location": 2,
      "content": "现在你辞职了之后",
      "music": 0.0
    },
    {
      "from": 101.16,
      "to": 102.62,
      "sid": 69,
      "location": 2,
      "content": "你觉得你真的有安全感吗",
      "music": 0.0
    },
    {
      "from": 102.62,
      "to": 104.52,
      "sid": 70,
      "location": 2,
      "content": "可能某个平台某个政策风向一变",
      "music": 0.0
    },
    {
      "from": 104.52,
      "to": 105.6,
      "sid": 71,
      "location": 2,
      "content": "你那个生意就突然没了",
      "music": 0.0
    },
    {
      "from": 105.6,
      "to": 106.82,
      "sid": 72,
      "location": 2,
      "content": "你觉得他真的稳定吗",
      "music": 0.0
    },
    {
      "from": 106.82,
      "to": 109.42,
      "sid": 73,
      "location": 2,
      "content": "只有你从0~1把这个事做起来了",
      "music": 0.0
    },
    {
      "from": 109.42,
      "to": 111.1,
      "sid": 74,
      "location": 2,
      "content": "然后一次又一次的把这个事做起来了",
      "music": 0.0
    },
    {
      "from": 111.1,
      "to": 113.14,
      "sid": 75,
      "location": 2,
      "content": "并且你觉得这个能力是可迁移的",
      "music": 0.0
    },
    {
      "from": 113.14,
      "to": 114.52,
      "sid": 76,
      "location": 2,
      "content": "我可以换到另外一个平台",
      "music": 0.0
    },
    {
      "from": 114.52,
      "to": 116.44,
      "sid": 77,
      "location": 2,
      "content": "甚至换到另外一个国家去干这个事",
      "music": 0.0
    },
    {
      "from": 116.44,
      "to": 117.74,
      "sid": 78,
      "location": 2,
      "content": "你才有真的安全感",
      "music": 0.0
    },
    {
      "from": 117.74,
      "to": 119.58,
      "sid": 79,
      "location": 2,
      "content": "那马云每年的收入也不一样吧",
      "music": 0.0
    },
    {
      "from": 119.58,
      "to": 121.1,
      "sid": 80,
      "location": 2,
      "content": "你能想象马云没有安全感吗",
      "music": 0.0
    },
    {
      "from": 121.1,
      "to": 122.66,
      "sid": 81,
      "location": 2,
      "content": "所以说穿了副业是个伪命题",
      "music": 0.0
    },
    {
      "from": 122.66,
      "to": 123.62,
      "sid": 82,
      "location": 2,
      "content": "这两个字一个是父",
      "music": 0.0
    },
    {
      "from": 123.62,
      "to": 124.1,
      "sid": 83,
      "location": 2,
      "content": "一个是业",
      "music": 0.0
    },
    {
      "from": 124.1,
      "to": 125.74,
      "sid": 84,
      "location": 2,
      "content": "你觉得他的核心是富还是业呢",
      "music": 0.0
    },
    {
      "from": 125.74,
      "to": 127.46,
      "sid": 85,
      "location": 2,
      "content": "就如果你要一边上着班",
      "music": 0.0
    },
    {
      "from": 127.46,
      "to": 128.94,
      "sid": 86,
      "location": 2,
      "content": "你还要要求这个生意的啊",
      "music": 0.0
    },
    {
      "from": 128.94,
      "to": 130.7,
      "sid": 87,
      "location": 2,
      "content": "这个收入可以每个月都相等",
      "music": 0.0
    },
    {
      "from": 130.7,
      "to": 132.74,
      "sid": 88,
      "location": 2,
      "content": "我觉得你其实是不太尊重这个业务的",
      "music": 0.0
    },
    {
      "from": 132.74,
      "to": 133.7,
      "sid": 89,
      "location": 2,
      "content": "一个生意的初期",
      "music": 0.0
    },
    {
      "from": 133.7,
      "to": 134.64,
      "sid": 90,
      "location": 2,
      "content": "他就跟一个baby",
      "music": 0.0
    },
    {
      "from": 134.64,
      "to": 136.04,
      "sid": 91,
      "location": 2,
      "content": "一个小婴儿小宝宝一样",
      "music": 0.0
    },
    {
      "from": 136.04,
      "to": 137.08,
      "sid": 92,
      "location": 2,
      "content": "他是非常脆弱的",
      "music": 0.0
    },
    {
      "from": 137.08,
      "to": 138.32,
      "sid": 93,
      "location": 2,
      "content": "他经常可能这又出问题了",
      "music": 0.0
    },
    {
      "from": 138.32,
      "to": 139.1,
      "sid": 94,
      "location": 2,
      "content": "那又出问题了",
      "music": 0.0
    },
    {
      "from": 139.1,
      "to": 141.14,
      "sid": 95,
      "location": 2,
      "content": "你没有一个很长时间的一个培养",
      "music": 0.0
    },
    {
      "from": 141.14,
      "to": 142.98,
      "sid": 96,
      "location": 2,
      "content": "给他不断的这个加固基础设施",
      "music": 0.0
    },
    {
      "from": 142.98,
      "to": 145.56,
      "sid": 97,
      "location": 2,
      "content": "它就不可能稳定生意初期流量为王",
      "music": 0.0
    },
    {
      "from": 145.56,
      "to": 146.52,
      "sid": 98,
      "location": 2,
      "content": "你要是这个收入稳定",
      "music": 0.0
    },
    {
      "from": 146.52,
      "to": 147.4,
      "sid": 99,
      "location": 2,
      "content": "你就得流量稳定",
      "music": 0.0
    },
    {
      "from": 147.4,
      "to": 148.8,
      "sid": 100,
      "location": 2,
      "content": "但是流量稳定谈何容易",
      "music": 0.0
    },
    {
      "from": 148.8,
      "to": 150.58,
      "sid": 101,
      "location": 2,
      "content": "你需要一个比较长的一个建设周期",
      "music": 0.0
    },
    {
      "from": 150.58,
      "to": 152.44,
      "sid": 102,
      "location": 2,
      "content": "你在生意还是一个小婴儿的时候",
      "music": 0.0
    },
    {
      "from": 152.44,
      "to": 154.36,
      "sid": 103,
      "location": 2,
      "content": "就非要他这个收入怎么怎么稳定",
      "music": 0.0
    },
    {
      "from": 154.36,
      "to": 155.86,
      "sid": 104,
      "location": 2,
      "content": "你觉得你尊重这个业务吗",
      "music": 0.0
    },
    {
      "from": 155.86,
      "to": 157.76,
      "sid": 105,
      "location": 2,
      "content": "所以我觉得副业的核心根本就不是义",
      "music": 0.0
    },
    {
      "from": 157.76,
      "to": 158.3,
      "sid": 106,
      "location": 2,
      "content": "而是副",
      "music": 0.0
    },
    {
      "from": 158.3,
      "to": 159.78,
      "sid": 107,
      "location": 2,
      "content": "就是你又要一个主业",
      "music": 0.0
    },
    {
      "from": 159.78,
      "to": 161.62,
      "sid": 108,
      "location": 2,
      "content": "给你这个心理和财务上的安全感",
      "music": 0.0
    },
    {
      "from": 161.62,
      "to": 163.86,
      "sid": 109,
      "location": 2,
      "content": "又要一个副业可以让我看点看见点一点",
