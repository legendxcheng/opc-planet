{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.02,
      "to": 1.38,
      "sid": 1,
      "location": 2,
      "content": "去年我发了1万多条推文",
      "music": 0.0
    },
    {
      "from": 1.38,
      "to": 3.1,
      "sid": 2,
      "location": 2,
      "content": "我一个人运营了七个自媒体账号",
      "music": 0.0
    },
    {
      "from": 3.1,
      "to": 5.34,
      "sid": 3,
      "location": 2,
      "content": "很多人问我说怎么能搞定这个执行力的问题啊",
      "music": 0.0
    },
    {
      "from": 5.34,
      "to": 6.7,
      "sid": 4,
      "location": 2,
      "content": "我们今天一条视频3分钟",
      "music": 0.0
    },
    {
      "from": 6.7,
      "to": 8.02,
      "sid": 5,
      "location": 2,
      "content": "把这个根源彻底给讲清楚",
      "music": 0.0
    },
    {
      "from": 8.02,
      "to": 9.14,
      "sid": 6,
      "location": 2,
      "content": "核心其实就一条",
      "music": 0.0
    },
    {
      "from": 9.14,
      "to": 11.22,
      "sid": 7,
      "location": 2,
      "content": "就只要你此时此刻不是在执行",
      "music": 0.0
    },
    {
      "from": 11.22,
      "to": 12.38,
      "sid": 8,
      "location": 2,
      "content": "你手上的那个动作",
      "music": 0.0
    },
    {
      "from": 12.38,
      "to": 15.14,
      "sid": 9,
      "location": 2,
      "content": "大概率就是为了逃避执行而专门打造的动作",
      "music": 0.0
    },
    {
      "from": 15.14,
      "to": 16.22,
      "sid": 10,
      "location": 2,
      "content": "我解释一下这句话什么意思",
      "music": 0.0
    },
    {
      "from": 16.22,
      "to": 17.02,
      "sid": 11,
      "location": 2,
      "content": "他可能比较反常",
      "music": 0.0
    },
    {
      "from": 17.02,
      "to": 19.66,
      "sid": 12,
      "location": 2,
      "content": "但就是这句话彻底治好了我的拖延",
      "music": 0.0
    },
    {
      "from": 19.66,
      "to": 20.74,
      "sid": 13,
      "location": 2,
      "content": "我首先你要搞清楚啊",
      "music": 0.0
    },
    {
      "from": 20.74,
      "to": 22.54,
      "sid": 14,
      "location": 2,
      "content": "绝大多数的没有执行力的人",
      "music": 0.0
    },
    {
      "from": 22.54,
      "to": 24.26,
      "sid": 15,
      "location": 2,
      "content": "都不是所谓的什么不学无术",
      "music": 0.0
    },
    {
      "from": 24.26,
      "to": 24.9,
      "sid": 16,
      "location": 2,
      "content": "玩物丧志的人",
      "music": 0.0
    },
    {
      "from": 24.9,
      "to": 25.94,
      "sid": 17,
      "location": 2,
      "content": "没有执行力的人",
      "music": 0.0
    },
    {
      "from": 25.94,
      "to": 27.3,
      "sid": 18,
      "location": 2,
      "content": "大多数都是非常焦虑的",
      "music": 0.0
    },
    {
      "from": 27.3,
      "to": 27.98,
      "sid": 19,
      "location": 2,
      "content": "你真让他玩",
      "music": 0.0
    },
    {
      "from": 27.98,
      "to": 28.9,
      "sid": 20,
      "location": 2,
      "content": "他其实没心思玩",
      "music": 0.0
    },
    {
      "from": 28.9,
      "to": 31.18,
      "sid": 21,
      "location": 2,
      "content": "你面上看他一天刷了好几个小时短视频",
      "music": 0.0
    },
    {
      "from": 31.18,
      "to": 32.38,
      "sid": 22,
      "location": 2,
      "content": "实际上他是很焦虑的",
      "music": 0.0
    },
    {
      "from": 32.38,
      "to": 33.08,
      "sid": 23,
      "location": 2,
      "content": "在刷短视频",
      "music": 0.0
    },
    {
      "from": 33.08,
      "to": 34.66,
      "sid": 24,
      "location": 2,
      "content": "他时不时想起来我有个事没干完",
      "music": 0.0
    },
    {
      "from": 34.66,
      "to": 35.7,
      "sid": 25,
      "location": 2,
      "content": "时不时就想起来一下",
      "music": 0.0
    },
    {
      "from": 35.7,
      "to": 36.98,
      "sid": 26,
      "location": 2,
      "content": "所以他既不愿意把干了",
      "music": 0.0
    },
    {
      "from": 36.98,
      "to": 37.54,
      "sid": 27,
      "location": 2,
      "content": "你让他玩",
      "music": 0.0
    },
    {
      "from": 37.54,
      "to": 38.26,
      "sid": 28,
      "location": 2,
      "content": "他又玩不踏实",
      "music": 0.0
    },
    {
      "from": 38.26,
      "to": 39.26,
      "sid": 29,
      "location": 2,
      "content": "这个是第一阶段",
      "music": 0.0
    },
    {
      "from": 39.26,
      "to": 40.82,
      "sid": 30,
      "location": 2,
      "content": "第一阶段呢一般还好一点",
      "music": 0.0
    },
    {
      "from": 40.82,
      "to": 41.98,
      "sid": 31,
      "location": 2,
      "content": "只要稍微有个人鞭策一下",
      "music": 0.0
    },
    {
      "from": 41.98,
      "to": 44.1,
      "sid": 32,
      "location": 2,
      "content": "一般可以解决麻烦的是第二阶段",
      "music": 0.0
    },
    {
      "from": 44.1,
      "to": 45.1,
      "sid": 33,
      "location": 2,
      "content": "当这个人很焦虑",
      "music": 0.0
    },
    {
      "from": 45.1,
      "to": 46.22,
      "sid": 34,
      "location": 2,
      "content": "他不做点什么不踏实",
      "music": 0.0
    },
    {
      "from": 46.22,
      "to": 48.54,
      "sid": 35,
      "location": 2,
      "content": "但是他又不愿意直接去做那个",
      "music": 0.0
    },
    {
      "from": 48.54,
      "to": 49.94,
      "sid": 36,
      "location": 2,
      "content": "能达成目标的事情的时候",
      "music": 0.0
    },
    {
      "from": 49.94,
      "to": 52.86,
      "sid": 37,
      "location": 2,
      "content": "他会去找一些和这个目标有关系的",
      "music": 0.0
    },
    {
      "from": 52.86,
      "to": 53.9,
      "sid": 38,
      "location": 2,
      "content": "其他的事情去做",
      "music": 0.0
    },
    {
      "from": 53.9,
      "to": 54.74,
      "sid": 39,
      "location": 2,
      "content": "去缓解他的焦虑",
      "music": 0.0
    },
    {
      "from": 54.74,
      "to": 55.7,
      "sid": 40,
      "location": 2,
      "content": "你比如说我要做自媒体",
      "music": 0.0
    },
    {
      "from": 55.7,
      "to": 56.66,
      "sid": 41,
      "location": 2,
      "content": "那我得会写文案吧",
      "music": 0.0
    },
    {
      "from": 56.66,
      "to": 57.84,
      "sid": 42,
      "location": 2,
      "content": "可是我又写不出来咋办",
      "music": 0.0
    },
    {
      "from": 57.84,
      "to": 59.4,
      "sid": 43,
      "location": 2,
      "content": "没事咱先去报个课",
      "music": 0.0
    },
    {
      "from": 59.4,
      "to": 60.56,
      "sid": 44,
      "location": 2,
      "content": "一学就是两个月",
      "music": 0.0
    },
    {
      "from": 60.56,
      "to": 61.52,
      "sid": 45,
      "location": 2,
      "content": "你比如说我要做个项目",
      "music": 0.0
    },
    {
      "from": 61.52,
      "to": 62.64,
      "sid": 46,
      "location": 2,
      "content": "把这项目我要不懂咋办呀",
      "music": 0.0
    },
    {
      "from": 62.64,
      "to": 63.44,
      "sid": 47,
      "location": 2,
      "content": "我得调研呀",
      "music": 0.0
    },
    {
      "from": 63.44,
      "to": 64.36,
      "sid": 48,
      "location": 2,
      "content": "一调研就是两星期",
      "music": 0.0
    },
    {
      "from": 64.36,
      "to": 65.92,
      "sid": 49,
      "location": 2,
      "content": "那你能说我学习是不对的",
      "music": 0.0
    },
    {
      "from": 65.92,
      "to": 67.0,
      "sid": 50,
      "location": 2,
      "content": "我调研是不对的吗",
      "music": 0.0
    },
    {
      "from": 67.0,
      "to": 67.88,
      "sid": 51,
      "location": 2,
      "content": "当然不能啊",
      "music": 0.0
    },
    {
      "from": 67.88,
      "to": 69.58,
      "sid": 52,
      "location": 2,
      "content": "我前期准备不准备怎么能行啊",
      "music": 0.0
    },
    {
      "from": 69.58,
      "to": 70.56,
      "sid": 53,
      "location": 2,
      "content": "问题就出在这",
      "music": 0.0
    },
    {
      "from": 70.56,
      "to": 71.82,
      "sid": 54,
      "location": 2,
      "content": "就只要你在学习",
      "music": 0.0
    },
    {
      "from": 71.82,
      "to": 72.22,
      "sid": 55,
      "location": 2,
      "content": "在筹备",
      "music": 0.0
    },
    {
      "from": 72.22,
      "to": 72.66,
      "sid": 56,
      "location": 2,
      "content": "在调研",
      "music": 0.0
    },
    {
      "from": 72.66,
      "to": 73.7,
      "sid": 57,
      "location": 2,
      "content": "就没有人能反驳你了",
      "music": 0.0
    },
    {
      "from": 73.7,
      "to": 75.36,
      "sid": 58,
      "location": 2,
      "content": "这些事情都是为了达成目标",
      "music": 0.0
    },
    {
      "from": 75.36,
      "to": 76.48,
      "sid": 59,
      "location": 2,
      "content": "而不得不做的事情呀",
      "music": 0.0
    },
    {
      "from": 76.48,
      "to": 77.6,
      "sid": 60,
      "location": 2,
      "content": "那你就立于不败之地了",
      "music": 0.0
    },
    {
      "from": 77.6,
      "to": 79.12,
      "sid": 61,
      "location": 2,
      "content": "那这个借口完美到什么程度呢",
      "music": 0.0
    },
    {
      "from": 79.12,
      "to": 80.56,
      "sid": 62,
      "location": 2,
      "content": "比如说有的时候为了完成一件事情",
      "music": 0.0
    },
    {
      "from": 80.56,
      "to": 82.28,
      "sid": 63,
      "location": 2,
      "content": "我可能真的是不得不去调研",
      "music": 0.0
    },
    {
      "from": 82.28,
      "to": 83.5,
      "sid": 64,
      "location": 2,
      "content": "不调研是真的不行的",
      "music": 0.0
    },
    {
      "from": 83.5,
      "to": 85.26,
      "sid": 65,
      "location": 2,
      "content": "可是明明能半个小时调研的事",
      "music": 0.0
    },
    {
      "from": 85.26,
      "to": 86.74,
      "sid": 66,
      "location": 2,
      "content": "我就给你调研三四个小时",
      "music": 0.0
    },
    {
      "from": 86.74,
      "to": 88.82,
      "sid": 67,
      "location": 2,
      "content": "那多出来的那几个小时其实就是逃避嘛",
      "music": 0.0
    },
    {
      "from": 88.82,
      "to": 90.22,
      "sid": 68,
      "location": 2,
      "content": "所以这个箭头应该反着画",
      "music": 0.0
    },
    {
      "from": 90.22,
      "to": 91.88,
      "sid": 69,
      "location": 2,
      "content": "就是为了逃避这个目标",
      "music": 0.0
    },
    {
      "from": 91.88,
      "to": 93.14,
      "sid": 70,
      "location": 2,
      "content": "我才去调的研呀",
      "music": 0.0
    },
    {
      "from": 93.14,
      "to": 94.58,
      "sid": 71,
      "location": 2,
      "content": "为了这个醋才包的饺啊",
      "music": 0.0
    },
    {
      "from": 94.58,
      "to": 95.58,
      "sid": 72,
      "location": 2,
      "content": "你说我每天都在读书",
      "music": 0.0
    },
    {
      "from": 95.58,
      "to": 96.38,
      "sid": 73,
      "location": 2,
      "content": "读书总没错吧",
      "music": 0.0
    },
    {
      "from": 96.38,
      "to": 98.16,
      "sid": 74,
      "location": 2,
      "content": "我每天都在健身锻炼身体总没错吧",
      "music": 0.0
    },
    {
      "from": 98.16,
      "to": 99.8,
      "sid": 75,
      "location": 2,
      "content": "对读书跟健身都没错",
      "music": 0.0
    },
    {
      "from": 99.8,
      "to": 101.28,
      "sid": 76,
      "location": 2,
      "content": "所以只要你还在读书",
      "music": 0.0
    },
    {
      "from": 101.28,
      "to": 102.16,
      "sid": 77,
      "location": 2,
      "content": "只要你还在健身",
      "music": 0.0
    },
    {
      "from": 102.16,
      "to": 103.66,
      "sid": 78,
      "location": 2,
      "content": "你就永远立于不败之地",
      "music": 0.0
    },
    {
      "from": 103.66,
      "to": 104.92,
      "sid": 79,
      "location": 2,
      "content": "我一想起我有什么事",
      "music": 0.0
    },
    {
      "from": 104.92,
      "to": 106.26,
      "sid": 80,
      "location": 2,
      "content": "我咔我就把微信读书打开了",
      "music": 0.0
    },
    {
      "from": 106.26,
      "to": 107.38,
      "sid": 81,
      "location": 2,
      "content": "我一想起我有个什么事",
      "music": 0.0
    },
    {
      "from": 107.38,
      "to": 108.54,
      "sid": 82,
      "location": 2,
      "content": "我马上就往健身房一钻",
      "music": 0.0
    },
    {
      "from": 108.54,
      "to": 109.02,
      "sid": 83,
      "location": 2,
      "content": "所以你会发现",
      "music": 0.0
    },
    {
      "from": 109.02,
      "to": 110.82,
      "sid": 84,
      "location": 2,
      "content": "为什么身边很多人他每年都在说啊",
      "music": 0.0
    },
    {
      "from": 110.82,
      "to": 111.54,
      "sid": 85,
      "location": 2,
      "content": "我准备辞职了",
      "music": 0.0
    },
    {
      "from": 111.54,
      "to": 112.14,
      "sid": 86,
      "location": 2,
      "content": "我准备创业了",
      "music": 0.0
    },
    {
      "from": 112.14,
      "to": 113.14,
      "sid": 87,
      "location": 2,
      "content": "我准备做个副业了",
      "music": 0.0
    },
    {
      "from": 113.14,
      "to": 113.96,
      "sid": 88,
      "location": 2,
      "content": "但是他一直在教育",
      "music": 0.0
    },
    {
      "from": 113.96,
      "to": 114.72,
      "sid": 89,
      "location": 2,
      "content": "一直不开始做",
      "music": 0.0
    },
    {
      "from": 114.72,
      "to": 115.92,
      "sid": 90,
      "location": 2,
      "content": "我管这个叫模拟创业",
      "music": 0.0
    },
    {
      "from": 115.92,
      "to": 117.48,
      "sid": 91,
      "location": 2,
      "content": "就我们从经济学角度去看这个事",
      "music": 0.0
    },
    {
      "from": 117.48,
      "to": 119.12,
      "sid": 92,
      "location": 2,
      "content": "在一个真实的市场环境里面",
      "music": 0.0
    },
    {
      "from": 119.12,
      "to": 120.54,
      "sid": 93,
      "location": 2,
      "content": "信息收集是有成本的",
      "music": 0.0
    },
    {
      "from": 120.54,
      "to": 123.22,
      "sid": 94,
      "location": 2,
      "content": "创业者是不可能把所有的变量都摸清楚再行动",
      "music": 0.0
    },
    {
      "from": 123.22,
      "to": 125.62,
      "sid": 95,
      "location": 2,
      "content": "因为你每分每秒的拖延都是在损失成本",
      "music": 0.0
    },
    {
      "from": 125.62,
      "to": 127.34,
      "sid": 96,
      "location": 2,
      "content": "但是一旦我真的去做了这件事情",
      "music": 0.0
    },
    {
      "from": 127.34,
      "to": 129.4,
      "sid": 97,
      "location": 2,
      "content": "就很有可能会产生两个不好的结果",
      "music": 0.0
    },
    {
      "from": 129.4,
      "to": 131.2,
      "sid": 98,
      "location": 2,
      "content": "第一个是只要我干了这件事情",
      "music": 0.0
    },
    {
      "from": 131.2,
      "to": 132.04,
      "sid": 99,
      "location": 2,
      "content": "只要我执行了",
      "music": 0.0
    },
    {
      "from": 132.04,
      "to": 133.06,
      "sid": 100,
      "location": 2,
      "content": "我就有可能失败",
      "music": 0.0
    },
    {
      "from": 133.06,
      "to": 133.84,
      "sid": 101,
      "location": 2,
      "content": "第二个事情是",
      "music": 0.0
    },
    {
      "from": 133.84,
      "to": 135.78,
      "sid": 102,
      "location": 2,
      "content": "就算这个事情本身是成功的",
      "music": 0.0
    },
    {
      "from": 135.78,
      "to": 137.34,
      "sid": 103,
      "location": 2,
      "content": "可是在更大的社会层面上",
      "music": 0.0
    },
    {
      "from": 137.34,
      "to": 139.36,
      "sid": 104,
      "location": 2,
      "content": "我依然有可能不是一个成功人士",
      "music": 0.0
    },
    {
      "from": 139.36,
      "to": 140.56,
      "sid": 105,
      "location": 2,
      "content": "我赚了20万又怎么样",
      "music": 0.0
    },
    {
      "from": 140.56,
      "to": 141.8,
      "sid": 106,
      "location": 2,
      "content": "在社会公认的层面上",
      "music": 0.0
    },
    {
      "from": 141.8,
      "to": 142.8,
      "sid": 107,
      "location": 2,
      "content": "我依然不成功啊",
      "music": 0.0
    },
    {
      "from": 142.8,
      "to": 143.52,
      "sid": 108,
      "location": 2,
      "content": "那怎么办呢",
      "music": 0.0
    },
    {
      "from": 143.52,
      "to": 145.98,
      "sid": 109,
      "location": 2,
      "content": "就会有人开始在脑海中叫模拟创业",
      "music": 0.0
    },
    {
      "from": 145.98,
