{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.12,
      "to": 2.22,
      "sid": 1,
      "location": 2,
      "content": "人类科技总是螺旋上升",
      "music": 0.0
    },
    {
      "from": 2.22,
      "to": 3.3,
      "sid": 2,
      "location": 2,
      "content": "有人负责上升",
      "music": 0.0
    },
    {
      "from": 3.3,
      "to": 4.44,
      "sid": 3,
      "location": 2,
      "content": "有人负责螺旋",
      "music": 0.0
    },
    {
      "from": 4.44,
      "to": 6.78,
      "sid": 4,
      "location": 2,
      "content": "当一个技术问题很难解决的时候",
      "music": 0.0
    },
    {
      "from": 6.78,
      "to": 8.14,
      "sid": 5,
      "location": 2,
      "content": "总会有人另辟蹊径",
      "music": 0.0
    },
    {
      "from": 8.14,
      "to": 9.7,
      "sid": 6,
      "location": 2,
      "content": "简单粗暴地解决问题",
      "music": 0.0
    },
    {
      "from": 9.7,
      "to": 12.14,
      "sid": 7,
      "location": 2,
      "content": "比如有名的不锈钢战机米格25",
      "music": 0.0
    },
    {
      "from": 12.14,
      "to": 13.22,
      "sid": 8,
      "location": 2,
      "content": "机身材料受限",
      "music": 0.0
    },
    {
      "from": 13.22,
      "to": 15.26,
      "sid": 9,
      "location": 2,
      "content": "那就用力大砖飞的发动机来弥补",
      "music": 0.0
    },
    {
      "from": 15.26,
      "to": 16.36,
      "sid": 10,
      "location": 2,
      "content": "就如同有人问你",
      "music": 0.0
    },
    {
      "from": 16.36,
      "to": 18.24,
      "sid": 11,
      "location": 2,
      "content": "你女朋友怎么对你这么好呀",
      "music": 0.0
    },
    {
      "from": 18.24,
      "to": 19.32,
      "sid": 12,
      "location": 2,
      "content": "你叹了口气",
      "music": 0.0
    },
    {
      "from": 19.32,
      "to": 20.4,
      "sid": 13,
      "location": 2,
      "content": "拍拍双腿说",
      "music": 0.0
    },
    {
      "from": 20.4,
      "to": 21.96,
      "sid": 14,
      "location": 2,
      "content": "其实我只有一条腿",
      "music": 0.0
    },
    {
      "from": 21.96,
      "to": 25.2,
      "sid": 15,
      "location": 2,
      "content": "而现在站在0.7级文明门槛前的小受猴子",
      "music": 0.0
    },
    {
      "from": 25.2,
      "to": 26.02,
      "sid": 16,
      "location": 2,
      "content": "急得叽叽叫",
      "music": 0.0
    },
    {
      "from": 26.02,
      "to": 29.04,
      "sid": 17,
      "location": 2,
      "content": "因为他们要解决的重要难题就是可控核聚变",
      "music": 0.0
    },
    {
      "from": 29.04,
      "to": 31.98,
      "sid": 18,
      "location": 2,
      "content": "可控核聚变大家都知道永远50年稳定的",
      "music": 0.0
    },
    {
      "from": 31.98,
      "to": 34.02,
      "sid": 19,
      "location": 2,
      "content": "好像总是说下次一定的粉丝",
      "music": 0.0
    },
    {
      "from": 34.02,
      "to": 35.18,
      "sid": 20,
      "location": 2,
      "content": "目前的两条路子",
      "music": 0.0
    },
    {
      "from": 35.18,
      "to": 37.12,
      "sid": 21,
      "location": 2,
      "content": "不管是惯性约束还是磁约束",
      "music": 0.0
    },
    {
      "from": 37.12,
      "to": 40.28,
      "sid": 22,
      "location": 2,
      "content": "看着都像是王司徒追求三体元首一样虚无缥缈",
      "music": 0.0
    },
    {
      "from": 40.28,
      "to": 40.96,
      "sid": 23,
      "location": 2,
      "content": "甚至有人说",
      "music": 0.0
    },
    {
      "from": 40.96,
      "to": 42.12,
      "sid": 24,
      "location": 2,
      "content": "这根本不可能实现",
      "music": 0.0
    },
    {
      "from": 42.12,
      "to": 43.12,
      "sid": 25,
      "location": 2,
      "content": "走到死胡同了",
      "music": 0.0
    },
    {
      "from": 43.12,
      "to": 44.0,
      "sid": 26,
      "location": 2,
      "content": "该怎么办呢",
      "music": 0.0
    },
    {
      "from": 44.0,
      "to": 45.76,
      "sid": 27,
      "location": 2,
      "content": "当然是开挖掘机过来推了",
      "music": 0.0
    },
    {
      "from": 45.76,
      "to": 48.56,
      "sid": 28,
      "location": 2,
      "content": "他丫的大力出奇迹就成了极好的方式",
      "music": 0.0
    },
    {
      "from": 48.56,
      "to": 49.64,
      "sid": 29,
      "location": 2,
      "content": "贝格流曾写过",
      "music": 0.0
    },
    {
      "from": 49.64,
      "to": 53.12,
      "sid": 30,
      "location": 2,
      "content": "如果你的飞船不能通过正当途径加速到亚光速",
      "music": 0.0
    },
    {
      "from": 53.12,
      "to": 54.9,
      "sid": 31,
      "location": 2,
      "content": "那你就在后面持续放氢弹",
      "music": 0.0
    },
    {
      "from": 54.9,
      "to": 56.4,
      "sid": 32,
      "location": 2,
      "content": "让冲击波一级一级推进",
      "music": 0.0
    },
    {
      "from": 56.4,
      "to": 58.76,
      "sid": 33,
      "location": 2,
      "content": "你就是说当你田径考试不合格",
      "music": 0.0
    },
    {
      "from": 58.76,
      "to": 60.92,
      "sid": 34,
      "location": 2,
      "content": "可以考虑每隔50米放一条疯狗",
      "music": 0.0
    },
    {
      "from": 60.92,
      "to": 62.519,
      "sid": 35,
      "location": 2,
      "content": "绝对能撩的脚皮满天",
      "music": 0.0
    },
    {
      "from": 62.519,
      "to": 63.299,
      "sid": 36,
      "location": 2,
      "content": "俗话说",
      "music": 0.0
    },
    {
      "from": 63.299,
      "to": 64.839,
      "sid": 37,
      "location": 2,
      "content": "强扭的核聚变发不了电",
      "music": 0.0
    },
    {
      "from": 64.839,
      "to": 66.199,
      "sid": 38,
      "location": 2,
      "content": "既然人家桀骜不驯",
      "music": 0.0
    },
    {
      "from": 66.199,
      "to": 67.439,
      "sid": 39,
      "location": 2,
      "content": "那能不能不控制",
      "music": 0.0
    },
    {
      "from": 67.439,
      "to": 68.54,
      "sid": 40,
      "location": 2,
      "content": "直接拿来用呢",
      "music": 0.0
    },
    {
      "from": 68.54,
      "to": 71.2,
      "sid": 41,
      "location": 2,
      "content": "上世纪一个物理学家提出过戴森球的设想",
      "music": 0.0
    },
    {
      "from": 71.2,
      "to": 72.16,
      "sid": 42,
      "location": 2,
      "content": "说起来很简单",
      "music": 0.0
    },
    {
      "from": 72.16,
      "to": 73.52,
      "sid": 43,
      "location": 2,
      "content": "就跟现在景点差不多",
      "music": 0.0
    },
    {
      "from": 73.52,
      "to": 75.18,
      "sid": 44,
      "location": 2,
      "content": "给太阳安个围栏围起来",
      "music": 0.0
    },
    {
      "from": 75.18,
      "to": 75.94,
      "sid": 45,
      "location": 2,
      "content": "收费不对",
      "music": 0.0
    },
    {
      "from": 75.94,
      "to": 79.0,
      "sid": 46,
      "location": 2,
      "content": "发电太阳每时每刻都在不可控的核聚变",
      "music": 0.0
    },
    {
      "from": 79.0,
      "to": 80.7,
      "sid": 47,
      "location": 2,
      "content": "但大多数能量都浪费了",
      "music": 0.0
    },
    {
      "from": 80.7,
      "to": 84.0,
      "sid": 48,
      "location": 2,
      "content": "戴森球的目的就是对太阳辐射的能量连吃带拿",
      "music": 0.0
    },
    {
      "from": 84.0,
      "to": 84.76,
      "sid": 49,
      "location": 2,
      "content": "吃干抹净",
      "music": 0.0
    },
    {
      "from": 84.76,
      "to": 86.84,
      "sid": 50,
      "location": 2,
      "content": "不过这个构想多少沾点科幻",
      "music": 0.0
    },
    {
      "from": 86.84,
      "to": 89.4,
      "sid": 51,
      "location": 2,
      "content": "理论上这个戴森球直径要2亿公里",
      "music": 0.0
    },
    {
      "from": 89.4,
      "to": 91.5,
      "sid": 52,
      "location": 2,
      "content": "也就是要12亿平方公里的材料",
      "music": 0.0
    },
    {
      "from": 91.5,
      "to": 92.38,
      "sid": 53,
      "location": 2,
      "content": "这有多大呢",
      "music": 0.0
    },
    {
      "from": 92.38,
      "to": 94.84,
      "sid": 54,
      "location": 2,
      "content": "你把地球的皮扒两层都铺不满",
      "music": 0.0
    },
    {
      "from": 94.84,
      "to": 95.76,
      "sid": 55,
      "location": 2,
      "content": "你靠啥围啊",
      "music": 0.0
    },
    {
      "from": 95.76,
      "to": 96.56,
      "sid": 56,
      "location": 2,
      "content": "靠脸大呀",
      "music": 0.0
    },
    {
      "from": 96.56,
      "to": 98.42,
      "sid": 57,
      "location": 2,
      "content": "而太阳的原理和氢弹一样",
      "music": 0.0
    },
    {
      "from": 98.42,
      "to": 99.26,
      "sid": 58,
      "location": 2,
      "content": "都是核聚变",
      "music": 0.0
    },
    {
      "from": 99.26,
      "to": 100.1,
      "sid": 59,
      "location": 2,
      "content": "围不了太阳",
      "music": 0.0
    },
    {
      "from": 100.1,
      "to": 101.32,
      "sid": 60,
      "location": 2,
      "content": "我还围不了你了",
      "music": 0.0
    },
    {
      "from": 101.32,
      "to": 103.92,
      "sid": 61,
      "location": 2,
      "content": "那么一种半可控的核聚变方案就出炉了",
      "music": 0.0
    },
    {
      "from": 103.92,
      "to": 106.6,
      "sid": 62,
      "location": 2,
      "content": "围绕氢弹造一个小型戴森球核心",
      "music": 0.0
    },
    {
      "from": 106.6,
      "to": 107.66,
      "sid": 63,
      "location": 2,
      "content": "不断引爆氢弹",
      "music": 0.0
    },
    {
      "from": 107.66,
      "to": 109.5,
      "sid": 64,
      "location": 2,
      "content": "戴森球充分吸收利用核能",
      "music": 0.0
    },
    {
      "from": 109.5,
      "to": 112.14,
      "sid": 65,
      "location": 2,
      "content": "这怎么能不说是一种可控核聚变的方案呢",
      "music": 0.0
    },
    {
      "from": 112.14,
      "to": 113.6,
      "sid": 66,
      "location": 2,
      "content": "但紧接着问题就来了",
      "music": 0.0
    },
    {
      "from": 113.6,
      "to": 116.2,
      "sid": 67,
      "location": 2,
      "content": "核武器可不是蜘蛛王这样的小打小闹",
      "music": 0.0
    },
    {
      "from": 116.2,
      "to": 117.84,
      "sid": 68,
      "location": 2,
      "content": "你拿什么材料来围呢",
      "music": 0.0
    },
    {
      "from": 117.84,
      "to": 120.2,
      "sid": 69,
      "location": 2,
      "content": "你可别用一句纳米材料来糊弄兄弟们",
      "music": 0.0
    },
    {
      "from": 120.2,
      "to": 121.5,
      "sid": 70,
      "location": 2,
      "content": "在空气中放核弹",
      "music": 0.0
    },
    {
      "from": 121.5,
      "to": 122.28,
      "sid": 71,
      "location": 2,
      "content": "那是白骨度",
      "music": 0.0
    },
    {
      "from": 122.28,
      "to": 123.74,
      "sid": 72,
      "location": 2,
      "content": "遇野千里无鸡鸣",
      "music": 0.0
    },
    {
      "from": 123.74,
      "to": 125.14,
      "sid": 73,
      "location": 2,
      "content": "但在水下放核弹",
      "music": 0.0
    },
    {
      "from": 125.14,
      "to": 126.229,
      "sid": 74,
      "location": 2,
      "content": "水很难压缩",
      "music": 0.0
    },
    {
      "from": 126.229,
      "to": 127.609,
      "sid": 75,
      "location": 2,
      "content": "气化也非常吸热",
      "music": 0.0
    },
    {
      "from": 127.609,
      "to": 128.789,
      "sid": 76,
      "location": 2,
      "content": "威力就小了很多",
      "music": 0.0
    },
    {
      "from": 128.789,
      "to": 131.039,
      "sid": 77,
      "location": 2,
      "content": "要是在地下深层岩石中放核弹",
      "music": 0.0
    },
    {
      "from": 131.039,
      "to": 132.799,
      "sid": 78,
      "location": 2,
      "content": "也就形成个小空泡而已",
      "music": 0.0
    },
    {
      "from": 132.799,
      "to": 134.479,
      "sid": 79,
      "location": 2,
      "content": "岩石极难压缩和气化",
      "music": 0.0
    },
    {
      "from": 134.479,
      "to": 135.299,
      "sid": 80,
      "location": 2,
      "content": "随便崩一下",
      "music": 0.0
    },
    {
      "from": 135.299,
      "to": 136.6,
      "sid": 81,
      "location": 2,
      "content": "地震波都不明显",
      "music": 0.0
    },
    {
      "from": 136.6,
      "to": 139.36,
      "sid": 82,
      "location": 2,
      "content": "那么这个空炮就是个极好的戴森球球体",
      "music": 0.0
    },
    {
      "from": 139.36,
      "to": 140.88,
      "sid": 83,
      "location": 2,
      "content": "你氢弹不是牛逼吗",
      "music": 0.0
    },
    {
      "from": 140.88,
      "to": 142.0,
      "sid": 84,
      "location": 2,
      "content": "你不是劲儿大吗",
      "music": 0.0
    },
    {
      "from": 142.0,
      "to": 143.46,
      "sid": 85,
      "location": 2,
      "content": "你跟地球磕一磕呗",
      "music": 0.0
    },
    {
      "from": 143.46,
      "to": 145.96,
      "sid": 86,
      "location": 2,
      "content": "于是咱们设想的氢弹戴森球就产生了",
      "music": 0.0
    },
    {
      "from": 145.96,
      "to": 146.46,
      "sid": 87,
      "location": 2,
      "content": "第一步",
      "music": 0.0
    },
    {
      "from": 146.46,
      "to": 148.68,
      "sid": 88,
      "location": 2,
      "content": "先找一个岩石比较致密的地方",
      "music": 0.0
    },
    {
      "from": 148.68,
      "to": 150.56,
      "sid": 89,
      "location": 2,
      "content": "放置一颗氢弹作为核心球",
      "music": 0.0
    },
    {
      "from": 150.56,
      "to": 153.88,
      "sid": 90,
      "location": 2,
      "content": "然后围绕核心氢弹密密麻麻放置多枚氢弹之后",
      "music": 0.0
    },
    {
      "from": 153.88,
      "to": 155.28,
      "sid": 91,
      "location": 2,
      "content": "同时引爆外层氢弹",
      "music": 0.0
    },
    {
      "from": 155.28,
      "to": 157.4,
      "sid": 92,
      "location": 2,
      "content": "向内压缩核心氢弹对外爆发",
      "music": 0.0
    },
    {
      "from": 157.4,
      "to": 159.46,
      "sid": 93,
      "location": 2,
      "content": "这就把核心氢弹周围的岩层",
      "music": 0.0
    },
    {
      "from": 159.46,
      "to": 161.02,
      "sid": 94,
      "location": 2,
      "content": "挤压得更加密实坚硬",
      "music": 0.0
    },
    {
      "from": 161.02,
      "to": 161.78,
      "sid": 95,
      "location": 2,
      "content": "爆炸之后",
      "music": 0.0
    },
    {
      "from": 161.78,
      "to": 164.0,
      "sid": 96,
      "location": 2,
      "content": "核心氢弹的空枪就是戴森球了",
      "music": 0.0
    },
    {
      "from": 164.0,
      "to": 164.46,
      "sid": 97,
      "location": 2,
      "content": "第二步",
      "music": 0.0
    },
    {
      "from": 164.46,
      "to": 167.94,
      "sid": 98,
      "location": 2,
      "content": "在空腔的岩石壁上密密麻麻都给安上活塞装置",
      "music": 0.0
    },
    {
      "from": 167.94,
      "to": 169.2,
      "sid": 99,
      "location": 2,
      "content": "后面连接多种连杆",
      "music": 0.0
    },
    {
      "from": 169.2,
      "to": 172.02,
      "sid": 100,
      "location": 2,
      "content": "把活塞往复运动转化为绕轴自旋运动",
      "music": 0.0
    },
    {
      "from": 172.02,
      "to": 173.22,
      "sid": 101,
      "location": 2,
      "content": "接上发电机发电",
      "music": 0.0
    },
    {
      "from": 173.22,
      "to": 174.78,
      "sid": 102,
      "location": 2,
      "content": "活塞装置中间可以插空",
      "music": 0.0
    },
    {
      "from": 174.78,
      "to": 176.38,
      "sid": 103,
      "location": 2,
      "content": "放置太阳能板和导热材料",
      "music": 0.0
    },
    {
      "from": 176.38,
      "to": 178.32,
      "sid": 104,
      "location": 2,
      "content": "咱们的氢弹戴森球就完成了",
      "music": 0.0
    },
    {
      "from": 178.32,
      "to": 179.1,
      "sid": 105,
      "location": 2,
      "content": "最后一步",
      "music": 0.0
    },
    {
      "from": 179.1,
      "to": 180.98,
      "sid": 106,
      "location": 2,
      "content": "只需要投放同等当量的氢弹",
      "music": 0.0
    },
    {
      "from": 180.98,
      "to": 181.46,
      "sid": 107,
      "location": 2,
      "content": "大炮",
