{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 0.92,
      "sid": 1,
      "location": 2,
      "content": "在过去的一年里",
      "music": 0.0
    },
    {
      "from": 0.92,
      "to": 2.52,
      "sid": 2,
      "location": 2,
      "content": "我发布了1万3000多条帖子",
      "music": 0.0
    },
    {
      "from": 2.52,
      "to": 3.64,
      "sid": 3,
      "location": 2,
      "content": "150多条短视频",
      "music": 0.0
    },
    {
      "from": 3.64,
      "to": 5.6,
      "sid": 4,
      "location": 2,
      "content": "我几乎是用了一整年的时间去研究",
      "music": 0.0
    },
    {
      "from": 5.6,
      "to": 7.38,
      "sid": 5,
      "location": 2,
      "content": "如何才能做出更有有流量的内容",
      "music": 0.0
    },
    {
      "from": 7.38,
      "to": 9.58,
      "sid": 6,
      "location": 2,
      "content": "可是最终我只得到了一个极其简单粗暴",
      "music": 0.0
    },
    {
      "from": 9.58,
      "to": 12.1,
      "sid": 7,
      "location": 2,
      "content": "以至于有些丑陋的结论叫做有钱就是大爷",
      "music": 0.0
    },
    {
      "from": 12.1,
      "to": 13.14,
      "sid": 8,
      "location": 2,
      "content": "大V就是牛逼",
      "music": 0.0
    },
    {
      "from": 13.14,
      "to": 14.72,
      "sid": 9,
      "location": 2,
      "content": "我雇佣了人类员工和员工",
      "music": 0.0
    },
    {
      "from": 14.72,
      "to": 16.92,
      "sid": 10,
      "location": 2,
      "content": "一起去帮我搜集了成千上万的爆款模板",
      "music": 0.0
    },
    {
      "from": 16.92,
      "to": 19.12,
      "sid": 11,
      "location": 2,
      "content": "结果发现他们全都在用一模一样的套路",
      "music": 0.0
    },
    {
      "from": 19.12,
      "to": 21.08,
      "sid": 12,
      "location": 2,
      "content": "只要这个人在短视频的第一句话说",
      "music": 0.0
    },
    {
      "from": 21.08,
      "to": 22.4,
      "sid": 13,
      "location": 2,
      "content": "老娘去年赚了500万",
      "music": 0.0
    },
    {
      "from": 22.4,
      "to": 23.76,
      "sid": 14,
      "location": 2,
      "content": "今天教给你三个方法论",
      "music": 0.0
    },
    {
      "from": 23.76,
      "to": 25.36,
      "sid": 15,
      "location": 2,
      "content": "接下来不管他说的方法论是什么",
      "music": 0.0
    },
    {
      "from": 25.36,
      "to": 27.12,
      "sid": 16,
      "location": 2,
      "content": "你会发现这样的视频总是有人看",
      "music": 0.0
    },
    {
      "from": 27.12,
      "to": 27.96,
      "sid": 17,
      "location": 2,
      "content": "而很不幸的一点是",
      "music": 0.0
    },
    {
      "from": 27.96,
      "to": 29.44,
      "sid": 18,
      "location": 2,
      "content": "我发现我好像也是其中的一",
      "music": 0.0
    },
    {
      "from": 29.44,
      "to": 32.04,
      "sid": 19,
      "location": 2,
      "content": "一开始咱们的想法呢叫师夷长技以制夷",
      "music": 0.0
    },
    {
      "from": 32.04,
      "to": 32.84,
      "sid": 20,
      "location": 2,
      "content": "可是时间一久",
      "music": 0.0
    },
    {
      "from": 32.84,
      "to": 34.2,
      "sid": 21,
      "location": 2,
      "content": "这样的方法实在是太好用了",
      "music": 0.0
    },
    {
      "from": 34.2,
      "to": 37.14,
      "sid": 22,
      "location": 2,
      "content": "以至于我也分不清我是在质疑还是我那个疑",
      "music": 0.0
    },
    {
      "from": 37.14,
      "to": 39.54,
      "sid": 23,
      "location": 2,
      "content": "于是你会发现做短视频的人渐渐分成了两拨",
      "music": 0.0
    },
    {
      "from": 39.54,
      "to": 41.1,
      "sid": 24,
      "location": 2,
      "content": "其中一拨人深谙人性的弱点",
      "music": 0.0
    },
    {
      "from": 41.1,
      "to": 43.7,
      "sid": 25,
      "location": 2,
      "content": "他们每一条短视频的第一句话都是昨天直播",
      "music": 0.0
    },
    {
      "from": 43.7,
      "to": 44.66,
      "sid": 26,
      "location": 2,
      "content": "我又卖了五个亿",
      "music": 0.0
    },
    {
      "from": 44.66,
      "to": 46.38,
      "sid": 27,
      "location": 2,
      "content": "今天中午咱又谈成了八个客户",
      "music": 0.0
    },
    {
      "from": 46.38,
      "to": 47.14,
      "sid": 28,
      "location": 2,
      "content": "说出这句话",
      "music": 0.0
    },
    {
      "from": 47.14,
      "to": 48.14,
      "sid": 29,
      "location": 2,
      "content": "甚至不需要五秒钟",
      "music": 0.0
    },
    {
      "from": 48.14,
      "to": 49.82,
      "sid": 30,
      "location": 2,
      "content": "而用这五秒钟骗过了人性之后",
      "music": 0.0
    },
    {
      "from": 49.82,
      "to": 50.84,
      "sid": 31,
      "location": 2,
      "content": "在接下来的5分钟",
      "music": 0.0
    },
    {
      "from": 50.84,
      "to": 52.44,
      "sid": 32,
      "location": 2,
      "content": "他们可以为所欲为",
      "music": 0.0
    },
    {
      "from": 52.44,
      "to": 54.2,
      "sid": 33,
      "location": 2,
      "content": "毕竟语言是可以构建全力的",
      "music": 0.0
    },
    {
      "from": 54.2,
      "to": 56.84,
      "sid": 34,
      "location": 2,
      "content": "用足足5分钟的时间说服屏幕对面的观众",
      "music": 0.0
    },
    {
      "from": 56.84,
      "to": 57.44,
      "sid": 35,
      "location": 2,
      "content": "花点小钱",
      "music": 0.0
    },
    {
      "from": 57.44,
      "to": 58.96,
      "sid": 36,
      "location": 2,
      "content": "真的不是一个太难的事情",
      "music": 0.0
    },
    {
      "from": 58.96,
      "to": 59.56,
      "sid": 37,
      "location": 2,
      "content": "这也是为什么",
      "music": 0.0
    },
    {
      "from": 59.56,
      "to": 61.72,
      "sid": 38,
      "location": 2,
      "content": "抖音一年的交易额可以高达4万亿",
      "music": 0.0
    },
    {
      "from": 61.72,
      "to": 62.36,
      "sid": 39,
      "location": 2,
      "content": "而与此同时",
      "music": 0.0
    },
    {
      "from": 62.36,
      "to": 64.64,
      "sid": 40,
      "location": 2,
      "content": "另外一拨人觉得自己怀才不欲曲高和寡",
      "music": 0.0
    },
    {
      "from": 64.64,
      "to": 65.64,
      "sid": 41,
      "location": 2,
      "content": "我有一个做房产的朋友",
      "music": 0.0
    },
    {
      "from": 65.64,
      "to": 68.6,
      "sid": 42,
      "location": 2,
      "content": "他把自己十多年来沉淀的底层方法论如数公开",
      "music": 0.0
    },
    {
      "from": 68.6,
      "to": 69.64,
      "sid": 43,
      "location": 2,
      "content": "发现根本没人看",
      "music": 0.0
    },
    {
      "from": 69.64,
      "to": 70.3,
      "sid": 44,
      "location": 2,
      "content": "我跟他说",
      "music": 0.0
    },
    {
      "from": 70.3,
      "to": 72.66,
      "sid": 45,
      "location": 2,
      "content": "如果现在我有十个亿的现金要交给你打理",
      "music": 0.0
    },
    {
      "from": 72.66,
      "to": 74.26,
      "sid": 46,
      "location": 2,
      "content": "而你只有五秒钟用来说服我",
      "music": 0.0
    },
    {
      "from": 74.26,
      "to": 75.22,
      "sid": 47,
      "location": 2,
      "content": "你准备怎么说",
      "music": 0.0
    },
    {
      "from": 75.22,
      "to": 76.62,
      "sid": 48,
      "location": 2,
      "content": "他说他在海外从业20年",
      "music": 0.0
    },
    {
      "from": 76.62,
      "to": 78.62,
      "sid": 49,
      "location": 2,
      "content": "管理过的资产总共接近100亿",
      "music": 0.0
    },
    {
      "from": 78.62,
      "to": 79.82,
      "sid": 50,
      "location": 2,
      "content": "服务过12个超级富豪",
      "music": 0.0
    },
    {
      "from": 79.82,
      "to": 80.5,
      "sid": 51,
      "location": 2,
      "content": "我说恭喜你",
      "music": 0.0
    },
    {
      "from": 80.5,
      "to": 81.54,
      "sid": 52,
      "location": 2,
      "content": "找到了自己的流量密码",
      "music": 0.0
    },
    {
      "from": 81.54,
      "to": 82.46,
      "sid": 53,
      "location": 2,
      "content": "从现在开始",
      "music": 0.0
    },
    {
      "from": 82.46,
      "to": 83.94,
      "sid": 54,
      "location": 2,
      "content": "你的每一条短视频的第一句话",
      "music": 0.0
    },
    {
      "from": 83.94,
      "to": 85.46,
      "sid": 55,
      "location": 2,
      "content": "全部都是我从业12年",
      "music": 0.0
    },
    {
      "from": 85.46,
      "to": 86.18,
      "sid": 56,
      "location": 2,
      "content": "管理100亿",
      "music": 0.0
    },
    {
      "from": 86.18,
      "to": 87.34,
      "sid": 57,
      "location": 2,
      "content": "服务过12个超级富豪",
      "music": 0.0
    },
    {
      "from": 87.34,
      "to": 88.96,
      "sid": 58,
      "location": 2,
      "content": "接下来你想说什么说什么",
      "music": 0.0
    },
    {
      "from": 88.96,
      "to": 89.88,
      "sid": 59,
      "location": 2,
      "content": "因为大家感兴趣的",
      "music": 0.0
    },
    {
      "from": 89.88,
      "to": 91.76,
      "sid": 60,
      "location": 2,
      "content": "根本就不是配置房产的底层逻辑",
      "music": 0.0
    },
    {
      "from": 91.76,
      "to": 93.6,
      "sid": 61,
      "location": 2,
      "content": "而是我想找到一个足够牛逼的人",
      "music": 0.0
    },
    {
      "from": 93.6,
      "to": 94.82,
      "sid": 62,
      "location": 2,
      "content": "帮我打理这点小钱",
      "music": 0.0
    },
    {
      "from": 94.82,
      "to": 96.16,
      "sid": 63,
      "location": 2,
      "content": "至于你的方法论是什么",
      "music": 0.0
    },
    {
      "from": 96.16,
      "to": 97.44,
      "sid": 64,
      "location": 2,
      "content": "我根本不想听",
      "music": 0.0
    },
    {
      "from": 97.44,
      "to": 98.72,
      "sid": 65,
      "location": 2,
      "content": "很快这位朋友的生意就变好了",
      "music": 0.0
    },
    {
      "from": 98.72,
      "to": 100.28,
      "sid": 66,
      "location": 2,
      "content": "而我也很庆幸他的顾客们",
      "music": 0.0
    },
    {
      "from": 100.28,
      "to": 101.36,
      "sid": 67,
      "location": 2,
      "content": "找到了一个有能力的人",
      "music": 0.0
    },
    {
      "from": 101.36,
      "to": 102.04,
      "sid": 68,
      "location": 2,
      "content": "可是这个时候呢",
      "music": 0.0
    },
    {
      "from": 102.04,
      "to": 103.78,
      "sid": 69,
      "location": 2,
      "content": "这个朋友又给我发出了灵魂意见",
      "music": 0.0
    },
    {
      "from": 103.78,
      "to": 105.9,
      "sid": 70,
      "location": 2,
      "content": "他说我总不能天天说我从业20年",
      "music": 0.0
    },
    {
      "from": 105.9,
      "to": 106.54,
      "sid": 71,
      "location": 2,
      "content": "管理100亿吧",
      "music": 0.0
    },
    {
      "from": 106.54,
      "to": 107.54,
      "sid": 72,
      "location": 2,
      "content": "我是不是得说点别的",
      "music": 0.0
    },
    {
      "from": 107.54,
      "to": 108.12,
      "sid": 73,
      "location": 2,
      "content": "我说恭喜你",
      "music": 0.0
    },
    {
      "from": 108.12,
      "to": 110.0,
      "sid": 74,
      "location": 2,
      "content": "你再次触及到了自媒体的本质",
      "music": 0.0
    },
    {
      "from": 110.0,
      "to": 111.96,
      "sid": 75,
      "location": 2,
      "content": "在于一个人有流量的根本原因",
      "music": 0.0
    },
    {
      "from": 111.96,
      "to": 114.16,
      "sid": 76,
      "location": 2,
      "content": "在于他是一个值得被关注的人",
      "music": 0.0
    },
    {
      "from": 114.16,
      "to": 114.8,
      "sid": 77,
      "location": 2,
      "content": "表面上",
      "music": 0.0
    },
    {
      "from": 114.8,
      "to": 117.04,
      "sid": 78,
      "location": 2,
      "content": "你看见很多人用短视频的开头去愚弄人性",
      "music": 0.0
    },
    {
      "from": 117.04,
      "to": 118.42,
      "sid": 79,
      "location": 2,
      "content": "但背后的真实情况是",
      "music": 0.0
    },
    {
      "from": 118.42,
      "to": 119.74,
      "sid": 80,
      "location": 2,
      "content": "观众们在刷短视频的时候",
      "music": 0.0
    },
    {
      "from": 119.74,
      "to": 121.42,
      "sid": 81,
      "location": 2,
      "content": "只能用这五秒钟去判断",
      "music": 0.0
    },
    {
      "from": 121.42,
      "to": 123.58,
      "sid": 82,
      "location": 2,
      "content": "我值不值得花5分钟去看这个视频",
      "music": 0.0
    },
    {
      "from": 123.58,
      "to": 125.46,
      "sid": 83,
      "location": 2,
      "content": "而我的这位朋友用短短的五秒钟",
      "music": 0.0
    },
    {
      "from": 125.46,
      "to": 127.14,
      "sid": 84,
      "location": 2,
      "content": "把他从业20年的牌都打出来了",
      "music": 0.0
    },
    {
      "from": 127.14,
      "to": 129.06,
      "sid": 85,
      "location": 2,
      "content": "那他当然就没有更多的牌可以打了",
      "music": 0.0
    },
    {
      "from": 129.06,
      "to": 130.78,
      "sid": 86,
      "location": 2,
      "content": "这实际上在倒逼他成为一个",
      "music": 0.0
    },
    {
      "from": 130.78,
      "to": 132.14,
      "sid": 87,
      "location": 2,
      "content": "更加值得被关注的人",
      "music": 0.0
    },
    {
      "from": 132.14,
      "to": 135.42,
      "sid": 88,
      "location": 2,
      "content": "而我认为这才是做自媒体真正应该去做的事情",
      "music": 0.0
    },
    {
      "from": 135.42,
      "to": 136.06,
      "sid": 89,
      "location": 2,
      "content": "话说到这儿呢",
      "music": 0.0
    },
    {
      "from": 136.06,
      "to": 137.66,
      "sid": 90,
      "location": 2,
      "content": "按照短视频创作的常规流程",
      "music": 0.0
    },
    {
      "from": 137.66,
      "to": 139.54,
      "sid": 91,
      "location": 2,
      "content": "我应该在这个地方给大家一些建议了",
      "music": 0.0
    },
    {
      "from": 139.54,
      "to": 141.46,
      "sid": 92,
      "location": 2,
      "content": "而这个时候我恰好想起了一句",
      "music": 0.0
    },
    {
      "from": 141.46,
      "to": 142.7,
      "sid": 93,
      "location": 2,
      "content": "看似与此无关的话",
      "music": 0.0
    },
    {
      "from": 142.7,
      "to": 144.02,
      "sid": 94,
      "location": 2,
      "content": "是赵丹皮特森曾经说",
      "music": 0.0
    },
    {
      "from": 144.02,
      "to": 144.9,
      "sid": 95,
      "location": 2,
      "content": "善良不是软弱",
      "music": 0.0
    },
    {
      "from": 144.9,
      "to": 147.08,
      "sid": 96,
      "location": 2,
      "content": "而是在你有能力伤害其他人的情况下",
      "music": 0.0
    },
    {
      "from": 147.08,
      "to": 148.22,
      "sid": 97,
      "location": 2,
      "content": "你选择不这样去做",
      "music": 0.0
    },
    {
      "from": 148.22,
      "to": 150.08,
      "sid": 98,
      "location": 2,
      "content": "所以呢如果你恰好是一个创作者",
      "music": 0.0
    },
    {
      "from": 150.08,
      "to": 151.04,
      "sid": 99,
      "location": 2,
      "content": "你又是一个好人",
      "music": 0.0
    },
    {
      "from": 151.04,
      "to": 153.0,
      "sid": 100,
      "location": 2,
      "content": "我希望你可以竭尽所能的去学习",
      "music": 0.0
    },
    {
      "from": 153.0,
      "to": 154.0,
      "sid": 101,
      "location": 2,
      "content": "那些搞流量的技巧",
      "music": 0.0
    },
    {
      "from": 154.0,
      "to": 155.32,
      "sid": 102,
      "location": 2,
      "content": "让你的那些好内容",
      "music": 0.0
    },
    {
      "from": 155.32,
      "to": 157.78,
      "sid": 103,
      "location": 2,
      "content": "可以在算法的帮助下传播出去",
      "music": 0.0
    },
    {
      "from": 157.78,
      "to": 159.58,
      "sid": 104,
      "location": 2,
      "content": "不要把这个世界让给那些烂人",
      "music": 0.0
    },
    {
      "from": 159.58,
      "to": 161.34,
      "sid": 105,
      "location": 2,
      "content": "而如果你恰好就是那个坏人的话",
      "music": 0.0
    },
    {
      "from": 161.34,
      "to": 163.36,
      "sid": 106,
      "location": 2,
      "content": "那我只能在此苍白无力的建议",
      "music": 0.0
    },
    {
      "from": 163.36,
      "to": 164.76,
      "sid": 107,
      "location": 2,
      "content": "你尽可能还是去做个好人",
