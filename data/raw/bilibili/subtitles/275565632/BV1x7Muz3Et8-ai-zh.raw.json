{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.1,
      "to": 1.1,
      "sid": 1,
      "location": 2,
      "content": "哈喽各位小可爱",
      "music": 0.0
    },
    {
      "from": 1.1,
      "to": 3.26,
      "sid": 2,
      "location": 2,
      "content": "这里依旧是那个每天问你喵钻的罐头",
      "music": 0.0
    },
    {
      "from": 3.26,
      "to": 5.04,
      "sid": 3,
      "location": 2,
      "content": "还是先恳请各位小可爱呢",
      "music": 0.0
    },
    {
      "from": 5.04,
      "to": 6.56,
      "sid": 4,
      "location": 2,
      "content": "动动您发财的小手指",
      "music": 0.0
    },
    {
      "from": 6.56,
      "to": 7.48,
      "sid": 5,
      "location": 2,
      "content": "给罐头点赞",
      "music": 0.0
    },
    {
      "from": 7.48,
      "to": 8.56,
      "sid": 6,
      "location": 2,
      "content": "投币鼓励支持一下",
      "music": 0.0
    },
    {
      "from": 8.56,
      "to": 9.72,
      "sid": 7,
      "location": 2,
      "content": "真是万分感谢了",
      "music": 0.0
    },
    {
      "from": 9.72,
      "to": 10.94,
      "sid": 8,
      "location": 2,
      "content": "昨天咱们说到啊",
      "music": 0.0
    },
    {
      "from": 10.94,
      "to": 13.24,
      "sid": 9,
      "location": 2,
      "content": "建坤已经站到卓世奇一边了",
      "music": 0.0
    },
    {
      "from": 13.24,
      "to": 16.48,
      "sid": 10,
      "location": 2,
      "content": "他提的要求就是拿到王卓的一家子公司",
      "music": 0.0
    },
    {
      "from": 16.48,
      "to": 18.42,
      "sid": 11,
      "location": 2,
      "content": "卓世奇全盘答应下来",
      "music": 0.0
    },
    {
      "from": 18.42,
      "to": 21.06,
      "sid": 12,
      "location": 2,
      "content": "而当年那双高跟鞋呢是36码",
      "music": 0.0
    },
    {
      "from": 21.06,
      "to": 22.76,
      "sid": 13,
      "location": 2,
      "content": "范玉玲穿39码",
      "music": 0.0
    },
    {
      "from": 22.76,
      "to": 23.94,
      "sid": 14,
      "location": 2,
      "content": "这又是为什么呢",
      "music": 0.0
    },
    {
      "from": 23.94,
      "to": 26.16,
      "sid": 15,
      "location": 2,
      "content": "还没等到于满月再找到机会调查",
      "music": 0.0
    },
    {
      "from": 26.16,
      "to": 28.68,
      "sid": 16,
      "location": 2,
      "content": "卓昊天就因为暴露私人行程的照片",
      "music": 0.0
    },
    {
      "from": 28.68,
      "to": 29.78,
      "sid": 17,
      "location": 2,
      "content": "解雇了于满月",
      "music": 0.0
    },
    {
      "from": 29.78,
      "to": 32.9,
      "sid": 18,
      "location": 2,
      "content": "而调查下来那些照片是勇士发出去的",
      "music": 0.0
    },
    {
      "from": 32.9,
      "to": 34.64,
      "sid": 19,
      "location": 2,
      "content": "故意栽赃给了于满月",
      "music": 0.0
    },
    {
      "from": 34.64,
      "to": 37.5,
      "sid": 20,
      "location": 2,
      "content": "紧接着也是勇士接替了于满月的职位",
      "music": 0.0
    },
    {
      "from": 37.5,
      "to": 38.76,
      "sid": 21,
      "location": 2,
      "content": "不过真实原因呢",
      "music": 0.0
    },
    {
      "from": 38.76,
      "to": 41.6,
      "sid": 22,
      "location": 2,
      "content": "是一篇关于卓世荣车祸真相的报道",
      "music": 0.0
    },
    {
      "from": 41.6,
      "to": 43.34,
      "sid": 23,
      "location": 2,
      "content": "被勇士拦截了下来",
      "music": 0.0
    },
    {
      "from": 43.34,
      "to": 46.14,
      "sid": 24,
      "location": 2,
      "content": "也是他表示背后的人就是于满月",
      "music": 0.0
    },
    {
      "from": 46.14,
      "to": 48.32,
      "sid": 25,
      "location": 2,
      "content": "建坤当时也想赶走于满月",
      "music": 0.0
    },
    {
      "from": 48.32,
      "to": 49.28,
      "sid": 26,
      "location": 2,
      "content": "还没等出手",
      "music": 0.0
    },
    {
      "from": 49.28,
      "to": 51.02,
      "sid": 27,
      "location": 2,
      "content": "勇士背后的人就出手了",
      "music": 0.0
    },
    {
      "from": 51.02,
      "to": 52.98,
      "sid": 28,
      "location": 2,
      "content": "而这个背后的人就是卓慧云",
      "music": 0.0
    },
    {
      "from": 52.98,
      "to": 55.06,
      "sid": 29,
      "location": 2,
      "content": "他故意拿了报道给卓昊天看",
      "music": 0.0
    },
    {
      "from": 55.06,
      "to": 57.78,
      "sid": 30,
      "location": 2,
      "content": "然后让勇士安排好记者统一口径",
      "music": 0.0
    },
    {
      "from": 57.78,
      "to": 59.74,
      "sid": 31,
      "location": 2,
      "content": "把一切都推到于满月身上",
      "music": 0.0
    },
    {
      "from": 59.74,
      "to": 61.18,
      "sid": 32,
      "location": 2,
      "content": "余曼星呢有个习惯",
      "music": 0.0
    },
    {
      "from": 61.18,
      "to": 62.98,
      "sid": 33,
      "location": 2,
      "content": "开心不开心的都爱购物",
      "music": 0.0
    },
    {
      "from": 62.98,
      "to": 65.0,
      "sid": 34,
      "location": 2,
      "content": "后面再卖给二手店回血",
      "music": 0.0
    },
    {
      "from": 65.0,
      "to": 67.32,
      "sid": 35,
      "location": 2,
      "content": "余曦辰干脆叫姐姐拿回家里",
      "music": 0.0
    },
    {
      "from": 67.32,
      "to": 69.34,
      "sid": 36,
      "location": 2,
      "content": "有合适的自己和余满月买下来",
      "music": 0.0
    },
    {
      "from": 69.34,
      "to": 70.9,
      "sid": 37,
      "location": 2,
      "content": "回的血不是更多吗",
      "music": 0.0
    },
    {
      "from": 70.9,
      "to": 72.8,
      "sid": 38,
      "location": 2,
      "content": "其实就是因为吵架过后啊",
      "music": 0.0
    },
    {
      "from": 72.8,
      "to": 74.5,
      "sid": 39,
      "location": 2,
      "content": "大姐二姐一直都没和好",
      "music": 0.0
    },
    {
      "from": 74.5,
      "to": 76.78,
      "sid": 40,
      "location": 2,
      "content": "余希辰想要帮忙制造见面的机会",
      "music": 0.0
    },
    {
      "from": 76.78,
      "to": 78.06,
      "sid": 41,
      "location": 2,
      "content": "有了于希辰的助攻啊",
      "music": 0.0
    },
    {
      "from": 78.06,
      "to": 79.92,
      "sid": 42,
      "location": 2,
      "content": "大家终于一起回到了家里",
      "music": 0.0
    },
    {
      "from": 79.92,
      "to": 83.94,
      "sid": 43,
      "location": 2,
      "content": "却没想到余曼星手上也有那双卡索利的鞋",
      "music": 0.0
    },
    {
      "from": 83.94,
      "to": 86.9,
      "sid": 44,
      "location": 2,
      "content": "原来同款设计呢有钻的是限量版",
      "music": 0.0
    },
    {
      "from": 86.9,
      "to": 88.3,
      "sid": 45,
      "location": 2,
      "content": "没有钻的是普通版",
      "music": 0.0
    },
    {
      "from": 88.3,
      "to": 90.0,
      "sid": 46,
      "location": 2,
      "content": "余曼星买的普通款啊",
      "music": 0.0
    },
    {
      "from": 90.0,
      "to": 91.04,
      "sid": 47,
      "location": 2,
      "content": "也是很喜欢",
      "music": 0.0
    },
    {
      "from": 91.04,
      "to": 92.94,
      "sid": 48,
      "location": 2,
      "content": "可后面大姐一直没穿过",
      "music": 0.0
    },
    {
      "from": 92.94,
      "to": 93.66,
      "sid": 49,
      "location": 2,
      "content": "就不气",
      "music": 0.0
    },
    {
      "from": 93.66,
      "to": 94.979,
      "sid": 50,
      "location": 2,
      "content": "更大白了",
      "music": 0.0
    },
    {
      "from": 94.979,
      "to": 97.219,
      "sid": 51,
      "location": 2,
      "content": "最早出穿透子",
      "music": 0.0
    },
    {
      "from": 97.219,
      "to": 99.899,
      "sid": 52,
      "location": 2,
      "content": "这可见到有个人同我这么同婚的",
      "music": 0.0
    },
    {
      "from": 99.899,
      "to": 101.519,
      "sid": 53,
      "location": 2,
      "content": "可是我对她是好人吧",
      "music": 0.0
    },
    {
      "from": 101.519,
      "to": 104.17,
      "sid": 54,
      "location": 2,
      "content": "你见都见了我的老婆",
      "music": 0.0
    },
    {
      "from": 104.17,
      "to": 107.54,
      "sid": 55,
      "location": 2,
      "content": "全村人真的都你舍得买名牌照过",
      "music": 0.05147058634299338
    },
    {
      "from": 107.54,
      "to": 108.94,
      "sid": 56,
      "location": 2,
      "content": "从右边写的还行",
      "music": 0.0
    },
    {
      "from": 108.94,
      "to": 109.86,
      "sid": 57,
      "location": 2,
      "content": "两版了",
      "music": 0.0
    },
    {
      "from": 109.86,
      "to": 111.66,
      "sid": 58,
      "location": 2,
      "content": "今年才有所不知了",
      "music": 0.0
    },
    {
      "from": 111.66,
      "to": 113.24,
      "sid": 59,
      "location": 2,
      "content": "哥哥在出外人呢",
      "music": 0.0
    },
    {
      "from": 113.24,
      "to": 114.52,
      "sid": 60,
      "location": 2,
      "content": "你是当事人",
      "music": 0.0
    },
    {
      "from": 114.52,
      "to": 116.69,
      "sid": 61,
      "location": 2,
      "content": "他已经成生命体的",
      "music": 0.0
    },
    {
      "from": 116.69,
      "to": 118.93,
      "sid": 62,
      "location": 2,
      "content": "刚才外文可超好听的",
      "music": 0.0
    },
    {
      "from": 118.93,
      "to": 120.95,
      "sid": 63,
      "location": 2,
      "content": "仙女都不提啊",
      "music": 0.0
    },
    {
      "from": 120.95,
      "to": 122.97,
      "sid": 64,
      "location": 2,
      "content": "私生孙女的吗",
      "music": 0.0
    },
    {
      "from": 122.97,
      "to": 124.81,
      "sid": 65,
      "location": 2,
      "content": "是秋天的孙女",
      "music": 0.0
    },
    {
      "from": 124.81,
      "to": 127.61,
      "sid": 66,
      "location": 2,
      "content": "应该记得2年前的",
      "music": 0.0
    },
    {
      "from": 127.61,
      "to": 129.45,
      "sid": 67,
      "location": 2,
      "content": "那这么算下来",
      "music": 0.0
    },
    {
      "from": 129.45,
      "to": 132.78,
      "sid": 68,
      "location": 2,
      "content": "还有怀疑的就是范玉林房间里的另一个女人了",
      "music": 0.0
    },
    {
      "from": 132.78,
      "to": 133.52,
      "sid": 69,
      "location": 2,
      "content": "于满月啊",
      "music": 0.0
    },
    {
      "from": 133.52,
      "to": 134.62,
      "sid": 70,
      "location": 2,
      "content": "还是去找了乐瑶",
      "music": 0.0
    },
    {
      "from": 134.62,
      "to": 137.1,
      "sid": 71,
      "location": 2,
      "content": "这就找到了一篇18年前的老手稿",
      "music": 0.0
    },
    {
      "from": 137.1,
      "to": 138.88,
      "sid": 72,
      "location": 2,
      "content": "根本没有刊登出来过",
      "music": 0.0
    },
    {
      "from": 138.88,
      "to": 140.6,
      "sid": 73,
      "location": 2,
      "content": "当时那个记者就发现",
      "music": 0.0
    },
    {
      "from": 140.6,
      "to": 142.8,
      "sid": 74,
      "location": 2,
      "content": "范玉玲的孩子根本没有夭折",
      "music": 0.0
    },
    {
      "from": 142.8,
      "to": 143.5,
      "sid": 75,
      "location": 2,
      "content": "于满月",
      "music": 0.0
    },
    {
      "from": 143.5,
      "to": 145.3,
      "sid": 76,
      "location": 2,
      "content": "还没有找到突破口的时候",
      "music": 0.0
    },
    {
      "from": 145.3,
      "to": 147.28,
      "sid": 77,
      "location": 2,
      "content": "真的突然开始想念程风了",
      "music": 0.0
    },
    {
      "from": 147.28,
      "to": 148.4,
      "sid": 78,
      "location": 2,
      "content": "乘风也是一样啊",
      "music": 0.0
    },
    {
      "from": 148.4,
      "to": 149.44,
      "sid": 79,
      "location": 2,
      "content": "衣服洗了又洗",
      "music": 0.0
    },
    {
      "from": 149.44,
      "to": 152.66,
      "sid": 80,
      "location": 2,
      "content": "也不知道还能不能再遇到于满月",
      "music": 0.0
    },
    {
      "from": 171.22,
      "to": 172.62,
      "sid": 81,
      "location": 2,
      "content": "我问你啊",
      "music": 0.0
    },
    {
      "from": 172.62,
      "to": 174.41,
      "sid": 82,
      "location": 2,
      "content": "我都要问你",
      "music": 0.0
    },
    {
      "from": 174.41,
      "to": 176.99,
      "sid": 83,
      "location": 2,
      "content": "这是于满月第一次到了程峰家里",
      "music": 0.0
    },
    {
      "from": 176.99,
      "to": 179.29,
      "sid": 84,
      "location": 2,
      "content": "也是他第一次开口来找程峰帮忙",
      "music": 0.0
    },
    {
      "from": 179.29,
      "to": 181.09,
      "sid": 85,
      "location": 2,
      "content": "程峰知道了于满月被解雇",
      "music": 0.0
    },
    {
      "from": 181.09,
      "to": 182.34,
      "sid": 86,
      "location": 2,
      "content": "就一直在等着他",
      "music": 0.0
    },
    {
      "from": 182.34,
      "to": 185.08,
      "sid": 87,
      "location": 2,
      "content": "程峰很想知道到底是谁要害于满月",
      "music": 0.0
    },
    {
      "from": 185.08,
      "to": 187.7,
      "sid": 88,
      "location": 2,
      "content": "于满月更想知道范玉玲到底有没有孩子",
      "music": 0.0
    },
    {
      "from": 187.7,
      "to": 189.4,
      "sid": 89,
      "location": 2,
      "content": "这一点程峰倒是可以确认",
      "music": 0.0
    },
    {
      "from": 189.4,
      "to": 191.41,
      "sid": 90,
      "location": 2,
      "content": "那就是范玉玲有个女儿梅宝",
      "music": 0.0
    },
    {
      "from": 191.41,
      "to": 193.65,
      "sid": 91,
      "location": 2,
      "content": "卓昊天现在需要梅宝的骨髓",
      "music": 0.0
    },
    {
      "from": 193.65,
      "to": 195.33,
      "sid": 92,
      "location": 2,
      "content": "很快卓昊天同意了",
      "music": 0.0
    },
    {
      "from": 195.33,
      "to": 196.15,
      "sid": 93,
      "location": 2,
      "content": "录一段视频",
      "music": 0.0
    },
    {
      "from": 196.15,
      "to": 197.7,
      "sid": 94,
      "location": 2,
      "content": "说明卓世荣的情况",
      "music": 0.0
    },
    {
      "from": 197.7,
      "to": 200.42,
      "sid": 95,
      "location": 2,
      "content": "手术当天才允许视频公开发出",
      "music": 0.0
    },
    {
      "from": 200.42,
      "to": 202.72,
      "sid": 96,
      "location": 2,
      "content": "于满月先去见了一趟勇士",
      "music": 0.0
    },
    {
      "from": 202.72,
      "to": 204.24,
      "sid": 97,
      "location": 2,
      "content": "想要直接问问情况",
      "music": 0.0
    },
    {
      "from": 204.24,
      "to": 205.42,
      "sid": 98,
      "location": 2,
      "content": "看看勇士的反应",
      "music": 0.0
    },
    {
      "from": 205.42,
      "to": 206.74,
      "sid": 99,
      "location": 2,
      "content": "1米96的耶",
      "music": 0.0
    },
    {
      "from": 206.74,
      "to": 209.11,
      "sid": 100,
      "location": 2,
      "content": "我都跟你好个子",
      "music": 0.0
    },
    {
      "from": 209.59,
      "to": 212.03,
      "sid": 101,
      "location": 2,
      "content": "如果你中当我是你师傅的话",
      "music": 0.0
    },
    {
      "from": 212.03,
      "to": 213.55,
      "sid": 102,
      "location": 2,
      "content": "我奉劝你一句",
      "music": 0.0
    },
    {
      "from": 213.55,
      "to": 215.49,
      "sid": 103,
      "location": 2,
      "content": "你今晚对我做过耶",
      "music": 0.0
    },
    {
      "from": 215.49,
      "to": 218.19,
      "sid": 104,
      "location": 2,
      "content": "但也可以让我对你做饭",
      "music": 0.0
    },
    {
      "from": 219.86,
      "to": 222.3,
      "sid": 105,
      "location": 2,
      "content": "我怎么干呢",
      "music": 0.0
    },
    {
      "from": 223.34,
      "to": 225.14,
      "sid": 106,
      "location": 2,
      "content": "为了避免卓昊天直接抢人",
      "music": 0.0
    },
    {
      "from": 225.14,
      "to": 227.3,
      "sid": 107,
      "location": 2,
      "content": "建坤帮范玉玲换了新的酒店",
      "music": 0.0
    },
    {
      "from": 227.3,
      "to": 229.78,
      "sid": 108,
      "location": 2,
      "content": "程峰很快把地址发给了于满月",
      "music": 0.0
    },
    {
