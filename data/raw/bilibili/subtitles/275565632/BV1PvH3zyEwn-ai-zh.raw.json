{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "sync-v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 0.8,
      "sid": 1,
      "location": 2,
      "content": "赚钱费劲",
      "music": 0.0
    },
    {
      "from": 0.8,
      "to": 4.68,
      "sid": 2,
      "location": 2,
      "content": "大概率是因为没有商业模式而没有商业模式的核心体现就是不会定价",
      "music": 0.0
    },
    {
      "from": 4.68,
      "to": 5.36,
      "sid": 3,
      "location": 2,
      "content": "而不会定价",
      "music": 0.0
    },
    {
      "from": 5.36,
      "to": 8.4,
      "sid": 4,
      "location": 2,
      "content": "给你带来的第一个麻烦就是搞不清什么是价格带什么价格梯度",
      "music": 0.0
    },
    {
      "from": 8.4,
      "to": 9.08,
      "sid": 5,
      "location": 2,
      "content": "搞不清价格带",
      "music": 0.0
    },
    {
      "from": 9.08,
      "to": 10.92,
      "sid": 6,
      "location": 2,
      "content": "你就区分不开你的引流款和利润款",
      "music": 0.0
    },
    {
      "from": 10.92,
      "to": 12.88,
      "sid": 7,
      "location": 2,
      "content": "而引流款和利润款的这个组合结构",
      "music": 0.0
    },
    {
      "from": 12.88,
      "to": 16.88,
      "sid": 8,
      "location": 2,
      "content": "又是恰好是现在能让你去对抗高昂的获客成本的最有力的武器",
      "music": 0.0
    },
    {
      "from": 16.88,
      "to": 17.64,
      "sid": 9,
      "location": 2,
      "content": "什么叫价格带",
      "music": 0.0
    },
    {
      "from": 17.64,
      "to": 18.96,
      "sid": 10,
      "location": 2,
      "content": "我们拿IPHONE的价格来举个例子",
      "music": 0.0
    },
    {
      "from": 18.96,
      "to": 20.08,
      "sid": 11,
      "location": 2,
      "content": "你可能很快就清楚了",
      "music": 0.0
    },
    {
      "from": 20.08,
      "to": 21.84,
      "sid": 12,
      "location": 2,
      "content": "在国内的苹果官网上",
      "music": 0.0
    },
    {
      "from": 21.84,
      "to": 24.46,
      "sid": 13,
      "location": 2,
      "content": "目前正在销售的最新款的这些手机里面",
      "music": 0.0
    },
    {
      "from": 24.46,
      "to": 26.1,
      "sid": 14,
      "location": 2,
      "content": "最便宜的一款叫IPHONE16E",
      "music": 0.0
    },
    {
      "from": 26.1,
      "to": 28.0,
      "sid": 15,
      "location": 2,
      "content": "它的官方售价是4499",
      "music": 0.0
    },
    {
      "from": 28.0,
      "to": 30.88,
      "sid": 16,
      "location": 2,
      "content": "最贵的一款是2tb版本的IPHONE17pro max",
      "music": 0.0
    },
    {
      "from": 30.88,
      "to": 32.96,
      "sid": 17,
      "location": 2,
      "content": "它的官方售价是1万7999",
      "music": 0.0
    },
    {
      "from": 32.96,
      "to": 35.02,
      "sid": 18,
      "location": 2,
      "content": "而这两个产品的价格刚刚好就差了四倍",
      "music": 0.0
    },
    {
      "from": 35.02,
      "to": 35.9,
      "sid": 19,
      "location": 2,
      "content": "这个不是巧合",
      "music": 0.0
    },
    {
      "from": 35.9,
      "to": 37.98,
      "sid": 20,
      "location": 2,
      "content": "是绝对非常合理的一套定价结构",
      "music": 0.0
    },
    {
      "from": 37.98,
      "to": 39.74,
      "sid": 21,
      "location": 2,
      "content": "由于受这个汇率和关税的影响",
      "music": 0.0
    },
    {
      "from": 39.74,
      "to": 42.12,
      "sid": 22,
      "location": 2,
      "content": "你在其他国家所看看到的苹果官网上",
      "music": 0.0
    },
    {
      "from": 42.12,
      "to": 43.94,
      "sid": 23,
      "location": 2,
      "content": "最便宜和最贵产品之间的这个差距啊",
      "music": 0.0
    },
    {
      "from": 43.94,
      "to": 44.7,
      "sid": 24,
      "location": 2,
      "content": "可能不是四倍",
      "music": 0.0
    },
    {
      "from": 44.7,
      "to": 47.96,
      "sid": 25,
      "location": 2,
      "content": "但是一般都是3~4倍之间是很稳定的一个区间",
      "music": 0.0
    },
    {
      "from": 47.96,
      "to": 49.56,
      "sid": 26,
      "location": 2,
      "content": "我们就想这里面底层逻辑是什么",
      "music": 0.0
    },
    {
      "from": 49.56,
      "to": 50.56,
      "sid": 27,
      "location": 2,
      "content": "从消费者的角度来讲",
      "music": 0.0
    },
    {
      "from": 50.56,
      "to": 52.68,
      "sid": 28,
      "location": 2,
      "content": "他可能会觉得你这个手机价格怎么差这么多",
      "music": 0.0
    },
    {
      "from": 52.68,
      "to": 54.5,
      "sid": 29,
      "location": 2,
      "content": "你这个最贵的手机一个能买我四个人",
      "music": 0.0
    },
    {
      "from": 54.5,
      "to": 55.34,
      "sid": 30,
      "location": 2,
      "content": "实在太夸张了",
      "music": 0.0
    },
    {
      "from": 55.34,
      "to": 56.5,
      "sid": 31,
      "location": 2,
      "content": "但是我们站在商家",
      "music": 0.0
    },
    {
      "from": 56.5,
      "to": 58.1,
      "sid": 32,
      "location": 2,
      "content": "站在苹果公司的角度来想一想",
      "music": 0.0
    },
    {
      "from": 58.1,
      "to": 61.66,
      "sid": 33,
      "location": 2,
      "content": "他其实肯定是希望越贵的手机越贵越好",
      "music": 0.0
    },
    {
      "from": 61.66,
      "to": 63.38,
      "sid": 34,
      "location": 2,
      "content": "比如说我恨不得最贵的手机卖你个10万",
      "music": 0.0
    },
    {
      "from": 63.38,
      "to": 63.86,
      "sid": 35,
      "location": 2,
      "content": "20万",
      "music": 0.0
    },
    {
      "from": 63.86,
      "to": 65.18,
      "sid": 36,
      "location": 2,
      "content": "便宜的手机越便宜越好",
      "music": 0.0
    },
    {
      "from": 65.18,
      "to": 66.74,
      "sid": 37,
      "location": 2,
      "content": "比如说三五百块钱你可以买一个",
      "music": 0.0
    },
    {
      "from": 66.74,
      "to": 68.9,
      "sid": 38,
      "location": 2,
      "content": "那为什么明明可以把这个价格带拉的很广",
      "music": 0.0
    },
    {
      "from": 68.9,
      "to": 69.74,
      "sid": 39,
      "location": 2,
      "content": "让我赚更多的钱",
      "music": 0.0
    },
    {
      "from": 69.74,
      "to": 70.38,
      "sid": 40,
      "location": 2,
      "content": "他却没有做",
      "music": 0.0
    },
    {
      "from": 70.38,
      "to": 74.5,
      "sid": 41,
      "location": 2,
      "content": "核心原因是是为了保证消费者不会出现所谓的叫决策瘫痪的行为",
      "music": 0.0
    },
    {
      "from": 74.5,
      "to": 75.58,
      "sid": 42,
      "location": 2,
      "content": "因为价格太繁多了",
      "music": 0.0
    },
    {
      "from": 75.58,
      "to": 76.68,
      "sid": 43,
      "location": 2,
      "content": "我不知道该买什么了",
      "music": 0.0
    },
    {
      "from": 76.68,
      "to": 78.6,
      "sid": 44,
      "location": 2,
      "content": "以及保证自己的品牌定位",
      "music": 0.0
    },
    {
      "from": 78.6,
      "to": 81.64,
      "sid": 45,
      "location": 2,
      "content": "就是我让大家知道我在大概在什么一个价格带区间",
      "music": 0.0
    },
    {
      "from": 81.64,
      "to": 82.96,
      "sid": 46,
      "location": 2,
      "content": "为了保证这两件事情",
      "music": 0.0
    },
    {
      "from": 82.96,
      "to": 85.24,
      "sid": 47,
      "location": 2,
      "content": "他要尽量让自己的一款产品",
      "music": 0.0
    },
    {
      "from": 85.24,
      "to": 88.18,
      "sid": 48,
      "location": 2,
      "content": "比如说IPHONE或者IPAD维持在同一个价格带区间以内",
      "music": 0.0
    },
    {
      "from": 88.18,
      "to": 90.22,
      "sid": 49,
      "location": 2,
      "content": "而这个价格带的极限就是四倍",
      "music": 0.0
    },
    {
      "from": 90.22,
      "to": 91.38,
      "sid": 50,
      "location": 2,
      "content": "这和我们前面说的引流款",
      "music": 0.0
    },
    {
      "from": 91.38,
      "to": 92.3,
      "sid": 51,
      "location": 2,
      "content": "利润款有什么关系呢",
      "music": 0.0
    },
    {
      "from": 92.3,
      "to": 95.88,
      "sid": 52,
      "location": 2,
      "content": "我要跟你说的不是你的两款产品之间的价格不要超过四倍",
      "music": 0.0
    },
    {
      "from": 95.88,
      "to": 97.36,
      "sid": 53,
      "location": 2,
      "content": "而是一定要超过四倍",
      "music": 0.0
    },
    {
      "from": 97.36,
      "to": 99.32,
      "sid": 54,
      "location": 2,
      "content": "为了对抗平台的高昂的广告获客成本",
      "music": 0.0
    },
    {
      "from": 99.32,
      "to": 101.0,
      "sid": 55,
      "location": 2,
      "content": "我们有一把利器叫引流款",
      "music": 0.0
    },
    {
      "from": 101.0,
      "to": 102.56,
      "sid": 56,
      "location": 2,
      "content": "就一把尖刀扎进去就出现",
      "music": 0.0
    },
    {
      "from": 102.56,
      "to": 103.48,
      "sid": 57,
      "location": 2,
      "content": "结果它很便宜",
      "music": 0.0
    },
    {
      "from": 103.48,
      "to": 105.56,
      "sid": 58,
      "location": 2,
      "content": "它可以让那些没有买过我们东西的人",
      "music": 0.0
    },
    {
      "from": 105.56,
      "to": 106.86,
      "sid": 59,
      "location": 2,
      "content": "第一次尝试买我们的东西",
      "music": 0.0
    },
    {
      "from": 106.86,
      "to": 109.78,
      "sid": 60,
      "location": 2,
      "content": "那做引流款带来的结果就是这玩意他必定不怎么挣钱",
      "music": 0.0
    },
    {
      "from": 109.78,
      "to": 111.02,
      "sid": 61,
      "location": 2,
      "content": "甚至可能还稍微赔一点钱",
      "music": 0.0
    },
    {
      "from": 111.02,
      "to": 113.38,
      "sid": 62,
      "location": 2,
      "content": "你后面还得有一个利润款来支撑你的核心收入",
      "music": 0.0
    },
    {
      "from": 113.38,
      "to": 115.94,
      "sid": 63,
      "location": 2,
      "content": "而这个东西和你做不做私域其实是没有关系的",
      "music": 0.0
    },
    {
      "from": 115.94,
      "to": 116.98,
      "sid": 64,
      "location": 2,
      "content": "哪怕是在公寓",
      "music": 0.0
    },
    {
      "from": 116.98,
      "to": 118.92,
      "sid": 65,
      "location": 2,
      "content": "就是你买了东西之后不用加我微信",
      "music": 0.0
    },
    {
      "from": 118.92,
      "to": 120.4,
      "sid": 66,
      "location": 2,
      "content": "你只要买了这个引流款",
      "music": 0.0
    },
    {
      "from": 120.4,
      "to": 121.16,
      "sid": 67,
      "location": 2,
      "content": "你对我满意",
      "music": 0.0
    },
    {
      "from": 121.16,
      "to": 121.8,
      "sid": 68,
      "location": 2,
      "content": "你对我信任",
      "music": 0.0
    },
    {
      "from": 121.8,
      "to": 124.88,
      "sid": 69,
      "location": 2,
      "content": "日后你再来我的店铺主动搜索来买我的利润款",
      "music": 0.0
    },
    {
      "from": 124.88,
      "to": 125.88,
      "sid": 70,
      "location": 2,
      "content": "这个事也是OK的",
      "music": 0.0
    },
    {
      "from": 125.88,
      "to": 128.2,
      "sid": 71,
      "location": 2,
      "content": "因为平台卡我们卡的最狠的其实是广告费",
      "music": 0.0
    },
    {
      "from": 128.2,
      "to": 128.919,
      "sid": 72,
      "location": 2,
      "content": "而不是抽佣",
      "music": 0.0
    },
    {
      "from": 128.919,
      "to": 130.439,
      "sid": 73,
      "location": 2,
      "content": "只要他是主动搜索",
      "music": 0.0
    },
    {
      "from": 130.439,
      "to": 131.259,
      "sid": 74,
      "location": 2,
      "content": "我去复购的",
      "music": 0.0
    },
    {
      "from": 131.259,
      "to": 132.559,
      "sid": 75,
      "location": 2,
      "content": "让平台多抽一点成",
      "music": 0.0
    },
    {
      "from": 132.559,
      "to": 133.359,
      "sid": 76,
      "location": 2,
      "content": "其实无所谓的",
      "music": 0.0
    },
    {
      "from": 133.359,
      "to": 134.42,
      "sid": 77,
      "location": 2,
      "content": "只要他买的第二单",
      "music": 0.0
    },
    {
      "from": 134.42,
      "to": 135.98,
      "sid": 78,
      "location": 2,
      "content": "他没有让我再付一笔广告费",
      "music": 0.0
    },
    {
      "from": 135.98,
      "to": 136.82,
      "sid": 79,
      "location": 2,
      "content": "这个事就是成立的",
      "music": 0.0
    },
    {
      "from": 136.82,
      "to": 138.58,
      "sid": 80,
      "location": 2,
      "content": "所以我就拿做虚拟产品来举一个例子",
      "music": 0.0
    },
    {
      "from": 138.58,
      "to": 141.66,
      "sid": 81,
      "location": 2,
      "content": "因为这个是从0~1可能做起来门槛相对低的一个事",
      "music": 0.0
    },
    {
      "from": 141.66,
      "to": 146.0,
      "sid": 82,
      "location": 2,
      "content": "如果这个人店铺里面的那两个产品的价格倍数小于四倍",
      "music": 0.0
    },
    {
      "from": 146.0,
      "to": 146.84,
      "sid": 83,
      "location": 2,
      "content": "出现一个什么问题",
      "music": 0.0
    },
    {
      "from": 146.84,
      "to": 147.96,
      "sid": 84,
      "location": 2,
      "content": "比如说第一单99",
      "music": 0.0
    },
    {
      "from": 147.96,
      "to": 148.86,
      "sid": 85,
      "location": 2,
      "content": "第二单199",
      "music": 0.0
    },
    {
      "from": 148.86,
      "to": 150.66,
      "sid": 86,
      "location": 2,
      "content": "做出这个产品结构的人",
      "music": 0.0
    },
    {
      "from": 150.66,
      "to": 151.76,
      "sid": 87,
      "location": 2,
      "content": "做出这个定价的人",
      "music": 0.0
    },
    {
      "from": 151.76,
      "to": 153.26,
      "sid": 88,
      "location": 2,
      "content": "他可能觉得99是引流款",
      "music": 0.0
    },
    {
      "from": 153.26,
      "to": 154.36,
      "sid": 89,
      "location": 2,
      "content": "199是利润款",
      "music": 0.0
    },
    {
      "from": 154.36,
      "to": 155.8,
      "sid": 90,
      "location": 2,
      "content": "但是对于买家来说",
      "music": 0.0
    },
    {
      "from": 155.8,
      "to": 159.32,
      "sid": 91,
      "location": 2,
      "content": "对于一个愿意支持你99的这么一个人来说",
      "music": 0.0
    },
    {
      "from": 159.32,
      "to": 161.56,
      "sid": 92,
      "location": 2,
      "content": "他其实会觉得我都花了99的",
      "music": 0.0
    },
    {
      "from": 161.56,
      "to": 163.6,
      "sid": 93,
      "location": 2,
      "content": "我再花199可能问题也不大",
      "music": 0.0
    },
    {
      "from": 163.6,
      "to": 165.06,
      "sid": 94,
      "location": 2,
      "content": "那我买一个更好的产品",
      "music": 0.0
    },
    {
      "from": 165.06,
      "to": 165.58,
      "sid": 95,
      "location": 2,
      "content": "不是更好吗",
      "music": 0.0
    },
    {
      "from": 165.58,
      "to": 166.26,
      "sid": 96,
      "location": 2,
      "content": "不是更值吗",
      "music": 0.0
    },
    {
      "from": 166.26,
      "to": 167.5,
      "sid": 97,
      "location": 2,
      "content": "99的我就可以不用买了",
      "music": 0.0
    },
    {
      "from": 167.5,
      "to": 170.2,
      "sid": 98,
      "location": 2,
      "content": "所以你的99这个不仅没有起到引流的效果",
      "music": 0.0
    },
    {
      "from": 170.2,
      "to": 171.96,
      "sid": 99,
      "location": 2,
      "content": "你还把一个更贵的产品扔进来",
      "music": 0.0
    },
    {
      "from": 171.96,
      "to": 172.92,
      "sid": 100,
      "location": 2,
      "content": "扰乱了大家的心智",
      "music": 0.0
    },
    {
      "from": 172.92,
      "to": 176.16,
      "sid": 101,
      "location": 2,
      "content": "因为他本来有一个机会发现我靠贵的产品都特别贵",
      "music": 0.0
    },
    {
      "from": 176.16,
      "to": 177.24,
      "sid": 102,
      "location": 2,
      "content": "前面就一个99的",
      "music": 0.0
    },
    {
      "from": 177.24,
      "to": 178.68,
      "sid": 103,
      "location": 2,
      "content": "那我也只能接受这个价位的产品",
      "music": 0.0
    },
    {
      "from": 178.68,
      "to": 178.96,
      "sid": 104,
      "location": 2,
      "content": "我对吧",
      "music": 0.0
    },
    {
      "from": 178.96,
      "to": 179.98,
      "sid": 105,
      "location": 2,
      "content": "我就直接无脑冲了",
      "music": 0.0
    },
    {
