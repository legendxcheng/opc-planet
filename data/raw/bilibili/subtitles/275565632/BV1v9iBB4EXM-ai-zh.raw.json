{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 2.38,
      "sid": 1,
      "location": 2,
      "content": "要问地球上最大的地主是谁",
      "music": 0.0
    },
    {
      "from": 2.38,
      "to": 3.74,
      "sid": 2,
      "location": 2,
      "content": "当属有名的乌干达",
      "music": 0.0
    },
    {
      "from": 3.74,
      "to": 5.859,
      "sid": 3,
      "location": 2,
      "content": "阳阳姐已经和阳阳姐确认过了",
      "music": 0.0
    },
    {
      "from": 5.859,
      "to": 8.559,
      "sid": 4,
      "location": 2,
      "content": "家族庄园2.5亿平方公里的面积",
      "music": 0.0
    },
    {
      "from": 8.559,
      "to": 9.6,
      "sid": 5,
      "location": 2,
      "content": "正好半拉地球",
      "music": 0.0
    },
    {
      "from": 9.6,
      "to": 13.02,
      "sid": 6,
      "location": 2,
      "content": "要说正经的地球上陆地面积1.5亿平方公里",
      "music": 0.0
    },
    {
      "from": 13.02,
      "to": 14.62,
      "sid": 7,
      "location": 2,
      "content": "均分给80亿人口",
      "music": 0.0
    },
    {
      "from": 14.62,
      "to": 16.84,
      "sid": 8,
      "location": 2,
      "content": "一个人足足有1万8000平方米",
      "music": 0.0
    },
    {
      "from": 16.84,
      "to": 18.64,
      "sid": 9,
      "location": 2,
      "content": "这要按照1万块一平米算",
      "music": 0.0
    },
    {
      "from": 18.64,
      "to": 20.34,
      "sid": 10,
      "location": 2,
      "content": "我高低也是个亿万富翁",
      "music": 0.0
    },
    {
      "from": 20.34,
      "to": 22.12,
      "sid": 11,
      "location": 2,
      "content": "当然均分是均不了一点的",
      "music": 0.0
    },
    {
      "from": 22.12,
      "to": 22.86,
      "sid": 12,
      "location": 2,
      "content": "地球虽大",
      "music": 0.0
    },
    {
      "from": 22.86,
      "to": 23.76,
      "sid": 13,
      "location": 2,
      "content": "但环境各异",
      "music": 0.0
    },
    {
      "from": 23.76,
      "to": 25.46,
      "sid": 14,
      "location": 2,
      "content": "给别人分富饶大平原",
      "music": 0.0
    },
    {
      "from": 25.46,
      "to": 27.22,
      "sid": 15,
      "location": 2,
      "content": "轮到你就剩下贫瘠大沙漠",
      "music": 0.0
    },
    {
      "from": 27.22,
      "to": 29.0,
      "sid": 16,
      "location": 2,
      "content": "别人是棒打狍子瓢舀鱼",
      "music": 0.0
    },
    {
      "from": 29.0,
      "to": 30.6,
      "sid": 17,
      "location": 2,
      "content": "你就只能看野骆驼呲牙了",
      "music": 0.0
    },
    {
      "from": 30.6,
      "to": 33.36,
      "sid": 18,
      "location": 2,
      "content": "于是人类群落就变成现在这样好地方",
      "music": 0.0
    },
    {
      "from": 33.36,
      "to": 33.9,
      "sid": 19,
      "location": 2,
      "content": "住的人",
      "music": 0.0
    },
    {
      "from": 33.9,
      "to": 34.72,
      "sid": 20,
      "location": 2,
      "content": "愁的都能开",
      "music": 0.0
    },
    {
      "from": 34.72,
      "to": 35.56,
      "sid": 21,
      "location": 2,
      "content": "银河系party",
      "music": 0.0
    },
    {
      "from": 35.56,
      "to": 37.7,
      "sid": 22,
      "location": 2,
      "content": "恶劣地方连半只细菌都没有",
      "music": 0.0
    },
    {
      "from": 37.7,
      "to": 40.64,
      "sid": 23,
      "location": 2,
      "content": "珠峰上拉头大的它能保鲜几万年不串味",
      "music": 0.0
    },
    {
      "from": 40.64,
      "to": 41.16,
      "sid": 24,
      "location": 2,
      "content": "当然了",
      "music": 0.0
    },
    {
      "from": 41.16,
      "to": 43.14,
      "sid": 25,
      "location": 2,
      "content": "除了多少沾点的霸道总裁",
      "music": 0.0
    },
    {
      "from": 43.14,
      "to": 45.18,
      "sid": 26,
      "location": 2,
      "content": "没几个人乐意一个人住上万平",
      "music": 0.0
    },
    {
      "from": 45.18,
      "to": 48.18,
      "sid": 27,
      "location": 2,
      "content": "但你想要开心愉悦的吃饭瞎闹厕所睡觉",
      "music": 0.0
    },
    {
      "from": 48.18,
      "to": 50.1,
      "sid": 28,
      "location": 2,
      "content": "活动空间至少得几百平方米",
      "music": 0.0
    },
    {
      "from": 50.1,
      "to": 51.14,
      "sid": 29,
      "location": 2,
      "content": "在家就不说了",
      "music": 0.0
    },
    {
      "from": 51.14,
      "to": 52.26,
      "sid": 30,
      "location": 2,
      "content": "到了人多地方",
      "music": 0.0
    },
    {
      "from": 52.26,
      "to": 54.78,
      "sid": 31,
      "location": 2,
      "content": "最多也就能保证身边五平米范围内没人",
      "music": 0.0
    },
    {
      "from": 54.78,
      "to": 56.42,
      "sid": 32,
      "location": 2,
      "content": "于是一个严肃问题就来了",
      "music": 0.0
    },
    {
      "from": 56.42,
      "to": 57.62,
      "sid": 33,
      "location": 2,
      "content": "地球呢也就这么大",
      "music": 0.0
    },
    {
      "from": 57.62,
      "to": 58.8,
      "sid": 34,
      "location": 2,
      "content": "一个球不大不小",
      "music": 0.0
    },
    {
      "from": 58.8,
      "to": 59.38,
      "sid": 35,
      "location": 2,
      "content": "不增不减",
      "music": 0.0
    },
    {
      "from": 59.38,
      "to": 61.68,
      "sid": 36,
      "location": 2,
      "content": "但上面的小兽猴子却可以虚空造人",
      "music": 0.0
    },
    {
      "from": 61.68,
      "to": 64.0,
      "sid": 37,
      "location": 2,
      "content": "那地球最终能承载多少人类生活呢",
      "music": 0.0
    },
    {
      "from": 64.0,
      "to": 64.64,
      "sid": 38,
      "location": 2,
      "content": "俗话说",
      "music": 0.0
    },
    {
      "from": 65.94,
      "to": 67.04,
      "sid": 39,
      "location": 2,
      "content": "站在人类立场上",
      "music": 0.0
    },
    {
      "from": 67.04,
      "to": 69.0,
      "sid": 40,
      "location": 2,
      "content": "地球也许只能供应数10亿人",
      "music": 0.0
    },
    {
      "from": 69.0,
      "to": 69.52,
      "sid": 41,
      "location": 2,
      "content": "舒坦日子",
      "music": 0.0
    },
    {
      "from": 69.52,
      "to": 70.88,
      "sid": 42,
      "location": 2,
      "content": "如果不能剥削人肉",
      "music": 0.0
    },
    {
      "from": 70.88,
      "to": 71.26,
      "sid": 43,
      "location": 2,
      "content": "牛马",
      "music": 0.0
    },
    {
      "from": 71.26,
      "to": 72.48,
      "sid": 44,
      "location": 2,
      "content": "在科技的加持下",
      "music": 0.0
    },
    {
      "from": 72.48,
      "to": 73.78,
      "sid": 45,
      "location": 2,
      "content": "可以剥削赛博牲口",
      "music": 0.0
    },
    {
      "from": 73.78,
      "to": 75.42,
      "sid": 46,
      "location": 2,
      "content": "现在的机器人走起路来",
      "music": 0.0
    },
    {
      "from": 75.42,
      "to": 77.6,
      "sid": 47,
      "location": 2,
      "content": "已经表现出脑血栓出狱的感觉",
      "music": 0.0
    },
    {
      "from": 77.6,
      "to": 78.38,
      "sid": 48,
      "location": 2,
      "content": "以后能干嘛",
      "music": 0.0
    },
    {
      "from": 78.38,
      "to": 79.44,
      "sid": 49,
      "location": 2,
      "content": "我都不敢想了",
      "music": 0.0
    },
    {
      "from": 79.44,
      "to": 80.76,
      "sid": 50,
      "location": 2,
      "content": "我觉得应该能干",
      "music": 0.0
    },
    {
      "from": 80.76,
      "to": 82.54,
      "sid": 51,
      "location": 2,
      "content": "我要是站在囚禁的立场上",
      "music": 0.0
    },
    {
      "from": 82.54,
      "to": 83.9,
      "sid": 52,
      "location": 2,
      "content": "让外星太君看到了",
      "music": 0.0
    },
    {
      "from": 83.9,
      "to": 86.06,
      "sid": 53,
      "location": 2,
      "content": "那可就自修过母猪",
      "music": 0.0
    },
    {
      "from": 86.06,
      "to": 87.06,
      "sid": 54,
      "location": 2,
      "content": "产后护理的兄弟",
      "music": 0.0
    },
    {
      "from": 87.06,
      "to": 89.24,
      "sid": 55,
      "location": 2,
      "content": "可以讲讲养殖场怎么算承载力呢",
      "music": 0.0
    },
    {
      "from": 89.24,
      "to": 91.66,
      "sid": 56,
      "location": 2,
      "content": "外星人养殖人类理由或许很多",
      "music": 0.0
    },
    {
      "from": 91.66,
      "to": 93.02,
      "sid": 57,
      "location": 2,
      "content": "但以人类好吃懒做",
      "music": 0.0
    },
    {
      "from": 93.02,
      "to": 93.58,
      "sid": 58,
      "location": 2,
      "content": "不运动",
      "music": 0.0
    },
    {
      "from": 93.58,
      "to": 95.18,
      "sid": 59,
      "location": 2,
      "content": "绝不长肌肉的基因特性",
      "music": 0.0
    },
    {
      "from": 95.18,
      "to": 96.4,
      "sid": 60,
      "location": 2,
      "content": "吃起来或许很腻",
      "music": 0.0
    },
    {
      "from": 96.4,
      "to": 97.58,
      "sid": 61,
      "location": 2,
      "content": "大家可以舒口气了",
      "music": 0.0
    },
    {
      "from": 97.58,
      "to": 99.0,
      "sid": 62,
      "location": 2,
      "content": "而且作为顶级掠食者",
      "music": 0.0
    },
    {
      "from": 99.0,
      "to": 101.44,
      "sid": 63,
      "location": 2,
      "content": "生物富集下来的毒素也不容小觑",
      "music": 0.0
    },
    {
      "from": 101.44,
      "to": 103.42,
      "sid": 64,
      "location": 2,
      "content": "如果汉尼拔最终因病而死",
      "music": 0.0
    },
    {
      "from": 103.42,
      "to": 104.62,
      "sid": 65,
      "location": 2,
      "content": "那必然是肝衰竭",
      "music": 0.0
    },
    {
      "from": 104.62,
      "to": 107.38,
      "sid": 66,
      "location": 2,
      "content": "所以我比较倾向于黑客帝国里的生物电池",
      "music": 0.0
    },
    {
      "from": 107.38,
      "to": 109.3,
      "sid": 67,
      "location": 2,
      "content": "毕竟脂肪是个优良的储能物质",
      "music": 0.0
    },
    {
      "from": 109.3,
      "to": 110.56,
      "sid": 68,
      "location": 2,
      "content": "当年董卓死了以后",
      "music": 0.0
    },
    {
      "from": 110.56,
      "to": 111.84,
      "sid": 69,
      "location": 2,
      "content": "被做成人油路灯",
      "music": 0.0
    },
    {
      "from": 111.84,
      "to": 113.42,
      "sid": 70,
      "location": 2,
      "content": "扔街上还烧了一天一夜呢",
      "music": 0.0
    },
    {
      "from": 113.42,
      "to": 115.7,
      "sid": 71,
      "location": 2,
      "content": "在座的各位肥宅兄弟可有福了",
      "music": 0.0
    },
    {
      "from": 115.7,
      "to": 117.7,
      "sid": 72,
      "location": 2,
      "content": "是外星老爷的重点帮扶对象啊",
      "music": 0.0
    },
    {
      "from": 117.7,
      "to": 119.3,
      "sid": 73,
      "location": 2,
      "content": "对于被当作生物电池的",
      "music": 0.0
    },
    {
      "from": 119.3,
      "to": 121.62,
      "sid": 74,
      "location": 2,
      "content": "咱们其实是可以赞美外星老爷的",
      "music": 0.0
    },
    {
      "from": 121.62,
      "to": 122.94,
      "sid": 75,
      "location": 2,
      "content": "你不再需要任何劳动",
      "music": 0.0
    },
    {
      "from": 122.94,
      "to": 124.7,
      "sid": 76,
      "location": 2,
      "content": "因为要防止肌肉消耗养分",
      "music": 0.0
    },
    {
      "from": 124.7,
      "to": 126.98,
      "sid": 77,
      "location": 2,
      "content": "外星老爷还在持续给你提供任何食物",
      "music": 0.0
    },
    {
      "from": 126.98,
      "to": 128.46,
      "sid": 78,
      "location": 2,
      "content": "以便于你囤积脂肪",
      "music": 0.0
    },
    {
      "from": 128.46,
      "to": 129.62,
      "sid": 79,
      "location": 2,
      "content": "考虑到心情不好",
      "music": 0.0
    },
    {
      "from": 129.62,
      "to": 130.28,
      "sid": 80,
      "location": 2,
      "content": "不爱吃饭",
      "music": 0.0
    },
    {
      "from": 130.28,
      "to": 131.06,
      "sid": 81,
      "location": 2,
      "content": "容易抑郁",
      "music": 0.0
    },
    {
      "from": 131.06,
      "to": 132.04,
      "sid": 82,
      "location": 2,
      "content": "引起体重骤减",
      "music": 0.0
    },
    {
      "from": 132.04,
      "to": 135.2,
      "sid": 83,
      "location": 2,
      "content": "他们还会对某些困扰20多岁雄性智人的问题",
      "music": 0.0
    },
    {
      "from": 135.2,
      "to": 136.36,
      "sid": 84,
      "location": 2,
      "content": "进行歌一统治",
      "music": 0.0
    },
    {
      "from": 136.36,
      "to": 138.72,
      "sid": 85,
      "location": 2,
      "content": "彼时的舔狗肥宅变成西格玛肥宅",
      "music": 0.0
    },
    {
      "from": 138.72,
      "to": 140.38,
      "sid": 86,
      "location": 2,
      "content": "更加心无旁骛的囤积脂肪",
      "music": 0.0
    },
    {
      "from": 140.38,
      "to": 142.58,
      "sid": 87,
      "location": 2,
      "content": "于是生物电池的一天是这样的",
      "music": 0.0
    },
    {
      "from": 142.58,
      "to": 143.6,
      "sid": 88,
      "location": 2,
      "content": "在你醒来之际",
      "music": 0.0
    },
    {
      "from": 143.6,
      "to": 145.86,
      "sid": 89,
      "location": 2,
      "content": "大脑就通过脑机接口进入虚拟世界",
      "music": 0.0
    },
    {
      "from": 145.86,
      "to": 147.12,
      "sid": 90,
      "location": 2,
      "content": "伺候你的机器启动",
      "music": 0.0
    },
    {
      "from": 147.12,
      "to": 149.08,
      "sid": 91,
      "location": 2,
      "content": "源源不断给你供应各种美食",
      "music": 0.0
    },
    {
      "from": 149.08,
      "to": 151.52,
      "sid": 92,
      "location": 2,
      "content": "想吃的时候你敞开肚皮随意吃",
      "music": 0.0
    },
    {
      "from": 151.52,
      "to": 152.94,
      "sid": 93,
      "location": 2,
      "content": "不想吃了也没关系",
      "music": 0.0
    },
    {
      "from": 152.94,
      "to": 156.0,
      "sid": 94,
      "location": 2,
      "content": "万幸老爷会很贴心的把管子放进你的胃里",
      "music": 0.0
    },
    {
      "from": 156.0,
      "to": 156.88,
      "sid": 95,
      "location": 2,
      "content": "煞费苦心",
      "music": 0.0
    },
    {
      "from": 156.88,
      "to": 158.78,
      "sid": 96,
      "location": 2,
      "content": "苦口婆心地照顾你的饮食",
      "music": 0.0
    },
    {
      "from": 158.78,
      "to": 160.92,
      "sid": 97,
      "location": 2,
      "content": "虚拟世界里你可以拥有整个世界",
      "music": 0.0
    },
    {
      "from": 160.92,
      "to": 162.7,
      "sid": 98,
      "location": 2,
      "content": "现实中两平米就够了",
      "music": 0.0
    },
    {
      "from": 162.7,
      "to": 164.3,
      "sid": 99,
      "location": 2,
      "content": "多余地方不是怕你挤着",
      "music": 0.0
    },
    {
      "from": 164.3,
      "to": 165.82,
      "sid": 100,
      "location": 2,
      "content": "而是给人家设备散热的",
      "music": 0.0
    },
    {
      "from": 165.82,
      "to": 167.04,
      "sid": 101,
      "location": 2,
      "content": "到时候别说80亿",
      "music": 0.0
    },
    {
      "from": 167.04,
      "to": 168.84,
      "sid": 102,
      "location": 2,
      "content": "800亿生物电池也够猪的",
      "music": 0.0
    },
    {
      "from": 168.84,
      "to": 169.52,
      "sid": 103,
      "location": 2,
      "content": "回到现实",
      "music": 0.0
    },
    {
      "from": 169.52,
      "to": 170.56,
      "sid": 104,
      "location": 2,
      "content": "我想到一个问题",
      "music": 0.0
    },
    {
      "from": 170.56,
      "to": 172.68,
      "sid": 105,
      "location": 2,
      "content": "有研究说猪其实挺爱干净",
      "music": 0.0
    },
    {
      "from": 172.68,
      "to": 174.96,
      "sid": 106,
      "location": 2,
      "content": "之所以看着粑粑混稀饭同吃",
      "music": 0.0
    },
    {
      "from": 174.96,
      "to": 176.32,
      "sid": 107,
      "location": 2,
      "content": "纯粹这是猪圈太小",
      "music": 0.0
    },
    {
      "from": 176.32,
      "to": 177.36,
      "sid": 108,
      "location": 2,
      "content": "我也想拉远一点",
      "music": 0.0
    },
    {
