  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.08,
      "to": 1.2,
      "sid": 1,
      "location": 2,
      "content": "会赚钱的品牌",
      "music": 0.0
    },
    {
      "from": 1.2,
      "to": 3.56,
      "sid": 2,
      "location": 2,
      "content": "可以用一句话去表达出他的商业效率",
      "music": 0.0
    },
    {
      "from": 3.56,
      "to": 5.56,
      "sid": 3,
      "location": 2,
      "content": "同时还让你觉得他是为了你好",
      "music": 0.0
    },
    {
      "from": 5.56,
      "to": 6.88,
      "sid": 4,
      "location": 2,
      "content": "让你很丝滑的去买单",
      "music": 0.0
    },
    {
      "from": 6.88,
      "to": 9.53,
      "sid": 5,
      "location": 2,
      "content": "你看这个墙叫全时段享乐主义",
      "music": 0.0
    },
    {
      "from": 9.53,
      "to": 10.57,
      "sid": 6,
      "location": 2,
      "content": "今天我走在路上看见了",
      "music": 0.0
    },
    {
      "from": 10.57,
      "to": 11.58,
      "sid": 7,
      "location": 2,
      "content": "你说他什么意思呢",
      "music": 0.0
    },
    {
      "from": 11.58,
      "to": 14.02,
      "sid": 8,
      "location": 2,
      "content": "这家店是做这个西餐冷餐轻食的",
      "music": 0.0
    },
    {
      "from": 14.02,
      "to": 15.46,
      "sid": 9,
      "location": 2,
      "content": "就像什么这个三文鱼饭呀",
      "music": 0.0
    },
    {
      "from": 15.46,
      "to": 16.22,
      "sid": 10,
      "location": 2,
      "content": "什么牛排呀",
      "music": 0.0
    },
    {
      "from": 16.22,
      "to": 17.46,
      "sid": 11,
      "location": 2,
      "content": "给你整个咖啡水果茶呀",
      "music": 0.0
    },
    {
      "from": 17.46,
      "to": 18.36,
      "sid": 12,
      "location": 2,
      "content": "就干这个东西的",
      "music": 0.0
    },
    {
      "from": 18.36,
      "to": 19.84,
      "sid": 13,
      "location": 2,
      "content": "这东西有一个天然的优势",
      "music": 0.0
    },
    {
      "from": 19.84,
      "to": 21.0,
      "sid": 14,
      "location": 2,
      "content": "就假如说是中餐馆",
      "music": 0.0
    },
    {
      "from": 21.0,
      "to": 22.32,
      "sid": 15,
      "location": 2,
      "content": "我就给你做一个午饭",
      "music": 0.0
    },
    {
      "from": 22.32,
      "to": 22.96,
      "sid": 16,
      "location": 2,
      "content": "一个晚饭",
      "music": 0.0
    },
    {
      "from": 22.96,
      "to": 24.4,
      "sid": 17,
      "location": 2,
      "content": "你一天只能来两次人",
      "music": 0.0
    },
    {
      "from": 24.4,
      "to": 26.0,
      "sid": 18,
      "location": 2,
      "content": "你就翻台率翻到天上去",
      "music": 0.0
    },
    {
      "from": 26.0,
      "to": 28.46,
      "sid": 19,
      "location": 2,
      "content": "一天也就中午和晚上这两个时段有人",
      "music": 0.0
    },
    {
      "from": 28.46,
      "to": 29.62,
      "sid": 20,
      "location": 2,
      "content": "但是这玩意儿不一样",
      "music": 0.0
    },
    {
      "from": 29.62,
      "to": 30.86,
      "sid": 21,
      "location": 2,
      "content": "你从早可以吃到晚",
      "music": 0.0
    },
    {
      "from": 30.86,
      "to": 31.94,
      "sid": 22,
      "location": 2,
      "content": "你这个上午十点来了",
      "music": 0.0
    },
    {
      "from": 31.94,
      "to": 32.9,
      "sid": 23,
      "location": 2,
      "content": "我给你来个早午餐",
      "music": 0.0
    },
    {
      "from": 32.9,
      "to": 33.62,
      "sid": 24,
      "location": 2,
      "content": "叫不让吃对吧",
      "music": 0.0
    },
    {
      "from": 33.62,
      "to": 34.18,
      "sid": 25,
      "location": 2,
      "content": "中午来了",
      "music": 0.0
    },
    {
      "from": 34.18,
      "to": 35.5,
      "sid": 26,
      "location": 2,
      "content": "给你来个什么三文鱼",
      "music": 0.0
    },
    {
      "from": 35.5,
      "to": 36.3,
      "sid": 27,
      "location": 2,
      "content": "什么泡菜饭",
      "music": 0.0
    },
    {
      "from": 36.3,
      "to": 37.84,
      "sid": 28,
      "location": 2,
      "content": "你下午两点来还有咖啡",
      "music": 0.0
    },
    {
      "from": 37.84,
      "to": 40.14,
      "sid": 29,
      "location": 2,
      "content": "下午四点来再点个什么蛋糕水果茶",
      "music": 0.0
    },
    {
      "from": 40.14,
      "to": 42.3,
      "sid": 30,
      "location": 2,
      "content": "你晚上六七点了还能再吃个晚饭",
      "music": 0.0
    },
    {
      "from": 42.3,
      "to": 44.24,
      "sid": 31,
      "location": 2,
      "content": "你晚上十点了还能再吃个夜宵",
      "music": 0.0
    },
    {
      "from": 44.24,
      "to": 46.88,
      "sid": 32,
      "location": 2,
      "content": "所以哪怕我在一天当中的某一个时段",
      "music": 0.0
    },
    {
      "from": 46.88,
      "to": 47.72,
      "sid": 33,
      "location": 2,
      "content": "我的翻台率",
      "music": 0.0
    },
    {
      "from": 47.72,
      "to": 49.34,
      "sid": 34,
      "location": 2,
      "content": "我的排队的人数没有那么高",
      "music": 0.0
    },
    {
      "from": 49.34,
      "to": 51.68,
      "sid": 35,
      "location": 2,
      "content": "因为你顾客来了一天可以吃八顿",
      "music": 0.0
    },
    {
      "from": 51.68,
      "to": 53.32,
      "sid": 36,
      "location": 2,
      "content": "我最终的商业效率还是能上来",
      "music": 0.0
    },
    {
      "from": 53.32,
      "to": 54.56,
      "sid": 37,
      "location": 2,
      "content": "我的评效自然就高了",
      "music": 0.0
    },
    {
      "from": 54.56,
      "to": 56.88,
      "sid": 38,
      "location": 2,
      "content": "所以这就是我们怎么把一个品牌符号",
      "music": 0.0
    },
    {
      "from": 56.88,
      "to": 58.82,
      "sid": 39,
      "location": 2,
      "content": "一个口号变成商业化效率",
      "music": 0.0
    },
    {
      "from": 58.82,
      "to": 59.66,
      "sid": 40,
      "location": 2,
      "content": "正常来讲",
      "music": 0.0
    },
    {
      "from": 59.66,
      "to": 62.06,
      "sid": 41,
      "location": 2,
      "content": "我做的这个冷餐不像你们这个什么火锅",
      "music": 0.0
    },
    {
      "from": 62.06,
      "to": 63.88,
      "sid": 42,
      "location": 2,
      "content": "麻辣烫这么重油",
      "music": 0.0
    },
    {
      "from": 63.88,
      "to": 64.74,
      "sid": 43,
      "location": 2,
      "content": "这么重口味",
      "music": 0.0
    },
    {
      "from": 64.74,
      "to": 66.26,
      "sid": 44,
      "location": 2,
      "content": "所以它可能没有那么能吸引人",
      "music": 0.0
    },
    {
      "from": 66.26,
      "to": 68.7,
      "sid": 45,
      "location": 2,
      "content": "但是我靠着我这个冷餐所带来的",
      "music": 0.0
    },
    {
      "from": 68.7,
      "to": 70.14,
      "sid": 46,
      "location": 2,
      "content": "一天能吃八顿的这个优势",
      "music": 0.0
    },
    {
      "from": 70.14,
      "to": 71.64,
      "sid": 47,
      "location": 2,
      "content": "我的商业化效率又可以得到弥补",
      "music": 0.0
    },
    {
      "from": 71.64,
      "to": 72.28,
      "sid": 48,
      "location": 2,
      "content": "完了这个事",
      "music": 0.0
    },
    {
      "from": 72.28,
      "to": 74.68,
      "sid": 49,
      "location": 2,
      "content": "就让我想起国内有一个女性内衣品牌",
      "music": 0.0
    },
    {
      "from": 74.68,
      "to": 76.02,
      "sid": 50,
      "location": 2,
      "content": "我就不说这品牌叫什么名了",
      "music": 0.0
    },
    {
      "from": 76.02,
      "to": 77.12,
      "sid": 51,
      "location": 2,
      "content": "这品牌特征是什么呢",
      "music": 0.0
    },
    {
      "from": 77.12,
      "to": 79.98,
      "sid": 52,
      "location": 2,
      "content": "她打着这个女性悦己的这个口号",
      "music": 0.0
    },
    {
      "from": 79.98,
      "to": 82.02,
      "sid": 53,
      "location": 2,
      "content": "给女性内衣只提供大概三个尺码",
      "music": 0.0
    },
    {
      "from": 82.02,
      "to": 83.78,
      "sid": 54,
      "location": 2,
      "content": "就小号中号大号本质是什么呢",
      "music": 0.0
    },
    {
      "from": 83.78,
      "to": 85.18,
      "sid": 55,
      "location": 2,
      "content": "本质其实是一个库存管理问题",
      "music": 0.0
    },
    {
      "from": 85.18,
      "to": 87.3,
      "sid": 56,
      "location": 2,
      "content": "你这个服装尤其是内衣或者鞋呀",
      "music": 0.0
    },
    {
      "from": 87.3,
      "to": 88.48,
      "sid": 57,
      "location": 2,
      "content": "这个库存管理很麻烦",
      "music": 0.0
    },
    {
      "from": 88.48,
      "to": 90.0,
      "sid": 58,
      "location": 2,
      "content": "比如这个女性的这个尺码",
      "music": 0.0
    },
    {
      "from": 90.0,
      "to": 92.44,
      "sid": 59,
      "location": 2,
      "content": "什么这个75B什么75C乱七八糟",
      "music": 0.0
    },
    {
      "from": 92.44,
      "to": 93.94,
      "sid": 60,
      "location": 2,
      "content": "你一整整好几十个尺码去",
      "music": 0.0
    },
    {
      "from": 93.94,
      "to": 94.54,
      "sid": 61,
      "location": 2,
      "content": "我做多了",
      "music": 0.0
    },
    {
      "from": 94.54,
      "to": 95.26,
      "sid": 62,
      "location": 2,
      "content": "我担心卖不掉",
      "music": 0.0
    },
    {
      "from": 95.26,
      "to": 95.78,
      "sid": 63,
      "location": 2,
      "content": "积压库存",
      "music": 0.0
    },
    {
      "from": 95.78,
      "to": 96.5,
      "sid": 64,
      "location": 2,
      "content": "我要做少了",
      "music": 0.0
    },
    {
      "from": 96.5,
      "to": 97.78,
      "sid": 65,
      "location": 2,
      "content": "可能你某一个尺码买不掉",
      "music": 0.0
    },
    {
      "from": 97.78,
      "to": 98.34,
      "sid": 66,
      "location": 2,
      "content": "你又着急用",
      "music": 0.0
    },
    {
      "from": 98.34,
      "to": 99.58,
      "sid": 67,
      "location": 2,
      "content": "你就去别的品牌了对吧",
      "music": 0.0
    },
    {
      "from": 99.58,
      "to": 100.22,
      "sid": 68,
      "location": 2,
      "content": "怎么着都不讨好",
      "music": 0.0
    },
    {
      "from": 100.22,
      "to": 101.5,
      "sid": 69,
      "location": 2,
      "content": "所以最后就打出一张牌",
      "music": 0.0
    },
    {
      "from": 101.5,
      "to": 102.58,
      "sid": 70,
      "location": 2,
      "content": "就说你带这个钢圈",
      "music": 0.0
    },
    {
      "from": 102.58,
      "to": 103.78,
      "sid": 71,
      "location": 2,
      "content": "这不是不舒服吗对吧",
      "music": 0.0
    },
    {
      "from": 103.78,
      "to": 105.3,
      "sid": 72,
      "location": 2,
      "content": "你带那个肯定是取悦男性啊",
      "music": 0.0
    },
    {
      "from": 105.3,
      "to": 106.68,
      "sid": 73,
      "location": 2,
      "content": "那咱们以后就取悦自己",
      "music": 0.0
    },
    {
      "from": 106.68,
      "to": 108.3,
      "sid": 74,
      "location": 2,
      "content": "取悦自己呢就穿那个舒服的",
      "music": 0.0
    },
    {
      "from": 108.3,
      "to": 108.94,
      "sid": 75,
      "location": 2,
      "content": "就有弹性",
      "music": 0.0
    },
    {
      "from": 108.94,
      "to": 110.04,
      "sid": 76,
      "location": 2,
      "content": "有了弹性之后",
      "music": 0.0
    },
    {
      "from": 110.04,
      "to": 111.78,
      "sid": 77,
      "location": 2,
      "content": "哎你就不用分那么多尺码了",
      "music": 0.0
    },
    {
      "from": 111.78,
      "to": 112.42,
      "sid": 78,
      "location": 2,
      "content": "有一个大号",
      "music": 0.0
    },
    {
      "from": 112.42,
      "to": 112.82,
      "sid": 79,
      "location": 2,
      "content": "有个中号",
      "music": 0.0
    },
    {
      "from": 112.82,
      "to": 113.5,
      "sid": 80,
      "location": 2,
      "content": "有个小号就够",
      "music": 0.0
    },
    {
      "from": 113.5,
      "to": 115.26,
      "sid": 81,
      "location": 2,
      "content": "你用了咱这库存瞬间就好管理了",
      "music": 0.0
    },
    {
      "from": 115.26,
      "to": 116.06,
      "sid": 82,
      "location": 2,
      "content": "有人说不对对呀",
      "music": 0.0
    },
    {
      "from": 116.06,
      "to": 117.74,
      "sid": 83,
      "location": 2,
      "content": "你说他是打着这个越级的口号",
      "music": 0.0
    },
    {
      "from": 117.74,
      "to": 119.14,
      "sid": 84,
      "location": 2,
      "content": "去搞这个库存管理的效率",
      "music": 0.0
    },
    {
      "from": 119.14,
      "to": 120.74,
      "sid": 85,
      "location": 2,
      "content": "可是我穿上确实觉得很舒服呀",
      "music": 0.0
    },
    {
      "from": 120.74,
      "to": 121.54,
      "sid": 86,
      "location": 2,
      "content": "没有这个钢圈",
      "music": 0.0
    },
    {
      "from": 121.54,
      "to": 123.2,
      "sid": 87,
      "location": 2,
      "content": "我确实觉得得到了解放对吧",
      "music": 0.0
    },
    {
      "from": 123.2,
      "to": 123.96,
      "sid": 88,
      "location": 2,
      "content": "你去查查",
      "music": 0.0
    },
    {
      "from": 123.96,
      "to": 125.0,
      "sid": 89,
      "location": 2,
      "content": "美国有一个品牌",
      "music": 0.0
    },
    {
      "from": 125.0,
      "to": 127.08,
      "sid": 90,
      "location": 2,
      "content": "我忘了它叫third love还是叫什么具体名字",
      "music": 0.0
    },
    {
      "from": 127.08,
      "to": 127.66,
      "sid": 91,
      "location": 2,
      "content": "我忘了",
      "music": 0.0
    },
    {
      "from": 127.66,
      "to": 130.04,
      "sid": 92,
      "location": 2,
      "content": "他们也是同样的品牌理念",
      "music": 0.0
    },
    {
      "from": 130.04,
      "to": 131.7,
      "sid": 93,
      "location": 2,
      "content": "但是用的是不一样的解决方案",
      "music": 0.0
    },
    {
      "from": 131.7,
      "to": 133.26,
      "sid": 94,
      "location": 2,
      "content": "他们就疯狂给自己搞库存",
      "music": 0.0
    },
    {
      "from": 133.26,
      "to": 133.88,
      "sid": 95,
      "location": 2,
      "content": "搞定制",
      "music": 0.0
    },
    {
      "from": 133.88,
      "to": 134.78,
      "sid": 96,
      "location": 2,
      "content": "一般来讲",
      "music": 0.0
    },
    {
      "from": 134.78,
      "to": 136.78,
      "sid": 97,
      "location": 2,
      "content": "这个女性的尺码可能就分个什么75",
      "music": 0.0
    },
    {
      "from": 136.78,
      "to": 138.0,
      "sid": 98,
      "location": 2,
      "content": "C他们搞的什么呢",
      "music": 0.0
    },
    {
      "from": 138.0,
      "to": 140.28,
      "sid": 99,
      "location": 2,
      "content": "他们搞的是75又三分之1C",
      "music": 0.0
    },
    {
      "from": 140.28,
      "to": 143.28,
      "sid": 100,
      "location": 2,
      "content": "75又三分之2C75又34",
      "music": 0.0
    },
    {
      "from": 143.28,
      "to": 145.76,
      "sid": 101,
      "location": 2,
      "content": "C考搞了一大堆细非常细的尺码",
      "music": 0.0
    },
    {
      "from": 145.76,
      "to": 147.28,
      "sid": 102,
      "location": 2,
      "content": "然后人家商业也很成功啊",
      "music": 0.0
    },
    {
      "from": 147.28,
      "to": 149.84,
      "sid": 103,
      "location": 2,
      "content": "就是真正让大家可以找到真正适合自己的尺码",
      "music": 0.0
    },
    {
      "from": 149.84,
      "to": 150.52,
      "sid": 104,
      "location": 2,
      "content": "可以定制嘛",
      "music": 0.0
    },
    {
      "from": 150.52,
      "to": 151.86,
      "sid": 105,
      "location": 2,
      "content": "不过今天讲这个有点跑题啊",
      "music": 0.0
    },
    {
      "from": 151.86,
      "to": 152.9,
      "sid": 106,
      "location": 2,
      "content": "并不是要黑这些品牌",
      "music": 0.0
    },
    {
      "from": 152.9,
      "to": 155.7,
      "sid": 107,
      "location": 2,
      "content": "只是说当你看到一个品牌打出一个slogan",
      "music": 0.0
    },
    {
      "from": 155.7,
      "to": 156.58,
      "sid": 108,
      "location": 2,
      "content": "一个口号的时候",
      "music": 0.0
    },
    {
      "from": 156.58,
      "to": 160.06,
      "sid": 109,
      "location": 2,
