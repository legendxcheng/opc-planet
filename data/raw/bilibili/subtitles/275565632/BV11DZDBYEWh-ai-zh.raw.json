{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 2.48,
      "sid": 1,
      "location": 2,
      "content": "如何借助AI比任何人学的都快十倍",
      "music": 0.0
    },
    {
      "from": 2.48,
      "to": 3.4,
      "sid": 2,
      "location": 2,
      "content": "今天我们用这张表",
      "music": 0.0
    },
    {
      "from": 3.4,
      "to": 4.8,
      "sid": 3,
      "location": 2,
      "content": "只需要2分钟就可以讲清楚啊",
      "music": 0.0
    },
    {
      "from": 4.8,
      "to": 5.4,
      "sid": 4,
      "location": 2,
      "content": "但我不知道为什么",
      "music": 0.0
    },
    {
      "from": 5.4,
      "to": 7.2,
      "sid": 5,
      "location": 2,
      "content": "其实身边很少看到有人用这个方法",
      "music": 0.0
    },
    {
      "from": 7.2,
      "to": 8.3,
      "sid": 6,
      "location": 2,
      "content": "其实早在AI出现之前",
      "music": 0.0
    },
    {
      "from": 8.3,
      "to": 9.26,
      "sid": 7,
      "location": 2,
      "content": "上世纪80年代",
      "music": 0.0
    },
    {
      "from": 9.26,
      "to": 10.78,
      "sid": 8,
      "location": 2,
      "content": "就有一个教育心理学家叫布鲁姆",
      "music": 0.0
    },
    {
      "from": 10.78,
      "to": 11.78,
      "sid": 9,
      "location": 2,
      "content": "就发表过一个研究啊",
      "music": 0.0
    },
    {
      "from": 11.78,
      "to": 13.76,
      "sid": 10,
      "location": 2,
      "content": "他说一个学生如果在学习的时候",
      "music": 0.0
    },
    {
      "from": 13.76,
      "to": 14.92,
      "sid": 11,
      "location": 2,
      "content": "可以满足两个条件",
      "music": 0.0
    },
    {
      "from": 14.92,
      "to": 16.8,
      "sid": 12,
      "location": 2,
      "content": "就可以超过其他98%的学生",
      "music": 0.0
    },
    {
      "from": 16.8,
      "to": 17.92,
      "sid": 13,
      "location": 2,
      "content": "叫这个to c格玛问题",
      "music": 0.0
    },
    {
      "from": 17.92,
      "to": 19.56,
      "sid": 14,
      "location": 2,
      "content": "这两个条件虽然听起来很简单啊",
      "music": 0.0
    },
    {
      "from": 19.56,
      "to": 20.44,
      "sid": 15,
      "location": 2,
      "content": "一个叫一对一辅导",
      "music": 0.0
    },
    {
      "from": 20.44,
      "to": 21.68,
      "sid": 16,
      "location": 2,
      "content": "一个叫掌握学习法啊",
      "music": 0.0
    },
    {
      "from": 21.68,
      "to": 23.56,
      "sid": 17,
      "location": 2,
      "content": "就说学生必须对现有的知识",
      "music": 0.0
    },
    {
      "from": 23.56,
      "to": 24.8,
      "sid": 18,
      "location": 2,
      "content": "达到一定的掌握标准啊",
      "music": 0.0
    },
    {
      "from": 24.8,
      "to": 26.96,
      "sid": 19,
      "location": 2,
      "content": "比如说80%或者90的正确率好",
      "music": 0.0
    },
    {
      "from": 26.96,
      "to": 28.24,
      "sid": 20,
      "location": 2,
      "content": "才能进入到下一个部分",
      "music": 0.0
    },
    {
      "from": 28.24,
      "to": 30.4,
      "sid": 21,
      "location": 2,
      "content": "当时这个研究提出来的这个叫图西格玛",
      "music": 0.0
    },
    {
      "from": 30.4,
      "to": 31.72,
      "sid": 22,
      "location": 2,
      "content": "这个问题呢其实非常出名",
      "music": 0.0
    },
    {
      "from": 31.72,
      "to": 32.84,
      "sid": 23,
      "location": 2,
      "content": "因为这个心理学家这个bloom",
      "music": 0.0
    },
    {
      "from": 32.84,
      "to": 33.4,
      "sid": 24,
      "location": 2,
      "content": "他认为说",
      "music": 0.0
    },
    {
      "from": 33.4,
      "to": 35.8,
      "sid": 25,
      "location": 2,
      "content": "一对一辅导是人类能设计出来的",
      "music": 0.0
    },
    {
      "from": 35.8,
      "to": 36.88,
      "sid": 26,
      "location": 2,
      "content": "最好的学习条件",
      "music": 0.0
    },
    {
      "from": 36.88,
      "to": 37.52,
      "sid": 27,
      "location": 2,
      "content": "但他太贵",
      "music": 0.0
    },
    {
      "from": 37.52,
      "to": 38.24,
      "sid": 28,
      "location": 2,
      "content": "太耗人力了",
      "music": 0.0
    },
    {
      "from": 38.24,
      "to": 39.04,
      "sid": 29,
      "location": 2,
      "content": "导致什么问题呢",
      "music": 0.0
    },
    {
      "from": 39.04,
      "to": 41.88,
      "sid": 30,
      "location": 2,
      "content": "富人一定程度上对穷人实际上形成了知识垄断",
      "music": 0.0
    },
    {
      "from": 41.88,
      "to": 43.08,
      "sid": 31,
      "location": 2,
      "content": "或者说学习方法的垄断",
      "music": 0.0
    },
    {
      "from": 43.08,
      "to": 44.08,
      "sid": 32,
      "location": 2,
      "content": "就说你穷人",
      "music": 0.0
    },
    {
      "from": 44.08,
      "to": 45.6,
      "sid": 33,
      "location": 2,
      "content": "你们家孩子光聪明没有用啊",
      "music": 0.0
    },
    {
      "from": 45.6,
      "to": 46.28,
      "sid": 34,
      "location": 2,
      "content": "你的基因",
      "music": 0.0
    },
    {
      "from": 46.28,
      "to": 48.34,
      "sid": 35,
      "location": 2,
      "content": "你的人认知机制就决定了啊",
      "music": 0.0
    },
    {
      "from": 48.34,
      "to": 50.3,
      "sid": 36,
      "location": 2,
      "content": "人类必须定制化学习才最快",
      "music": 0.0
    },
    {
      "from": 50.3,
      "to": 51.18,
      "sid": 37,
      "location": 2,
      "content": "但是你没有钱",
      "music": 0.0
    },
    {
      "from": 51.18,
      "to": 51.86,
      "sid": 38,
      "location": 2,
      "content": "你雇不起老师",
      "music": 0.0
    },
    {
      "from": 51.86,
      "to": 53.92,
      "sid": 39,
      "location": 2,
      "content": "你就没办法用最快的方式去学习对吧",
      "music": 0.0
    },
    {
      "from": 53.92,
      "to": 55.44,
      "sid": 40,
      "location": 2,
      "content": "而现在的这个AI大模型呢",
      "music": 0.0
    },
    {
      "from": 55.44,
      "to": 57.06,
      "sid": 41,
      "location": 2,
      "content": "其实是人类历史上第一次",
      "music": 0.0
    },
    {
      "from": 57.06,
      "to": 59.12,
      "sid": 42,
      "location": 2,
      "content": "有可能以这个极低的成本",
      "music": 0.0
    },
    {
      "from": 59.12,
      "to": 61.0,
      "sid": 43,
      "location": 2,
      "content": "几乎是无限规模的去复制啊",
      "music": 0.0
    },
    {
      "from": 61.0,
      "to": 63.74,
      "sid": 44,
      "location": 2,
      "content": "就优秀的人类导师给你做一对一辅导这种体验",
      "music": 0.0
    },
    {
      "from": 63.74,
      "to": 66.38,
      "sid": 45,
      "location": 2,
      "content": "但是呢绝大多数人用AI其实都用错了啊",
      "music": 0.0
    },
    {
      "from": 66.38,
      "to": 68.24,
      "sid": 46,
      "location": 2,
      "content": "就或者说我们现在所看到的这个",
      "music": 0.0
    },
    {
      "from": 68.24,
      "to": 69.66,
      "sid": 47,
      "location": 2,
      "content": "绝大多数的AI产品",
      "music": 0.0
    },
    {
      "from": 69.66,
      "to": 70.42,
      "sid": 48,
      "location": 2,
      "content": "就是典型的",
      "music": 0.0
    },
    {
      "from": 70.42,
      "to": 72.7,
      "sid": 49,
      "location": 2,
      "content": "就是这种一打就有一个输入框的这种产品",
      "music": 0.0
    },
    {
      "from": 72.7,
      "to": 74.82,
      "sid": 50,
      "location": 2,
      "content": "并不适合用来干这种事情与原因是什么",
      "music": 0.0
    },
    {
      "from": 74.82,
      "to": 77.86,
      "sid": 51,
      "location": 2,
      "content": "就这种通过对话来驱动的AI产品",
      "music": 0.0
    },
    {
      "from": 77.86,
      "to": 79.34,
      "sid": 52,
      "location": 2,
      "content": "你要想得到高质量的回复",
      "music": 0.0
    },
    {
      "from": 79.34,
      "to": 80.78,
      "sid": 53,
      "location": 2,
      "content": "首先你得有高质量的问题对吧",
      "music": 0.0
    },
    {
      "from": 80.78,
      "to": 84.34,
      "sid": 54,
      "location": 2,
      "content": "但问题就在于人类在接触一个未知领域的时候",
      "music": 0.0
    },
    {
      "from": 84.34,
      "to": 86.54,
      "sid": 55,
      "location": 2,
      "content": "我核心的困扰就是我不知道",
      "music": 0.0
    },
    {
      "from": 86.54,
      "to": 87.74,
      "sid": 56,
      "location": 2,
      "content": "我不知道什么问题对吧",
      "music": 0.0
    },
    {
      "from": 87.74,
      "to": 89.18,
      "sid": 57,
      "location": 2,
      "content": "所以我没法向你提问",
      "music": 0.0
    },
    {
      "from": 89.18,
      "to": 90.5,
      "sid": 58,
      "location": 2,
      "content": "他是一个知识储备的问题",
      "music": 0.0
    },
    {
      "from": 90.5,
      "to": 91.9,
      "sid": 59,
      "location": 2,
      "content": "就为什么一对一辅导这么管",
      "music": 0.0
    },
    {
      "from": 91.9,
      "to": 94.78,
      "sid": 60,
      "location": 2,
      "content": "就是因为他这个机制是让导师主动去发起",
      "music": 0.0
    },
    {
      "from": 94.78,
      "to": 95.78,
      "sid": 61,
      "location": 2,
      "content": "定制化的提问对吧",
      "music": 0.0
    },
    {
      "from": 95.78,
      "to": 97.18,
      "sid": 62,
      "location": 2,
      "content": "就根据学生的反馈来提问",
      "music": 0.0
    },
    {
      "from": 97.18,
      "to": 99.62,
      "sid": 63,
      "location": 2,
      "content": "我学生只需要想办法回答你的问题就可以了",
      "music": 0.0
    },
    {
      "from": 99.62,
      "to": 102.14,
      "sid": 64,
      "location": 2,
      "content": "所以呢就说现在的这个主流AI产品的",
      "music": 0.0
    },
    {
      "from": 102.14,
      "to": 104.68,
      "sid": 65,
      "location": 2,
      "content": "这个交互方式和人类最适应的学习机制",
      "music": 0.0
    },
    {
      "from": 104.68,
      "to": 106.1,
      "sid": 66,
      "location": 2,
      "content": "它其实是相反的",
      "music": 0.0
    },
    {
      "from": 106.1,
      "to": 109.16,
      "sid": 67,
      "location": 2,
      "content": "那么有个简单粗暴的一个短期解决方案啊",
      "music": 0.0
    },
    {
      "from": 109.16,
      "to": 110.58,
      "sid": 68,
      "location": 2,
      "content": "就是写这么一个提示词啊",
      "music": 0.0
    },
    {
      "from": 110.58,
      "to": 111.82,
      "sid": 69,
      "location": 2,
      "content": "就说你是一个什么什么",
      "music": 0.0
    },
    {
      "from": 111.82,
      "to": 113.54,
      "sid": 70,
      "location": 2,
      "content": "苏格拉底式的一个AI导师啊",
      "music": 0.0
    },
    {
      "from": 113.54,
      "to": 115.28,
      "sid": 71,
      "location": 2,
      "content": "啥你要帮助人类交互式学习啊",
      "music": 0.0
    },
    {
      "from": 115.28,
      "to": 115.72,
      "sid": 72,
      "location": 2,
      "content": "怎么怎么样",
      "music": 0.0
    },
    {
      "from": 115.72,
      "to": 116.68,
      "sid": 73,
      "location": 2,
      "content": "你要问我诊断问题",
      "music": 0.0
    },
    {
      "from": 116.68,
      "to": 118.12,
      "sid": 74,
      "location": 2,
      "content": "但显然这个方法有一些问题对吧",
      "music": 0.0
    },
    {
      "from": 118.12,
      "to": 119.12,
      "sid": 75,
      "location": 2,
      "content": "首先上下文不够长",
      "music": 0.0
    },
    {
      "from": 119.12,
      "to": 122.02,
      "sid": 76,
      "location": 2,
      "content": "就如果你跟AI聊天聊的足够多的话",
      "music": 0.0
    },
    {
      "from": 122.02,
      "to": 124.02,
      "sid": 77,
      "location": 2,
      "content": "你经常会发现你在一个对话框里面",
      "music": 0.0
    },
    {
      "from": 124.02,
      "to": 124.78,
      "sid": 78,
      "location": 2,
      "content": "聊了很久之后",
      "music": 0.0
    },
    {
      "from": 124.78,
      "to": 125.82,
      "sid": 79,
      "location": 2,
      "content": "这个对话框就不好用了",
      "music": 0.0
    },
    {
      "from": 125.82,
      "to": 126.92,
      "sid": 80,
      "location": 2,
      "content": "你要重新开一个对话",
      "music": 0.0
    },
    {
      "from": 126.92,
      "to": 128.98,
      "sid": 81,
      "location": 2,
      "content": "但这种对话本身它又不可迁移",
      "music": 0.0
    },
    {
      "from": 128.98,
      "to": 130.82,
      "sid": 82,
      "location": 2,
      "content": "所以导致虽然它看起来是这么回事",
      "music": 0.0
    },
    {
      "from": 130.82,
      "to": 132.56,
      "sid": 83,
      "location": 2,
      "content": "但是它并不能真正解决问题",
      "music": 0.0
    },
    {
      "from": 132.56,
      "to": 134.76,
      "sid": 84,
      "location": 2,
      "content": "我跟大家说一下我真实的这个使用场景啊",
      "music": 0.0
    },
    {
      "from": 134.76,
      "to": 136.52,
      "sid": 85,
      "location": 2,
      "content": "就比如说我接触一个新领域的时候",
      "music": 0.0
    },
    {
      "from": 136.52,
      "to": 138.8,
      "sid": 86,
      "location": 2,
      "content": "我很可能会觉得啊入门的书太浅了",
      "music": 0.0
    },
    {
      "from": 138.8,
      "to": 139.62,
      "sid": 87,
      "location": 2,
      "content": "我看了也没有用",
      "music": 0.0
    },
    {
      "from": 139.62,
      "to": 140.82,
      "sid": 88,
      "location": 2,
      "content": "那还有些专业著作呢",
      "music": 0.0
    },
    {
      "from": 140.82,
      "to": 141.46,
      "sid": 89,
      "location": 2,
      "content": "我又啃不动",
      "music": 0.0
    },
    {
      "from": 141.46,
      "to": 142.42,
      "sid": 90,
      "location": 2,
      "content": "那为什么叫啃书啊",
      "music": 0.0
    },
    {
      "from": 142.42,
      "to": 143.94,
      "sid": 91,
      "location": 2,
      "content": "就真的是你每看一句话",
      "music": 0.0
    },
    {
      "from": 143.94,
      "to": 145.42,
      "sid": 92,
      "location": 2,
      "content": "恨不都得用AI去查一下对吧",
      "music": 0.0
    },
    {
      "from": 145.42,
      "to": 148.26,
      "sid": 93,
      "location": 2,
      "content": "所以当我面对这个非常陌生的一个领域的时候",
      "music": 0.0
    },
    {
      "from": 148.26,
      "to": 150.5,
      "sid": 94,
      "location": 2,
      "content": "我的学习其实是以小时为单位",
      "music": 0.0
    },
    {
      "from": 150.5,
      "to": 151.58,
      "sid": 95,
      "location": 2,
      "content": "甚至是以天为单位的",
      "music": 0.0
    },
    {
      "from": 151.58,
      "to": 153.32,
      "sid": 96,
      "location": 2,
      "content": "那像刚刚这么一小段提示词发给你",
      "music": 0.0
    },
    {
      "from": 153.32,
      "to": 155.36,
      "sid": 97,
      "location": 2,
      "content": "就可以想象我这东西我还没怎么学会呢",
      "music": 0.0
    },
    {
      "from": 155.36,
      "to": 156.68,
      "sid": 98,
      "location": 2,
      "content": "这个聊天框你就不让我聊了",
      "music": 0.0
    },
    {
      "from": 156.68,
      "to": 158.24,
      "sid": 99,
      "location": 2,
      "content": "那我要开一个新的对话框",
      "music": 0.0
    },
    {
      "from": 158.24,
      "to": 159.28,
      "sid": 100,
      "location": 2,
      "content": "我得费多大劲",
      "music": 0.0
    },
    {
      "from": 159.28,
      "to": 161.5,
      "sid": 101,
      "location": 2,
      "content": "才能让新的这个对话框能理解",
      "music": 0.0
    },
    {
      "from": 161.5,
      "to": 162.5,
      "sid": 102,
      "location": 2,
      "content": "我的学习程度对吧",
      "music": 0.0
    },
    {
      "from": 162.5,
      "to": 163.18,
      "sid": 103,
      "location": 2,
      "content": "所以说到这呢",
      "music": 0.0
    },
    {
      "from": 163.18,
      "to": 164.24,
      "sid": 104,
      "location": 2,
      "content": "就答案就很清晰了",
      "music": 0.0
    },
    {
      "from": 164.24,
      "to": 167.16,
      "sid": 105,
      "location": 2,
      "content": "你需要在你的电脑里面有一个本地的这个agent啊",
      "music": 0.0
    },
    {
      "from": 167.16,
      "to": 169.32,
      "sid": 106,
      "location": 2,
      "content": "就不管是cloud code还是codex还是train",
      "music": 0.0
    },
    {
      "from": 169.32,
      "to": 170.24,
      "sid": 107,
      "location": 2,
      "content": "还是别的什么啊",
      "music": 0.0
    },
    {
      "from": 170.24,
      "to": 173.42,
      "sid": 108,
      "location": 2,
