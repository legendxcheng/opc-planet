  "body": [
    {
      "from": 0.04,
      "to": 1.74,
      "sid": 1,
      "location": 2,
      "content": "自己这车也太吓人了",
      "music": 0.0
    },
    {
      "from": 1.74,
      "to": 2.68,
      "sid": 2,
      "location": 2,
      "content": "满车是血",
      "music": 0.0
    },
    {
      "from": 2.68,
      "to": 3.48,
      "sid": 3,
      "location": 2,
      "content": "不过还好",
      "music": 0.0
    },
    {
      "from": 3.48,
      "to": 4.42,
      "sid": 4,
      "location": 2,
      "content": "这不是人的血",
      "music": 0.0
    },
    {
      "from": 4.42,
      "to": 6.279,
      "sid": 5,
      "location": 2,
      "content": "而是这位车主喜提新车",
      "music": 0.0
    },
    {
      "from": 6.279,
      "to": 9.139,
      "sid": 6,
      "location": 2,
      "content": "而车主丈母娘找了一个神婆给新车做法",
      "music": 0.0
    },
    {
      "from": 9.139,
      "to": 11.039,
      "sid": 7,
      "location": 2,
      "content": "把这辆车里里外外涂满了鸡血",
      "music": 0.0
    },
    {
      "from": 11.039,
      "to": 13.359,
      "sid": 8,
      "location": 2,
      "content": "猛一看这车还以为发生什么事故",
      "music": 0.0
    },
    {
      "from": 13.359,
      "to": 14.7,
      "sid": 9,
      "location": 2,
      "content": "全都是血手印",
      "music": 0.0
    },
    {
      "from": 14.7,
      "to": 17.11,
      "sid": 10,
      "location": 2,
      "content": "要是在晚上恐怖片都不敢这么拍",
      "music": 0.0
    },
    {
      "from": 17.11,
      "to": 18.93,
      "sid": 11,
      "location": 2,
      "content": "连方向盘地板上都是鸡血",
      "music": 0.0
    },
    {
      "from": 18.93,
      "to": 21.13,
      "sid": 12,
      "location": 2,
      "content": "的确有不少人给新买的车开光",
      "music": 0.0
    },
    {
      "from": 21.13,
      "to": 22.25,
      "sid": 13,
      "location": 2,
      "content": "但顶多放个鞭炮",
      "music": 0.0
    },
    {
      "from": 22.25,
      "to": 23.13,
      "sid": 14,
      "location": 2,
      "content": "图个吉利",
      "music": 0.0
    },
    {
      "from": 23.13,
      "to": 25.22,
      "sid": 15,
      "location": 2,
      "content": "但是这种操作感觉不是吉利",
      "music": 0.0
    },
    {
      "from": 25.22,
      "to": 26.54,
      "sid": 16,
      "location": 2,
      "content": "是血光之灾啊",
      "music": 0.0
    },
    {
      "from": 26.54,
      "to": 28.7,
      "sid": 17,
      "location": 2,
      "content": "真不知道这位丈母娘怎么想的",
      "music": 0.0
    },
    {
      "from": 28.7,
      "to": 29.84,
      "sid": 18,
      "location": 2,
      "content": "这一通操作下来",
      "music": 0.0
    },
    {
      "from": 29.84,
      "to": 31.04,
      "sid": 19,
      "location": 2,
      "content": "这车还能要吗",
      "music": 0.0
    },
    {
      "from": 31.04,
      "to": 33.56,
      "sid": 20,
      "location": 2,
      "content": "你们那新买的车会给汽车搞什么仪式吗",
      "music": 0.0
    }
  ]
}