  "body": [
    {
      "from": 0.12,
      "to": 1.92,
      "sid": 1,
      "location": 2,
      "content": "如何练出一个会赚钱的脑子",
      "music": 0.0
    },
    {
      "from": 1.92,
      "to": 4.0,
      "sid": 2,
      "location": 2,
      "content": "其实说白了就一个概念叫做系统性思维",
      "music": 0.0
    },
    {
      "from": 4.0,
      "to": 5.64,
      "sid": 3,
      "location": 2,
      "content": "有这个思维和没这个思维的人",
      "music": 0.0
    },
    {
      "from": 5.64,
      "to": 7.54,
      "sid": 4,
      "location": 2,
      "content": "区别是在于他们在解决不同的问题",
      "music": 0.0
    },
    {
      "from": 7.54,
      "to": 8.7,
      "sid": 5,
      "location": 2,
      "content": "如果你在解决错误的问题",
      "music": 0.0
    },
    {
      "from": 8.7,
      "to": 9.7,
      "sid": 6,
      "location": 2,
      "content": "你就一定拿不到结果",
      "music": 0.0
    },
    {
      "from": 9.7,
      "to": 11.0,
      "sid": 7,
      "location": 2,
      "content": "而正确的问题一定圆",
      "music": 0.0
    },
    {
      "from": 11.0,
      "to": 12.76,
      "sid": 8,
      "location": 2,
      "content": "你能看到一个全局的系统",
      "music": 0.0
    },
    {
      "from": 12.76,
      "to": 14.44,
      "sid": 9,
      "location": 2,
      "content": "错误的问题也就是挣不了钱的问题",
      "music": 0.0
    },
    {
      "from": 14.44,
      "to": 14.96,
      "sid": 10,
      "location": 2,
      "content": "长什么样子",
      "music": 0.0
    },
    {
      "from": 14.96,
      "to": 16.12,
      "sid": 11,
      "location": 2,
      "content": "我举几个例子你就知道了",
      "music": 0.0
    },
    {
      "from": 16.12,
      "to": 17.36,
      "sid": 12,
      "location": 2,
      "content": "比如有人社群问资料",
      "music": 0.0
    },
    {
      "from": 17.36,
      "to": 18.88,
      "sid": 13,
      "location": 2,
      "content": "就问A卖社群这个事还能做吗",
      "music": 0.0
    },
    {
      "from": 18.88,
      "to": 20.24,
      "sid": 14,
      "location": 2,
      "content": "这个问的是产品的交付",
      "music": 0.0
    },
    {
      "from": 20.24,
      "to": 20.92,
      "sid": 15,
      "location": 2,
      "content": "还有人说哎",
      "music": 0.0
    },
    {
      "from": 20.92,
      "to": 22.68,
      "sid": 16,
      "location": 2,
      "content": "我看你全平台都在分发你的内容了",
      "music": 0.0
    },
    {
      "from": 22.68,
      "to": 23.64,
      "sid": 17,
      "location": 2,
      "content": "抖音现在还能做吗",
      "music": 0.0
    },
    {
      "from": 23.64,
      "to": 24.66,
      "sid": 18,
      "location": 2,
      "content": "这个问的是平台",
      "music": 0.0
    },
    {
      "from": 24.66,
      "to": 26.28,
      "sid": 19,
      "location": 2,
      "content": "有人问卖水晶现在还能做吗",
      "music": 0.0
    },
    {
      "from": 26.28,
      "to": 27.18,
      "sid": 20,
      "location": 2,
      "content": "这个说的是类目",
      "music": 0.0
    },
    {
      "from": 27.18,
      "to": 27.88,
      "sid": 21,
      "location": 2,
      "content": "还有人问诶",
      "music": 0.0
    },
    {
      "from": 27.88,
      "to": 28.72,
      "sid": 22,
      "location": 2,
      "content": "像你这种观点类",
      "music": 0.0
    },
    {
      "from": 28.72,
      "to": 29.56,
      "sid": 23,
      "location": 2,
      "content": "你的视频还能做吗",
      "music": 0.0
    },
    {
      "from": 29.56,
      "to": 30.88,
      "sid": 24,
      "location": 2,
      "content": "这个说的是内容的形式",
      "music": 0.0
    },
    {
      "from": 30.88,
      "to": 31.96,
      "sid": 25,
      "location": 2,
      "content": "刚刚说的这几类问题",
      "music": 0.0
    },
    {
      "from": 31.96,
      "to": 34.32,
      "sid": 26,
      "location": 2,
      "content": "就属于是你越研究就越不挣钱的问题",
      "music": 0.0
    },
    {
      "from": 34.32,
      "to": 35.68,
      "sid": 27,
      "location": 2,
      "content": "下面系统性讲一下原因啊",
      "music": 0.0
    },
    {
      "from": 35.68,
      "to": 36.88,
      "sid": 28,
      "location": 2,
      "content": "拿我自己的业务来举例子",
      "music": 0.0
    },
    {
      "from": 36.88,
      "to": 37.82,
      "sid": 29,
      "location": 2,
      "content": "先说平台的选择",
      "music": 0.0
    },
    {
      "from": 37.82,
      "to": 39.34,
      "sid": 30,
      "location": 2,
      "content": "我发内容的第一个平台是X",
      "music": 0.0
    },
    {
      "from": 39.34,
      "to": 41.28,
      "sid": 31,
      "location": 2,
      "content": "就是前两年被马斯克收购的那个产品",
      "music": 0.0
    },
    {
      "from": 41.28,
      "to": 43.12,
      "sid": 32,
      "location": 2,
      "content": "做这个平台是没有想过变现的",
      "music": 0.0
    },
    {
      "from": 43.12,
      "to": 44.6,
      "sid": 33,
      "location": 2,
      "content": "只是为了记录我日常的文字",
      "music": 0.0
    },
    {
      "from": 44.6,
      "to": 45.8,
      "sid": 34,
      "location": 2,
      "content": "然后因为我在这里的内容",
      "music": 0.0
    },
    {
      "from": 45.8,
      "to": 48.0,
      "sid": 35,
      "location": 2,
      "content": "并不是围绕着热点爆款选题来阐述的",
      "music": 0.0
    },
    {
      "from": 48.0,
      "to": 49.84,
      "sid": 36,
      "location": 2,
      "content": "是围绕着我日常的思考来产出的",
      "music": 0.0
    },
    {
      "from": 49.84,
      "to": 51.36,
      "sid": 37,
      "location": 2,
      "content": "所以就一定要特别警惕",
      "music": 0.0
    },
    {
      "from": 51.36,
      "to": 52.96,
      "sid": 38,
      "location": 2,
      "content": "你日常展出的东西是不是自嗨",
      "music": 0.0
    },
    {
      "from": 52.96,
      "to": 54.28,
      "sid": 39,
      "location": 2,
      "content": "你发出来到底有没有人看",
      "music": 0.0
    },
    {
      "from": 54.28,
      "to": 56.2,
      "sid": 40,
      "location": 2,
      "content": "所以前期我一定不会做视频",
      "music": 0.0
    },
    {
      "from": 56.2,
      "to": 56.88,
      "sid": 41,
      "location": 2,
      "content": "我要做文字",
      "music": 0.0
    },
    {
      "from": 56.88,
      "to": 57.88,
      "sid": 42,
      "location": 2,
      "content": "因为文字的创作更快",
      "music": 0.0
    },
    {
      "from": 57.88,
      "to": 59.24,
      "sid": 43,
      "location": 2,
      "content": "我拿到反馈的速度也更快",
      "music": 0.0
    },
    {
      "from": 59.24,
      "to": 60.48,
      "sid": 44,
      "location": 2,
      "content": "结果是去年10月份",
      "music": 0.0
    },
    {
      "from": 60.48,
      "to": 62.12,
      "sid": 45,
      "location": 2,
      "content": "我的这个地方一个月干了1万粉丝",
      "music": 0.0
    },
    {
      "from": 62.12,
      "to": 64.2,
      "sid": 46,
      "location": 2,
      "content": "而这件事情是我在其他的任何平台",
