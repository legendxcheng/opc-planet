    },
    {
      "from": 64.2,
      "to": 65.06,
      "sid": 47,
      "location": 2,
      "content": "都不可能实现的",
      "music": 0.0
    },
    {
      "from": 65.06,
      "to": 67.34,
      "sid": 48,
      "location": 2,
      "content": "因为去年的那个时候我根本就不会拍视频",
      "music": 0.0
    },
    {
      "from": 67.34,
      "to": 68.3,
      "sid": 49,
      "location": 2,
      "content": "而这个平台打通了之后",
