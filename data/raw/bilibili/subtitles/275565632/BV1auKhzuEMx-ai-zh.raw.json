  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 2.32,
      "sid": 1,
      "location": 2,
      "content": "我现在真的是不会再花一分钱去买流量了",
      "music": 0.0
    },
    {
      "from": 2.32,
      "to": 3.48,
      "sid": 2,
      "location": 2,
      "content": "无论你是哪个平台",
      "music": 0.0
    },
    {
      "from": 3.48,
      "to": 4.4,
      "sid": 3,
      "location": 2,
      "content": "看见我这个账号啊",
      "music": 0.0
    },
    {
      "from": 4.4,
      "to": 5.56,
      "sid": 4,
      "location": 2,
      "content": "我都是一分钱没花",
      "music": 0.0
    },
    {
      "from": 5.56,
      "to": 6.42,
      "sid": 5,
      "location": 2,
      "content": "把这个账号做起来的",
      "music": 0.0
    },
    {
      "from": 6.42,
      "to": 7.62,
      "sid": 6,
      "location": 2,
      "content": "不是不想投",
      "music": 0.0
    },
    {
      "from": 7.62,
      "to": 8.54,
      "sid": 7,
      "location": 2,
      "content": "也不是不会投",
      "music": 0.0
    },
    {
      "from": 8.54,
      "to": 10.22,
      "sid": 8,
      "location": 2,
      "content": "是现在投了真的没有用",
      "music": 0.0
    },
    {
      "from": 10.22,
      "to": 11.74,
      "sid": 9,
      "location": 2,
      "content": "我每天在后台收到无数的提问",
      "music": 0.0
    },
    {
      "from": 11.74,
      "to": 13.82,
      "sid": 10,
      "location": 2,
      "content": "就是关于斗家和薯条这样的工具怎么用",
      "music": 0.0
    },
    {
      "from": 13.82,
      "to": 14.82,
      "sid": 11,
      "location": 2,
      "content": "但是要搞清楚这个问题",
      "music": 0.0
    },
    {
      "from": 14.82,
      "to": 15.96,
      "sid": 12,
      "location": 2,
      "content": "我们首先要讲一下",
      "music": 0.0
    },
    {
      "from": 15.96,
      "to": 17.04,
      "sid": 13,
      "location": 2,
      "content": "在算法平台",
      "music": 0.0
    },
    {
      "from": 17.04,
      "to": 18.64,
      "sid": 14,
      "location": 2,
      "content": "我们发布了一个内容之后",
      "music": 0.0
    },
    {
      "from": 18.64,
      "to": 20.92,
      "sid": 15,
      "location": 2,
      "content": "这个内容传播的这个逻辑是什么",
      "music": 0.0
    },
    {
      "from": 20.92,
      "to": 22.4,
      "sid": 16,
      "location": 2,
      "content": "在我们发出来一个内容之后",
      "music": 0.0
    },
    {
      "from": 22.4,
      "to": 25.26,
      "sid": 17,
      "location": 2,
      "content": "算法会把这个内容小批量的曝光给一些人",
      "music": 0.0
    },
    {
      "from": 25.26,
      "to": 27.14,
      "sid": 18,
      "location": 2,
      "content": "比如说很多人觉得我小红书流量特别差",
      "music": 0.0
    },
    {
      "from": 27.14,
      "to": 28.14,
      "sid": 19,
      "location": 2,
      "content": "就可能有100个小眼睛",
      "music": 0.0
    },
    {
      "from": 28.14,
      "to": 29.24,
      "sid": 20,
      "location": 2,
      "content": "这个流量就停了对吧",
      "music": 0.0
    },
    {
      "from": 29.24,
      "to": 31.68,
      "sid": 21,
      "location": 2,
      "content": "就是系统帮助你把内容分发出去之后",
      "music": 0.0
    },
    {
      "from": 31.68,
      "to": 32.86,
      "sid": 22,
      "location": 2,
      "content": "我进行了一个测试",
      "music": 0.0
    },
    {
      "from": 32.86,
      "to": 33.94,
      "sid": 23,
      "location": 2,
      "content": "这个测试的结果是",
      "music": 0.0
    },
    {
      "from": 33.94,
      "to": 36.56,
      "sid": 24,
      "location": 2,
      "content": "有100个人点进来看了我的内容",
      "music": 0.0
    },
    {
      "from": 36.56,
      "to": 38.8,
      "sid": 25,
      "location": 2,
      "content": "但是我统计了我的这个点击率",
      "music": 0.0
    },
    {
      "from": 38.8,
      "to": 39.34,
      "sid": 26,
      "location": 2,
      "content": "互动率",
      "music": 0.0
    },
    {
      "from": 39.34,
      "to": 40.82,
      "sid": 27,
      "location": 2,
      "content": "完播率等等的指标之后",
      "music": 0.0
    },
    {
      "from": 40.82,
      "to": 42.1,
      "sid": 28,
      "location": 2,
      "content": "我发现你的数据不是很好",
      "music": 0.0
    },
    {
      "from": 42.1,
      "to": 43.58,
      "sid": 29,
      "location": 2,
      "content": "所以我就不会再继续给你去推了",
      "music": 0.0
    },
    {
      "from": 43.58,
      "to": 44.78,
      "sid": 30,
      "location": 2,
      "content": "但是如果你的数据还不错",
      "music": 0.0
    },
    {
      "from": 44.78,
      "to": 46.58,
      "sid": 31,
      "location": 2,
      "content": "你在发完内容的几个小时之后",
      "music": 0.0
    },
    {
      "from": 46.58,
      "to": 47.94,
      "sid": 32,
      "location": 2,
      "content": "会在后台看见一个数据分析",
      "music": 0.0
    },
    {
      "from": 47.94,
      "to": 49.02,
      "sid": 33,
      "location": 2,
      "content": "会有有个五边形",
      "music": 0.0
    },
    {
      "from": 49.02,
      "to": 50.02,
      "sid": 34,
      "location": 2,
      "content": "就长这个样子啊",
      "music": 0.0
    },
    {
      "from": 50.02,
      "to": 52.86,
      "sid": 35,
      "location": 2,
      "content": "如果这个五边形的五个数据都是拉满的",
      "music": 0.0
    },
    {
      "from": 52.86,
      "to": 55.26,
      "sid": 36,
      "location": 2,
      "content": "就是全部都超越了同类数据的9%",
      "music": 0.0
    },
    {
      "from": 55.26,
      "to": 55.92,
      "sid": 37,
      "location": 2,
      "content": "19的人",
      "music": 0.0
    },
    {
      "from": 55.92,
      "to": 57.28,
      "sid": 38,
      "location": 2,
      "content": "你这个东西就会持续去传播",
      "music": 0.0
    },
    {
      "from": 57.28,
      "to": 58.72,
      "sid": 39,
      "location": 2,
      "content": "但是每个平台对于数据的考核",
      "music": 0.0
    },
    {
      "from": 58.72,
      "to": 59.64,
      "sid": 40,
      "location": 2,
      "content": "标准都不太一样啊",
      "music": 0.0
    },
    {
      "from": 59.64,
      "to": 60.6,
      "sid": 41,
      "location": 2,
      "content": "这也是为什么很多人说",
      "music": 0.0
    },
    {
      "from": 60.6,
      "to": 62.6,
      "sid": 42,
      "location": 2,
      "content": "哎我小红书火的东西怎么发抖音没人看",
      "music": 0.0
    },
    {
      "from": 62.6,
      "to": 64.66,
      "sid": 43,
      "location": 2,
      "content": "或者我抖音火东西发到视频号怎么没人看",
      "music": 0.0
    },
    {
      "from": 64.66,
      "to": 65.6,
      "sid": 44,
      "location": 2,
      "content": "如果是小红书的话",
      "music": 0.0
    },
    {
      "from": 65.6,
      "to": 67.22,
      "sid": 45,
      "location": 2,
      "content": "他因为有那个双列的信息流嘛",
      "music": 0.0
    },
    {
      "from": 67.22,
      "to": 69.68,
      "sid": 46,
      "location": 2,
      "content": "他非常考核创作者有没有能力说",
      "music": 0.0
    },
    {
      "from": 69.68,
      "to": 72.16,
      "sid": 47,
      "location": 2,
      "content": "用户在看到我这个双列的屏幕的时候",
      "music": 0.0
    },
    {
      "from": 72.16,
      "to": 73.88,
      "sid": 48,
      "location": 2,
      "content": "我对你的东西就非常感兴趣",
      "music": 0.0
    },
    {
      "from": 73.88,
      "to": 74.84,
      "sid": 49,
      "location": 2,
      "content": "我就一下点进去了",
      "music": 0.0
    },
    {
      "from": 74.84,
      "to": 77.08,
      "sid": 50,
      "location": 2,
      "content": "所以你的封面和标题的点击率也是非常重要的",
      "music": 0.0
    },
    {
      "from": 77.08,
      "to": 77.94,
      "sid": 51,
      "location": 2,
      "content": "等用户点进去了之后",
      "music": 0.0
    },
    {
      "from": 77.94,
      "to": 80.18,
      "sid": 52,
      "location": 2,
      "content": "我又会考核你的这个互动率和完播率的",
      "music": 0.0
    },
    {
      "from": 80.18,
      "to": 80.66,
      "sid": 53,
      "location": 2,
      "content": "这个数据",
      "music": 0.0
    },
    {
      "from": 80.66,
      "to": 81.62,
      "sid": 54,
      "location": 2,
      "content": "如果是互动的话",
      "music": 0.0
    },
    {
      "from": 81.62,
      "to": 84.62,
      "sid": 55,
      "location": 2,
      "content": "那现在的指标是点赞和收藏的权重",
      "music": 0.0
    },
    {
      "from": 84.62,
      "to": 86.42,
      "sid": 56,
      "location": 2,
      "content": "肯定是小于评论和关注的",
      "music": 0.0
    },
    {
      "from": 86.42,
      "to": 87.62,
      "sid": 57,
      "location": 2,
      "content": "那如果是看完播率的话",
      "music": 0.0
    },
    {
      "from": 87.62,
      "to": 89.32,
      "sid": 58,
      "location": 2,
      "content": "各个平台考核的标准就不太一样",
      "music": 0.0
    },
    {
      "from": 89.32,
      "to": 90.54,
      "sid": 59,
      "location": 2,
      "content": "抖音是看五秒完播率",
      "music": 0.0
    },
    {
      "from": 90.54,
      "to": 91.74,
      "sid": 60,
      "location": 2,
      "content": "视频号是看三秒完播率",
      "music": 0.0
    },
    {
      "from": 91.74,
      "to": 93.94,
      "sid": 61,
      "location": 2,
      "content": "小红书是看两秒的跳出率",
      "music": 0.0
    },
    {
      "from": 93.94,
      "to": 95.56,
      "sid": 62,
      "location": 2,
      "content": "但两秒跳出率就是两秒完播嘛",
      "music": 0.0
    },
    {
      "from": 95.56,
      "to": 97.6,
      "sid": 63,
      "location": 2,
      "content": "30%的人在两秒钟内跳出了",
      "music": 0.0
    },
    {
      "from": 97.6,
      "to": 99.68,
      "sid": 64,
      "location": 2,
      "content": "那其实你的两秒完播率就是70%对吧",
      "music": 0.0
    },
    {
      "from": 99.68,
      "to": 100.88,
      "sid": 65,
      "location": 2,
      "content": "那不管考核标准是什么",
      "music": 0.0
    },
    {
      "from": 100.88,
      "to": 101.88,
      "sid": 66,
      "location": 2,
      "content": "测量方法都大差不差",
      "music": 0.0
    },
    {
      "from": 101.88,
      "to": 104.04,
      "sid": 67,
      "location": 2,
      "content": "就你发的内容给你点流量测试一下",
      "music": 0.0
    },
    {
      "from": 104.04,
      "to": 105.08,
      "sid": 68,
      "location": 2,
      "content": "如果你是个新号呢",
      "music": 0.0
    },
    {
      "from": 105.08,
      "to": 106.52,
      "sid": 69,
      "location": 2,
      "content": "就给你点垃圾流量测试一下",
      "music": 0.0
    },
    {
      "from": 106.52,
      "to": 108.3,
      "sid": 70,
      "location": 2,
      "content": "毕竟你没有证明过你有创作能力嘛",
      "music": 0.0
    },
    {
      "from": 108.3,
      "to": 110.22,
      "sid": 71,
      "location": 2,
      "content": "我也没有这个必要把好的流量给你",
      "music": 0.0
    },
    {
      "from": 110.22,
      "to": 111.46,
      "sid": 72,
      "location": 2,
      "content": "如果你是一个老账号的话",
      "music": 0.0
    },
    {
      "from": 111.46,
      "to": 113.72,
      "sid": 73,
      "location": 2,
      "content": "就让你的老粉丝来测试一下这个内容好不好",
      "music": 0.0
    },
    {
      "from": 113.72,
      "to": 114.46,
      "sid": 74,
      "location": 2,
      "content": "如果好的话",
      "music": 0.0
    },
    {
      "from": 114.46,
      "to": 115.1,
      "sid": 75,
      "location": 2,
      "content": "就持续传播",
      "music": 0.0
    },
    {
      "from": 115.1,
      "to": 115.54,
      "sid": 76,
      "location": 2,
      "content": "不好的话",
      "music": 0.0
    },
    {
      "from": 115.54,
      "to": 116.38,
      "sid": 77,
      "location": 2,
      "content": "这事就拉倒了",
      "music": 0.0
    },
    {
      "from": 116.38,
      "to": 117.64,
      "sid": 78,
      "location": 2,
      "content": "但如果好的话",
      "music": 0.0
    },
    {
      "from": 117.64,
      "to": 119.66,
      "sid": 79,
      "location": 2,
      "content": "这个持续传播的路径是怎么样的呢",
      "music": 0.0
    },
    {
      "from": 119.66,
      "to": 120.66,
      "sid": 80,
      "location": 2,
      "content": "如果你的内容很好",
      "music": 0.0
    },
    {
      "from": 120.66,
      "to": 123.14,
      "sid": 81,
      "location": 2,
      "content": "你会在一开始收获一个非常饱满的五边形",
      "music": 0.0
    },
    {
      "from": 123.14,
      "to": 123.9,
      "sid": 82,
      "location": 2,
      "content": "如果是在抖音的话",
      "music": 0.0
    },
    {
      "from": 123.9,
      "to": 125.31,
      "sid": 83,
      "location": 2,
      "content": "那就是一条完播率曲线啊",
      "music": 0.0
    },
    {
      "from": 125.31,
      "to": 128.61,
      "sid": 84,
      "location": 2,
      "content": "然后这个数据它是系统给你推算出来的",
      "music": 0.0
    },
    {
      "from": 128.61,
      "to": 130.77,
      "sid": 85,
      "location": 2,
      "content": "最精准的一帮人帮你打造出来的",
      "music": 0.0
    },
    {
      "from": 130.77,
      "to": 134.21,
      "sid": 86,
      "location": 2,
      "content": "就是你可以理解为全网最喜欢你这个内容的人",
      "music": 0.0
    },
    {
      "from": 134.21,
      "to": 135.42,
      "sid": 87,
      "location": 2,
      "content": "在这个时候已经出现了",
      "music": 0.0
    },
    {
      "from": 135.42,
      "to": 136.82,
      "sid": 88,
      "location": 2,
      "content": "所以随着继续给你推流",
      "music": 0.0
    },
    {
      "from": 136.82,
      "to": 138.46,
      "sid": 89,
      "location": 2,
      "content": "你的这个数据是一定会崩塌的",
      "music": 0.0
    },
    {
      "from": 138.46,
      "to": 141.24,
      "sid": 90,
      "location": 2,
      "content": "你的那些非常精准的老观众看完你的内容之后",
      "music": 0.0
    },
    {
      "from": 141.24,
      "to": 142.0,
      "sid": 91,
      "location": 2,
      "content": "又是给你点赞",
      "music": 0.0
    },
    {
      "from": 142.0,
      "to": 142.68,
      "sid": 92,
      "location": 2,
      "content": "又是给你评论",
      "music": 0.0
    },
    {
      "from": 142.68,
      "to": 144.08,
      "sid": 93,
      "location": 2,
      "content": "他证明你的内容是一个好内容",
      "music": 0.0
    },
    {
      "from": 144.08,
      "to": 145.3,
      "sid": 94,
      "location": 2,
      "content": "所以他就会持续传播出去",
      "music": 0.0
    },
    {
      "from": 145.3,
      "to": 147.14,
      "sid": 95,
      "location": 2,
      "content": "传播出去之后来的第二茬观众",
      "music": 0.0
    },
    {
      "from": 147.14,
      "to": 148.94,
      "sid": 96,
      "location": 2,
      "content": "第三场观众他就不是那么的精准了",
      "music": 0.0
    },
    {
      "from": 148.94,
      "to": 150.0,
      "sid": 97,
      "location": 2,
      "content": "然后你的五边形就会崩",
      "music": 0.0
    },
    {
      "from": 150.0,
      "to": 151.34,
      "sid": 98,
      "location": 2,
      "content": "崩完之后可能就长这个样子",
      "music": 0.0
    },
    {
      "from": 151.34,
      "to": 152.74,
      "sid": 99,
      "location": 2,
      "content": "他已经变成四边形了对吧",
      "music": 0.0
    },
    {
      "from": 152.74,
      "to": 154.38,
      "sid": 100,
      "location": 2,
      "content": "甚至再传播可能变成三角形了",
      "music": 0.0
    },
    {
      "from": 154.38,
      "to": 156.22,
      "sid": 101,
      "location": 2,
      "content": "等这个五边形崩的不能再崩",
      "music": 0.0
    },
    {
      "from": 156.22,
      "to": 157.9,
      "sid": 102,
      "location": 2,
      "content": "崩的这个数据已经一塌糊涂的时候",
      "music": 0.0
    },
    {
      "from": 157.9,
      "to": 158.88,
      "sid": 103,
      "location": 2,
      "content": "它就会停止传播",
      "music": 0.0
    },
    {
      "from": 158.88,
      "to": 160.86,
      "sid": 104,
      "location": 2,
      "content": "所以薯条和斗家这种东西什么时候可以用嘛",
      "music": 0.0
    },
    {
      "from": 160.86,
      "to": 162.56,
      "sid": 105,
      "location": 2,
      "content": "假如说我是一个新账号",
      "music": 0.0
    },
    {
      "from": 162.56,
      "to": 164.36,
      "sid": 106,
      "location": 2,
      "content": "我发的这个内容明明很好",
      "music": 0.0
    },
    {
      "from": 164.36,
      "to": 165.76,
      "sid": 107,
      "location": 2,
      "content": "在任何一个平台都火了",
      "music": 0.0
