{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.0,
      "to": 1.28,
      "sid": 1,
      "location": 2,
      "content": "在小红书这种地方要赚钱",
      "music": 0.0
    },
    {
      "from": 1.28,
      "to": 2.2,
      "sid": 2,
      "location": 2,
      "content": "你就记住一句话",
      "music": 0.0
    },
    {
      "from": 2.2,
      "to": 4.88,
      "sid": 3,
      "location": 2,
      "content": "只有你的小红书笔记才是你真正的产品",
      "music": 0.0
    },
    {
      "from": 4.88,
      "to": 5.92,
      "sid": 4,
      "location": 2,
      "content": "你要卖的那些东西",
      "music": 0.0
    },
    {
      "from": 5.92,
      "to": 7.86,
      "sid": 5,
      "location": 2,
      "content": "只是是帮助你打造笔记的素材",
      "music": 0.0
    },
    {
      "from": 7.86,
      "to": 10.26,
      "sid": 6,
      "location": 2,
      "content": "而且越是以前做传统电商赚到钱的人",
      "music": 0.0
    },
    {
      "from": 10.26,
      "to": 11.5,
      "sid": 7,
      "location": 2,
      "content": "他这个思维越是扭不过来",
      "music": 0.0
    },
    {
      "from": 11.5,
      "to": 13.26,
      "sid": 8,
      "location": 2,
      "content": "比如说很多传统电商的老板找到我",
      "music": 0.0
    },
    {
      "from": 13.26,
      "to": 15.14,
      "sid": 9,
      "location": 2,
      "content": "他问我的第一句话都出奇的一致",
      "music": 0.0
    },
    {
      "from": 15.14,
      "to": 17.42,
      "sid": 10,
      "location": 2,
      "content": "就说我们这个产品在淘宝上都卖爆了",
      "music": 0.0
    },
    {
      "from": 17.42,
      "to": 19.1,
      "sid": 11,
      "location": 2,
      "content": "你教教我在小红书上怎么测评",
      "music": 0.0
    },
    {
      "from": 19.1,
      "to": 20.44,
      "sid": 12,
      "location": 2,
      "content": "我说小红书不能测评",
      "music": 0.0
    },
    {
      "from": 20.44,
      "to": 21.88,
      "sid": 13,
      "location": 2,
      "content": "然后对方就石化了",
      "music": 0.0
    },
    {
      "from": 21.88,
      "to": 22.64,
      "sid": 14,
      "location": 2,
      "content": "就陷入沉默了",
      "music": 0.0
    },
    {
      "from": 22.64,
      "to": 23.32,
      "sid": 15,
      "location": 2,
      "content": "我说你们想想",
      "music": 0.0
    },
    {
      "from": 23.32,
      "to": 25.12,
      "sid": 16,
      "location": 2,
      "content": "咱们说测评测评测评说了这么多年",
      "music": 0.0
    },
    {
      "from": 25.12,
      "to": 26.2,
      "sid": 17,
      "location": 2,
      "content": "这个事到底怎么来的",
      "music": 0.0
    },
    {
      "from": 26.2,
      "to": 27.72,
      "sid": 18,
      "location": 2,
      "content": "大概从2010年开始",
      "music": 0.0
    },
    {
      "from": 27.72,
      "to": 28.92,
      "sid": 19,
      "location": 2,
      "content": "这是移动互联网的元年",
      "music": 0.0
    },
    {
      "from": 28.92,
      "to": 31.38,
      "sid": 20,
      "location": 2,
      "content": "开始有这个所谓的互联网思维的这个说法",
      "music": 0.0
    },
    {
      "from": 31.38,
      "to": 33.24,
      "sid": 21,
      "location": 2,
      "content": "MVP测试ab测试小无破解",
      "music": 0.0
    },
    {
      "from": 33.24,
      "to": 34.5,
      "sid": 22,
      "location": 2,
      "content": "带小步快跑等对吧",
      "music": 0.0
    },
    {
      "from": 34.5,
      "to": 36.74,
      "sid": 23,
      "location": 2,
      "content": "然后随着电商的竞争日益激烈",
      "music": 0.0
    },
    {
      "from": 36.74,
      "to": 37.7,
      "sid": 24,
      "location": 2,
      "content": "有了精细化运营",
      "music": 0.0
    },
    {
      "from": 37.7,
      "to": 39.58,
      "sid": 25,
      "location": 2,
      "content": "我们就把互联网思维给挪用过来了",
      "music": 0.0
    },
    {
      "from": 39.58,
      "to": 40.24,
      "sid": 26,
      "location": 2,
      "content": "瓶子怎么测",
      "music": 0.0
    },
    {
      "from": 40.24,
      "to": 40.86,
      "sid": 27,
      "location": 2,
      "content": "简单讲",
      "music": 0.0
    },
    {
      "from": 40.86,
      "to": 42.22,
      "sid": 28,
      "location": 2,
      "content": "假如说我现在有一个新品",
      "music": 0.0
    },
    {
      "from": 42.22,
      "to": 43.22,
      "sid": 29,
      "location": 2,
      "content": "我觉得有可能卖得掉",
      "music": 0.0
    },
    {
      "from": 43.22,
      "to": 44.74,
      "sid": 30,
      "location": 2,
      "content": "但是我又底气不是很足",
      "music": 0.0
    },
    {
      "from": 44.74,
      "to": 46.22,
      "sid": 31,
      "location": 2,
      "content": "我怕这个大规模进货了",
      "music": 0.0
    },
    {
      "from": 46.22,
      "to": 46.92,
      "sid": 32,
      "location": 2,
      "content": "砸在我手里",
      "music": 0.0
    },
    {
      "from": 46.92,
      "to": 48.8,
      "sid": 33,
      "location": 2,
      "content": "所以我就小批量先进个50件",
      "music": 0.0
    },
    {
      "from": 48.8,
      "to": 50.4,
      "sid": 34,
      "location": 2,
      "content": "我先把链接往上一挂进去之后",
      "music": 0.0
    },
    {
      "from": 50.4,
      "to": 51.72,
      "sid": 35,
      "location": 2,
      "content": "因为我的这这个销量也比较少",
      "music": 0.0
    },
    {
      "from": 51.72,
      "to": 52.56,
      "sid": 36,
      "location": 2,
      "content": "好评数也比较少",
      "music": 0.0
    },
    {
      "from": 52.56,
      "to": 54.72,
      "sid": 37,
      "location": 2,
      "content": "那我的价格就比主流的这个竞品低一点",
      "music": 0.0
    },
    {
      "from": 54.72,
      "to": 55.72,
      "sid": 38,
      "location": 2,
      "content": "低个15%吧",
      "music": 0.0
    },
    {
      "from": 55.72,
      "to": 56.52,
      "sid": 39,
      "location": 2,
      "content": "然后我也不推广",
      "music": 0.0
    },
    {
      "from": 56.52,
      "to": 57.28,
      "sid": 40,
      "location": 2,
      "content": "就靠自然流",
      "music": 0.0
    },
    {
      "from": 57.28,
      "to": 57.8,
      "sid": 41,
      "location": 2,
      "content": "先跑一跑",
      "music": 0.0
    },
    {
      "from": 57.8,
      "to": 59.5,
      "sid": 42,
      "location": 2,
      "content": "看看跑得动我就加大投入",
      "music": 0.0
    },
    {
      "from": 59.5,
      "to": 60.54,
      "sid": 43,
      "location": 2,
      "content": "跑不动我就换一个品",
      "music": 0.0
    },
    {
      "from": 60.54,
      "to": 61.18,
      "sid": 44,
      "location": 2,
      "content": "接着再测",
      "music": 0.0
    },
    {
      "from": 61.18,
      "to": 64.04,
      "sid": 45,
      "location": 2,
      "content": "那整个这件事情能发生的大前提大背景是什么",
      "music": 0.0
    },
    {
      "from": 64.04,
      "to": 65.52,
      "sid": 46,
      "location": 2,
      "content": "是买家的购物心智",
      "music": 0.0
    },
    {
      "from": 65.52,
      "to": 66.84,
      "sid": 47,
      "location": 2,
      "content": "不需要由你来建立",
      "music": 0.0
    },
    {
      "from": 66.84,
      "to": 68.24,
      "sid": 48,
      "location": 2,
      "content": "他在遇到你之前",
      "music": 0.0
    },
    {
      "from": 68.24,
      "to": 69.96,
      "sid": 49,
      "location": 2,
      "content": "已经知道自己要买什么东西了",
      "music": 0.0
    },
    {
      "from": 69.96,
      "to": 71.6,
      "sid": 50,
      "location": 2,
      "content": "这件事情会发生在淘宝",
      "music": 0.0
    },
    {
      "from": 71.6,
      "to": 73.6,
      "sid": 51,
      "location": 2,
      "content": "京东这一类的传统的电商平台",
      "music": 0.0
    },
    {
      "from": 73.6,
      "to": 74.72,
      "sid": 52,
      "location": 2,
      "content": "这个叫货架电商",
      "music": 0.0
    },
    {
      "from": 74.72,
      "to": 75.64,
      "sid": 53,
      "location": 2,
      "content": "什么叫货架电商",
      "music": 0.0
    },
    {
      "from": 75.64,
      "to": 77.4,
      "sid": 54,
      "location": 2,
      "content": "比如说我们去线下的便利店",
      "music": 0.0
    },
    {
      "from": 77.4,
      "to": 78.12,
      "sid": 55,
      "location": 2,
      "content": "超市买东西的时候",
      "music": 0.0
    },
    {
      "from": 78.12,
      "to": 79.52,
      "sid": 56,
      "location": 2,
      "content": "是不是看到所有的商品",
      "music": 0.0
    },
    {
      "from": 79.52,
      "to": 81.08,
      "sid": 57,
      "location": 2,
      "content": "陈列在一个又一个那个架子上",
      "music": 0.0
    },
    {
      "from": 81.08,
      "to": 83.94,
      "sid": 58,
      "location": 2,
      "content": "架子上的商品是按照它的相关性品类的",
      "music": 0.0
    },
    {
      "from": 83.94,
      "to": 85.58,
      "sid": 59,
      "location": 2,
      "content": "是否接近来进行摆放的",
      "music": 0.0
    },
    {
      "from": 85.58,
      "to": 86.44,
      "sid": 60,
      "location": 2,
      "content": "然后销量好的",
      "music": 0.0
    },
    {
      "from": 86.44,
      "to": 88.4,
      "sid": 61,
      "location": 2,
      "content": "可能放在人眼睛的这个高度的地方",
      "music": 0.0
    },
    {
      "from": 88.4,
      "to": 89.88,
      "sid": 62,
      "location": 2,
      "content": "销量不好的可能就放在特别高的",
      "music": 0.0
    },
    {
      "from": 89.88,
      "to": 90.8,
      "sid": 63,
      "location": 2,
      "content": "或者特别低的地方",
      "music": 0.0
    },
    {
      "from": 90.8,
      "to": 91.52,
      "sid": 64,
      "location": 2,
      "content": "这个叫船",
      "music": 0.0
    },
    {
      "from": 91.52,
      "to": 93.14,
      "sid": 65,
      "location": 2,
      "content": "传统的线下货架卖场",
      "music": 0.0
    },
    {
      "from": 93.14,
      "to": 94.8,
      "sid": 66,
      "location": 2,
      "content": "我们去淘宝搜索的时候也一样啊",
      "music": 0.0
    },
    {
      "from": 94.8,
      "to": 95.6,
      "sid": 67,
      "location": 2,
      "content": "也是销量好的",
      "music": 0.0
    },
    {
      "from": 95.6,
      "to": 96.64,
      "sid": 68,
      "location": 2,
      "content": "在前面销量不好的",
      "music": 0.0
    },
    {
      "from": 96.64,
      "to": 97.98,
      "sid": 69,
      "location": 2,
      "content": "在后面也是相似的",
      "music": 0.0
    },
    {
      "from": 97.98,
      "to": 100.5,
      "sid": 70,
      "location": 2,
      "content": "产品放在一个又一个临近的这个格子里面",
      "music": 0.0
    },
    {
      "from": 100.5,
      "to": 102.82,
      "sid": 71,
      "location": 2,
      "content": "只不过线下的那个货架是有限的",
      "music": 0.0
    },
    {
      "from": 102.82,
      "to": 104.66,
      "sid": 72,
      "location": 2,
      "content": "毕竟超市和商场的空间是有限的",
      "music": 0.0
    },
    {
      "from": 104.66,
      "to": 106.24,
      "sid": 73,
      "location": 2,
      "content": "而在淘宝网上的这个货架",
      "music": 0.0
    },
    {
      "from": 106.24,
      "to": 107.44,
      "sid": 74,
      "location": 2,
      "content": "你可以一直划一直划",
      "music": 0.0
    },
    {
      "from": 107.44,
      "to": 107.96,
      "sid": 75,
      "location": 2,
      "content": "划不到底",
      "music": 0.0
    },
    {
      "from": 107.96,
      "to": 110.12,
      "sid": 76,
      "location": 2,
      "content": "所以以前有一个说法叫无限货架",
      "music": 0.0
    },
    {
      "from": 110.12,
      "to": 111.92,
      "sid": 77,
      "location": 2,
      "content": "那么当货架出现在消费者面前的时候",
      "music": 0.0
    },
    {
      "from": 111.92,
      "to": 112.88,
      "sid": 78,
      "location": 2,
      "content": "有一个必然的点",
      "music": 0.0
    },
    {
      "from": 112.88,
      "to": 115.54,
      "sid": 79,
      "location": 2,
      "content": "就是消费者一定知道我想要买一个什么东西",
      "music": 0.0
    },
    {
      "from": 115.54,
      "to": 117.04,
      "sid": 80,
      "location": 2,
      "content": "比如说我是想买一瓶水",
      "music": 0.0
    },
    {
      "from": 117.04,
      "to": 118.14,
      "sid": 81,
      "location": 2,
      "content": "我才去的711",
      "music": 0.0
    },
    {
      "from": 118.14,
      "to": 120.3,
      "sid": 82,
      "location": 2,
      "content": "我才看见了一个油水啊",
      "music": 0.0
    },
    {
      "from": 120.3,
      "to": 120.94,
      "sid": 83,
      "location": 2,
      "content": "饮料啊",
      "music": 0.0
    },
    {
      "from": 120.94,
      "to": 122.7,
      "sid": 84,
      "location": 2,
      "content": "茶啊等等组成的一个货架",
      "music": 0.0
    },
    {
      "from": 122.7,
      "to": 123.94,
      "sid": 85,
      "location": 2,
      "content": "如果我是想买一个沙发",
      "music": 0.0
    },
    {
      "from": 123.94,
      "to": 125.22,
      "sid": 86,
      "location": 2,
      "content": "我肯定不会去711的",
      "music": 0.0
    },
    {
      "from": 125.22,
      "to": 125.94,
      "sid": 87,
      "location": 2,
      "content": "淘宝也一样",
      "music": 0.0
    },
    {
      "from": 125.94,
      "to": 127.56,
      "sid": 88,
      "location": 2,
      "content": "我肯定是搜索了洗衣液",
      "music": 0.0
    },
    {
      "from": 127.56,
      "to": 129.2,
      "sid": 89,
      "location": 2,
      "content": "才出现了一个由洗衣粉",
      "music": 0.0
    },
    {
      "from": 129.2,
      "to": 132.48,
      "sid": 90,
      "location": 2,
      "content": "洗衣一夜洗衣皂和洗衣凝珠组成的一个货架",
      "music": 0.0
    },
    {
      "from": 132.48,
      "to": 135.62,
      "sid": 91,
      "location": 2,
      "content": "结果是你打开小红书抖音快手视频号是这样吗",
      "music": 0.0
    },
    {
      "from": 135.62,
      "to": 136.4,
      "sid": 92,
      "location": 2,
      "content": "肯定不是吧",
      "music": 0.0
    },
    {
      "from": 136.4,
      "to": 138.32,
      "sid": 93,
      "location": 2,
      "content": "抖音打开是单列的视频信息流",
      "music": 0.0
    },
    {
      "from": 138.32,
      "to": 140.16,
      "sid": 94,
      "location": 2,
      "content": "快手打开是双列的视频信息流",
      "music": 0.0
    },
    {
      "from": 140.16,
      "to": 141.48,
      "sid": 95,
      "location": 2,
      "content": "小红书打开是双列的",
      "music": 0.0
    },
    {
      "from": 141.48,
      "to": 143.96,
      "sid": 96,
      "location": 2,
      "content": "由视频和图文进行混排的一个信息流",
      "music": 0.0
    },
    {
      "from": 143.96,
      "to": 146.64,
      "sid": 97,
      "location": 2,
      "content": "那么在这样一个打开之后看不见商品",
      "music": 0.0
    },
    {
      "from": 146.64,
      "to": 148.48,
      "sid": 98,
      "location": 2,
      "content": "只能能看见大量的内容的地方",
      "music": 0.0
    },
    {
      "from": 148.48,
      "to": 149.78,
      "sid": 99,
      "location": 2,
      "content": "你问我测评怎么测",
      "music": 0.0
    },
    {
      "from": 149.78,
      "to": 150.56,
      "sid": 100,
      "location": 2,
      "content": "测不了呀",
      "music": 0.0
    },
    {
      "from": 150.56,
      "to": 151.68,
      "sid": 101,
      "location": 2,
      "content": "神仙来了也测不了呀",
      "music": 0.0
    },
    {
      "from": 151.68,
      "to": 152.64,
      "sid": 102,
      "location": 2,
      "content": "如果是抖音的话",
      "music": 0.0
    },
    {
      "from": 152.64,
      "to": 153.6,
      "sid": 103,
      "location": 2,
      "content": "还稍微好一点",
      "music": 0.0
    },
    {
      "from": 153.6,
      "to": 155.6,
      "sid": 104,
      "location": 2,
      "content": "比如淘宝去年的g ma是8万亿",
      "music": 0.0
    },
    {
      "from": 155.6,
      "to": 157.08,
      "sid": 105,
      "location": 2,
      "content": "抖音大概3.5万亿",
      "music": 0.0
    },
    {
      "from": 157.08,
      "to": 158.609,
      "sid": 106,
      "location": 2,
      "content": "虽然有些差距",
      "music": 0.0
    },
    {
      "from": 158.609,
      "to": 160.009,
      "sid": 107,
      "location": 2,
      "content": "但总体上还在一个量级上",
      "music": 0.0
    },
    {
      "from": 160.009,
      "to": 163.08,
      "sid": 108,
      "location": 2,
      "content": "这么大的量级意味着抖音上其实是有一部分人",
      "music": 0.0
